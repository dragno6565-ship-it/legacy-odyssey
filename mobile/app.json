{
  "expo": {
    "name": "Legacy Odyssey",
    "slug": "legacy-odyssey",
    "version": "1.0.6",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.legacyodyssey.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Legacy Odyssey uses your camera to take photos for your baby book sections, such as capturing monthly milestones, family member portraits, and memorable moments to add to your book.",
        "NSPhotoLibraryUsageDescription": "Legacy Odyssey uses your photo library to let you add photos to your baby book — for example, uploading a birth story photo, a monthly milestone image, a family portrait, or a recipe photo to preserve in your family's keepsake book."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF9F6"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.legacyodyssey.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "14daf713-2b41-4ac0-b413-1179afa6e6a9"
      }
    },
    "owner": "dragno65",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/14daf713-2b41-4ac0-b413-1179afa6e6a9"
    }
  }
}
