<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Subscription Expired — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Jost', sans-serif;
      background: #1a1510;
      color: #f5f0eb;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
    }
    .container { max-width: 500px; }
    .icon { font-size: 3rem; margin-bottom: 1.5rem; }
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem;
      font-weight: 400;
      margin-bottom: 1rem;
      color: #f5f0eb;
    }
    p {
      color: #a09080;
      font-size: 1.05rem;
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }
    .reactivate-btn {
      display: inline-block;
      background: #c8a96e;
      color: #1a1510;
      padding: 0.9rem 2rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 500;
      font-size: 1rem;
      transition: background 0.2s;
      margin-bottom: 1rem;
    }
    .reactivate-btn:hover { background: #b8944e; }
    .help-link {
      display: block;
      color: #c8a96e;
      font-size: 0.9rem;
      text-decoration: none;
      margin-top: 0.5rem;
    }
    .help-link:hover { text-decoration: underline; }
    .brand {
      margin-top: 3rem;
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.9rem;
      color: #4a4035;
      letter-spacing: 2px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="icon">&#128218;</div>
    <h1>This Book is Currently Unavailable</h1>
    <% if (family.subscription_status === 'past_due') { %>
      <p>There was a problem processing the payment for this book. The book owner can update their payment method to restore access.</p>
    <% } else if (family.subscription_status === 'canceled') { %>
      <p>The subscription for this book has been canceled. The book owner can reactivate their subscription to restore access.</p>
    <% } else { %>
      <p>The subscription for this book has expired. The book owner can reactivate their subscription to restore access.</p>
    <% } %>
    <a href="https://legacyodyssey.com" class="reactivate-btn">Visit Legacy Odyssey</a>
    <a href="mailto:help@legacyodyssey.com" class="help-link">Need help? Contact us</a>
    <div class="brand">LEGACY ODYSSEY</div>
  </div>
</body>
</html>
