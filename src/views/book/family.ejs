<section id="page-family" class="page-section">
  <div class="page-header">
    <h2 class="page-header-title"><%= t('family.header_title') %></h2>
    <p class="page-header-sub"><%= t('family.header_sub') %></p>
  </div>
  <div class="family-intro">
    <div class="family-tree-label"><%= t('family.tree_label') %></div>
    <p class="family-tree-sub"><%= t('family.tree_sub') %></p>
  </div>

  <%
    const members = familyMembers || [];
    const parents = members.filter(fm => fm.member_key === 'mom' || fm.member_key === 'dad');
    const rest = members.filter(fm => fm.member_key !== 'mom' && fm.member_key !== 'dad');
  %>

  <% if (parents.length) { %>
    <div class="family-section-title">&#10022; <%= t('family.mom_and_dad') %></div>
    <div class="family-cards">
      <% parents.forEach(fm => { %>
        <div class="family-card" onclick="openFamilyDetail('<%= fm.member_key %>')">
          <% if (fm.photo_path) { %>
            <div class="family-photo">
              <img src="<%= imageUrl(fm.photo_path) %>" alt="<%= fm.name %>" loading="lazy" style="<%= photoPos(fm.photo_path) %>">
            </div>
          <% } else { %>
            <div class="family-photo placeholder"><svg viewBox="0 0 24 24" width="40%" height="40%" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-6 8-6s8 2 8 6"/></svg></div>
          <% } %>
          <div class="family-card-body">
            <div class="family-card-name"><%= fm.name %></div>
            <div class="family-card-relation"><%= fm.relation %></div>
            <p class="family-card-bio"><%= t('common.tap_to_read_more') %></p>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>

  <% if (rest.length) { %>
    <div class="family-cards">
      <% rest.forEach(fm => { %>
        <div class="family-card" onclick="openFamilyDetail('<%= fm.member_key %>')">
          <% if (fm.photo_path) { %>
            <div class="family-photo">
              <img src="<%= imageUrl(fm.photo_path) %>" alt="<%= fm.name %>" loading="lazy" style="<%= photoPos(fm.photo_path) %>">
            </div>
          <% } else { %>
            <div class="family-photo placeholder"><svg viewBox="0 0 24 24" width="40%" height="40%" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:0.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-6 8-6s8 2 8 6"/></svg></div>
          <% } %>
          <div class="family-card-body">
            <div class="family-card-name"><%= fm.name %></div>
            <div class="family-card-relation"><%= fm.relation %></div>
            <p class="family-card-bio"><%= t('common.tap_to_read_more') %></p>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</section>

<!-- Family Member Detail Panel -->
<div id="family-detail">
  <div class="fdetail-hero">
    <div class="fdetail-hero-overlay"></div>
    <button class="fdetail-back" onclick="closeFamilyDetail()">&#8592; <%= t('family.back_to_family') %></button>
    <div class="fdetail-hero-text">
      <div class="fdetail-relation" id="fdetail-relation"></div>
      <div class="fdetail-name" id="fdetail-name"></div>
    </div>
  </div>
  <div class="fdetail-body">
    <div class="fdetail-meta" id="fdetail-meta"></div>
    <div class="fdetail-portrait-wrap" id="fdetail-portrait-wrap"></div>
    <div class="fdetail-story-label">&#10022; <%= t('family.their_story') %></div>
    <div class="fdetail-story" id="fdetail-story"></div>
    <div class="fdetail-quote" id="fdetail-quote"></div>
    <div class="fdetail-story" id="fdetail-story2"></div>
    <div class="fdetail-photos" id="fdetail-photos"></div>
    <div class="fdetail-video" id="fdetail-video"></div>
  </div>
</div>
<style>
  .fdetail-video { margin-top: 18px; }
  .fdetail-video-frame { position: relative; width: 100%; aspect-ratio: 16/9; background: #1a1510; border-radius: 12px; overflow: hidden; }
  .fdetail-video-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
</style>

<!-- Photo lightbox -->
<div id="photo-lightbox" onclick="closeLightbox()">
  <button class="lightbox-close" onclick="closeLightbox()">&#10005;</button>
  <img id="lightbox-img" src="" alt="">
</div>
