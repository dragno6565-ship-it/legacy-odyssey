<section id="page-home" class="page-section">
  <div class="page-header">
    <h2 class="page-header-title"><%= t('home.header_title') %></h2>
    <p class="page-header-sub"><%= t('home.header_sub') %></p>
  </div>
  <div class="page-body">
    <div class="before-grid">
      <% (comingHomeCards || []).forEach(card => { %>
        <div class="before-card">
          <div class="before-card-photo">
            <% if (card.photo_path) { %>
              <img src="<%= imageUrl(card.photo_path) %>" alt="<%= card.title %>" loading="lazy" style="<%= photoPos(card.photo_path) %>">
            <% } %>
            <% if (card.subtitle) { %>
              <span class="photo-label"><%= card.subtitle %></span>
            <% } %>
          </div>
          <div class="before-card-body">
            <div class="before-card-title"><%= card.title %></div>
            <p class="before-card-text"><%- (card.body || '').replace(/\n/g, '<br>') %></p>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>
