<section id="page-holidays" class="page-section">
  <div class="page-header">
    <div class="page-header-eyebrow">Chapter Seven</div>
    <h2 class="page-header-title"><em>Celebrations</em> &amp; Traditions</h2>
    <p class="page-header-sub">The holidays, cultural traditions, and family rituals that will mark every year of your life.</p>
  </div>

  <% const yearGroups = celebrationsByYear && celebrationsByYear.length ? celebrationsByYear : [{label: 'Your First Year', items: celebrations || []}]; %>
  <% yearGroups.forEach(function(year) { %>
    <% if (year.items && year.items.length > 0) { %>
      <% if (yearGroups.filter(y => y.items && y.items.length > 0).length > 1) { %>
        <h3 class="celebrations-year-heading"><%= year.label %></h3>
      <% } %>
      <div class="holidays-list">
        <% year.items.forEach(function(c, i) { %>
          <div class="holiday-card<%= i % 2 === 1 ? ' reverse' : '' %>">
            <div class="holiday-photo">
              <% if (c.photo_path) { %>
                <img src="<%= imageUrl(c.photo_path) %>" alt="<%= c.title %>" loading="lazy" style="<%= photoPos(c.photo_path) %>">
              <% } %>
            </div>
            <div class="holiday-body">
              <div class="holiday-eyebrow"><%= c.eyebrow || '' %></div>
              <h3 class="holiday-title"><%= c.title %></h3>
              <p class="holiday-text"><%- (c.body || '').replace(/\n/g, '<br>') %></p>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  <% }); %>
</section>
