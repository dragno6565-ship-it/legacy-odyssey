<!-- Mobile Header -->
<header class="mobile-header">
  <span class="mobile-logo"><%= book.child_first_name %>'s Book</span>
  <button class="hamburger" onclick="toggleNav()" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</header>

<!-- Nav Overlay -->
<div class="nav-overlay" id="navOverlay" onclick="toggleNav()"></div>

<!-- Sidebar Navigation -->
<nav id="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-logo">&#10022; Legacy Odyssey</div>
    <div class="sidebar-child-name"><%= book.child_first_name %><%= book.child_middle_name ? ' ' + book.child_middle_name : '' %> <%= book.child_last_name %></div>
    <div class="sidebar-tagline">Born &middot; <%= book.birth_date ? new Date(book.birth_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '' %> &middot; <%= book.city || '' %></div>
  </div>
  <div class="sidebar-nav">
    <div class="nav-section-label">The Book</div>
    <a class="nav-item active" onclick="showPage('welcome')">
      <span class="nav-icon"><i data-lucide="sparkles"></i></span>
      <span class="nav-label">Welcome</span>
    </a>
    <% if (visibleSections.before) { %>
    <a class="nav-item" onclick="showPage('before')">
      <span class="nav-icon"><i data-lucide="heart"></i></span>
      <span class="nav-label">Before You Arrived</span>
    </a>
    <% } %>
    <% if (visibleSections.birth) { %>
    <a class="nav-item" onclick="showPage('birth')">
      <span class="nav-icon"><i data-lucide="book-open"></i></span>
      <span class="nav-label">Birth Story</span>
    </a>
    <% } %>

    <% if (isFree) { %>
    <!-- Locked sections shown in sidebar for free users -->
    <a class="nav-item" onclick="showPage('home')" style="opacity:0.5;">
      <span class="nav-icon"><i data-lucide="lock"></i></span>
      <span class="nav-label">Coming Home</span>
    </a>
    <a class="nav-item" onclick="showPage('home')" style="opacity:0.5;">
      <span class="nav-icon"><i data-lucide="lock"></i></span>
      <span class="nav-label">Month by Month</span>
    </a>
    <div class="nav-section-label">Family &amp; Memories</div>
    <a class="nav-item" onclick="showPage('home')" style="opacity:0.5;">
      <span class="nav-icon"><i data-lucide="lock"></i></span>
      <span class="nav-label">Our Family</span>
    </a>
    <a class="nav-item" onclick="showPage('home')" style="opacity:0.5;">
      <span class="nav-icon"><i data-lucide="lock"></i></span>
      <span class="nav-label">Your Firsts</span>
    </a>
    <a class="nav-item" onclick="showPage('home')" style="opacity:0.5;">
      <span class="nav-icon"><i data-lucide="lock"></i></span>
      <span class="nav-label">Celebrations</span>
    </a>
    <a class="nav-item" onclick="showPage('home')" style="opacity:0.5;">
      <span class="nav-icon"><i data-lucide="lock"></i></span>
      <span class="nav-label">Letters To You</span>
    </a>
    <a class="nav-item" onclick="showPage('home')" style="opacity:0.5;">
      <span class="nav-icon"><i data-lucide="lock"></i></span>
      <span class="nav-label">Family Recipes</span>
    </a>
    <% } else { %>
    <% if (visibleSections.home) { %>
    <a class="nav-item" onclick="showPage('home')">
      <span class="nav-icon"><i data-lucide="home"></i></span>
      <span class="nav-label">Coming Home</span>
    </a>
    <% } %>
    <% if (visibleSections.months) { %>
    <a class="nav-item" onclick="showPage('months')">
      <span class="nav-icon"><i data-lucide="calendar"></i></span>
      <span class="nav-label">Month by Month</span>
    </a>
    <% } %>
    <% if (visibleSections.family || visibleSections.firsts || visibleSections.holidays || visibleSections.letters || visibleSections.recipes) { %>
    <div class="nav-section-label">Family &amp; Memories</div>
    <% } %>
    <% if (visibleSections.family) { %>
    <a class="nav-item" onclick="showPage('family')">
      <span class="nav-icon"><i data-lucide="users"></i></span>
      <span class="nav-label">Our Family</span>
    </a>
    <% } %>
    <% if (visibleSections.firsts) { %>
    <a class="nav-item" onclick="showPage('firsts')">
      <span class="nav-icon"><i data-lucide="star"></i></span>
      <span class="nav-label">Your Firsts</span>
    </a>
    <% } %>
    <% if (visibleSections.holidays) { %>
    <%
      // Build the nested celebration menu. Years come from book.celebration_years
      // (or default to 'Your First Year'). For each year, list the celebrations
      // that actually have content (title, body, location, attendees, gifts, or
      // photos) — empty placeholder rows are skipped so the menu doesn't get
      // cluttered with "(untitled)" entries.
      const celebrationYears = (typeof celebrationsByYear !== 'undefined' && celebrationsByYear)
        ? celebrationsByYear
        : [];
      const hasMeaningful = (c) => c && (
        (c.title && c.title.trim() && c.title !== '(untitled)') ||
        (c.body && c.body.trim()) ||
        c.location || c.attendees || c.gifts ||
        (c.photos && c.photos.length > 0) || c.photo_path
      );
      function slugifyYearLabel(label) {
        if (!label) return 'year';
        const s = String(label).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
        return s || 'year';
      }
      function celebSlug(c) {
        if (c && c.slug) return c.slug;
        const base = (c && c.title) ? c.title : 'celebration';
        return base.toString().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'celebration';
      }
      // Auto-open the year containing the currently-viewed celebration (if any),
      // and auto-open the parent Celebrations menu.
      const activeCelebrationId = (typeof activeCelebration !== 'undefined' && activeCelebration) ? activeCelebration.id : null;
      const activeYearLabel = (typeof activeCelebration !== 'undefined' && activeCelebration) ? activeCelebration.year_label : null;
      const isOnCelebrationDetail = !!activeCelebrationId;
    %>
    <div class="nav-parent <%= isOnCelebrationDetail ? 'open active' : '' %>"
         onclick="this.classList.toggle('open')">
      <span class="nav-icon"><i data-lucide="gift"></i></span>
      <a class="nav-label-link" onclick="event.stopPropagation();showPage('holidays')" style="flex:1;color:inherit;text-decoration:none;">Celebrations</a>
      <span class="nav-chevron">▸</span>
    </div>
    <div class="nav-children">
      <% celebrationYears.forEach(function(year) { %>
        <% const yearSlug = slugifyYearLabel(year.label); %>
        <% const yearHasItems = (year.items || []).some(hasMeaningful); %>
        <% const isActiveYear = (activeYearLabel === year.label) || (celebrationYears.length === 1); %>
        <div class="nav-year <%= isActiveYear ? 'open' : '' %>"
             onclick="event.stopPropagation();this.classList.toggle('open')">
          <span><%= year.label %></span>
          <% if (yearHasItems) { %><span class="nav-year-chevron">▸</span><% } %>
        </div>
        <% if (yearHasItems) { %>
          <div class="nav-celebrations">
            <% year.items.filter(hasMeaningful).forEach(function(c) { %>
              <a class="nav-celebration <%= activeCelebrationId === c.id ? 'active' : '' %>"
                 href="/celebrations/<%= yearSlug %>/<%= celebSlug(c) %>"><%= c.title %></a>
            <% }); %>
          </div>
        <% } %>
      <% }); %>
    </div>
    <% } %>
    <% if (visibleSections.letters) { %>
    <a class="nav-item" onclick="showPage('letters')">
      <span class="nav-icon"><i data-lucide="mail"></i></span>
      <span class="nav-label">Letters To You</span>
    </a>
    <% } %>
    <% if (visibleSections.recipes) { %>
    <a class="nav-item" onclick="showPage('recipes')">
      <span class="nav-icon"><i data-lucide="utensils-crossed"></i></span>
      <span class="nav-label">Family Recipes</span>
    </a>
    <% } %>
    <% if (visibleSections.vault) { %>
    <div class="nav-section-label">The Vault</div>
    <a class="nav-item locked" onclick="showPage('vault')">
      <span class="nav-icon"><i data-lucide="lock"></i></span>
      <span class="nav-label">Locked Until 18</span>
    </a>
    <% } %>
    <% } %>
  </div>
  <div class="sidebar-footer">
    <% if (isDemoDomain) { %>
    <p style="color:#d4bb8a;font-size:0.78rem;line-height:1.5;">You're viewing a demo.<br>Create your own baby book.</p>
    <a href="https://www.legacyodyssey.com" target="_blank" class="sidebar-edit-link" style="background:#c8a96e;color:#1a1510;padding:0.4rem 0.75rem;border-radius:2px;font-weight:600;text-align:center;display:block;">
      Get Your Own Book &rarr;
    </a>
    <% } else if (isFree) { %>
    <p style="color:#c8a96e;font-weight:600;">Free Plan</p>
    <a href="https://legacyodyssey.com/#pricing" target="_blank" class="sidebar-edit-link" style="background:#c8a96e;color:#1a1510;padding:0.4rem 0.75rem;border-radius:2px;font-weight:600;">
      Upgrade &rarr;
    </a>
    <% } else { %>
    <p>Crafted with love by<br><span>Legacy Odyssey</span><br>legacyodyssey.com</p>
    <a href="https://legacyodyssey.com/account" class="sidebar-edit-link" target="_blank" rel="noopener">
      Edit My Book &rarr;
    </a>
    <% } %>
  </div>
</nav>
