<%
  // Visitor-side Recipes overview. Shows cards for recipes with meaningful
  // content; tapping a card opens /recipes/:slug. Placeholder/empty rows
  // (no title or only seed defaults) are hidden so visitors don't see
  // ghost "Untitled" tiles.
  const allRecipes = recipes || [];
  const hasMeaningful = (r) => r && (
    (r.title && r.title.trim() && r.title !== '(untitled)' && r.title !== 'New Recipe') ||
    (r.description && r.description.trim()) ||
    (r.story && r.story.trim()) ||
    (r.ingredients && r.ingredients.length > 0) ||
    (r.directions && r.directions.length > 0) ||
    (r.photos && r.photos.length > 0) ||
    r.photo_path
  );
  const visibleRecipes = allRecipes.filter(hasMeaningful);
  function recipeSlugOf(x) {
    if (x && x.slug) return x.slug;
    const base = (x && x.title) ? x.title : 'recipe';
    return base.toString().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'recipe';
  }
  function snippet(text, n) {
    if (!text) return '';
    const t = String(text).replace(/\s+/g, ' ').trim();
    return t.length > n ? t.slice(0, n).trim() + '…' : t;
  }
%>
<section id="page-recipes" class="page-section">
  <div class="page-header">
    <h2 class="page-header-title"><%- t('recipes.header_title') %></h2>
    <p class="page-header-sub"><%= t('recipes.header_sub') %></p>
  </div>
  <div class="recipes-intro">
    <p class="recipes-intro-text"><%- t('recipes.intro_text') %></p>
  </div>

  <% if (visibleRecipes.length === 0) { %>
    <p style="text-align:center;color:var(--ink-light);font-style:italic;margin-top:2rem;"><%= t('recipes.empty_state') %></p>
  <% } else { %>
    <div class="recipes-grid">
      <% visibleRecipes.forEach(function(r) {
        const heroPhoto = (r.photos && r.photos[0] && r.photos[0].photo_path) || r.photo_path || null;
        const photoCount = (r.photos || []).length;
        const desc = (r.description && r.description.trim()) || snippet(r.story, 120) || '';
        const stepCount = (r.directions || []).length;
        const hasMeta = !!(r.prep_time || r.cook_time || r.servings || stepCount > 0);
      %>
        <a class="recipe-card-v2" href="/recipes/<%= recipeSlugOf(r) %>">
          <div class="recipe-card-v2-photo">
            <% if (heroPhoto) { %>
              <img src="<%= imageUrl(heroPhoto) %>" alt="<%= r.title %>" loading="lazy" style="<%= photoPos(heroPhoto) %>">
              <% if (photoCount > 1) { %>
                <span class="recipe-card-v2-badge"><i data-lucide="image"></i> <%= photoCount %></span>
              <% } %>
            <% } else { %>
              <div class="recipe-card-v2-empty"><i data-lucide="utensils-crossed"></i></div>
            <% } %>
          </div>
          <div class="recipe-card-v2-body">
            <% if (r.origin_label && r.origin_label.trim()) { %>
              <div class="recipe-card-v2-from"><%= r.origin_label %></div>
            <% } %>
            <div class="recipe-card-v2-title"><%= r.title %></div>
            <% if (desc) { %>
              <p class="recipe-card-v2-snippet"><%= desc %></p>
            <% } %>
            <% if (hasMeta) { %>
              <div class="recipe-card-v2-meta">
                <% if (r.prep_time || r.cook_time) { %>
                  <span><i data-lucide="clock"></i> <%= r.prep_time || r.cook_time %></span>
                <% } %>
                <% if (r.servings) { %>
                  <span><i data-lucide="users"></i> <%= r.servings %></span>
                <% } %>
                <% if (stepCount > 0) { %>
                  <span><i data-lucide="list-checks"></i> <%= stepCount === 1 ? t('recipes.step_count_one', { count: stepCount }) : t('recipes.step_count_other', { count: stepCount }) %></span>
                <% } %>
              </div>
            <% } %>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>
</section>
