<section id="page-letters" class="page-section">
  <div class="page-header">
    <h2 class="page-header-title"><%= t('letters.title_pre') %> <em><%= t('letters.title_em') %></em></h2>
    <p class="page-header-sub"><%= t('letters.subtitle') %></p>
  </div>
  <div class="letters-container">
    <% (letters || []).forEach(l => { %>
      <div class="letter-card">
        <div class="letter-from">&#10022; <%= l.from_label %></div>
        <div class="letter-salutation"><%= l.salutation %></div>
        <p class="letter-body"><%- (l.body || '').replace(/\n/g, '<br>') %></p>
        <div class="letter-signature"><%- (l.signature || '').replace(/\n/g, '<br>') %></div>
      </div>
    <% }); %>
  </div>
</section>
