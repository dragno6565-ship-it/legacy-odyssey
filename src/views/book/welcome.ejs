<section id="page-welcome" class="page-section active">
  <div class="welcome-hero">
    <div class="welcome-photo-half">
      <% if (book.hero_image_path) { %>
        <img src="<%= imageUrl(book.hero_image_path) %>" alt="<%= book.child_first_name %>" loading="lazy" style="<%= photoPos(book.hero_image_path) %>">
      <% } %>
      <div class="welcome-photo-overlay"></div>
    </div>
    <div class="welcome-text-half">
      <div class="welcome-eyebrow">&#10022; <%= t('welcome.eyebrow') %></div>
      <h1 class="welcome-name"><em><%= book.child_first_name %></em><% if (book.child_middle_name) { %> <em><%= book.child_middle_name %></em><% } %><br><%= book.child_last_name %></h1>
      <p class="welcome-meaning">"<%= book.name_quote || t('welcome.name_meaning_default') %>"</p>
      <div class="welcome-divider"></div>
      <%
        // Welcome-page vital stats. A tile renders only when it HAS a value
        // AND the customer hasn't switched it off (welcome_fields[key] !== false).
        // Empty fields auto-hide — important for adoptive families who often
        // don't have birth time, weight, length, hospital, etc.
        const wf = book.welcome_fields || {};
        const showStat = (key) => wf[key] !== false;
        const welcomeStats = [
          { key: 'born',       label: t('welcome.stat_born'),       value: book.birth_date ? new Date(book.birth_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '' },
          { key: 'time',       label: t('welcome.stat_time'),       value: book.birth_time || '' },
          { key: 'weight',     label: t('welcome.stat_weight'),     value: book.birth_weight_lbs ? book.birth_weight_lbs + ' lbs ' + (book.birth_weight_oz || 0) + ' oz' : '' },
          { key: 'length',     label: t('welcome.stat_length'),     value: book.birth_length_inches ? book.birth_length_inches + ' inches' : '' },
          { key: 'birthplace', label: t('welcome.stat_born_in'),    value: (book.birth_city || '') + (book.birth_state ? (book.birth_city ? ', ' : '') + book.birth_state : '') },
          { key: 'hospital',   label: t('welcome.stat_hospital'),   value: book.birth_hospital || '' },
        ].filter((s) => s.value && showStat(s.key));
      %>
      <% if (welcomeStats.length) { %>
      <div class="vital-stats">
        <% welcomeStats.forEach((s) => { %>
        <div class="stat-item">
          <div class="stat-label"><%= s.label %></div>
          <div class="stat-value"><%= s.value %></div>
        </div>
        <% }) %>
      </div>
      <% } %>
      <blockquote class="welcome-quote">
        "<%= book.parent_quote || t('welcome.parent_quote_default') %>"
        <cite>&mdash; <%= book.parent_quote_attribution || t('common.mom_and_dad') %></cite>
      </blockquote>
    </div>
  </div>
</section>
