<section id="page-galleries" class="page-section">
  <div class="page-header">
    <div class="page-header-eyebrow">Your collections</div>
    <h2 class="page-header-title">Photo <em>Galleries</em></h2>
  </div>
  <div class="page-body">
    <% (customGalleries || []).forEach(function (g) { %>
      <% if (g.photos && g.photos.length) { %>
        <div class="cg-gallery-block" id="cg-<%= g.id %>">
          <% if (g.title) { %><h3 class="cg-gallery-title"><%= g.title %></h3><% } %>
          <div class="cg-grid">
            <% g.photos.forEach(function (p) { %>
              <figure class="cg-item">
                <img src="<%= imageUrl(p.photo_path) %>" alt="<%= p.caption || '' %>" loading="lazy" style="<%= photoPos(p.photo_path) %>">
                <% if (p.caption) { %><figcaption><%= p.caption %></figcaption><% } %>
              </figure>
            <% }); %>
          </div>
        </div>
      <% } %>
    <% }); %>
  </div>
</section>

<style>
  .cg-gallery-block { max-width: 980px; margin: 0 auto 3rem; }
  .cg-gallery-title { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; color: #2c2416; text-align: center; margin-bottom: 1.25rem; }
  .cg-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 760px) { .cg-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; } }
  @media (max-width: 440px) { .cg-grid { grid-template-columns: 1fr; } }
  .cg-item { margin: 0; background: #fff; border: 1px solid #e0d5c4; border-radius: 10px; overflow: hidden; box-shadow: 0 6px 22px rgba(26,21,16,0.08); }
  .cg-item img { width: 100%; aspect-ratio: 1; object-fit: cover; display: block; }
  .cg-item figcaption { padding: 11px 13px; font-family: 'Cormorant Garamond', serif; font-size: 17px; color: #2c2416; text-align: center; }
</style>
