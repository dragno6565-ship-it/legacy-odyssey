<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gift Codes — Admin — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .code-badge {
      font-family: 'Courier New', monospace;
      font-size: 0.85rem;
      font-weight: 600;
      background: #f5f0e8;
      border: 1px solid #e0d5c4;
      border-radius: 4px;
      padding: 2px 8px;
      color: #2c2416;
      letter-spacing: 0.05em;
    }
    .badge-purchased { background: #fff8e7; color: #b08e4a; border: 1px solid #e8d9b0; }
    .badge-redeemed  { background: #e8f5e9; color: #2e7d32; border: 1px solid #b2dfdb; }
    .badge-expired   { background: #fafafa; color: #9e9e9e; border: 1px solid #e0e0e0; }

    /* Filter pills */
    .filter-row { display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom: 1.25rem; }
    .filter-pill {
      display:inline-flex; align-items:center; gap:0.4rem;
      padding: 0.45rem 0.9rem; border-radius: 999px;
      border: 1px solid #e0d5c4; background: #fff;
      color: #2c2416; text-decoration: none;
      font-size: 0.85rem; font-family: 'Jost', sans-serif;
      transition: all 0.15s;
    }
    .filter-pill:hover { border-color: #c8a96e; }
    .filter-pill.active { background: #1a1a2e; color: #fff; border-color: #1a1a2e; }
    .filter-pill .count { font-weight: 600; opacity: 0.7; font-size: 0.8rem; }
    .filter-pill.active .count { opacity: 1; }
    .filter-pill.pill-stale { border-color: #b08e4a; color: #b08e4a; }
    .filter-pill.pill-stale.active { background: #b08e4a; color: #fff; border-color: #b08e4a; }

    /* Stale row highlight */
    tr.row-stale { background: #fff8e7; }
    tr.row-stale td { border-color: #e8d9b0; }
    .cell-age { font-size: 0.85rem; color: var(--ink-mid); white-space: nowrap; }
    .cell-age.stale { color: #b08e4a; font-weight: 600; }

    /* Top alert banner */
    .stale-alert {
      background: #fff8e7;
      border: 1px solid #e8d9b0;
      border-left: 4px solid #b08e4a;
      border-radius: 8px;
      padding: 0.95rem 1.15rem;
      margin-bottom: 1.25rem;
      font-size: 0.9rem;
      color: #2c2416;
    }
    .stale-alert strong { color: #8c6a35; }
    .cell-message {
      max-width: 180px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: var(--ink-light);
      font-style: italic;
      font-size: 0.85rem;
    }
    .badge-comp { background: #ede7f6; color: #5e35b1; border: 1px solid #d1c4e9; font-size: 0.7rem; padding: 1px 6px; border-radius: 4px; margin-left: 4px; vertical-align: middle; }

    /* Comp gift form */
    .comp-panel { background: #fff; border: 1px solid #e0d5c4; border-radius: 10px; margin-bottom: 1.5rem; overflow: hidden; }
    .comp-panel summary { cursor: pointer; padding: 1rem 1.25rem; font-weight: 600; color: #2c2416; list-style: none; display: flex; align-items: center; gap: 0.5rem; background: #fdf8f0; }
    .comp-panel summary::-webkit-details-marker { display: none; }
    .comp-panel summary::after { content: '+'; margin-left: auto; color: #b08e4a; font-size: 1.2rem; }
    .comp-panel[open] summary::after { content: '\2013'; }
    .comp-body { padding: 1.25rem; }
    .comp-intro { font-size: 0.85rem; color: var(--ink-mid); margin: 0 0 1rem; line-height: 1.5; }
    .comp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem; }
    @media (max-width: 640px) { .comp-grid { grid-template-columns: 1fr; } }
    .comp-field label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.4px; color: var(--ink-mid); font-weight: 600; margin-bottom: 0.35rem; }
    .comp-field input, .comp-field select, .comp-field textarea {
      width: 100%; padding: 0.6rem 0.7rem; border: 1px solid #e0d5c4; border-radius: 6px;
      font-family: 'Jost', sans-serif; font-size: 0.9rem; color: #2c2416; background: #fff;
    }
    .comp-field textarea { min-height: 60px; resize: vertical; }
    .comp-field-full { grid-column: 1 / -1; }
    .comp-actions { margin-top: 1rem; display: flex; align-items: center; gap: 1rem; }
    .comp-banner { padding: 0.95rem 1.15rem; border-radius: 8px; margin-bottom: 1.25rem; font-size: 0.9rem; }
    .comp-banner-ok { background: #e8f5e9; border: 1px solid #b2dfdb; border-left: 4px solid #2e7d32; color: #1b5e20; }
    .comp-banner-err { background: #fdecea; border: 1px solid #f5c6cb; border-left: 4px solid #c0392b; color: #922; }
    .comp-banner code { background: rgba(0,0,0,0.06); padding: 1px 6px; border-radius: 4px; font-size: 0.85rem; }
    #compScheduledRow { display: none; }
  </style>
</head>
<body>
  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-brand">
        <h2>&#10022; Legacy Odyssey</h2>
        <span>Admin Portal</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin">
          <span class="nav-icon">&#128202;</span> Dashboard
        </a>
        <a href="/admin/gifts" class="active">
          <span class="nav-icon">&#127873;</span> Gift Codes
        </a>
        <a href="/admin/health">
          <span class="nav-icon">&#128300;</span> Health
        </a>
      </nav>
      <div class="sidebar-footer">
        <div class="admin-email"><%= admin.email %></div>
        <form action="/admin/logout" method="POST" style="display:inline;">
          <button type="submit" class="logout-btn">&#x2192; Sign Out</button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <div class="page-header">
        <h1>Gift Codes</h1>
        <p>All gift purchases — redeemed and pending</p>
      </div>

      <% if (typeof compCode !== 'undefined' && compCode) { %>
        <div class="comp-banner comp-banner-ok">
          &#127881; Free gift minted — code <code><%= compCode %></code>. It's in the table below, and the emails have gone out just like a paid gift.
        </div>
      <% } %>
      <% if (typeof compError !== 'undefined' && compError) { %>
        <div class="comp-banner comp-banner-err">&#9888; <%= compError %></div>
      <% } %>

      <!-- Comp gift (influencer / promo giveaway) -->
      <details class="comp-panel" <%= (typeof compError !== 'undefined' && compError) ? 'open' : '' %>>
        <summary>&#127873; Give a free gift (influencer / promo)</summary>
        <div class="comp-body">
          <p class="comp-intro">
            Mints a <strong>free</strong> 1-year gift — no charge to us beyond the domain. The recipient redeems it,
            gets a full free year, we register their <strong>.com</strong>, and after the year they can add their own
            card to renew at $49.99/yr (or let it lapse — no one is charged). Fires the same emails as a paid gift.
          </p>
          <form action="/admin/gifts/comp" method="POST" id="compForm">
            <div class="comp-grid">
              <div class="comp-field">
                <label for="recipientName">Recipient name</label>
                <input type="text" id="recipientName" name="recipientName" placeholder="e.g. Jordan Lee" required>
              </div>
              <div class="comp-field">
                <label for="recipientEmail">Recipient email</label>
                <input type="email" id="recipientEmail" name="recipientEmail" placeholder="them@example.com">
              </div>
              <div class="comp-field">
                <label for="deliveryMethod">Delivery</label>
                <select id="deliveryMethod" name="deliveryMethod" onchange="compSyncDelivery()">
                  <option value="email_now">Email them now</option>
                  <option value="email_scheduled">Schedule the email</option>
                  <option value="print">I'll give it to them myself</option>
                </select>
              </div>
              <div class="comp-field" id="compScheduledRow">
                <label for="scheduledDate">Send on</label>
                <input type="date" id="scheduledDate" name="scheduledDate">
              </div>
              <div class="comp-field">
                <label for="buyerEmail">Confirmation copy to</label>
                <input type="email" id="buyerEmail" name="buyerEmail" value="<%= admin.email %>" placeholder="you@legacyodyssey.com">
              </div>
              <div class="comp-field comp-field-full">
                <label for="recipientMessage">Personal note (optional)</label>
                <textarea id="recipientMessage" name="recipientMessage" placeholder="A note they'll see when they redeem…"></textarea>
              </div>
            </div>
            <div class="comp-actions">
              <button type="submit" class="btn btn-primary" id="compSubmit">Mint free gift &rarr;</button>
              <span style="font-size:0.8rem;color:var(--ink-light);">No charge — recipient gets a full free year.</span>
            </div>
          </form>
        </div>
      </details>

      <!-- KPI Cards -->
      <div class="kpi-grid">
        <div class="kpi-card">
          <div class="kpi-label">Total Gifts</div>
          <div class="kpi-value"><%= stats.total %></div>
        </div>
        <div class="kpi-card kpi-trialing">
          <div class="kpi-label">Awaiting Redemption</div>
          <div class="kpi-value"><%= stats.purchased %></div>
        </div>
        <div class="kpi-card kpi-active">
          <div class="kpi-label">Redeemed</div>
          <div class="kpi-value"><%= stats.redeemed %></div>
        </div>
        <div class="kpi-card kpi-canceled">
          <div class="kpi-label">Expired</div>
          <div class="kpi-value"><%= stats.expired %></div>
        </div>
        <% if (stats.stale > 0) { %>
        <div class="kpi-card" style="border-left:3px solid #b08e4a;">
          <div class="kpi-label" style="color:#b08e4a;">30+ days unredeemed</div>
          <div class="kpi-value" style="color:#b08e4a;"><%= stats.stale %></div>
        </div>
        <% } %>
      </div>

      <% if (stats.stale > 0 && filter !== 'stale') { %>
        <div class="stale-alert">
          <strong>&#9888; <%= stats.stale %> gift<%= stats.stale === 1 ? '' : 's' %> purchased 30+ days ago haven't been redeemed.</strong>
          Consider following up with the buyer to make sure the recipient got their code.
          <a href="/admin/gifts?filter=stale" style="color:#b08e4a;font-weight:600;margin-left:0.4rem;">Show only these &rarr;</a>
        </div>
      <% } %>

      <!-- Filter pills -->
      <div class="filter-row">
        <a class="filter-pill <%= filter === 'unredeemed' ? 'active' : '' %>" href="/admin/gifts?filter=unredeemed">
          Awaiting Redemption <span class="count">(<%= stats.purchased %>)</span>
        </a>
        <% if (stats.stale > 0) { %>
        <a class="filter-pill pill-stale <%= filter === 'stale' ? 'active' : '' %>" href="/admin/gifts?filter=stale">
          30+ days old <span class="count">(<%= stats.stale %>)</span>
        </a>
        <% } %>
        <a class="filter-pill <%= filter === 'redeemed' ? 'active' : '' %>" href="/admin/gifts?filter=redeemed">
          Redeemed <span class="count">(<%= stats.redeemed %>)</span>
        </a>
        <% if (stats.expired > 0) { %>
        <a class="filter-pill <%= filter === 'expired' ? 'active' : '' %>" href="/admin/gifts?filter=expired">
          Expired <span class="count">(<%= stats.expired %>)</span>
        </a>
        <% } %>
        <a class="filter-pill <%= filter === 'all' ? 'active' : '' %>" href="/admin/gifts?filter=all">
          All <span class="count">(<%= stats.total %>)</span>
        </a>
      </div>

      <!-- Search -->
      <div class="search-bar">
        <input type="text" id="searchInput" placeholder="Search by code, buyer, or recipient..." oninput="filterTable()">
      </div>

      <!-- Gift Codes Table -->
      <div class="table-container">
        <% if (gifts.length === 0) { %>
          <div style="text-align: center; padding: 60px; color: var(--ink-light);">
            <% if (filter === 'unredeemed') { %>
              <p>No gifts awaiting redemption — everything's been claimed.</p>
              <p style="margin-top:0.5rem;font-size:0.9rem;"><a href="/admin/gifts?filter=all" style="color:var(--gold);">View all gifts &rarr;</a></p>
            <% } else if (filter === 'stale') { %>
              <p>No stale gifts. Nothing 30+ days old without a redemption.</p>
              <p style="margin-top:0.5rem;font-size:0.9rem;"><a href="/admin/gifts?filter=unredeemed" style="color:var(--gold);">View all awaiting redemption &rarr;</a></p>
            <% } else if (filter === 'redeemed') { %>
              <p>No gifts have been redeemed yet.</p>
            <% } else if (filter === 'expired') { %>
              <p>No expired gifts.</p>
            <% } else if (stats.total === 0) { %>
              <p>No gift codes yet.</p>
            <% } else { %>
              <p>No gifts match this filter.</p>
            <% } %>
          </div>
        <% } else { %>
        <table class="data-table" id="giftsTable">
          <thead>
            <tr>
              <th>Code</th>
              <th>Status</th>
              <th>Buyer</th>
              <th>Recipient</th>
              <th>Message</th>
              <th>Purchased</th>
              <th>Age</th>
              <th>Expires</th>
              <th>Account</th>
            </tr>
          </thead>
          <tbody>
            <% gifts.forEach(function(gift) { %>
              <tr class="<%= gift.is_stale ? 'row-stale' : '' %>" data-search="<%= (gift.code || '').toLowerCase() %> <%= (gift.buyer_email || '').toLowerCase() %> <%= (gift.buyer_name || '').toLowerCase() %> <%= (gift.recipient_name || '').toLowerCase() %> <%= (gift.recipient_email || '').toLowerCase() %>">
                <td>
                  <span class="code-badge"><%= gift.code %></span>
                  <% if (gift.is_comp) { %><span class="badge-comp" title="Free influencer / promo gift — no charge">COMP</span><% } %>
                </td>
                <td>
                  <span class="badge badge-<%= gift.status %>"><%= gift.status %></span>
                </td>
                <td class="cell-name">
                  <%= gift.buyer_name || '—' %>
                  <% if (gift.buyer_email) { %>
                    <small><%= gift.buyer_email %></small>
                  <% } %>
                </td>
                <td class="cell-name">
                  <%= gift.recipient_name || '—' %>
                  <% if (gift.recipient_email) { %>
                    <small><%= gift.recipient_email %></small>
                  <% } %>
                </td>
                <td class="cell-message" title="<%= gift.recipient_message || '' %>">
                  <%= gift.recipient_message || '—' %>
                </td>
                <td class="cell-date">
                  <%= gift.created_at ? new Date(gift.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—' %>
                </td>
                <td class="cell-age <%= gift.is_stale ? 'stale' : '' %>">
                  <% if (gift.days_since_purchase === null) { %>
                    —
                  <% } else if (gift.days_since_purchase === 0) { %>
                    Today
                  <% } else if (gift.days_since_purchase === 1) { %>
                    1 day
                  <% } else { %>
                    <%= gift.days_since_purchase %> days
                  <% } %>
                </td>
                <td class="cell-date">
                  <% const now = new Date(); const exp = gift.expires_at ? new Date(gift.expires_at) : null; %>
                  <% if (exp && exp < now && gift.status !== 'redeemed') { %>
                    <span style="color: var(--rose);"><%= exp.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  <% } else if (exp) { %>
                    <%= exp.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td>
                  <% if (gift.family_id) { %>
                    <a href="/admin/families/<%= gift.family_id %>" class="btn btn-secondary btn-sm">View</a>
                  <% } else { %>
                    <span style="color: var(--ink-light); font-size: 0.8rem;">Not redeemed</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
        <% } %>
      </div>

      <div style="margin-top: 1.5rem; padding: 1rem 1.25rem; background: #fdf8f0; border: 1px solid #e8d9b0; border-radius: 8px; font-size: 0.875rem; color: var(--ink-mid);">
        <strong>If a customer contacts you about a lost gift code:</strong>
        search by their email above, copy the code from the table, and send it to them manually.
        The redemption link is <code style="font-size:0.8rem;">legacyodyssey.com/redeem?code=THEIR-CODE</code>.
      </div>
    </main>
  </div>

  <script>
    function filterTable() {
      const query = document.getElementById('searchInput').value.toLowerCase().trim();
      const rows = document.querySelectorAll('#giftsTable tbody tr');
      rows.forEach(function(row) {
        const text = row.getAttribute('data-search') || '';
        row.style.display = text.includes(query) ? '' : 'none';
      });
    }

    // Comp form: toggle the scheduled-date field; require recipient email
    // unless delivery is "I'll give it to them myself".
    function compSyncDelivery() {
      var method = document.getElementById('deliveryMethod').value;
      document.getElementById('compScheduledRow').style.display = (method === 'email_scheduled') ? '' : 'none';
      document.getElementById('recipientEmail').required = (method !== 'print');
    }
    document.addEventListener('DOMContentLoaded', function () {
      if (document.getElementById('deliveryMethod')) compSyncDelivery();
      var f = document.getElementById('compForm');
      if (f) f.addEventListener('submit', function () {
        var b = document.getElementById('compSubmit');
        b.disabled = true; b.textContent = 'Minting…';
      });
    });
  </script>
</body>
</html>
