<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-brand">
        <h2>&#10022; Legacy Odyssey</h2>
        <span>Admin Portal</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin" class="active">
          <span class="nav-icon">&#128202;</span> Dashboard
        </a>
        <a href="/admin/gifts">
          <span class="nav-icon">&#127873;</span> Gift Codes
        </a>
        <a href="/admin/health">
          <span class="nav-icon">&#128300;</span> Health
        </a>
      </nav>
      <div class="sidebar-footer">
        <div class="admin-email"><%= admin.email %></div>
        <form action="/admin/logout" method="POST" style="display:inline;">
          <button type="submit" class="logout-btn">&#x2192; Sign Out</button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start;">
        <div>
          <h1>Dashboard</h1>
          <p>Customer overview and management</p>
        </div>
        <a href="/admin/customers/new" class="btn btn-primary">&#x2795; Add Customer</a>
      </div>

      <!-- KPI Cards — click any card to see that group of customers below -->
      <div class="kpi-grid">
        <a class="kpi-card" href="/admin?filter=all" style="display:block;text-decoration:none;color:inherit;cursor:pointer;">
          <div class="kpi-label">Total Customers</div>
          <div class="kpi-value"><%= stats.total %></div>
        </a>
        <a class="kpi-card kpi-active" href="/admin?filter=active" style="display:block;text-decoration:none;color:inherit;cursor:pointer;">
          <div class="kpi-label">Active</div>
          <div class="kpi-value"><%= stats.active %></div>
        </a>
        <a class="kpi-card kpi-canceled" href="/admin?filter=canceled" style="display:block;text-decoration:none;color:inherit;cursor:pointer;">
          <div class="kpi-label">Canceled</div>
          <div class="kpi-value"><%= stats.canceled %></div>
        </a>
        <a class="kpi-card" href="/admin?filter=archived" style="display:block;text-decoration:none;color:inherit;cursor:pointer;border-left:3px solid #8a7e6b;">
          <div class="kpi-label">Archived</div>
          <div class="kpi-value"><%= stats.archived %></div>
        </a>
      </div>

      <% if (typeof giftStats !== 'undefined' && giftStats.total > 0) { %>
        <!-- Gift Cards Section -->
        <div style="margin-top: 2rem;">
          <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:0.75rem;">
            <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:600;color:var(--ink);margin:0;">Gift Cards</h2>
            <a href="/admin/gifts" style="font-size:0.85rem;color:var(--gold);text-decoration:none;">Manage gift codes &rarr;</a>
          </div>

          <% if (giftStats.stale > 0) { %>
            <div style="background:#fff8e7;border:1px solid #e8d9b0;border-left:4px solid #b08e4a;border-radius:8px;padding:0.85rem 1.1rem;margin-bottom:1rem;font-size:0.9rem;color:var(--ink);">
              <strong>&#9888; <%= giftStats.stale %> gift<%= giftStats.stale === 1 ? '' : 's' %> purchased 30+ days ago that haven't been redeemed yet.</strong>
              <a href="/admin/gifts?filter=stale" style="color:var(--gold);margin-left:0.4rem;">Review &rarr;</a>
            </div>
          <% } %>

          <div class="kpi-grid">
            <div class="kpi-card">
              <div class="kpi-label">Total Gifts Purchased</div>
              <div class="kpi-value"><%= giftStats.total %></div>
            </div>
            <div class="kpi-card kpi-trialing">
              <div class="kpi-label">Awaiting Redemption</div>
              <div class="kpi-value"><%= giftStats.unredeemed %></div>
              <% if (giftStats.unredeemed > 0) { %>
                <a href="/admin/gifts?filter=unredeemed" style="font-size:0.78rem;color:var(--gold);text-decoration:none;display:block;margin-top:0.4rem;">View &rarr;</a>
              <% } %>
            </div>
            <div class="kpi-card kpi-active">
              <div class="kpi-label">Redeemed</div>
              <div class="kpi-value"><%= giftStats.redeemed %></div>
            </div>
            <% if (giftStats.expired > 0) { %>
            <div class="kpi-card kpi-canceled">
              <div class="kpi-label">Expired Unused</div>
              <div class="kpi-value"><%= giftStats.expired %></div>
            </div>
            <% } %>
          </div>
        </div>
      <% } %>

      <!-- KPI filter indicator — shown when you arrive from a clicked KPI card -->
      <div id="kpiFilterBanner" style="display:none;align-items:center;gap:10px;margin:24px 0 4px;padding:10px 14px;background:#fff8e7;border:1px solid #e8d9b0;border-radius:8px;font-size:0.9rem;color:#1a1a2e;">
        <span id="kpiFilterText"></span>
        <a href="/admin" style="color:var(--gold);text-decoration:none;font-weight:600;">Clear &times;</a>
      </div>

      <!-- View tabs: Active customers vs Archived -->
      <div style="display:flex;gap:8px;margin:24px 0 12px;">
        <button type="button" id="tabActive" class="btn btn-sm" style="background:#1a1a2e;color:#fff;border:none;padding:8px 18px;border-radius:6px;cursor:pointer;" onclick="setView('active')">
          Active (<span id="activeCount"><%= stats.total - stats.archived %></span>)
        </button>
        <button type="button" id="tabArchived" class="btn btn-sm" style="background:#fff;color:#1a1a2e;border:1px solid #e0d5c4;padding:8px 18px;border-radius:6px;cursor:pointer;" onclick="setView('archived')">
          Archived (<%= stats.archived %>)
        </button>
      </div>

      <!-- Search -->
      <div class="search-bar">
        <input type="text" id="searchInput" placeholder="Search by name, email, or domain..." oninput="applyFilters()">
      </div>

      <!-- Customer Table -->
      <div class="table-container">
        <table class="data-table" id="customersTable">
          <thead>
            <tr>
              <th class="sortable" data-sort="name" onclick="sortBy('name')" style="cursor:pointer;user-select:none;">Customer <span class="sort-arrow"></span></th>
              <th>Email</th>
              <th>Website</th>
              <th class="sortable" data-sort="status" onclick="sortBy('status')" style="cursor:pointer;user-select:none;">Status <span class="sort-arrow"></span></th>
              <th class="sortable" data-sort="date" onclick="sortBy('date')" style="cursor:pointer;user-select:none;">Signed Up <span class="sort-arrow"></span></th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% families.forEach(function(fam) { %>
              <tr
                data-archived="<%= fam.archived_at ? '1' : '0' %>"
                data-name="<%= ((fam.customer_name || fam.display_name || fam.email || '').toLowerCase()) %>"
                data-status="<%= (fam.subscription_status || '').toLowerCase() %>"
                data-date="<%= fam.created_at ? new Date(fam.created_at).getTime() : 0 %>"
                data-search="<%= (fam.customer_name || '').toLowerCase() %> <%= (fam.display_name || '').toLowerCase() %> <%= (fam.childName || '').toLowerCase() %> <%= (fam.email || '').toLowerCase() %> <%= (fam.subdomain || '').toLowerCase() %> <%= (fam.custom_domain || '').toLowerCase() %> <%= (fam.subscription_status || '').toLowerCase() %>">
                <td class="cell-name">
                  <%= fam.customer_name || fam.display_name || 'Unnamed' %>
                  <% if (fam.customer_name && fam.display_name) { %>
                    <small><%= fam.display_name %></small>
                  <% } else if (fam.childName) { %>
                    <small><%= fam.childName %></small>
                  <% } %>
                </td>
                <td class="cell-email"><%= fam.email %></td>
                <td class="cell-domain">
                  <% if (fam.custom_domain) { %>
                    <a href="/book/<%= fam.subdomain %>" target="_blank"><%= fam.custom_domain %></a>
                  <% } else if (fam.subdomain) { %>
                    <a href="/book/<%= fam.subdomain %>" target="_blank"><%= fam.subdomain %>.legacyodyssey.com</a>
                  <% } else { %>
                    <span style="color: var(--ink-light);">No domain</span>
                  <% } %>
                </td>
                <td>
                  <% if (!fam.is_active) { %>
                    <span class="badge badge-inactive">Inactive</span>
                  <% } else { %>
                    <span class="badge badge-<%= fam.subscription_status %>"><%= fam.subscription_status %></span>
                  <% } %>
                </td>
                <td class="cell-date">
                  <%= fam.created_at ? new Date(fam.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—' %>
                </td>
                <td>
                  <a href="/admin/families/<%= fam.id %>" class="btn btn-secondary btn-sm">View</a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (families.length === 0) { %>
        <div style="text-align: center; padding: 60px; color: var(--ink-light);">
          <p>No customers yet.</p>
        </div>
      <% } %>
    </main>
  </div>

  <script>
    // ── State ──
    let currentView = 'active';   // 'active' | 'archived'
    let currentSort = { key: 'date', dir: 'desc' }; // default: newest signups first

    // KPI filter — set when arriving via a clicked KPI card (?filter=...).
    // When set, it drives the table scope instead of the Active/Archived tab.
    let kpiFilter = new URLSearchParams(window.location.search).get('filter');
    if (!['all', 'active', 'canceled', 'archived'].includes(kpiFilter)) kpiFilter = null;

    // ── Filter (combines KPI filter OR tab, plus search) ──
    function applyFilters() {
      const query = (document.getElementById('searchInput').value || '').toLowerCase().trim();
      const rows = document.querySelectorAll('#customersTable tbody tr');
      rows.forEach(function(row) {
        const archived = row.getAttribute('data-archived') === '1';
        const status = row.getAttribute('data-status') || '';
        let matchesScope;
        if (kpiFilter === 'all') {
          matchesScope = true;
        } else if (kpiFilter === 'active') {
          matchesScope = status === 'active';
        } else if (kpiFilter === 'canceled') {
          matchesScope = status === 'canceled';
        } else if (kpiFilter === 'archived') {
          matchesScope = archived;
        } else {
          matchesScope = (currentView === 'archived') ? archived : !archived;
        }
        const matchesSearch = !query || (row.getAttribute('data-search') || '').includes(query);
        row.style.display = (matchesScope && matchesSearch) ? '' : 'none';
      });
    }

    // ── Tab switching ──
    function setView(view) {
      // Clicking a tab clears any KPI-card filter.
      kpiFilter = null;
      const banner = document.getElementById('kpiFilterBanner');
      if (banner) banner.style.display = 'none';
      currentView = view;
      const active = document.getElementById('tabActive');
      const archived = document.getElementById('tabArchived');
      if (view === 'active') {
        active.style.background = '#1a1a2e'; active.style.color = '#fff'; active.style.border = 'none';
        archived.style.background = '#fff'; archived.style.color = '#1a1a2e'; archived.style.border = '1px solid #e0d5c4';
      } else {
        archived.style.background = '#1a1a2e'; archived.style.color = '#fff'; archived.style.border = 'none';
        active.style.background = '#fff'; active.style.color = '#1a1a2e'; active.style.border = '1px solid #e0d5c4';
      }
      applyFilters();
    }

    // ── Sortable columns ──
    function sortBy(key) {
      // Toggle direction if same key clicked twice; otherwise default ascending
      // (except date, which defaults to descending — newest first feels right)
      if (currentSort.key === key) {
        currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
      } else {
        currentSort.key = key;
        currentSort.dir = (key === 'date') ? 'desc' : 'asc';
      }
      applySort();
      updateSortArrows();
    }

    function applySort() {
      const tbody = document.querySelector('#customersTable tbody');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      const key = currentSort.key;
      const dir = currentSort.dir === 'asc' ? 1 : -1;
      rows.sort(function(a, b) {
        let av = a.getAttribute('data-' + key) || '';
        let bv = b.getAttribute('data-' + key) || '';
        if (key === 'date') { av = parseInt(av, 10) || 0; bv = parseInt(bv, 10) || 0; return (av - bv) * dir; }
        if (av < bv) return -1 * dir;
        if (av > bv) return 1 * dir;
        return 0;
      });
      rows.forEach(function(r) { tbody.appendChild(r); });
    }

    function updateSortArrows() {
      document.querySelectorAll('.sortable').forEach(function(th) {
        const arrow = th.querySelector('.sort-arrow');
        if (!arrow) return;
        if (th.getAttribute('data-sort') === currentSort.key) {
          arrow.textContent = currentSort.dir === 'asc' ? ' ▲' : ' ▼';
          arrow.style.color = '#c8a96e';
        } else {
          arrow.textContent = ' ↕';
          arrow.style.color = '#c8c0b0';
        }
      });
    }

    // ── Init ──
    document.addEventListener('DOMContentLoaded', function() {
      if (kpiFilter) {
        const labels = {
          all: 'all customers',
          active: 'active customers',
          canceled: 'canceled customers',
          archived: 'archived customers',
        };
        const banner = document.getElementById('kpiFilterBanner');
        const txt = document.getElementById('kpiFilterText');
        if (banner && txt) {
          txt.textContent = 'Showing ' + (labels[kpiFilter] || kpiFilter);
          banner.style.display = 'flex';
        }
      }
      applySort();
      updateSortArrows();
      applyFilters();
    });
  </script>
</body>
</html>
