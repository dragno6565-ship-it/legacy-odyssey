<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css?v=20260529">
</head>
<body>
  <div class="login-page">
    <div class="login-card">
      <div class="login-logo">&#10022; Legacy Odyssey</div>
      <div class="login-subtitle">Admin Portal</div>

      <% if (error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>

      <form action="/admin/login" method="POST">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" placeholder="admin@legacyodyssey.com">

        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="Enter your password">

        <button type="submit">Sign In</button>
      </form>
    </div>
  </div>
</body>
</html>
