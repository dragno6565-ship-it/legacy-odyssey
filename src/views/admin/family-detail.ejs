<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= family.customer_name || family.display_name || 'Customer' %> — Admin — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-brand">
        <h2>&#10022; Legacy Odyssey</h2>
        <span>Admin Portal</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin">
          <span class="nav-icon">&#128202;</span> Dashboard
        </a>
        <a href="/admin/gifts">
          <span class="nav-icon">&#127873;</span> Gift Codes
        </a>
        <a href="/admin/health">
          <span class="nav-icon">&#128300;</span> Health
        </a>
      </nav>
      <div class="sidebar-footer">
        <div class="admin-email"><%= admin.email %></div>
        <form action="/admin/logout" method="POST" style="display:inline;">
          <button type="submit" class="logout-btn">&#x2192; Sign Out</button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <div class="page-header">
        <p style="margin-bottom: 8px;"><a href="/admin">&larr; Back to Dashboard</a></p>
        <h1><%= family.customer_name || family.display_name || 'Customer Detail' %></h1>
        <% if (family.customer_name && family.display_name) { %>
          <p style="color: var(--ink-light); font-size: 0.9rem; margin: 0 0 4px;">Site: <%= family.display_name %></p>
        <% } %>
        <p>
          <% if (!family.is_active) { %>
            <span class="badge badge-inactive">Inactive</span>
          <% } else { %>
            <span class="badge badge-<%= family.subscription_status %>"><%= family.subscription_status %></span>
          <% } %>
          &nbsp;&middot;&nbsp;
          Joined <%= family.created_at ? new Date(family.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : 'Unknown' %>
        </p>
      </div>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="flash-message flash-success"><%= success %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="flash-message flash-error"><%= error %></div>
      <% } %>

      <form action="/admin/families/<%= family.id %>" method="POST">
        <div class="detail-grid">
          <!-- Left Column -->
          <div>
            <!-- Account Info -->
            <div class="detail-card">
              <h3>Account Information</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>Customer Name</label>
                  <input type="text" name="customer_name" value="<%= family.customer_name || '' %>" placeholder="e.g. Dan Ragno">
                  <div class="help-text">Real purchaser's name — used for admin lookup and support</div>
                </div>
                <div class="form-group">
                  <label>Email</label>
                  <input type="email" name="email" value="<%= family.email || '' %>">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Site / Family Name</label>
                  <input type="text" name="display_name" value="<%= family.display_name || '' %>" placeholder="Family name">
                </div>
                <div class="form-group">
                  <label>Book Password</label>
                  <input type="text" name="book_password" value="<%= family.book_password || '' %>">
                  <div class="help-text">Password visitors need to view the public book</div>
                </div>
              </div>
            </div>

            <!-- Website Info -->
            <div class="detail-card">
              <h3>Website</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>Subdomain</label>
                  <input type="text" name="subdomain" value="<%= family.subdomain || '' %>" placeholder="e.g. smithfamily">
                  <% if (family.subdomain) { %>
                    <div class="help-text">
                      <a href="/book/<%= family.subdomain %>" target="_blank"><%= family.subdomain %>.legacyodyssey.com &#8599;</a>
                    </div>
                  <% } %>
                </div>
                <div class="form-group">
                  <label>Custom Domain</label>
                  <input type="text" name="custom_domain" value="<%= family.custom_domain || '' %>" placeholder="e.g. www.example.com">
                  <% if (family.custom_domain) { %>
                    <div class="help-text">
                      <a href="https://<%= family.custom_domain %>" target="_blank"><%= family.custom_domain %> &#8599;</a>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>

            <!-- Subscription -->
            <div class="detail-card">
              <h3>Subscription</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>Status</label>
                  <select name="subscription_status">
                    <option value="trialing" <%= family.subscription_status === 'trialing' ? 'selected' : '' %>>Trialing</option>
                    <option value="active" <%= family.subscription_status === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="past_due" <%= family.subscription_status === 'past_due' ? 'selected' : '' %>>Past Due</option>
                    <option value="canceled" <%= family.subscription_status === 'canceled' ? 'selected' : '' %>>Canceled</option>
                    <option value="unpaid" <%= family.subscription_status === 'unpaid' ? 'selected' : '' %>>Unpaid</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Trial Ends</label>
                  <input type="text" value="<%= family.trial_ends_at ? new Date(family.trial_ends_at).toLocaleDateString('en-US') : 'N/A' %>" readonly>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Stripe Customer ID</label>
                  <% if (family.stripe_customer_id) { %>
                    <input type="text" value="<%= family.stripe_customer_id %>" readonly>
                    <div class="help-text">
                      <a href="https://dashboard.stripe.com/customers/<%= family.stripe_customer_id %>" target="_blank">View in Stripe &#8599;</a>
                    </div>
                  <% } else { %>
                    <input type="text" value="No Stripe account" readonly>
                  <% } %>
                </div>
                <div class="form-group">
                  <label>Subscription ID</label>
                  <input type="text" value="<%= family.stripe_subscription_id || 'None' %>" readonly>
                </div>
              </div>
            </div>

            <!-- Child Info (from book) -->
            <% if (bookData && bookData.book) { %>
            <div class="detail-card">
              <h3>Child Information</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>First Name</label>
                  <input type="text" value="<%= bookData.book.child_first_name || '' %>" readonly>
                </div>
                <div class="form-group">
                  <label>Middle Name</label>
                  <input type="text" value="<%= bookData.book.child_middle_name || '' %>" readonly>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Last Name</label>
                  <input type="text" value="<%= bookData.book.child_last_name || '' %>" readonly>
                </div>
                <div class="form-group">
                  <label>Birth Date</label>
                  <input type="text" value="<%= bookData.book.birth_date ? new Date(bookData.book.birth_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : 'Not set' %>" readonly>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Birth City</label>
                  <input type="text" value="<%= bookData.book.birth_city || '' %><%= bookData.book.birth_state ? ', ' + bookData.book.birth_state : '' %>" readonly>
                </div>
                <div class="form-group">
                  <label>Hospital</label>
                  <input type="text" value="<%= bookData.book.birth_hospital || '' %>" readonly>
                </div>
              </div>
            </div>
            <% } %>
          </div>

          <!-- Right Column -->
          <div>
            <!-- Dates -->
            <div class="detail-card">
              <h3>Account Dates</h3>
              <div class="form-group">
                <label>Created</label>
                <input type="text" value="<%= family.created_at ? new Date(family.created_at).toLocaleString('en-US') : 'Unknown' %>" readonly>
              </div>
              <div class="form-group">
                <label>Last Updated</label>
                <input type="text" value="<%= family.updated_at ? new Date(family.updated_at).toLocaleString('en-US') : 'Unknown' %>" readonly>
              </div>
              <div class="form-group">
                <label>Family ID</label>
                <input type="text" value="<%= family.id %>" readonly style="font-size: 0.75rem;">
              </div>
            </div>

            <!-- Gift Code (if account was created via gift redemption) -->
            <% if (giftCode) { %>
            <div class="detail-card">
              <h3>&#127873; Gift Code</h3>
              <p style="font-size: 0.85rem; color: var(--ink-light); margin-bottom: 12px;">
                This account was created by redeeming a gift. If the customer contacts you about their code, copy it below.
              </p>
              <div class="form-group">
                <label>Code</label>
                <div style="display: flex; gap: 8px; align-items: center;">
                  <input type="text" value="<%= giftCode.code %>" readonly
                    style="font-family: 'Courier New', monospace; font-weight: 600; letter-spacing: 0.05em;">
                  <button type="button" onclick="copyGiftCode('<%= giftCode.code %>')"
                    class="btn btn-secondary btn-sm" style="white-space: nowrap;">Copy</button>
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Purchased By</label>
                  <input type="text" value="<%= [giftCode.buyer_name, giftCode.buyer_email].filter(Boolean).join(' — ') || '—' %>" readonly>
                </div>
                <div class="form-group">
                  <label>Redeemed</label>
                  <input type="text" value="<%= giftCode.redeemed_at ? new Date(giftCode.redeemed_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '—' %>" readonly>
                </div>
              </div>
              <% if (giftCode.recipient_message) { %>
              <div class="form-group">
                <label>Gift Message</label>
                <textarea readonly style="resize: none; background: #fdf8f0; font-style: italic; color: var(--ink-mid);"><%= giftCode.recipient_message %></textarea>
              </div>
              <% } %>
              <div style="margin-top: 8px;">
                <a href="/admin/gifts" class="btn btn-secondary btn-sm">&#8592; All Gift Codes</a>
              </div>
            </div>
            <% } %>

            <!-- Book Progress -->
            <% if (bookData && bookData.visibleSections) { %>
            <div class="detail-card">
              <h3>Book Progress</h3>
              <ul class="progress-list">
                <% const sectionLabels = {
                  before: 'Before Arrived',
                  birth: 'Birth Story',
                  home: 'Coming Home',
                  months: 'Month by Month',
                  family: 'Our Family',
                  firsts: 'Your Firsts',
                  holidays: 'Celebrations',
                  letters: 'Letters',
                  recipes: 'Family Recipes',
                  vault: 'The Vault'
                }; %>
                <% Object.entries(sectionLabels).forEach(function([key, label]) { %>
                  <li>
                    <span class="check <%= bookData.visibleSections[key] ? 'check-yes' : 'check-no' %>">
                      <%= bookData.visibleSections[key] ? '&#10003;' : '&#8212;' %>
                    </span>
                    <%= label %>
                  </li>
                <% }); %>
              </ul>
            </div>
            <% } %>

            <!-- Quick Links -->
            <div class="detail-card">
              <h3>Quick Links</h3>
              <div style="display: flex; flex-direction: column; gap: 10px;">
                <% if (family.subdomain) { %>
                  <a href="/book/<%= family.subdomain %>" target="_blank" class="btn btn-secondary btn-sm">
                    &#128214; View Public Book
                  </a>
                <% } %>
                <% if (family.stripe_customer_id) { %>
                  <a href="https://dashboard.stripe.com/customers/<%= family.stripe_customer_id %>" target="_blank" class="btn btn-secondary btn-sm">
                    &#128179; Stripe Dashboard
                  </a>
                <% } %>
              </div>
            </div>

            <!-- Reset Password -->
            <div class="detail-card">
              <h3>&#128272; Reset Password</h3>
              <p style="font-size: 0.85rem; color: var(--ink-light); margin-bottom: 12px;">
                Resets the password for both the <strong>mobile app</strong> and the <strong>account area</strong> (legacyodyssey.com/account). Both use the same login credentials.
              </p>
              <form action="/admin/families/<%= family.id %>/reset-password" method="POST"
                    onsubmit="return confirm('Reset the password for <%= family.email %>? This affects both app and account login.');">
                <div class="form-group" style="margin-bottom: 10px;">
                  <label>New Password</label>
                  <input type="text" name="new_password" placeholder="Min. 6 characters" autocomplete="off">
                </div>
                <button type="submit" class="btn btn-secondary btn-sm">Reset Password</button>
              </form>
            </div>

            <!-- Send Welcome Email -->
            <div class="detail-card">
              <h3>&#9993; Send Welcome Email</h3>
              <p style="font-size: 0.85rem; color: var(--ink-light); margin-bottom: 12px;">
                Sends a fresh temporary password (auto-generated and applied to their account) plus their book password and app download link.
              </p>
              <div style="display: flex; flex-direction: column; gap: 10px;">
                <div class="form-group">
                  <label>Send To (leave blank to use account email)</label>
                  <input type="text" id="welcomeSendTo" placeholder="<%= family.email %>" value="">
                </div>
                <button type="button" class="btn btn-primary btn-sm" onclick="sendWelcomeEmail()" id="sendEmailBtn">
                  &#9993; Send Welcome Email
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Action Bar -->
        <div class="action-bar">
          <button type="submit" class="btn btn-primary">Save Changes</button>
          <% if (family.subdomain) { %>
            <a href="/book/<%= family.subdomain %>" target="_blank" class="btn btn-secondary">View Book</a>
          <% } %>
          <div style="flex: 1;"></div>
          <% if (family.is_active) { %>
            <a href="/admin/families/<%= family.id %>/toggle-active" class="btn btn-danger btn-sm"
               onclick="return confirm('Are you sure you want to deactivate this account?');">
              Deactivate Account
            </a>
          <% } else { %>
            <a href="/admin/families/<%= family.id %>/toggle-active" class="btn btn-success btn-sm">
              Reactivate Account
            </a>
          <% } %>
          <!-- Cancel & Archive: soft cancel that keeps all data for resubscribe. -->
          <form action="/admin/families/<%= family.id %>/cancel" method="POST" style="margin-left: 8px;"
                onsubmit="return confirm('Cancel & archive this account?\n\n• Stripe subscription cancels at period end\n• Spaceship domain auto-renew stops\n• Family marked archived; book shows suspended page\n• Photos, content, and login user PRESERVED for resubscribe');">
            <button type="submit" class="btn btn-sm" style="background:#b08e4a;color:white;border:none;padding:6px 16px;border-radius:6px;cursor:pointer;">
              Cancel & Archive
            </button>
          </form>
          <!-- Permanent delete: requires typing email to confirm. -->
          <form action="/admin/families/<%= family.id %>/delete" method="POST" style="margin-left: 8px;"
                onsubmit="return confirmPermanentDelete(this);">
            <input type="hidden" name="confirm_email" id="confirmEmailInput" value="">
            <button type="submit" class="btn btn-sm" style="background:#8b0000;color:white;border:none;padding:6px 16px;border-radius:6px;cursor:pointer;">
              Permanently Delete
            </button>
          </form>
        </div>
      </form>
    </main>
  </div>
  <script>
    function copyGiftCode(code) {
      navigator.clipboard.writeText(code).then(function() {
        alert('Gift code copied: ' + code);
      });
    }

    // PERMANENTLY DELETE — typed email confirmation. Photos + auth user wiped,
    // SQL rows deleted, Stripe cancelled, Spaceship auto-renew stopped.
    function confirmPermanentDelete(form) {
      const expected = '<%= (family.email || "").toLowerCase() %>';
      if (!expected) { alert('This family has no email — cannot use typed-email confirm. Use Cancel & Archive instead.'); return false; }
      const typed = window.prompt(
        'PERMANENTLY DELETE this account?\n\n' +
        'This wipes ALL data: photos, books, content, login user.\n' +
        'Stripe subscription cancels, Spaceship auto-renew stops, but the\n' +
        'domain registration itself stays in your account until expiry.\n\n' +
        'CANNOT BE UNDONE.\n\n' +
        'Type the family email to confirm:\n' + expected
      );
      if (!typed) return false;
      if (typed.trim().toLowerCase() !== expected) { alert('Typed email did not match. Aborted.'); return false; }
      form.querySelector('#confirmEmailInput').value = typed.trim();
      return true;
    }

    function sendWelcomeEmail() {
      const sendTo = document.getElementById('welcomeSendTo').value.trim() || '<%= family.email %>';
      if (!confirm('Send welcome email to ' + sendTo + '?\n\nThis will reset their app login password to a new temporary one.')) return;

      // Create a hidden form and submit it
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '/admin/families/<%= family.id %>/send-welcome';

      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'send_to_email';
      input.value = sendTo;
      form.appendChild(input);

      document.body.appendChild(form);
      form.submit();
    }
  </script>
</body>
</html>
