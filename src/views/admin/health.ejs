<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Health Check — Admin · Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .health-summary { display:flex; gap:16px; flex-wrap:wrap; margin-bottom:24px; }
    .health-card { flex:1; min-width:140px; padding:18px 22px; border-radius:8px; border:1px solid var(--border); background:#fff; }
    .health-card h3 { margin:0 0 4px; font-size:11px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; color:var(--ink-light); }
    .health-card .num { font-family:'Cormorant Garamond',serif; font-size:36px; font-weight:600; line-height:1; }
    .health-card.pass { border-left:3px solid #2e7d4f; }
    .health-card.pass .num { color:#2e7d4f; }
    .health-card.warn { border-left:3px solid #b08e4a; }
    .health-card.warn .num { color:#b08e4a; }
    .health-card.fail { border-left:3px solid #c0392b; }
    .health-card.fail .num { color:#c0392b; }
    .health-card.total .num { color:var(--ink); }
    .health-meta { font-size:12px; color:var(--ink-light); margin-bottom:18px; }
    .filter-pills { display:flex; gap:6px; flex-wrap:wrap; margin:18px 0 12px; }
    .filter-pills a { padding:5px 12px; border-radius:18px; border:1px solid var(--border); font-size:12px; text-decoration:none; color:var(--ink); background:#fff; }
    .filter-pills a.active { background:#1a1a2e; color:#fff; border-color:#1a1a2e; }
    table.checks { width:100%; border-collapse:collapse; }
    table.checks th, table.checks td { padding:10px 14px; border-bottom:1px solid var(--border); font-size:13px; text-align:left; vertical-align:top; }
    table.checks th { font-size:11px; text-transform:uppercase; letter-spacing:1px; color:var(--ink-light); font-weight:600; background:#faf7f0; }
    .badge-pass { background:#e9f4ec; color:#2e7d4f; padding:2px 9px; border-radius:12px; font-size:11px; font-weight:600; }
    .badge-warn { background:#fcf2dc; color:#b08e4a; padding:2px 9px; border-radius:12px; font-size:11px; font-weight:600; }
    .badge-fail { background:#fdecea; color:#c0392b; padding:2px 9px; border-radius:12px; font-size:11px; font-weight:600; }
    .check-detail { color:var(--ink-light); font-size:12px; margin-top:2px; }
    .check-ms { color:#a09080; font-size:11px; }
    .run-btn { background:#c8a96e; color:#fff; border:none; padding:9px 20px; border-radius:6px; font-weight:600; cursor:pointer; font-size:13px; text-decoration:none; display:inline-block; }
    .run-btn:hover { background:#b08e4a; }
  </style>
</head>
<body>
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="sidebar-brand">
        <h2>&#10022; Legacy Odyssey</h2>
        <span>Admin Portal</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin"><span class="nav-icon">&#128202;</span> Dashboard</a>
        <a href="/admin/gifts"><span class="nav-icon">&#127873;</span> Gift Codes</a>
        <a href="/admin/health" class="active"><span class="nav-icon">&#128300;</span> Health</a>
      </nav>
      <div class="sidebar-footer">
        <div class="admin-email"><%= admin.email %></div>
        <form action="/admin/logout" method="POST" style="display:inline;">
          <button type="submit" class="logout-btn">&#x2192; Sign Out</button>
        </form>
      </div>
    </aside>

    <main class="admin-main">
      <div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div>
          <h1>Health Check</h1>
          <p>Live system check across every operational block.</p>
        </div>
        <a href="/admin/health<%= blockFilter ? '?block=' + blockFilter : '' %>" class="run-btn">⟳ Re-run</a>
      </div>

      <div class="health-summary">
        <div class="health-card total">
          <h3>Total</h3>
          <div class="num"><%= report.summary.total %></div>
        </div>
        <div class="health-card pass">
          <h3>Pass</h3>
          <div class="num"><%= report.summary.pass %></div>
        </div>
        <div class="health-card warn">
          <h3>Warn</h3>
          <div class="num"><%= report.summary.warn %></div>
        </div>
        <div class="health-card fail">
          <h3>Fail</h3>
          <div class="num"><%= report.summary.fail %></div>
        </div>
      </div>

      <div class="health-meta">
        Ran in <%= (report.totalMs / 1000).toFixed(1) %>s · <%= new Date(report.ranAt).toLocaleString() %>
      </div>

      <div class="filter-pills">
        <a href="/admin/health" class="<%= !blockFilter ? 'active' : '' %>">All blocks</a>
        <% blocks.forEach(function(b) { %>
          <a href="/admin/health?block=<%= b.blockName %>" class="<%= blockFilter === b.blockName ? 'active' : '' %>"><%= b.blockLabel %> (<%= b.count %>)</a>
        <% }) %>
      </div>

      <div class="table-container">
        <table class="checks">
          <thead>
            <tr>
              <th style="width:90px;">Status</th>
              <th style="width:170px;">Block</th>
              <th>Check</th>
              <th style="width:70px;text-align:right;">Time</th>
            </tr>
          </thead>
          <tbody>
            <% report.results.forEach(function(r) { %>
              <tr>
                <td><span class="badge-<%= r.status %>"><%= r.status.toUpperCase() %></span></td>
                <td style="font-size:12px;color:var(--ink-light);"><%= r.blockLabel %></td>
                <td>
                  <strong><%= r.name %></strong>
                  <% if (r.detail) { %><div class="check-detail"><%= r.detail %></div><% } %>
                </td>
                <td style="text-align:right;" class="check-ms"><%= r.ms %>ms</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</body>
</html>
