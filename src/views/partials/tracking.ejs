<%# Shared analytics/ads with EU/UK consent gating (G1).
     Include in <head>. Relies on res.locals.consentRequired (set by
     middleware/consentRegion.js). Loads /js/consent.js which shows the
     banner for EU/UK visitors and calls window.loEnableTracking on consent. %>
<script>
  // Region flag from the server (true only for EU/EEA/UK visitors).
  window.LO_CONSENT_REQUIRED = <%= (typeof consentRequired !== 'undefined' && consentRequired) ? 'true' : 'false' %>;
  // Microsoft Clarity project id (empty unless CLARITY_PROJECT_ID is set in env).
  window.LO_CLARITY_ID = '<%= (typeof clarityProjectId !== 'undefined' && clarityProjectId) ? clarityProjectId : '' %>';
</script>

<!-- Google Analytics 4 (Consent Mode v2) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-LMJVX82M3Q"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  // Default everything non-essential to DENIED until consent (or auto-granted
  // for non-EU/UK visitors by consent.js).
  gtag('consent', 'default', {
    ad_storage: 'denied', ad_user_data: 'denied', ad_personalization: 'denied',
    analytics_storage: 'denied', functionality_storage: 'granted', security_storage: 'granted'
  });
  gtag('js', new Date());
  <% if (typeof landingVariant !== 'undefined' && landingVariant) { %>
  gtag('set', { 'landing_variant': '<%= landingVariant %>' });
  <% } %>
  gtag('config', 'G-LMJVX82M3Q');

  // Safe stubs so any fbq()/pintrk() calls queue harmlessly before/without consent.
  (function (f) {
    if (!f.fbq) { var n = f.fbq = function(){ n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); }; if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0'; n.queue = []; }
    f.pintrk = f.pintrk || function(){ f.pintrk.queue.push(Array.prototype.slice.call(arguments)); };
    f.pintrk.queue = f.pintrk.queue || []; f.pintrk.version = '3.0';
  })(window);

  // Called once on consent (or immediately for non-EU/UK): grants Consent Mode
  // and loads the remote analytics/ad scripts + their PageView events.
  window.loEnableTracking = function () {
    if (window.__loTrackingOn) return; window.__loTrackingOn = true;
    gtag('consent', 'update', { ad_storage:'granted', ad_user_data:'granted', ad_personalization:'granted', analytics_storage:'granted' });
    var fb = document.createElement('script'); fb.async = true; fb.src = 'https://connect.facebook.net/en_US/fbevents.js'; document.head.appendChild(fb);
    fbq('init', '839009299208301'); fbq('track', 'PageView');
    var pi = document.createElement('script'); pi.async = true; pi.src = 'https://s.pinimg.com/ct/core.js'; document.head.appendChild(pi);
    pintrk('load', '2613467907928'); pintrk('page');
    var hj = document.createElement('script'); hj.async = true; hj.src = 'https://t.contentsquare.net/uxa/38cdf4e1f1a56.js'; document.head.appendChild(hj);
    // Microsoft Clarity (heatmaps + session recordings) — only when a project id
    // is configured. Loaded here so it inherits the same EU/UK consent gating.
    if (window.LO_CLARITY_ID) {
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window, document, 'clarity', 'script', window.LO_CLARITY_ID);
    }
  };
</script>
<script src="/js/consent.js" defer></script>
