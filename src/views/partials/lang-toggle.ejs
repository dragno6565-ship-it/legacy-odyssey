<%# Reusable EN|ES toggle for standalone pages (account auth). Uses ?lang= which
   the i18n middleware persists to the lo_lang cookie. `lang` is in res.locals. %>
<div style="text-align:center;margin-bottom:1.25rem;">
  <span style="display:inline-flex;border:1px solid #e0d5c4;border-radius:999px;padding:2px;font-family:'Inter',sans-serif;font-size:0.72rem;letter-spacing:0.06em;">
    <a href="?lang=en" style="padding:3px 13px;border-radius:999px;text-decoration:none;<%= lang === 'en' ? 'background:#c8a96e;color:#fff;font-weight:600;' : 'color:#8a7e6b;' %>">EN</a>
    <a href="?lang=es" style="padding:3px 13px;border-radius:999px;text-decoration:none;<%= lang === 'es' ? 'background:#c8a96e;color:#fff;font-weight:600;' : 'color:#8a7e6b;' %>">ES</a>
  </span>
</div>
