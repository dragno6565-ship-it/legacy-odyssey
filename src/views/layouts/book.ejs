<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Pinterest Domain Verification -->
  <meta name="p:domain_verify" content="b146e195f22b09a16cdab391ec6f75c1"/>
  <title><%= book.child_first_name %><%= book.child_middle_name ? ' ' + book.child_middle_name : '' %> <%= book.child_last_name %> — A Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/book.css">
  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LMJVX82M3Q"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LMJVX82M3Q');
  </script>
  <!-- End Google Analytics 4 -->

  <!-- Meta Pixel Code -->
  <script>
  !function(f,b,e,v,n,t,s)
  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window, document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '839009299208301');
  fbq('track', 'PageView');
  </script>
  <noscript>
  <img height="1" width="1" style="display:none"
  src="https://www.facebook.com/tr?id=839009299208301&ev=PageView&noscript=1"/>
  </noscript>
  <!-- End Meta Pixel Code -->

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1341319558382851"
       crossorigin="anonymous"></script>
  <!-- End Google AdSense -->

  <!-- Pinterest Tag -->
  <script>
  !function(e){if(!window.pintrk){window.pintrk = function () {
  window.pintrk.queue.push(Array.prototype.slice.call(arguments))};var
    n=window.pintrk;n.queue=[],n.version="3.0";var
    t=document.createElement("script");t.async=!0,t.src=e;var
    r=document.getElementsByTagName("script")[0];
    r.parentNode.insertBefore(t,r)}}("https://s.pinimg.com/ct/core.js");
  pintrk('load', '2613467907928');
  pintrk('page');
  </script>
  <noscript>
  <img height="1" width="1" style="display:none;" alt=""
    src="https://ct.pinterest.com/v3/?event=init&tid=2613467907928&noscript=1" />
  </noscript>
  <!-- end Pinterest Tag -->

  <% if (isFree) { %>
  <style>
    .free-ad-banner { margin: 2rem auto; max-width: 728px; text-align: center; }
    .free-upgrade-banner {
      background: linear-gradient(135deg, #1a1510 0%, #2c2416 100%);
      color: #faf7f2;
      padding: 2.5rem 2rem;
      text-align: center;
      margin: 3rem 0;
      border-top: 1px solid #c8a96e;
    }
    .free-upgrade-banner h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.8rem;
      color: #c8a96e;
      margin: 0 0 0.5rem;
    }
    .free-upgrade-banner p {
      font-family: 'Jost', sans-serif;
      font-size: 0.9rem;
      color: #d4bb8a;
      margin: 0 0 1.25rem;
      opacity: 0.85;
    }
    .free-upgrade-banner a {
      display: inline-block;
      background: #c8a96e;
      color: #1a1510;
      font-family: 'Jost', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.75rem 2rem;
      text-decoration: none;
      border-radius: 2px;
    }
    .free-locked-section {
      background: #f0e8dc;
      border: 1px dashed #c8a96e;
      border-radius: 4px;
      padding: 3rem 2rem;
      text-align: center;
      margin: 2rem 0;
    }
    .free-locked-section .lock-icon { font-size: 2rem; margin-bottom: 0.75rem; }
    .free-locked-section h4 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      color: #2c2416;
      margin: 0 0 0.5rem;
    }
    .free-locked-section p {
      font-family: 'Jost', sans-serif;
      font-size: 0.85rem;
      color: #8a7e6b;
      margin: 0 0 1.25rem;
    }
    .free-locked-section a {
      display: inline-block;
      background: #c8a96e;
      color: #1a1510;
      font-family: 'Jost', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.6rem 1.5rem;
      text-decoration: none;
      border-radius: 2px;
    }
    .powered-by-footer {
      text-align: center;
      padding: 1.5rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.75rem;
      color: #8a7e6b;
      border-top: 1px solid #e0d5c4;
      margin-top: 2rem;
    }
    .powered-by-footer a { color: #c8a96e; text-decoration: none; }
  </style>
  <% } %>
</head>
<body>
  <div id="app">
    <!-- Sidebar -->
    <%- include('../book/sidebar', { book, family, visibleSections, isFree }) %>

    <!-- Main Content -->
    <div id="main-content">
      <%- include('../book/welcome', { book, imageUrl, photoPos }) %>

      <% if (isFree) { %>
      <!-- AdSense Banner Ad (free tier) -->
      <div class="free-ad-banner">
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-1341319558382851"
             data-ad-slot="auto"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
      <% } %>

      <% if (visibleSections.before) { %>
        <%- include('../book/before', { beforeCards, checklist, imageUrl, photoPos }) %>
      <% } %>
      <% if (visibleSections.birth) { %>
        <%- include('../book/birth', { book, birthStory, imageUrl, photoPos }) %>
      <% } %>

      <% if (isFree) { %>
        <!-- Locked sections for free tier -->
        <div id="section-home" class="book-section free-locked-section">
          <div class="lock-icon">🏠</div>
          <h4>Coming Home</h4>
          <p>Upgrade to unlock Coming Home, Month by Month, Our Family, Firsts, Celebrations, Letters, Recipes &amp; The Vault.</p>
          <a href="https://legacyodyssey.com/#pricing" target="_blank">Upgrade to Full Access →</a>
        </div>
      <% } else { %>
        <% if (visibleSections.home) { %>
          <%- include('../book/home', { comingHomeCards, imageUrl, photoPos }) %>
        <% } %>
        <% if (visibleSections.months) { %>
          <%- include('../book/months', { months, imageUrl }) %>
        <% } %>
        <% if (visibleSections.family) { %>
          <%- include('../book/family', { familyMembers, imageUrl, photoPos }) %>
        <% } %>
        <% if (visibleSections.firsts) { %>
          <%- include('../book/firsts', { firsts }) %>
        <% } %>
        <% if (visibleSections.holidays) { %>
          <%- include('../book/holidays', { celebrations, imageUrl, photoPos }) %>
        <% } %>
        <% if (visibleSections.letters) { %>
          <%- include('../book/letters', { book, letters }) %>
        <% } %>
        <% if (visibleSections.recipes) { %>
          <%- include('../book/recipes', { recipes, imageUrl, photoPos }) %>
        <% } %>
        <% if (visibleSections.vault) { %>
          <%- include('../book/vault', { book, vaultItems }) %>
        <% } %>
      <% } %>

      <% if (isFree) { %>
      <!-- Upgrade CTA Banner -->
      <div class="free-upgrade-banner">
        <h3>Your Story Deserves More</h3>
        <p>Unlock all sections, add unlimited photos, and get your own custom domain.</p>
        <a href="https://legacyodyssey.com/#pricing" target="_blank">Upgrade — Starting at $4.99/mo</a>
      </div>
      <!-- Second AdSense Ad -->
      <div class="free-ad-banner">
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-1341319558382851"
             data-ad-slot="auto"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
      <% } %>

    </div>
  </div>

  <!-- Inject data for client-side JS (modals, etc.) -->
  <script>
    <% if (!isFree && visibleSections.months) { %>
    const months = <%- JSON.stringify((months || []).map(m => ({
      num: m.month_number,
      label: m.label,
      highlight: m.highlight,
      weight: m.weight,
      length: m.length,
      photo: m.photo_path ? imageUrl(m.photo_path) : null,
      pos: m.photo_path ? photoPos(m.photo_path) : '',
      note: m.note
    }))) %>;
    <% } else { %>
    const months = [];
    <% } %>

    <% if (!isFree && visibleSections.family) { %>
    const familyMembers = <%- JSON.stringify(
      Object.fromEntries((familyMembers || []).map(fm => [fm.member_key, {
        name: fm.name,
        relation: fm.relation,
        emoji: fm.emoji,
        photo: fm.photo_path ? imageUrl(fm.photo_path) : null,
        meta: [
          { label: fm.meta_1_label, value: fm.meta_1_value },
          { label: fm.meta_2_label, value: fm.meta_2_value },
          { label: fm.meta_3_label, value: fm.meta_3_value },
          { label: fm.meta_4_label, value: fm.meta_4_value },
        ].filter(m => m.label),
        story: fm.story,
        story2: fm.story2,
        quote: { text: fm.quote_text, cite: fm.quote_cite },
        photos: [
          { img: fm.album_1_path ? imageUrl(fm.album_1_path) : null, caption: fm.album_1_caption },
          { img: fm.album_2_path ? imageUrl(fm.album_2_path) : null, caption: fm.album_2_caption },
          { img: fm.album_3_path ? imageUrl(fm.album_3_path) : null, caption: fm.album_3_caption },
        ].filter(p => p.img || p.caption)
      }]))
    ) %>;
    <% } else { %>
    const familyMembers = {};
    <% } %>

    // Birth date for vault countdown
    window.birthDate = '<%= book.birth_date || '' %>';
  </script>


  <!-- Image Lightbox -->
  <div class="book-lightbox" id="bookLightbox">
    <button class="book-lightbox-close" onclick="closeLightbox()">&times;</button>
    <img id="lightboxImg" src="" alt="Full size image">
  </div>

  <% if (isFree) { %>
  <!-- Powered by Legacy Odyssey footer -->
  <div class="powered-by-footer">
    This free baby book is powered by <a href="https://legacyodyssey.com" target="_blank">Legacy Odyssey</a> —
    <a href="https://legacyodyssey.com/#pricing" target="_blank">Upgrade for full access</a>
  </div>
  <% } %>

  <script src="/js/book.js"></script>
</body>
</html>
