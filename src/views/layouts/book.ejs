      text-align: center;
      margin: 3rem 0;
      border-top: 1px solid #c8a96e;
    }
    .free-upgrade-banner h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.8rem;
      color: #c8a96e;
      margin: 0 0 0.5rem;
    }
    .free-upgrade-banner p {
      font-family: 'Jost', sans-serif;
      font-size: 0.9rem;
      color: #d4bb8a;
      margin: 0 0 1.25rem;
      opacity: 0.85;
    }
    .free-upgrade-banner a {
