<body class="<%= isDemoDomain ? 'demo-bar-visible' : '' %>">

  <% if (isDemoDomain) { %>
  <div class="demo-banner" id="demoBanner">
    <strong>This is a demo book.</strong>
    <span>Preserve your own baby's story — get your own custom domain.</span>
    <a href="https://www.legacyodyssey.com" target="_blank" class="demo-cta">Create Your Own →</a>
    <button class="demo-banner-close" onclick="document.getElementById('demoBanner').style.display='none';document.body.classList.remove('demo-bar-visible');" aria-label="Dismiss">&times;</button>
  </div>
  <% } %>

  <div id="app">
    <!-- Sidebar -->
    <%- include('../book/sidebar', { book, family, visibleSections, isFree, isDemoDomain, celebrationsByYear, activeCelebration: null, recipes, activeRecipe: null, keepsakes, activeKeepsake: null }) %>

    <!-- Main Content -->
    <div id="main-content">
      <%- include('../book/welcome', { book, imageUrl, photoPos }) %>

      <% if (isFree) { %>
      <!-- AdSense Banner Ad (free tier) -->
      <div class="free-ad-banner">
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-1341319558382851"
             data-ad-slot="auto"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
      <% } %>

      <% if (visibleSections.before) { %>
        <%- include('../book/before', { beforeCards, checklist, imageUrl, photoPos }) %>
      <% } %>
      <% if (visibleSections.birth) { %>
        <%- include('../book/birth', { book, birthStory, imageUrl, photoPos }) %>
      <% } %>
      <% if (visibleSections.birthday) { %>
        <%- include('../book/birthday', { birthdayPhotos, imageUrl, photoPos }) %>
      <% } %>
      <% if (visibleSections.moments) { %>
        <%- include('../book/video-moments', { momentsVideos }) %>
      <% } %>
      <% if (visibleSections.journey) { %>
        <%- include('../book/journey', { journeyStory, imageUrl, photoPos }) %>
      <% } %>

      <% if (isFree) { %>
        <!-- Locked sections for free tier -->
        <div id="section-home" class="book-section free-locked-section">
          <div class="lock-icon">🏠</div>
          <h4>Coming Home</h4>
          <p>Upgrade to unlock Coming Home, Month by Month, Our Family, Firsts, Celebrations, Letters, Recipes &amp; The Vault.</p>
          <a href="https://legacyodyssey.com/#pricing" target="_blank">Upgrade to Full Access →</a>
        </div>
      <% } else { %>
        <% if (visibleSections.home) { %>
          <%- include('../book/home', { comingHomeCards, imageUrl, photoPos }) %>
        <% } %>
        <% if (visibleSections.months) { %>
          <%- include('../book/months', { months, imageUrl }) %>
        <% } %>
        <% if (visibleSections.family) { %>
          <%- include('../book/family', { familyMembers, imageUrl, photoPos }) %>
        <% } %>
        <% if (visibleSections.firsts) { %>
          <%- include('../book/firsts', { firsts }) %>
        <% } %>
        <% if (visibleSections.holidays) { %>
          <%- include('../book/holidays', { celebrations, celebrationsByYear, imageUrl, photoPos }) %>
        <% } %>
        <% if (visibleSections.letters) { %>
          <%- include('../book/letters', { book, letters }) %>
        <% } %>
        <% if (visibleSections.recipes) { %>
          <%- include('../book/recipes', { recipes, imageUrl, photoPos }) %>
        <% } %>
        <% if (visibleSections.keepsakes) { %>
          <%- include('../book/keepsakes', { keepsakes, imageUrl, photoPos }) %>
        <% } %>
        <% if (visibleSections.vault) { %>
          <%- include('../book/vault', { book, vaultItems }) %>
        <% } %>
      <% } %>

      <% if (isDemoDomain) { %>
      <!-- Demo End-of-Book CTA -->
      <div class="demo-end-cta">
        <h3>Ready to Create Your Own?</h3>
        <p>Every family deserves a beautiful book like this one — with their own custom domain, their own photos, and their own story.</p>
        <a href="https://www.legacyodyssey.com" target="_blank">Get Started at Legacy Odyssey</a>
        <a href="https://www.legacyodyssey.com/#pricing" target="_blank" class="secondary">See Pricing</a>
      </div>
      <% } %>

      <% if (isFree) { %>
      <!-- Upgrade CTA Banner -->
      <div class="free-upgrade-banner">
        <h3>Your Story Deserves More</h3>
        <p>Unlock all sections, add unlimited photos, and get your own custom domain.</p>
        <a href="https://legacyodyssey.com/#pricing" target="_blank">Upgrade — Starting at $4.99/mo</a>
      </div>
      <!-- Second AdSense Ad -->
      <div class="free-ad-banner">
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-1341319558382851"
             data-ad-slot="auto"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
      <% } %>

    </div>
  </div>

  <!-- Inject data for client-side JS (modals, etc.) -->
  <script>
    <% if (!isFree && visibleSections.months) { %>
    const months = <%- JSON.stringify((months || []).map(m => ({
      num: m.month_number,
      label: m.label,
      highlight: m.highlight,
      weight: m.weight,
      length: m.length,
      photo: m.photo_path ? imageUrl(m.photo_path) : null,
      pos: m.photo_path ? photoPos(m.photo_path) : '',
      note: m.note
    }))) %>;
    <% } else { %>
    const months = [];
    <% } %>

    <% if (!isFree && visibleSections.family) { %>
    const familyMembers = <%- JSON.stringify(
      Object.fromEntries((familyMembers || []).map(fm => [fm.member_key, {
        name: fm.name,
        relation: fm.relation,
        emoji: fm.emoji,
        photo: fm.photo_path ? imageUrl(fm.photo_path) : null,
        meta: [
          { label: fm.meta_1_label, value: fm.meta_1_value },
          { label: fm.meta_2_label, value: fm.meta_2_value },
          { label: fm.meta_3_label, value: fm.meta_3_value },
          { label: fm.meta_4_label, value: fm.meta_4_value },
        ].filter(m => m.label),
        story: fm.story,
        story2: fm.story2,
        quote: { text: fm.quote_text, cite: fm.quote_cite },
        photos: [
          { img: fm.album_1_path ? imageUrl(fm.album_1_path) : null, caption: fm.album_1_caption },
          { img: fm.album_2_path ? imageUrl(fm.album_2_path) : null, caption: fm.album_2_caption },
          { img: fm.album_3_path ? imageUrl(fm.album_3_path) : null, caption: fm.album_3_caption },
        ].filter(p => p.img || p.caption),
        videoUid: (function () {
          var vid = (typeof videos !== 'undefined' ? videos : []).find(function (v) { return v.context === 'family_member' && v.family_member_id === fm.id && v.status === 'ready'; });
          return vid ? vid.stream_uid : null;
        })()
      }]))
    ) %>;
    <% } else { %>
    const familyMembers = {};
    <% } %>

    // Birth date for vault countdown
    window.birthDate = '<%= book.birth_date || '' %>';
  </script>


  <!-- Image Lightbox -->
  <div class="book-lightbox" id="bookLightbox">
    <button class="book-lightbox-close" onclick="closeLightbox()" aria-label="Close">&times;</button>
    <button class="book-lightbox-nav book-lightbox-prev" id="lightboxPrev" onclick="event.stopPropagation();lightboxNav(-1)" aria-label="Previous photo" hidden>&#8249;</button>
    <img id="lightboxImg" src="" alt="Full size image">
    <button class="book-lightbox-nav book-lightbox-next" id="lightboxNext" onclick="event.stopPropagation();lightboxNav(1)" aria-label="Next photo" hidden>&#8250;</button>
    <div class="book-lightbox-caption" id="lightboxCaption"></div>
  </div>

  <% if (isFree) { %>
  <!-- Powered by Legacy Odyssey footer -->
  <div class="powered-by-footer">
    This free baby book is powered by <a href="https://legacyodyssey.com" target="_blank">Legacy Odyssey</a> —
    <a href="https://legacyodyssey.com/#pricing" target="_blank">Upgrade for full access</a>
  </div>
  <% } %>

  <style>
    /* Content photos are click-to-enlarge; cards that open their own detail view keep the normal pointer. */
    #main-content img, #month-modal img, #family-detail img { cursor: zoom-in; }
    .month-card img, .family-card img, .nav-item img { cursor: pointer; }

    /* Lightbox gallery navigation (prev/next arrows + caption). */
    .book-lightbox-nav {
      position: absolute; top: 50%; transform: translateY(-50%);
      width: 56px; height: 56px; border: none; border-radius: 50%;
      background: rgba(0,0,0,0.45); color: #fff; cursor: pointer;
      font-size: 2.1rem; line-height: 1; font-family: serif;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s; z-index: 3; padding: 0;
    }
    .book-lightbox-nav:hover { background: rgba(0,0,0,0.75); }
    .book-lightbox-nav[hidden] { display: none; }
    .book-lightbox-prev { left: 28px; }
    .book-lightbox-next { right: 28px; }
    .book-lightbox-caption {
      position: absolute; bottom: 26px; left: 0; right: 0;
      text-align: center; color: #fff; pointer-events: none;
      font-family: 'Cormorant Garamond', serif; font-size: 1.3rem;
      padding: 0 1.5rem; text-shadow: 0 1px 6px rgba(0,0,0,0.7);
    }
    .book-lightbox-caption:empty { display: none; }
    @media (max-width: 560px) {
      .book-lightbox-nav { width: 44px; height: 44px; font-size: 1.7rem; }
      .book-lightbox-prev { left: 10px; } .book-lightbox-next { right: 10px; }
      .book-lightbox-caption { font-size: 1.1rem; bottom: 16px; }
    }
  </style>
  <script src="/js/book.js?v=20260603"></script>
  <script>
    // Self-contained photo lightbox — defined inline (server-rendered, never
    // cached) and INDEPENDENT of book.js, so a JS error or a stale cached
    // book.js can't stop photos from enlarging. Click any content photo to open.
    (function () {
      // Galleries whose photos can be paged through with the prev/next arrows.
      // A clicked photo inside one of these becomes a navigable group; any other
      // photo opens on its own (single image, arrows hidden).
      var GALLERY_SELECTOR = '.birthday-gallery, .celebration-album, .journey-gallery, .recipe-photo-gallery, .photo-gallery, .fdetail-photos';

      var group = [];   // [{ src, alt, caption }]
      var idx = 0;

      function isEnlargeable(img) {
        if (!img || !img.src) return false;
        if (img.closest('.book-lightbox, #bookLightbox, .month-card, .family-card, .nav-item, a, button')) return false;
        if (!img.closest('#main-content, #month-modal, .month-modal, #family-detail, .family-detail')) return false;
        return true;
      }
      function captionFor(img) {
        var fig = img.closest('figure');
        var cap = fig && fig.querySelector('figcaption');
        var t = cap && cap.textContent ? cap.textContent.trim().replace(/^"|"$/g, '') : '';
        return t;
      }
      function toItem(el) { return { src: el.src, alt: el.alt || '', caption: captionFor(el) }; }

      function buildGroup(img) {
        var container = img.closest(GALLERY_SELECTOR);
        var imgs = null;
        if (container) {
          imgs = Array.prototype.slice.call(container.querySelectorAll('img')).filter(isEnlargeable);
        }
        if (!imgs || imgs.length < 1) return [toItem(img)];
        return imgs.map(toItem);
      }
      function render() {
        var img = document.getElementById('lightboxImg');
        var cap = document.getElementById('lightboxCaption');
        var prev = document.getElementById('lightboxPrev');
        var next = document.getElementById('lightboxNext');
        if (!img) return;
        var item = group[idx] || { src: '', alt: '', caption: '' };
        img.src = item.src; img.alt = item.alt || '';
        if (cap) cap.textContent = item.caption || '';
        var multi = group.length > 1;
        if (prev) prev.hidden = !multi;
        if (next) next.hidden = !multi;
      }
      function show() {
        var lb = document.getElementById('bookLightbox');
        if (!lb) return;
        render();
        lb.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function openFromImg(imgEl) {
        group = buildGroup(imgEl);
        idx = 0;
        for (var i = 0; i < group.length; i++) { if (group[i].src === imgEl.src) { idx = i; break; } }
        show();
      }
      function openLB(src, alt) {           // backward-compatible single-image entry point
        group = [{ src: src, alt: alt || '', caption: '' }];
        idx = 0; show();
      }
      function closeLB() {
        var lb = document.getElementById('bookLightbox');
        if (lb) lb.classList.remove('open');
        document.body.style.overflow = '';
      }
      function nav(delta) {
        if (group.length < 2) return;
        idx = (idx + delta + group.length) % group.length;
        render();
      }
      // Expose for inline onclick="" handlers / the arrow + close buttons.
      window.openLightbox = openLB;
      window.closeLightbox = closeLB;
      window.lightboxNav = nav;

      document.addEventListener('click', function (e) {
        var lb = document.getElementById('bookLightbox');
        // Click on the backdrop (or close button) closes it.
        if (lb && lb.classList.contains('open') && (e.target === lb || (e.target.closest && e.target.closest('.book-lightbox-close')))) {
          closeLB(); return;
        }
        var img = e.target.closest && e.target.closest('img');
        if (!img || !img.src) return;
        // Skip images that have their own behavior, the lightbox image, and chrome.
        if (img.closest('.book-lightbox, #bookLightbox, .month-card, .family-card, .nav-item, a, button')) return;
        // Only enlarge real book photos (content + the month/family overlays).
        if (!img.closest('#main-content, #month-modal, .month-modal, #family-detail, .family-detail')) return;
        openFromImg(img);
      });
      document.addEventListener('keydown', function (e) {
        var lb = document.getElementById('bookLightbox');
        if (!lb || !lb.classList.contains('open')) return;
        if (e.key === 'Escape') closeLB();
        else if (e.key === 'ArrowLeft') nav(-1);
        else if (e.key === 'ArrowRight') nav(1);
      });
    })();
  </script>
  <!-- Render Lucide icons placed by sidebar.ejs / book sections -->
  <script>
    if (window.lucide) lucide.createIcons();
    else window.addEventListener('load', () => window.lucide && lucide.createIcons());
  </script>
