      color: #2c2416;
      margin: 0 0 0.5rem;
    }
    .free-locked-section p {
      font-family: 'Jost', sans-serif;
      font-size: 0.85rem;
      color: #8a7e6b;
      margin: 0 0 1.25rem;
    }
    .free-locked-section a {
      display: inline-block;
      background: #c8a96e;
      color: #1a1510;
      font-family: 'Jost', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
