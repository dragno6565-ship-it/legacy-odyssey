  <link rel="stylesheet" href="/css/book.css">
  <!-- Lucide line-art icons (replaces emoji in sidebar nav per v1.0.7 brand-consistency pass) -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
