  <% if (isDemoDomain) { %>
  <style>
    .demo-banner {
      position: fixed; top: 0; left: 0; right: 0; z-index: 300;
      background: #1a1510; border-bottom: 2px solid #c8a96e;
      height: 44px; display: flex; align-items: center; justify-content: center;
      font-family: 'Jost', sans-serif; font-size: 0.85rem; color: #d4bb8a;
      padding: 0 3rem; gap: 0.75rem; text-align: center;
    }
    .demo-banner strong { color: #faf7f2; }
    .demo-banner a.demo-cta {
      background: #c8a96e; color: #1a1510; font-weight: 700;
      padding: 0.25rem 0.9rem; border-radius: 2px; text-decoration: none;
      font-size: 0.8rem; letter-spacing: 0.05em; white-space: nowrap;
    }
    .demo-banner a.demo-cta:hover { background: #d4bb8a; }
    .demo-banner-close {
      position: absolute; right: 1rem; background: none; border: none;
      color: #8a7e6b; font-size: 1.3rem; cursor: pointer; line-height: 1; padding: 0;
    }
    .demo-banner-close:hover { color: #faf7f2; }
    body.demo-bar-visible #sidebar { top: 44px; height: calc(100vh - 44px); }
    body.demo-bar-visible #main-content { padding-top: 44px; }
    body.demo-bar-visible .mobile-header { top: 44px; }
    @media (max-width: 768px) {
      body.demo-bar-visible #main-content { padding-top: calc(56px + 44px); }
      .demo-banner { font-size: 0.75rem; }
    }
    .demo-end-cta {
      background: linear-gradient(135deg, #1a1510 0%, #2c2416 100%);
      border-top: 2px solid #c8a96e; padding: 4rem 2rem; text-align: center;
    }
    .demo-end-cta h3 {
      font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-style: italic;
      color: #c8a96e; margin: 0 0 0.75rem;
    }
    .demo-end-cta p {
      font-family: 'Jost', sans-serif; font-size: 0.95rem; color: #d4bb8a;
      margin: 0 0 1.75rem; max-width: 480px; margin-left: auto; margin-right: auto; line-height: 1.6;
    }
    .demo-end-cta a {
      display: inline-block; background: #c8a96e; color: #1a1510;
      font-family: 'Jost', sans-serif; font-size: 0.9rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase; padding: 0.85rem 2.5rem;
      text-decoration: none; border-radius: 2px; margin: 0.4rem;
    }
