<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
  <title><%= celebration.title %> · <%= book.child_first_name %><%= book.child_middle_name ? ' ' + book.child_middle_name : '' %> <%= book.child_last_name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/book.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LMJVX82M3Q"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LMJVX82M3Q');
  </script>

  <style>
    /* ─── Celebration detail page styles ─── */
    .celebration-detail-page {
      padding: 3rem 2.5rem 5rem;
      max-width: 1080px;
      margin: 0 auto;
    }

    .celebration-breadcrumb {
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-light);
      margin-bottom: 2rem;
    }
    .celebration-breadcrumb a.bc-link {
      color: var(--ink-light);
      text-decoration: none;
      transition: color 0.15s;
    }
    .celebration-breadcrumb a.bc-link:hover { color: var(--gold); }
    .celebration-breadcrumb .bc-sep { margin: 0 0.5em; opacity: 0.5; }
    .celebration-breadcrumb .bc-current { color: var(--ink); }

    .celebration-hero { margin-bottom: 3rem; }

    .celebration-eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 500;
      margin-bottom: 1rem;
    }

    .celebration-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 5vw, 4rem);
      font-weight: 400;
      line-height: 1.05;
      color: var(--ink);
      margin-bottom: 1rem;
      letter-spacing: -0.01em;
    }

    .celebration-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      font-size: 0.85rem;
      color: var(--ink-mid);
      margin-bottom: 2.5rem;
    }
    .celebration-meta-item { display: flex; align-items: center; gap: 0.4rem; }
    .celebration-meta-item svg { width: 14px; height: 14px; color: var(--gold); }

    .celebration-hero-photo {
      width: 100%;
      aspect-ratio: 16/8;
      background: var(--ink);
      border-radius: 4px;
      overflow: hidden;
      margin-bottom: 1rem;
    }
    .celebration-hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .celebration-section { margin-bottom: 3rem; }

    .celebration-section-label {
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 500;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .cs-rule { width: 24px; height: 1px; background: var(--gold); display: inline-block; }
    .cs-meta { color: var(--ink-light); margin-left: 0.25rem; font-weight: 400; letter-spacing: 0.1em; }

    .celebration-story {
      max-width: 720px;
      font-size: 1.02rem;
      line-height: 1.85;
      color: var(--ink-mid);
      font-weight: 300;
    }
    .celebration-story p { margin-bottom: 1.4rem; }

    .celebration-attendees {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .celebration-pill {
      display: inline-flex;
      align-items: center;
      background: rgba(184,147,90,0.1);
      border: 1px solid rgba(184,147,90,0.3);
      border-radius: 999px;
      padding: 0.4rem 1rem;
      font-size: 0.88rem;
      color: var(--ink);
      font-weight: 500;
    }

    .celebration-gifts {
      list-style: none;
      padding: 0;
      max-width: 720px;
    }
    .celebration-gifts li {
      padding: 0.65rem 0;
      border-bottom: 1px dashed rgba(184,147,90,0.25);
      font-size: 1rem;
      color: var(--ink-mid);
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .celebration-gifts li:last-child { border-bottom: none; }
    .celebration-gifts li::before {
      content: '✦';
      color: var(--gold);
      flex-shrink: 0;
      font-size: 0.85rem;
      margin-top: 0.15rem;
    }

    .celebration-album {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.25rem;
    }
    .celebration-photo-card {
      background: var(--ivory);
      border-radius: 4px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(30,24,18,0.05);
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: zoom-in;
    }
    .celebration-photo-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(30,24,18,0.12);
    }
    .cpc-img {
      aspect-ratio: 4/5;
      overflow: hidden;
      background: var(--blush);
    }
    .cpc-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .cpc-caption {
      padding: 0.85rem 1rem;
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.95rem;
      font-style: italic;
      color: var(--ink-mid);
      line-height: 1.5;
    }

    .celebration-pager {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(184,147,90,0.25);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .cp-link {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      color: var(--ink-mid);
      text-decoration: none;
      transition: color 0.15s;
    }
    .cp-link:hover { color: var(--gold); }
    .cp-arrow { font-size: 1.4rem; color: var(--ink-light); }
    .cp-label {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-light);
    }
    .cp-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
    }
    .cp-next { margin-left: auto; text-align: right; }

    @media (max-width: 768px) {
      .celebration-detail-page { padding: 2rem 1.25rem 4rem; }
      .celebration-meta { gap: 0.85rem; }
    }

    /* ─── Lightbox ─── */
    #celebration-lightbox {
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(15, 12, 8, 0.94);
      display: none;
      align-items: center; justify-content: center;
      cursor: zoom-out;
      padding: 2rem;
    }
    #celebration-lightbox.open { display: flex; }
    #celebration-lightbox img {
      max-width: 95vw;
      max-height: calc(90vh - 60px);
      object-fit: contain;
      box-shadow: 0 30px 80px rgba(0,0,0,0.6);
      border-radius: 4px;
      display: block;
    }
    #celebration-lightbox .lb-inner {
      display: flex; flex-direction: column; align-items: center; gap: 1rem;
      max-width: 100%;
    }
    #celebration-lightbox .lb-caption {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.05rem;
      color: rgba(248,242,230,0.9);
      max-width: 720px;
      text-align: center;
      line-height: 1.55;
    }
    #celebration-lightbox .lb-close {
      position: absolute; top: 1.25rem; right: 1.5rem;
      background: none; border: 2px solid rgba(248,242,230,0.45);
      color: rgba(248,242,230,0.85);
      width: 40px; height: 40px; border-radius: 50%;
      font-size: 1.2rem; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.15s;
    }
    #celebration-lightbox .lb-close:hover {
      border-color: var(--gold); color: var(--gold);
    }
    #celebration-lightbox .lb-nav {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: none; border: none; color: rgba(248,242,230,0.6);
      font-size: 3rem; cursor: pointer;
      padding: 1rem 1.5rem;
      transition: color 0.15s;
      user-select: none;
    }
    #celebration-lightbox .lb-nav:hover { color: var(--gold); }
    #celebration-lightbox .lb-nav.prev { left: 0.5rem; }
    #celebration-lightbox .lb-nav.next { right: 0.5rem; }
    #celebration-lightbox .lb-counter {
      position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
      color: rgba(248,242,230,0.55);
      font-size: 0.8rem;
      letter-spacing: 0.15em;
    }
  </style>
</head>
<body>

  <% if (isDemoDomain) { %>
  <div class="demo-banner" id="demoBanner">
    <strong>This is a demo book.</strong>
    <span>Preserve your own baby's story — get your own custom domain.</span>
    <a href="https://www.legacyodyssey.com" target="_blank" class="demo-cta">Create Your Own →</a>
    <button class="demo-banner-close" onclick="document.getElementById('demoBanner').style.display='none';document.body.classList.remove('demo-bar-visible');" aria-label="Dismiss">&times;</button>
  </div>
  <% } %>

  <div id="app">
    <%- include('../book/sidebar', { book, family, visibleSections, isFree, isDemoDomain, celebrationsByYear, activeCelebration: celebration }) %>

    <div id="main-content">
      <%- include('../book/celebration-detail', { celebration, yearLabel, prevCelebration, nextCelebration, imageUrl, photoPos }) %>
    </div>
  </div>

  <!-- Lightbox overlay (populated by JS when a photo is clicked) -->
  <div id="celebration-lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button class="lb-close" type="button" aria-label="Close">×</button>
    <button class="lb-nav prev" type="button" aria-label="Previous photo">‹</button>
    <button class="lb-nav next" type="button" aria-label="Next photo">›</button>
    <div class="lb-inner">
      <img alt="">
      <div class="lb-caption"></div>
    </div>
    <div class="lb-counter"></div>
  </div>

  <script>
    // Initialize Lucide icons
    if (window.lucide) window.lucide.createIcons();

    // Mobile hamburger toggle (same as book.ejs SPA)
    function toggleNav() {
      document.getElementById('sidebar').classList.toggle('mobile-open');
      document.getElementById('navOverlay').classList.toggle('show');
    }
    window.toggleNav = toggleNav;

    // ─── Photo lightbox ───────────────────────────────────────────────────
    (function () {
      const lb = document.getElementById('celebration-lightbox');
      if (!lb) return;
      const img = lb.querySelector('img');
      const cap = lb.querySelector('.lb-caption');
      const counter = lb.querySelector('.lb-counter');
      const btnClose = lb.querySelector('.lb-close');
      const btnPrev = lb.querySelector('.lb-nav.prev');
      const btnNext = lb.querySelector('.lb-nav.next');

      // Collect every photo card on the page in display order. Each card
      // exposes its image src + alt (caption) via the existing markup;
      // no extra data attributes needed.
      const cards = Array.from(document.querySelectorAll('.celebration-photo-card'));
      const photos = cards.map((card) => {
        const i = card.querySelector('.cpc-img img');
        const c = card.querySelector('.cpc-caption');
        return {
          src: i ? i.getAttribute('src') : '',
          caption: c ? c.textContent.replace(/^"|"$/g, '').trim() : '',
        };
      }).filter((p) => p.src);

      let currentIndex = -1;

      function open(index) {
        if (index < 0 || index >= photos.length) return;
        currentIndex = index;
        const p = photos[index];
        img.setAttribute('src', p.src);
        img.setAttribute('alt', p.caption || '');
        cap.textContent = p.caption ? '"' + p.caption + '"' : '';
        cap.style.display = p.caption ? '' : 'none';
        counter.textContent = (index + 1) + ' / ' + photos.length;
        btnPrev.style.visibility = index > 0 ? 'visible' : 'hidden';
        btnNext.style.visibility = index < photos.length - 1 ? 'visible' : 'hidden';
        lb.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        lb.classList.remove('open');
        document.body.style.overflow = '';
        currentIndex = -1;
      }
      function go(delta) {
        const next = currentIndex + delta;
        if (next < 0 || next >= photos.length) return;
        open(next);
      }

      // Wire up the cards
      cards.forEach((card, i) => {
        card.addEventListener('click', (e) => {
          e.preventDefault();
          open(i);
        });
      });

      // Click overlay (but not inside the inner image group) to close
      lb.addEventListener('click', (e) => {
        if (e.target === lb || e.target.classList.contains('lb-inner')) close();
      });
      btnClose.addEventListener('click', close);
      btnPrev.addEventListener('click', (e) => { e.stopPropagation(); go(-1); });
      btnNext.addEventListener('click', (e) => { e.stopPropagation(); go(1); });

      // Keyboard: Esc closes, arrows navigate
      document.addEventListener('keydown', (e) => {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft') go(-1);
        else if (e.key === 'ArrowRight') go(1);
      });
    })();
  </script>
</body>
</html>
