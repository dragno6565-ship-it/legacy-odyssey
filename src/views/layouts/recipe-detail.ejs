<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
  <title><%= recipe.title %> · <%= book.child_first_name %><%= book.child_middle_name ? ' ' + book.child_middle_name : '' %> <%= book.child_last_name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/book.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>

  <!-- Analytics removed from the private book viewer (G8) — no tracking on private content. -->

  <style>
    /* ─── Recipe detail page styles ─── */
    .recipe-detail-page {
      padding: 3rem 2.5rem 5rem;
      max-width: 1080px;
      margin: 0 auto;
    }

    .recipe-breadcrumb {
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-light);
      margin-bottom: 2rem;
    }
    .recipe-breadcrumb a.bc-link {
      color: var(--ink-light);
      text-decoration: none;
      transition: color 0.15s;
    }
    .recipe-breadcrumb a.bc-link:hover { color: var(--gold); }
    .recipe-breadcrumb .bc-sep { margin: 0 0.5em; opacity: 0.5; }
    .recipe-breadcrumb .bc-current { color: var(--ink); }

    /* Hero */
    .recipe-hero {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 2.5rem;
      align-items: center;
      margin-bottom: 3rem;
    }
    @media (max-width: 760px) {
      .recipe-hero { grid-template-columns: 1fr; gap: 1.75rem; }
    }
    .recipe-hero-photo {
      aspect-ratio: 4/3;
      border-radius: 12px;
      overflow: hidden;
      background: var(--card);
      box-shadow: 0 8px 28px rgba(44,36,22,0.12);
    }
    .recipe-hero-photo img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .recipe-hero-from {
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-light);
      margin-bottom: 0.85rem;
    }
    .recipe-hero-from::before {
      content: '✦  ';
      color: var(--gold);
    }
    .recipe-hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.2rem, 4.4vw, 3.4rem);
      font-weight: 400;
      line-height: 1.1;
      color: var(--ink);
      margin-bottom: 1rem;
    }
    .recipe-hero-desc {
      font-size: 1.04rem;
      color: var(--ink);
      opacity: 0.88;
      line-height: 1.65;
    }

    /* Stat strip */
    .recipe-stats {
      display: flex;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 3rem;
      box-shadow: 0 2px 10px rgba(44,36,22,0.04);
    }
    .recipe-stat {
      flex: 1;
      padding: 1rem 0.75rem;
      text-align: center;
      border-right: 1px solid var(--border);
    }
    .recipe-stat:last-child { border-right: 0; }
    .recipe-stat-icon {
      color: var(--gold);
      margin-bottom: 0.45rem;
      display: flex;
      justify-content: center;
    }
    .recipe-stat-icon svg { width: 1.3rem; height: 1.3rem; stroke-width: 1.5; }
    .recipe-stat-label {
      color: var(--ink-light);
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      margin-bottom: 0.25rem;
    }
    .recipe-stat-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--ink);
    }

    /* Section blocks */
    .recipe-section { margin-bottom: 3rem; }
    .recipe-section-eyebrow {
      color: var(--gold);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 0.65rem;
    }
    .recipe-section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.7rem;
      font-weight: 400;
      margin-bottom: 1.1rem;
      color: var(--ink);
    }

    .recipe-story p {
      font-size: 1.04rem;
      line-height: 1.85;
      margin-bottom: 1rem;
      color: var(--ink);
    }
    .recipe-story p.story-lead::first-letter {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3.4rem;
      float: left;
      line-height: 0.9;
      padding: 0.2rem 0.55rem 0 0;
      color: var(--gold);
      font-style: italic;
    }

    /* Two-column on desktop, stacked on mobile */
    .recipe-content {
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      gap: 2.75rem;
      margin-bottom: 3rem;
    }
    @media (max-width: 760px) {
      .recipe-content { grid-template-columns: 1fr; gap: 2rem; }
    }

    .ingredients-card {
      background: #fff;
      border-radius: 12px;
      padding: 1.5rem 1.75rem;
      border: 1px solid var(--border);
    }
    .ingredients-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .ingredients-list li {
      padding: 0.7rem 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: flex-start;
      gap: 0.85rem;
      font-size: 0.98rem;
      line-height: 1.45;
    }
    .ingredients-list li:last-child { border-bottom: 0; }
    .ingredients-list li::before {
      content: '';
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 50%;
      background: var(--gold);
      margin-top: 0.55rem;
      flex-shrink: 0;
    }
    .ingredient-amount {
      color: var(--gold);
      font-weight: 500;
      min-width: 5rem;
      display: inline-block;
    }
    .ingredient-item { color: var(--ink); }

    .directions-list {
      list-style: none;
      counter-reset: step;
      padding: 0;
      margin: 0;
    }
    .directions-list li {
      counter-increment: step;
      padding: 0 0 1.6rem 3.4rem;
      position: relative;
      font-size: 1.02rem;
      line-height: 1.75;
      color: var(--ink);
    }
    .directions-list li::before {
      content: counter(step);
      position: absolute; left: 0; top: 0;
      width: 2.5rem; height: 2.5rem; border-radius: 50%;
      background: var(--gold); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem; font-weight: 600;
    }
    .directions-list li:last-child { padding-bottom: 0; }

    /* Notes block — pull-quote style */
    .recipe-notes {
      background: #fdf9f3;
      border-left: 4px solid var(--gold);
      border-radius: 0 10px 10px 0;
      padding: 1.4rem 1.6rem;
      font-style: italic;
      color: var(--ink);
      font-size: 0.98rem;
      line-height: 1.75;
    }
    .recipe-notes::before {
      content: '“';
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.6rem;
      color: var(--gold);
      line-height: 0;
      vertical-align: -0.65rem;
      margin-right: 0.3rem;
    }

    /* Photo gallery (matches celebration gallery — uses lightbox below) */
    .recipe-photo-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.1rem;
    }
    .recipe-photo-card {
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      cursor: zoom-in;
      box-shadow: 0 2px 10px rgba(44,36,22,0.06);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .recipe-photo-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 18px rgba(44,36,22,0.1);
    }
    .recipe-photo-card .rpc-img {
      aspect-ratio: 1/1;
      overflow: hidden;
      background: var(--card);
    }
    .recipe-photo-card .rpc-img img {
      width: 100%; height: 100%; object-fit: cover;
      display: block; transition: transform 0.4s;
    }
    .recipe-photo-card:hover .rpc-img img { transform: scale(1.04); }
    .recipe-photo-card .rpc-caption {
      padding: 0.6rem 0.85rem 0.85rem;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      color: var(--ink-light);
      font-size: 0.92rem;
      line-height: 1.45;
    }

    /* Pager */
    .recipe-pager {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      margin-top: 2.5rem;
    }
    .recipe-pager a {
      color: var(--ink);
      text-decoration: none;
      flex: 1;
      max-width: 48%;
      padding: 0.9rem 1.1rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      transition: all 0.15s;
      background: #fff;
    }
    .recipe-pager a:hover { border-color: var(--gold); background: #fdf9f3; }
    .recipe-pager-label {
      color: var(--ink-light);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 0.3rem;
    }
    .recipe-pager-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
    }
    .recipe-pager a.next { text-align: right; }

    @media (max-width: 760px) {
      .recipe-detail-page { padding: 2rem 1.25rem 4rem; }
      .recipe-stats { flex-wrap: wrap; }
      .recipe-stat { flex: 1 1 50%; border-bottom: 1px solid var(--border); }
      .recipe-stat:nth-last-child(-n+2) { border-bottom: 0; }
      .recipe-stat:nth-child(2n) { border-right: 0; }
    }

    /* Lightbox (shared pattern with celebration detail) */
    #recipe-lightbox {
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(15, 12, 8, 0.94);
      display: none;
      align-items: center; justify-content: center;
      cursor: zoom-out;
      padding: 2rem;
    }
    #recipe-lightbox.open { display: flex; }
    #recipe-lightbox img {
      max-width: 95vw; max-height: 80vh;
      object-fit: contain;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      border-radius: 4px;
    }
    #recipe-lightbox .lb-inner {
      display: flex; flex-direction: column;
      align-items: center; gap: 1rem;
      max-width: 95vw;
    }
    #recipe-lightbox .lb-caption {
      color: #f8f2e6;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.05rem;
      text-align: center;
      max-width: 60ch;
    }
    #recipe-lightbox .lb-close {
      position: absolute; top: 1rem; right: 1.25rem;
      background: transparent; border: none;
      color: rgba(248,242,230,0.7);
      font-size: 2.4rem;
      line-height: 1;
      cursor: pointer;
      padding: 0.25rem 0.6rem;
    }
    #recipe-lightbox .lb-close:hover { color: var(--gold); }
    #recipe-lightbox .lb-nav {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: transparent; border: none;
      color: rgba(248,242,230,0.7);
      font-size: 3rem;
      line-height: 1;
      cursor: pointer;
      padding: 0.25rem 0.85rem;
      user-select: none;
    }
    #recipe-lightbox .lb-nav:hover { color: var(--gold); }
    #recipe-lightbox .lb-nav.prev { left: 0.5rem; }
    #recipe-lightbox .lb-nav.next { right: 0.5rem; }
    #recipe-lightbox .lb-counter {
      position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
      color: rgba(248,242,230,0.55);
      font-size: 0.8rem;
      letter-spacing: 0.15em;
    }
  </style>
</head>
<body class="<%= isDemoDomain ? 'demo-bar-visible' : '' %>">

  <% if (isDemoDomain) { %>
  <div class="demo-banner" id="demoBanner">
    <strong>This is a demo book.</strong>
    <span>Preserve your own baby's story — get your own custom domain.</span>
    <a href="https://www.legacyodyssey.com" target="_blank" class="demo-cta">Create Your Own →</a>
    <button class="demo-banner-close" onclick="document.getElementById('demoBanner').style.display='none';document.body.classList.remove('demo-bar-visible');" aria-label="Dismiss">&times;</button>
  </div>
  <% } %>

  <div id="app">
    <%- include('../book/sidebar', { book, family, visibleSections, isFree, isDemoDomain, celebrationsByYear, activeCelebration: null, recipesList, activeRecipe: recipe, keepsakes: typeof keepsakesList !== 'undefined' ? keepsakesList : [], activeKeepsake: null }) %>

    <div id="main-content">
      <%- include('../book/recipe-detail', { recipe, prevRecipe, nextRecipe, imageUrl, photoPos }) %>
    </div>
  </div>

  <!-- Lightbox overlay -->
  <div id="recipe-lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button class="lb-close" type="button" aria-label="Close">×</button>
    <button class="lb-nav prev" type="button" aria-label="Previous photo">‹</button>
    <button class="lb-nav next" type="button" aria-label="Next photo">›</button>
    <div class="lb-inner">
      <img alt="">
      <div class="lb-caption"></div>
    </div>
    <div class="lb-counter"></div>
  </div>

  <script>
    if (window.lucide) window.lucide.createIcons();

    function toggleNav() {
      document.getElementById('sidebar').classList.toggle('mobile-open');
      document.getElementById('navOverlay').classList.toggle('show');
    }
    window.toggleNav = toggleNav;

    // Sidebar showPage handler — recipes detail is standalone so hop back to /#section
    window.showPage = function(pageId) {
      window.location.href = '/#' + pageId;
    };

    // ─── Photo lightbox ───────────────────────────────────────────────────
    (function () {
      const lb = document.getElementById('recipe-lightbox');
      if (!lb) return;
      const img = lb.querySelector('img');
      const cap = lb.querySelector('.lb-caption');
      const counter = lb.querySelector('.lb-counter');
      const btnClose = lb.querySelector('.lb-close');
      const btnPrev = lb.querySelector('.lb-nav.prev');
      const btnNext = lb.querySelector('.lb-nav.next');

      const cards = Array.from(document.querySelectorAll('.recipe-photo-card'));
      const photos = cards.map((card) => {
        const i = card.querySelector('.rpc-img img');
        const c = card.querySelector('.rpc-caption');
        return {
          src: i ? i.getAttribute('src') : '',
          caption: c ? c.textContent.replace(/^"|"$/g, '').trim() : '',
        };
      }).filter((p) => p.src);

      let currentIndex = -1;

      function open(index) {
        if (index < 0 || index >= photos.length) return;
        currentIndex = index;
        const p = photos[index];
        img.setAttribute('src', p.src);
        img.setAttribute('alt', p.caption || '');
        cap.textContent = p.caption ? '"' + p.caption + '"' : '';
        cap.style.display = p.caption ? '' : 'none';
        counter.textContent = (index + 1) + ' / ' + photos.length;
        btnPrev.style.visibility = index > 0 ? 'visible' : 'hidden';
        btnNext.style.visibility = index < photos.length - 1 ? 'visible' : 'hidden';
        lb.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        lb.classList.remove('open');
        document.body.style.overflow = '';
        currentIndex = -1;
      }
      function go(delta) {
        const next = currentIndex + delta;
        if (next < 0 || next >= photos.length) return;
        open(next);
      }

      cards.forEach((card, i) => {
        card.addEventListener('click', (e) => {
          e.preventDefault();
          open(i);
        });
      });

      lb.addEventListener('click', (e) => {
        if (e.target === lb || e.target.classList.contains('lb-inner')) close();
      });
      btnClose.addEventListener('click', close);
      btnPrev.addEventListener('click', (e) => { e.stopPropagation(); go(-1); });
      btnNext.addEventListener('click', (e) => { e.stopPropagation(); go(1); });

      document.addEventListener('keydown', (e) => {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft') go(-1);
        else if (e.key === 'ArrowRight') go(1);
      });
    })();
  </script>
</body>
</html>
