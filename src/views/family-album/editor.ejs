<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Your Family Album — Legacy Odyssey</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #F8F2E6;
  --ivory: #FFFCF5;
  --gold: #B8935A;
  --gold-light: #D4B483;
  --gold-dark: #8C6A35;
  --ink: #1E1812;
  --ink-mid: #4A3F32;
  --ink-light: #9C8B78;
  --nav-width: 240px;
  --green: #5a8a5a;
  --red: #c0392b;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Jost', sans-serif; background: var(--cream); color: var(--ink); line-height: 1.6; font-size: 15px; overflow: hidden; height: 100vh; }
h1, h2, h3, h4 { font-family: 'Cormorant Garamond', serif; font-weight: 600; }

/* ── AUTH SCREEN ── */
#auth-screen {
  position: fixed; inset: 0; background: var(--cream);
  display: flex; align-items: center; justify-content: center; z-index: 9999;
}
#auth-screen.hidden { display: none; }
.auth-box {
  background: var(--ink); border-radius: 16px; padding: 2.5rem;
  max-width: 400px; width: 100%; text-align: center;
}
.auth-box h2 { color: var(--gold); font-size: 1.8rem; margin-bottom: 0.25rem; }
.auth-box p { color: var(--ink-light); font-size: 0.85rem; margin-bottom: 2rem; }
.auth-box input {
  display: block; width: 100%; padding: 0.8rem 1rem; margin-bottom: 0.75rem;
  background: #2C2416; border: 1px solid rgba(184,147,90,0.35); border-radius: 8px;
  color: var(--cream); font-family: 'Jost', sans-serif; font-size: 0.95rem; outline: none;
}
.auth-box input:focus { border-color: var(--gold); }
.auth-box button {
  width: 100%; padding: 0.9rem; background: var(--gold); color: var(--ink);
  border: none; border-radius: 8px; font-weight: 700; font-size: 1rem; cursor: pointer;
}
.auth-box button:hover { background: var(--gold-light); }
.auth-error { color: #e07070; font-size: 0.85rem; margin-top: 0.75rem; }

/* ── APP LAYOUT ── */
#app { display: flex; height: 100vh; }
#app.hidden { display: none; }

/* ── SIDEBAR ── */
#sidebar {
  width: var(--nav-width); min-width: var(--nav-width);
  background: var(--ink); color: var(--cream);
  height: 100vh; overflow-y: auto; padding: 1.5rem 0;
  display: flex; flex-direction: column;
}
.sidebar-header { padding: 0 1.25rem 1.25rem; border-bottom: 1px solid rgba(184,147,90,0.2); margin-bottom: 0.75rem; }
.sidebar-header h2 { font-size: 1.1rem; color: var(--gold); }
.sidebar-header p { font-size: 0.7rem; color: var(--ink-light); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.15rem; }
.nav-group-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-light); padding: 0.85rem 1.25rem 0.35rem; }
.nav-item {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.5rem 1.25rem; color: var(--cream); font-size: 0.85rem;
  cursor: pointer; border-left: 3px solid transparent; transition: all 0.15s;
  user-select: none;
}
.nav-item:hover { background: rgba(184,147,90,0.08); color: var(--gold-light); }
.nav-item.active { background: rgba(184,147,90,0.15); color: var(--gold); border-left-color: var(--gold); }
.nav-item .saved-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); margin-left: auto; display: none; }
.nav-item .saved-dot.show { display: block; }
.sidebar-footer { margin-top: auto; padding: 1.25rem; border-top: 1px solid rgba(184,147,90,0.15); }
.sidebar-footer a { color: var(--gold); text-decoration: none; font-size: 0.78rem; display: block; margin-bottom: 0.4rem; }
.sidebar-footer a:hover { color: var(--gold-light); }
.btn-logout { background: none; border: 1px solid rgba(184,147,90,0.25); border-radius: 4px; color: var(--ink-light); font-size: 0.75rem; padding: 0.35rem 0.75rem; cursor: pointer; width: 100%; margin-top: 0.75rem; font-family: 'Jost', sans-serif; }
.btn-logout:hover { color: var(--cream); border-color: var(--ink-light); }

/* ── MAIN CONTENT ── */
#main-content { flex: 1; overflow-y: auto; padding: 2.5rem 3rem 4rem; }
.editor-section { display: none; }
.editor-section.active { display: block; }
.section-eyebrow { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--gold); margin-bottom: 0.4rem; }
.section-title { font-size: 2rem; color: var(--ink); margin-bottom: 0.25rem; }
.section-subtitle { font-size: 0.9rem; color: var(--ink-light); font-style: italic; margin-bottom: 1.75rem; }
.section-divider { width: 40px; height: 2px; background: var(--gold); margin-bottom: 1.75rem; }

/* ── FORM ELEMENTS ── */
.field-group { margin-bottom: 1.5rem; }
.field-group label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold); margin-bottom: 0.45rem; font-weight: 600; }
.field-group .hint { font-size: 0.78rem; color: var(--ink-light); margin-bottom: 0.5rem; font-style: italic; }
input[type="text"], input[type="number"], input[type="email"], textarea, select {
  width: 100%; padding: 0.75rem 1rem;
  background: var(--ivory); border: 1.5px solid rgba(184,147,90,0.2); border-radius: 8px;
  font-family: 'Jost', sans-serif; font-size: 0.95rem; color: var(--ink); outline: none;
  transition: border-color 0.2s;
}
input[type="text"]:focus, input[type="number"]:focus, textarea:focus, select:focus { border-color: var(--gold); }
textarea { resize: vertical; min-height: 100px; line-height: 1.7; }
textarea.tall { min-height: 160px; }
textarea.short { min-height: 70px; }
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
@media (max-width: 640px) { .field-row { grid-template-columns: 1fr; } }

/* ── SAVE BUTTON ── */
.save-bar { display: flex; align-items: center; gap: 1rem; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(184,147,90,0.15); }
.btn-save {
  padding: 0.75rem 2rem; background: var(--gold); color: var(--ink);
  border: none; border-radius: 8px; font-weight: 700; font-size: 0.95rem;
  cursor: pointer; transition: background 0.2s;
}
.btn-save:hover { background: var(--gold-light); }
.btn-save:disabled { background: #c8a06e; cursor: not-allowed; }
.save-status { font-size: 0.85rem; color: var(--ink-light); }
.save-status.saved { color: var(--green); }
.save-status.error { color: var(--red); }

/* ── LIST ITEMS (years, members, adventures, letters, recipes) ── */
.item-list { margin-bottom: 1.5rem; }
.list-item {
  background: var(--ivory); border: 1.5px solid rgba(184,147,90,0.15); border-radius: 10px;
  margin-bottom: 0.75rem; overflow: hidden;
}
.list-item-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.85rem 1.1rem; cursor: pointer; gap: 0.75rem;
}
.list-item-header:hover { background: rgba(184,147,90,0.04); }
.list-item-title { font-weight: 600; font-size: 0.95rem; color: var(--ink); flex: 1; }
.list-item-subtitle { font-size: 0.8rem; color: var(--ink-light); }
.list-item-toggle { color: var(--ink-light); font-size: 0.9rem; transition: transform 0.2s; }
.list-item.open .list-item-toggle { transform: rotate(180deg); }
.list-item-body { display: none; padding: 1.25rem; border-top: 1px solid rgba(184,147,90,0.12); }
.list-item.open .list-item-body { display: block; }
.btn-remove { background: none; border: 1px solid rgba(192,57,43,0.3); border-radius: 6px; color: var(--red); font-size: 0.78rem; padding: 0.3rem 0.75rem; cursor: pointer; font-family: 'Jost', sans-serif; }
.btn-remove:hover { background: rgba(192,57,43,0.08); }
.btn-add {
  display: flex; align-items: center; gap: 0.5rem; width: 100%;
  padding: 0.75rem 1rem; background: var(--ivory); border: 1.5px dashed rgba(184,147,90,0.3);
  border-radius: 10px; color: var(--gold); font-size: 0.9rem; font-weight: 600;
  cursor: pointer; font-family: 'Jost', sans-serif; transition: all 0.15s;
  margin-bottom: 1rem;
}
.btn-add:hover { border-color: var(--gold); background: rgba(184,147,90,0.04); }

/* ── EMOJI PICKER ── */
.emoji-options { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem; }
.emoji-opt {
  font-size: 1.4rem; padding: 0.3rem; border-radius: 6px; cursor: pointer;
  border: 2px solid transparent; transition: border-color 0.15s;
}
.emoji-opt:hover, .emoji-opt.selected { border-color: var(--gold); background: rgba(184,147,90,0.08); }

/* ── CHECKLIST EDITOR ── */
.checklist-editor { }
.checklist-row { display: flex; gap: 0.5rem; margin-bottom: 0.4rem; align-items: center; }
.checklist-row input { flex: 1; min-width: 0; }
.btn-rm-check { background: none; border: none; color: var(--ink-light); font-size: 1.1rem; cursor: pointer; padding: 0 0.25rem; }
.btn-rm-check:hover { color: var(--red); }

/* ── INGREDIENTS EDITOR ── */
.ing-row { display: flex; gap: 0.5rem; margin-bottom: 0.4rem; align-items: center; }
.ing-row input { flex: 1; }

/* ── META EDITOR ── */
.meta-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0.5rem; }

/* ── TOAST ── */
#toast {
  position: fixed; bottom: 2rem; right: 2rem; z-index: 9000;
  background: var(--ink); color: var(--cream); padding: 0.75rem 1.5rem;
  border-radius: 8px; font-size: 0.88rem; border-left: 3px solid var(--gold);
  opacity: 0; transform: translateY(10px); transition: all 0.3s; pointer-events: none;
}
#toast.show { opacity: 1; transform: translateY(0); }
#toast.error { border-left-color: var(--red); }
</style>
</head>
<body>

<!-- AUTH SCREEN -->
<div id="auth-screen">
  <div class="auth-box">
    <h2>Family Album Editor</h2>
    <p>Sign in to edit your album</p>
    <input type="email" id="auth-email" placeholder="your@email.com" autocomplete="email">
    <input type="password" id="auth-password" placeholder="Password" autocomplete="current-password">
    <button id="auth-btn">Sign In &rarr;</button>
    <p class="auth-error" id="auth-error"></p>
  </div>
</div>

<!-- EDITOR APP -->
<div id="app" class="hidden">
  <nav id="sidebar">
    <div class="sidebar-header">
      <h2 id="sidebar-family-name">Your Album</h2>
      <p>Family Album Editor</p>
    </div>

    <div class="nav-group-label">The Album</div>
    <div class="nav-item active" data-section="welcome">&#127775; Welcome <span class="saved-dot" id="dot-welcome"></span></div>
    <div class="nav-item" data-section="our_story">&#128145; Our Story <span class="saved-dot" id="dot-our_story"></span></div>
    <div class="nav-item" data-section="roots">&#127758; Where We Come From <span class="saved-dot" id="dot-roots"></span></div>
    <div class="nav-item" data-section="home">&#127969; Our Home <span class="saved-dot" id="dot-home"></span></div>
    <div class="nav-item" data-section="years">&#128197; Year by Year <span class="saved-dot" id="dot-years"></span></div>

    <div class="nav-group-label">Family &amp; Moments</div>
    <div class="nav-item" data-section="family_members">&#128106; The Family <span class="saved-dot" id="dot-family_members"></span></div>
    <div class="nav-item" data-section="adventures">&#9992;&#65039; Adventures <span class="saved-dot" id="dot-adventures"></span></div>
    <div class="nav-item" data-section="traditions">&#127881; Traditions <span class="saved-dot" id="dot-traditions"></span></div>
    <div class="nav-item" data-section="letters">&#128140; Letters <span class="saved-dot" id="dot-letters"></span></div>
    <div class="nav-item" data-section="recipes">&#127858; Recipes <span class="saved-dot" id="dot-recipes"></span></div>

    <div class="nav-group-label">The Vault</div>
    <div class="nav-item" data-section="vault">&#128274; Time Capsule <span class="saved-dot" id="dot-vault"></span></div>

    <div class="sidebar-footer">
      <a id="view-album-link" href="/" target="_blank">&#128065; View Public Album &rarr;</a>
      <button class="btn-logout" id="logout-btn">Sign Out</button>
    </div>
  </nav>

  <div id="main-content">

    <!-- ============ WELCOME ============ -->
    <div class="editor-section active" id="section-welcome">
      <p class="section-eyebrow">&#10022; Step 1</p>
      <h1 class="section-title">Welcome &amp; Overview</h1>
      <p class="section-subtitle">The first thing visitors see when they open your album.</p>
      <div class="section-divider"></div>

      <div class="field-row">
        <div class="field-group">
          <label>Family Name</label>
          <p class="hint">How your family is known — e.g. "The Smith Family" or "Smith &amp; Johnson"</p>
          <input type="text" id="w-family_name" placeholder="The Smith Family">
        </div>
        <div class="field-group">
          <label>Established Year</label>
          <p class="hint">The year your family "officially" began</p>
          <input type="number" id="w-established_year" placeholder="2009" min="1900" max="2099">
        </div>
      </div>
      <div class="field-group">
        <label>Home City / Region</label>
        <input type="text" id="w-hometown" placeholder="Portland, Oregon">
      </div>
      <div class="field-group">
        <label>Opening Quote</label>
        <p class="hint">A favourite line about family — or something your family says</p>
        <textarea class="short" id="w-welcome_quote" placeholder="A family is a collection of people who share the same memories, the same table, and — on the best days — the same laugh."></textarea>
      </div>
      <div class="field-group">
        <label>Quote Attribution</label>
        <input type="text" id="w-welcome_quote_attribution" placeholder="Your Family">
      </div>
      <div class="field-group">
        <label>Welcome Text</label>
        <p class="hint">A few sentences introducing your album. Each paragraph on its own line.</p>
        <textarea class="tall" id="w-welcome_texts" placeholder="This is the family album of the Smith Family — a living record of where we've been, who we are, and the moments we never want to forget.&#10;&#10;You'll find photos from ordinary Tuesdays and extraordinary vacations…"></textarea>
      </div>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('welcome')">Save Welcome</button>
        <span class="save-status" id="status-welcome"></span>
      </div>
    </div>

    <!-- ============ OUR STORY ============ -->
    <div class="editor-section" id="section-our_story">
      <p class="section-eyebrow">Chapter One</p>
      <h1 class="section-title">Our Story</h1>
      <p class="section-subtitle">How this family came to be.</p>
      <div class="section-divider"></div>

      <div class="field-group">
        <label>How It Started</label>
        <p class="hint">How you met, what drew you together, the early years before the family grew.</p>
        <textarea class="tall" id="os-how_it_started" placeholder="Every family has a beginning…"></textarea>
      </div>
      <div class="field-group">
        <label>The Decision to Build a Family</label>
        <p class="hint">The moment you decided this was the family you were making.</p>
        <textarea class="tall" id="os-decision_to_build" placeholder="Some families are built slowly, deliberately…"></textarea>
      </div>
      <div class="field-group">
        <label>The Early Years</label>
        <p class="hint">Before the traditions were traditions.</p>
        <textarea class="tall" id="os-early_years" placeholder="Before the traditions were traditions…"></textarea>
      </div>
      <div class="field-group">
        <label>Checklist Title</label>
        <input type="text" id="os-checklist_title" placeholder="How We Got Here">
      </div>
      <div class="field-group">
        <label>Checklist Items</label>
        <p class="hint">Milestones or moments — shown as a ✓ list. One per line.</p>
        <div id="os-checklist-editor" class="checklist-editor"></div>
        <button type="button" class="btn-add" onclick="addChecklistItem()">+ Add Item</button>
      </div>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('our_story')">Save Our Story</button>
        <span class="save-status" id="status-our_story"></span>
      </div>
    </div>

    <!-- ============ ROOTS ============ -->
    <div class="editor-section" id="section-roots">
      <p class="section-eyebrow">Chapter Two</p>
      <h1 class="section-title">Where We Come From</h1>
      <p class="section-subtitle">The roots that run beneath everything this family is.</p>
      <div class="section-divider"></div>

      <div class="field-group">
        <label>Introduction</label>
        <textarea class="tall" id="r-intro" placeholder="A family doesn't start when you do. It starts generations back…"></textarea>
      </div>
      <div class="field-row">
        <div class="field-group">
          <label>Mom's Side — Section Title</label>
          <input type="text" id="r-moms_side_title" placeholder="Mom's Side of the Family">
        </div>
        <div class="field-group">
          <label>Dad's Side — Section Title</label>
          <input type="text" id="r-dads_side_title" placeholder="Dad's Side of the Family">
        </div>
      </div>
      <div class="field-group">
        <label>Mom's Side</label>
        <textarea class="tall" id="r-moms_side" placeholder="Where her family came from, what generation immigrated…"></textarea>
      </div>
      <div class="field-group">
        <label>Dad's Side</label>
        <textarea class="tall" id="r-dads_side" placeholder="Write about the paternal heritage here…"></textarea>
      </div>
      <div class="field-group">
        <label>What We're Passing Down</label>
        <textarea class="tall" id="r-passing_down" placeholder="Heritage isn't just what happened before you. It's what you choose to carry forward…"></textarea>
      </div>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('roots')">Save Roots</button>
        <span class="save-status" id="status-roots"></span>
      </div>
    </div>

    <!-- ============ HOME ============ -->
    <div class="editor-section" id="section-home">
      <p class="section-eyebrow">Chapter Three</p>
      <h1 class="section-title">Our Home</h1>
      <p class="section-subtitle">The place where everything happened.</p>
      <div class="section-divider"></div>

      <div class="field-group">
        <label>Introduction</label>
        <textarea id="r-intro" id="h-intro" placeholder="A home is more than an address…"></textarea>
      </div>
      <div class="field-group">
        <label>The House</label>
        <textarea class="tall" id="h-the_house" placeholder="Describe the home — where it is, what it looks like, how you found it…"></textarea>
      </div>
      <div class="field-group">
        <label>The Neighborhood</label>
        <textarea id="h-neighborhood" placeholder="The street, the neighbors, the coffee shop two blocks over…"></textarea>
      </div>
      <div class="field-group">
        <label>The Homes Before This One</label>
        <textarea id="h-homes_before" placeholder="The starter apartment. The house you outgrew…"></textarea>
      </div>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('home')">Save Home</button>
        <span class="save-status" id="status-home"></span>
      </div>
    </div>

    <!-- ============ YEAR BY YEAR ============ -->
    <div class="editor-section" id="section-years">
      <p class="section-eyebrow">Chapter Four</p>
      <h1 class="section-title">Year by Year</h1>
      <p class="section-subtitle">Add a card for every year your family has been together.</p>
      <div class="section-divider"></div>

      <div id="years-list" class="item-list"></div>
      <button type="button" class="btn-add" onclick="addYear()">+ Add Year</button>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('years')">Save Years</button>
        <span class="save-status" id="status-years"></span>
      </div>
    </div>

    <!-- ============ FAMILY MEMBERS ============ -->
    <div class="editor-section" id="section-family_members">
      <p class="section-eyebrow">Chapter Five</p>
      <h1 class="section-title">The Family</h1>
      <p class="section-subtitle">Every person who makes up this family — by birth, marriage, or decades of showing up.</p>
      <div class="section-divider"></div>

      <div id="family-list" class="item-list"></div>
      <button type="button" class="btn-add" onclick="addFamilyMember()">+ Add Family Member</button>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('family_members')">Save Family Members</button>
        <span class="save-status" id="status-family_members"></span>
      </div>
    </div>

    <!-- ============ ADVENTURES ============ -->
    <div class="editor-section" id="section-adventures">
      <p class="section-eyebrow">Chapter Six</p>
      <h1 class="section-title">Adventures</h1>
      <p class="section-subtitle">The places you went and the things that happened when you got there.</p>
      <div class="section-divider"></div>

      <div id="adventures-list" class="item-list"></div>
      <button type="button" class="btn-add" onclick="addAdventure()">+ Add Adventure</button>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('adventures')">Save Adventures</button>
        <span class="save-status" id="status-adventures"></span>
      </div>
    </div>

    <!-- ============ TRADITIONS ============ -->
    <div class="editor-section" id="section-traditions">
      <p class="section-eyebrow">Chapter Seven</p>
      <h1 class="section-title">Traditions &amp; Celebrations</h1>
      <p class="section-subtitle">The rituals that mark every year of being a family.</p>
      <div class="section-divider"></div>

      <div class="field-group">
        <label>Introduction</label>
        <textarea id="t-intro" placeholder="A family's traditions are its fingerprint…"></textarea>
      </div>
      <div class="field-group">
        <label>How We Celebrate</label>
        <p class="hint">Holidays and how you celebrate them — the specific version, not the generic one.</p>
        <textarea class="tall" id="t-how_we_celebrate" placeholder="Write about the holidays your family celebrates and how you celebrate them…"></textarea>
      </div>
      <div class="field-group">
        <label>Things We Do Every Year</label>
        <p class="hint">Annual rituals that belong specifically to this family.</p>
        <textarea class="tall" id="t-annual" placeholder="Beyond the major holidays, most families develop their own annual rituals…"></textarea>
      </div>
      <div class="field-group">
        <label>A Tradition From Our Heritage</label>
        <textarea class="tall" id="t-heritage" placeholder="For the traditions that connect your family to where it came from…"></textarea>
      </div>
      <div class="field-group">
        <label>A Tradition We Started Ourselves</label>
        <textarea class="tall" id="t-started_ourselves" placeholder="Some traditions are born the year a family decides to start them…"></textarea>
      </div>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('traditions')">Save Traditions</button>
        <span class="save-status" id="status-traditions"></span>
      </div>
    </div>

    <!-- ============ LETTERS ============ -->
    <div class="editor-section" id="section-letters">
      <p class="section-eyebrow">Chapter Eight</p>
      <h1 class="section-title">Letters</h1>
      <p class="section-subtitle">Words written across time, for the people who matter most.</p>
      <div class="section-divider"></div>

      <div id="letters-list" class="item-list"></div>
      <button type="button" class="btn-add" onclick="addLetter()">+ Add Letter</button>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('letters')">Save Letters</button>
        <span class="save-status" id="status-letters"></span>
      </div>
    </div>

    <!-- ============ RECIPES ============ -->
    <div class="editor-section" id="section-recipes">
      <p class="section-eyebrow">Chapter Nine</p>
      <h1 class="section-title">Family Recipes</h1>
      <p class="section-subtitle">The flavors that always mean home.</p>
      <div class="section-divider"></div>

      <div id="recipes-list" class="item-list"></div>
      <button type="button" class="btn-add" onclick="addRecipe()">+ Add Recipe</button>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('recipes')">Save Recipes</button>
        <span class="save-status" id="status-recipes"></span>
      </div>
    </div>

    <!-- ============ VAULT ============ -->
    <div class="editor-section" id="section-vault">
      <p class="section-eyebrow">The Vault</p>
      <h1 class="section-title">Time Capsule Settings</h1>
      <p class="section-subtitle">Set when your family's sealed vault unlocks.</p>
      <div class="section-divider"></div>

      <div class="field-row">
        <div class="field-group">
          <label>Family Start Year</label>
          <p class="hint">The year your family began — used to calculate the countdown.</p>
          <input type="number" id="v-family_start_year" placeholder="2009" min="1900" max="2099">
        </div>
        <div class="field-group">
          <label>Anniversary Milestone (years)</label>
          <p class="hint">The vault unlocks on this anniversary. Default: 25.</p>
          <input type="number" id="v-anniversary_years" placeholder="25" min="1" max="100">
        </div>
      </div>
      <div class="field-group">
        <label>Vault Message</label>
        <p class="hint">Text shown on the vault page above the countdown.</p>
        <textarea class="tall" id="v-message" placeholder="Behind this lock are letters, photos, and memories sealed by your family…"></textarea>
      </div>

      <div class="save-bar">
        <button class="btn-save" onclick="saveSection('vault')">Save Vault Settings</button>
        <span class="save-status" id="status-vault"></span>
      </div>
    </div>

  </div><!-- /main-content -->
</div><!-- /app -->

<div id="toast"></div>

<script>
const API = '<%= appDomain %>' === 'legacyodyssey.com'
  ? 'https://legacyodyssey.com/api'
  : 'http://localhost:3000/api';

let _token = null;
let _album = {};

// ── AUTH ──
const supabaseUrl = 'https://vesaydfwwdbbajydbzmq.supabase.co';
const supabaseAnonKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZlc2F5ZGZ3d2RiYmFqeWRiem1xIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MTA5Nzg3MjEsImV4cCI6MjAyNjU1NDcyMX0.JuFyeQGqezYMz0OG8_4SunJT8BHJlDDJBNDjeSfhPuA';

// Check if already logged in (token in localStorage)
const stored = localStorage.getItem('lo_token');
if (stored) {
  _token = stored;
  loadAlbum();
} else {
  document.getElementById('auth-screen').classList.remove('hidden');
}

document.getElementById('auth-btn').addEventListener('click', signIn);
document.getElementById('auth-password').addEventListener('keydown', function(e) { if (e.key === 'Enter') signIn(); });

async function signIn() {
  const email = document.getElementById('auth-email').value.trim();
  const password = document.getElementById('auth-password').value;
  const errEl = document.getElementById('auth-error');
  errEl.textContent = '';
  if (!email || !password) { errEl.textContent = 'Please enter your email and password.'; return; }
  try {
    const res = await fetch(`${supabaseUrl}/auth/v1/token?grant_type=password`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'apikey': supabaseAnonKey },
      body: JSON.stringify({ email, password }),
    });
    const data = await res.json();
    if (data.access_token) {
      _token = data.access_token;
      localStorage.setItem('lo_token', _token);
      document.getElementById('auth-screen').classList.add('hidden');
      loadAlbum();
    } else {
      errEl.textContent = data.error_description || data.msg || 'Invalid email or password.';
    }
  } catch (e) {
    errEl.textContent = 'Connection error. Please try again.';
  }
}

document.getElementById('logout-btn').addEventListener('click', function() {
  localStorage.removeItem('lo_token');
  _token = null;
  window.location.reload();
});

// ── LOAD ALBUM ──
async function loadAlbum() {
  try {
    const res = await fetch(`${API}/album`, { headers: { Authorization: `Bearer ${_token}` } });
    if (res.status === 401) { localStorage.removeItem('lo_token'); window.location.reload(); return; }
    if (res.status === 400) {
      showToast('This account is not set up as a Family Album. Please contact support.', true);
      return;
    }
    const data = await res.json();
    _album = data.album || {};
    const family = data.family || {};

    // Update sidebar
    document.getElementById('sidebar-family-name').textContent = _album.family_name || family.display_name || 'Your Album';
    const slug = family.custom_domain ? `https://www.${family.custom_domain}` : (family.subdomain ? `https://${family.subdomain}.legacyodyssey.com` : '/');
    document.getElementById('view-album-link').href = slug;

    // Show app
    document.getElementById('app').classList.remove('hidden');
    populateFields();
  } catch (e) {
    showToast('Failed to load album data. Please refresh.', true);
  }
}

// ── POPULATE ALL FIELDS ──
function populateFields() {
  // Welcome
  setVal('w-family_name', _album.family_name);
  setVal('w-established_year', _album.established_year);
  setVal('w-hometown', _album.hometown);
  setVal('w-welcome_quote', _album.welcome_quote);
  setVal('w-welcome_quote_attribution', _album.welcome_quote_attribution);
  setVal('w-welcome_texts', (_album.welcome_texts || []).join('\n\n'));

  // Our Story
  const os = _album.our_story || {};
  setVal('os-how_it_started', os.how_it_started);
  setVal('os-decision_to_build', os.decision_to_build);
  setVal('os-early_years', os.early_years);
  setVal('os-checklist_title', os.checklist_title);
  renderChecklistEditor(os.checklist || []);

  // Roots
  const r = _album.roots || {};
  setVal('r-intro', r.intro);
  setVal('r-moms_side_title', r.moms_side_title);
  setVal('r-dads_side_title', r.dads_side_title);
  setVal('r-moms_side', r.moms_side);
  setVal('r-dads_side', r.dads_side);
  setVal('r-passing_down', r.passing_down);

  // Home
  const h = _album.home || {};
  setVal('h-intro', h.intro);
  setVal('h-the_house', h.the_house);
  setVal('h-neighborhood', h.neighborhood);
  setVal('h-homes_before', h.homes_before);

  // Years
  renderYears(_album.years || []);

  // Family members
  renderFamilyMembers(_album.family_members || []);

  // Adventures
  renderAdventures(_album.adventures || []);

  // Traditions
  const t = _album.traditions || {};
  setVal('t-intro', t.intro);
  setVal('t-how_we_celebrate', t.how_we_celebrate);
  setVal('t-annual', t.annual);
  setVal('t-heritage', t.heritage);
  setVal('t-started_ourselves', t.started_ourselves);

  // Letters
  renderLetters(_album.letters || []);

  // Recipes
  renderRecipes(_album.recipes || []);

  // Vault
  const v = _album.vault || {};
  setVal('v-family_start_year', v.family_start_year);
  setVal('v-anniversary_years', v.anniversary_years);
  setVal('v-message', v.message);
}

function setVal(id, val) {
  const el = document.getElementById(id);
  if (el && val !== undefined && val !== null) el.value = val;
}

// ── NAVIGATION ──
document.querySelectorAll('.nav-item').forEach(function(item) {
  item.addEventListener('click', function() {
    const section = this.getAttribute('data-section');
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.querySelectorAll('.editor-section').forEach(s => s.classList.remove('active'));
    this.classList.add('active');
    document.getElementById('section-' + section).classList.add('active');
    document.getElementById('main-content').scrollTop = 0;
  });
});

// ── SAVE SECTION ──
async function saveSection(section) {
  const statusEl = document.getElementById('status-' + section);
  statusEl.textContent = 'Saving…';
  statusEl.className = 'save-status';

  try {
    let body;
    if (section === 'welcome') {
      const textsRaw = document.getElementById('w-welcome_texts').value;
      const texts = textsRaw.split(/\n\n+/).map(t => t.trim()).filter(t => t.length > 0);
      body = {
        family_name: document.getElementById('w-family_name').value.trim(),
        established_year: document.getElementById('w-established_year').value ? parseInt(document.getElementById('w-established_year').value) : null,
        hometown: document.getElementById('w-hometown').value.trim(),
        welcome_quote: document.getElementById('w-welcome_quote').value.trim(),
        welcome_quote_attribution: document.getElementById('w-welcome_quote_attribution').value.trim(),
        welcome_texts: texts,
      };
    } else if (section === 'our_story') {
      body = {
        how_it_started: document.getElementById('os-how_it_started').value.trim(),
        decision_to_build: document.getElementById('os-decision_to_build').value.trim(),
        early_years: document.getElementById('os-early_years').value.trim(),
        checklist_title: document.getElementById('os-checklist_title').value.trim(),
        checklist: getChecklistItems(),
      };
    } else if (section === 'roots') {
      body = {
        intro: document.getElementById('r-intro').value.trim(),
        moms_side_title: document.getElementById('r-moms_side_title').value.trim(),
        dads_side_title: document.getElementById('r-dads_side_title').value.trim(),
        moms_side: document.getElementById('r-moms_side').value.trim(),
        dads_side: document.getElementById('r-dads_side').value.trim(),
        passing_down: document.getElementById('r-passing_down').value.trim(),
      };
    } else if (section === 'home') {
      body = {
        intro: document.getElementById('h-intro').value.trim(),
        the_house: document.getElementById('h-the_house').value.trim(),
        neighborhood: document.getElementById('h-neighborhood').value.trim(),
        homes_before: document.getElementById('h-homes_before').value.trim(),
      };
    } else if (section === 'years') {
      body = { years: collectYears() };
    } else if (section === 'family_members') {
      body = { family_members: collectFamilyMembers() };
    } else if (section === 'adventures') {
      body = { adventures: collectAdventures() };
    } else if (section === 'traditions') {
      body = {
        intro: document.getElementById('t-intro').value.trim(),
        how_we_celebrate: document.getElementById('t-how_we_celebrate').value.trim(),
        annual: document.getElementById('t-annual').value.trim(),
        heritage: document.getElementById('t-heritage').value.trim(),
        started_ourselves: document.getElementById('t-started_ourselves').value.trim(),
      };
    } else if (section === 'letters') {
      body = { letters: collectLetters() };
    } else if (section === 'recipes') {
      body = { recipes: collectRecipes() };
    } else if (section === 'vault') {
      body = {
        family_start_year: parseInt(document.getElementById('v-family_start_year').value) || null,
        anniversary_years: parseInt(document.getElementById('v-anniversary_years').value) || 25,
        message: document.getElementById('v-message').value.trim(),
      };
    }

    const res = await fetch(`${API}/album/${section}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${_token}` },
      body: JSON.stringify(body),
    });
    const data = await res.json();
    if (data.success) {
      _album = data.album;
      statusEl.textContent = '✓ Saved';
      statusEl.className = 'save-status saved';
      const dot = document.getElementById('dot-' + section);
      if (dot) { dot.classList.add('show'); }
      if (section === 'welcome' && _album.family_name) {
        document.getElementById('sidebar-family-name').textContent = _album.family_name;
      }
      showToast('Saved!');
      setTimeout(() => { statusEl.textContent = ''; }, 3000);
    } else {
      throw new Error(data.error || 'Save failed');
    }
  } catch (e) {
    statusEl.textContent = '✗ ' + e.message;
    statusEl.className = 'save-status error';
    showToast(e.message, true);
  }
}

// ── CHECKLIST EDITOR ──
function renderChecklistEditor(items) {
  const el = document.getElementById('os-checklist-editor');
  el.innerHTML = '';
  items.forEach(function(item, i) {
    el.appendChild(makeChecklistRow(item));
  });
}
function makeChecklistRow(value) {
  const row = document.createElement('div');
  row.className = 'checklist-row';
  const inp = document.createElement('input');
  inp.type = 'text'; inp.value = value || ''; inp.placeholder = 'e.g. Found each other';
  const rm = document.createElement('button');
  rm.type = 'button'; rm.className = 'btn-rm-check'; rm.innerHTML = '&times;';
  rm.onclick = function() { row.remove(); };
  row.appendChild(inp); row.appendChild(rm);
  return row;
}
function addChecklistItem() {
  document.getElementById('os-checklist-editor').appendChild(makeChecklistRow(''));
}
function getChecklistItems() {
  return Array.from(document.querySelectorAll('#os-checklist-editor .checklist-row input'))
    .map(i => i.value.trim()).filter(v => v);
}

// ── YEARS ──
var _years = [];
function renderYears(items) {
  _years = items.map(function(y) { return Object.assign({}, y); });
  const list = document.getElementById('years-list');
  list.innerHTML = '';
  _years.forEach(function(y, i) { list.appendChild(makeYearItem(y, i)); });
}
function makeYearItem(y, i) {
  const wrap = document.createElement('div');
  wrap.className = 'list-item';
  wrap.innerHTML = `<div class="list-item-header" onclick="toggleItem(this.parentElement)">
    <div><div class="list-item-title">${y.year || 'New Year'}</div><div class="list-item-subtitle">${y.label || ''}</div></div>
    <span class="list-item-toggle">&#9660;</span></div>
  <div class="list-item-body">
    <div class="field-row">
      <div class="field-group"><label>Year</label><input type="number" class="y-year" value="${y.year||''}" placeholder="2009"></div>
      <div class="field-group"><label>Label</label><input type="text" class="y-label" value="${escHtml(y.label||'')}" placeholder="The Beginning"></div>
    </div>
    <div class="field-group"><label>Highlight</label><input type="text" class="y-highlight" value="${escHtml(y.highlight||'')}" placeholder="A one-line summary"></div>
    <div class="field-group"><label>Story</label><textarea class="y-note tall">${escHtml(y.note||'')}</textarea></div>
    <button type="button" class="btn-remove" onclick="removeItem(this, 'years-list', ${i})">Remove Year</button>
  </div>`;
  return wrap;
}
function addYear() {
  _years.push({ year: new Date().getFullYear(), label: '', highlight: '', note: '' });
  renderYears(_years);
  const items = document.querySelectorAll('#years-list .list-item');
  if (items.length) { items[items.length - 1].classList.add('open'); items[items.length - 1].scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }
}
function collectYears() {
  return Array.from(document.querySelectorAll('#years-list .list-item')).map(function(item) {
    return {
      year: parseInt(item.querySelector('.y-year').value) || null,
      label: item.querySelector('.y-label').value.trim(),
      highlight: item.querySelector('.y-highlight').value.trim(),
      note: item.querySelector('.y-note').value.trim(),
    };
  }).filter(y => y.year);
}

// ── FAMILY MEMBERS ──
var _members = [];
const MEMBER_EMOJIS = ['👩','👨','👧','👦','👶','👵','👴','👩‍🦱','👨‍🦱','👩‍🦳','👨‍🦳','👩‍🦰','👨‍🦰','🧒','🧑','👤'];
function renderFamilyMembers(items) {
  _members = items.map(function(m) { return Object.assign({}, m); });
  const list = document.getElementById('family-list');
  list.innerHTML = '';
  _members.forEach(function(m, i) { list.appendChild(makeMemberItem(m, i)); });
}
function makeMemberItem(m, i) {
  const metaRows = (m.meta || []).map(function(pair, mi) {
    return `<div class="meta-row"><input type="text" class="m-meta-label" value="${escHtml(pair[0]||'')}" placeholder="Label (e.g. Hometown)"><input type="text" class="m-meta-value" value="${escHtml(pair[1]||'')}" placeholder="Value"></div>`;
  }).join('');
  const emojiOpts = MEMBER_EMOJIS.map(function(e) {
    return `<span class="emoji-opt${m.emoji === e ? ' selected' : ''}" onclick="selectEmoji(this, ${i})">${e}</span>`;
  }).join('');
  const wrap = document.createElement('div');
  wrap.className = 'list-item';
  wrap.innerHTML = `<div class="list-item-header" onclick="toggleItem(this.parentElement)">
    <div><div class="list-item-title">${m.emoji||'👤'} ${escHtml(m.name||'New Member')}</div><div class="list-item-subtitle">${escHtml(m.role||'')}</div></div>
    <span class="list-item-toggle">&#9660;</span></div>
  <div class="list-item-body">
    <div class="field-group"><label>Emoji</label><div class="emoji-options">${emojiOpts}</div><input type="hidden" class="m-emoji" value="${escHtml(m.emoji||'👤')}"></div>
    <div class="field-row">
      <div class="field-group"><label>Name</label><input type="text" class="m-name" value="${escHtml(m.name||'')}" placeholder="Mom's Name"></div>
      <div class="field-group"><label>Role</label><input type="text" class="m-role" value="${escHtml(m.role||'')}" placeholder="Mother"></div>
    </div>
    <div class="field-group"><label>Meta Fields (label + value pairs)</label><div class="m-meta-editor">${metaRows}</div>
      <button type="button" class="btn-add" style="margin-top:0.4rem;" onclick="addMetaRow(this.previousElementSibling)">+ Add Field</button>
    </div>
    <div class="field-group"><label>Their Story (part 1)</label><textarea class="m-story1 tall">${escHtml(m.story1||'')}</textarea></div>
    <div class="field-group"><label>Their Quote</label><input type="text" class="m-quote" value="${escHtml(m.quote||'')}" placeholder='"A family is the people you\'d choose even if you didn\'t have to."'></div>
    <div class="field-group"><label>Their Story (part 2)</label><textarea class="m-story2">${escHtml(m.story2||'')}</textarea></div>
    <button type="button" class="btn-remove" onclick="removeItem(this, 'family-list', ${i})">Remove Member</button>
  </div>`;
  return wrap;
}
function selectEmoji(el, memberIdx) {
  const body = el.closest('.list-item-body');
  body.querySelectorAll('.emoji-opt').forEach(e => e.classList.remove('selected'));
  el.classList.add('selected');
  body.querySelector('.m-emoji').value = el.textContent;
}
function addMetaRow(container) {
  const row = document.createElement('div');
  row.className = 'meta-row';
  row.innerHTML = '<input type="text" class="m-meta-label" placeholder="Label"><input type="text" class="m-meta-value" placeholder="Value">';
  container.appendChild(row);
}
function addFamilyMember() {
  _members.push({ emoji: '👤', name: '', role: '', meta: [], story1: '', quote: '', story2: '' });
  renderFamilyMembers(_members);
  const items = document.querySelectorAll('#family-list .list-item');
  if (items.length) { items[items.length - 1].classList.add('open'); }
}
function collectFamilyMembers() {
  return Array.from(document.querySelectorAll('#family-list .list-item')).map(function(item) {
    const metaLabels = item.querySelectorAll('.m-meta-label');
    const metaValues = item.querySelectorAll('.m-meta-value');
    const meta = Array.from(metaLabels).map(function(l, i) { return [l.value.trim(), metaValues[i] ? metaValues[i].value.trim() : '']; }).filter(p => p[0]);
    return {
      emoji: item.querySelector('.m-emoji').value,
      name: item.querySelector('.m-name').value.trim(),
      role: item.querySelector('.m-role').value.trim(),
      meta,
      story1: item.querySelector('.m-story1').value.trim(),
      quote: item.querySelector('.m-quote').value.trim(),
      story2: item.querySelector('.m-story2').value.trim(),
    };
  }).filter(m => m.name);
}

// ── ADVENTURES ──
var _adventures = [];
const ADV_COLORS = ['var(--dusty-blue)', 'var(--sage)', 'var(--gold-light)', 'var(--rose)', 'var(--blush)', 'var(--ink-light)'];
const ADV_EMOJIS = ['✈️','🏕️','🌍','🗺️','🏖️','🏔️','🚢','🚗','🌅','🎡'];
function renderAdventures(items) {
  _adventures = items.slice();
  const list = document.getElementById('adventures-list');
  list.innerHTML = '';
  _adventures.forEach(function(a, i) { list.appendChild(makeAdventureItem(a, i)); });
}
function makeAdventureItem(a, i) {
  const wrap = document.createElement('div');
  wrap.className = 'list-item';
  const emojiOpts = ADV_EMOJIS.map(e => `<span class="emoji-opt${a.emoji===e?' selected':''}" onclick="this.closest('.list-item-body').querySelector('.a-emoji').value='${e}';this.closest('.emoji-options').querySelectorAll('.emoji-opt').forEach(x=>x.classList.remove('selected'));this.classList.add('selected');">${e}</span>`).join('');
  wrap.innerHTML = `<div class="list-item-header" onclick="toggleItem(this.parentElement)">
    <div><div class="list-item-title">${a.emoji||'✈️'} ${escHtml(a.title||'New Adventure')}</div><div class="list-item-subtitle">${escHtml(a.dest||'')} ${a.year ? '· '+a.year : ''}</div></div>
    <span class="list-item-toggle">&#9660;</span></div>
  <div class="list-item-body">
    <div class="field-group"><label>Emoji</label><div class="emoji-options">${emojiOpts}</div><input type="hidden" class="a-emoji" value="${escHtml(a.emoji||'✈️')}"></div>
    <div class="field-row">
      <div class="field-group"><label>Title</label><input type="text" class="a-title" value="${escHtml(a.title||'')}" placeholder="The First Big Family Trip"></div>
      <div class="field-group"><label>Destination</label><input type="text" class="a-dest" value="${escHtml(a.dest||'')}" placeholder="Paris, France"></div>
    </div>
    <div class="field-row">
      <div class="field-group"><label>Year</label><input type="text" class="a-year" value="${escHtml(a.year||'')}" placeholder="2018"></div>
      <div class="field-group"><label>Tagline</label><input type="text" class="a-tagline" value="${escHtml(a.tagline||'')}" placeholder="The one that started it all."></div>
    </div>
    <div class="field-group"><label>Story</label><textarea class="a-story tall">${escHtml(a.story||'')}</textarea></div>
    <button type="button" class="btn-remove" onclick="removeItem(this, 'adventures-list', ${i})">Remove Adventure</button>
  </div>`;
  return wrap;
}
function addAdventure() {
  _adventures.push({ emoji: '✈️', title: '', dest: '', year: '', tagline: '', color: 'var(--dusty-blue)', story: '' });
  renderAdventures(_adventures);
  const items = document.querySelectorAll('#adventures-list .list-item');
  if (items.length) items[items.length - 1].classList.add('open');
}
function collectAdventures() {
  return Array.from(document.querySelectorAll('#adventures-list .list-item')).map(function(item) {
    return {
      emoji: item.querySelector('.a-emoji').value,
      title: item.querySelector('.a-title').value.trim(),
      dest: item.querySelector('.a-dest').value.trim(),
      year: item.querySelector('.a-year').value.trim(),
      tagline: item.querySelector('.a-tagline').value.trim(),
      story: item.querySelector('.a-story').value.trim(),
      color: 'var(--dusty-blue)',
    };
  }).filter(a => a.title);
}

// ── LETTERS ──
function renderLetters(items) {
  const list = document.getElementById('letters-list');
  list.innerHTML = '';
  items.forEach(function(l, i) { list.appendChild(makeLetterItem(l, i)); });
}
function makeLetterItem(l, i) {
  const wrap = document.createElement('div');
  wrap.className = 'list-item';
  wrap.innerHTML = `<div class="list-item-header" onclick="toggleItem(this.parentElement)">
    <div><div class="list-item-title">✦ ${escHtml(l.heading||'A Letter')}</div></div>
    <span class="list-item-toggle">&#9660;</span></div>
  <div class="list-item-body">
    <div class="field-group"><label>Letter Heading</label><input type="text" class="l-heading" value="${escHtml(l.heading||'')}" placeholder="From Mom · Written Today"></div>
    <div class="field-group"><label>Letter Body</label><p class="hint">Each paragraph on its own line.</p><textarea class="l-body tall" style="min-height:200px;">${escHtml(l.body||'')}</textarea></div>
    <button type="button" class="btn-remove" onclick="removeItem(this, 'letters-list', ${i})">Remove Letter</button>
  </div>`;
  return wrap;
}
function addLetter() {
  const items = document.getElementById('letters-list');
  items.appendChild(makeLetterItem({ heading: '', body: '' }, items.children.length));
  const all = document.querySelectorAll('#letters-list .list-item');
  if (all.length) all[all.length - 1].classList.add('open');
}
function collectLetters() {
  return Array.from(document.querySelectorAll('#letters-list .list-item')).map(function(item) {
    return { heading: item.querySelector('.l-heading').value.trim(), body: item.querySelector('.l-body').value.trim() };
  }).filter(l => l.heading || l.body);
}

// ── RECIPES ──
function renderRecipes(items) {
  const list = document.getElementById('recipes-list');
  list.innerHTML = '';
  items.forEach(function(r, i) { list.appendChild(makeRecipeItem(r, i)); });
}
function makeRecipeItem(r, i) {
  const ingRows = (r.ingredients || []).map(function(ing) {
    return `<div class="ing-row"><input type="text" class="r-ing" value="${escHtml(ing)}" placeholder="Ingredient"><button type="button" class="btn-rm-check" onclick="this.parentElement.remove()">&times;</button></div>`;
  }).join('');
  const wrap = document.createElement('div');
  wrap.className = 'list-item';
  wrap.innerHTML = `<div class="list-item-header" onclick="toggleItem(this.parentElement)">
    <div><div class="list-item-title">${escHtml(r.title||r.name||'New Recipe')}</div><div class="list-item-subtitle">${escHtml(r.label||'')}</div></div>
    <span class="list-item-toggle">&#9660;</span></div>
  <div class="list-item-body">
    <div class="field-row">
      <div class="field-group"><label>Title</label><input type="text" class="r-title" value="${escHtml(r.title||r.name||'')}" placeholder="Grandma's Apple Pie"></div>
      <div class="field-group"><label>Label / Category</label><input type="text" class="r-label" value="${escHtml(r.label||'')}" placeholder="Grandma's Recipe"></div>
    </div>
    <div class="field-group"><label>Story / Note</label><textarea class="r-note">${escHtml(r.note||r.description||'')}</textarea></div>
    <div class="field-group"><label>Ingredients</label><div class="r-ings-editor">${ingRows}</div>
      <button type="button" class="btn-add" style="margin-top:0.4rem;" onclick="addIngredient(this.previousElementSibling)">+ Add Ingredient</button>
    </div>
    <button type="button" class="btn-remove" onclick="removeItem(this, 'recipes-list', ${i})">Remove Recipe</button>
  </div>`;
  return wrap;
}
function addIngredient(container) {
  const row = document.createElement('div');
  row.className = 'ing-row';
  row.innerHTML = '<input type="text" class="r-ing" placeholder="Ingredient"><button type="button" class="btn-rm-check" onclick="this.parentElement.remove()">&times;</button>';
  container.appendChild(row);
}
function addRecipe() {
  const items = document.getElementById('recipes-list');
  items.appendChild(makeRecipeItem({ title: '', label: '', note: '', ingredients: [] }, items.children.length));
  const all = document.querySelectorAll('#recipes-list .list-item');
  if (all.length) all[all.length - 1].classList.add('open');
}
function collectRecipes() {
  return Array.from(document.querySelectorAll('#recipes-list .list-item')).map(function(item) {
    const ingredients = Array.from(item.querySelectorAll('.r-ing')).map(i => i.value.trim()).filter(v => v);
    return {
      title: item.querySelector('.r-title').value.trim(),
      label: item.querySelector('.r-label').value.trim(),
      note: item.querySelector('.r-note').value.trim(),
      ingredients,
    };
  }).filter(r => r.title);
}

// ── UTILITIES ──
function toggleItem(el) { el.classList.toggle('open'); }
function removeItem(btn, listId, idx) {
  if (!confirm('Remove this item?')) return;
  btn.closest('.list-item').remove();
}
function escHtml(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function showToast(msg, isError) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = isError ? 'show error' : 'show';
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(function() { t.className = ''; }, 3000);
}
</script>
</body>
</html>
