<!-- Year Modal -->
<div class="modal-overlay" id="yearModal">
  <div class="modal-content">
    <button class="modal-close" id="yearModalClose">&times;</button>
    <div class="year-num" id="modalYear"></div>
    <h3 id="modalLabel"></h3>
    <p class="highlight" id="modalHighlight"></p>
    <p class="note" id="modalNote"></p>
  </div>
</div>

<!-- Adventure Modal -->
<div class="modal-overlay" id="advModal">
  <div class="modal-content">
    <button class="modal-close" id="advModalClose">&times;</button>
    <h3 id="advModalTitle"></h3>
    <p class="highlight" id="advModalDest"></p>
    <p class="highlight" id="advModalTagline"></p>
    <p class="note" id="advModalStory"></p>
  </div>
</div>

<!-- Family Detail Panel -->
<div id="family-detail-overlay"></div>
<div id="family-detail">
  <button class="detail-close" id="detailClose">&times;</button>
  <div class="detail-emoji" id="detailEmoji"></div>
  <h2 class="detail-name" id="detailName"></h2>
  <p class="detail-role" id="detailRole"></p>
  <div class="detail-meta" id="detailMeta"></div>
  <p class="detail-story" id="detailStory1"></p>
  <div class="detail-quote" id="detailQuote"></div>
  <p class="detail-story" id="detailStory2"></p>
</div>

<script>
// ── SERVER DATA ──
const years = <%- JSON.stringify(years) %>;
const familyMembers = <%- JSON.stringify(familyMembers) %>;
const adventures = <%- JSON.stringify(adventures) %>;
const vaultStartYear = <%= parseInt(vaultStartYear) || 2000 %>;
const vaultAnniversaryYears = <%= parseInt(vaultAnniversary) || 25 %>;

// ── NAVIGATION ──
function showPage(id) {
  document.querySelectorAll('.page-section').forEach(function(s){ s.classList.remove('active'); });
  var el = document.getElementById(id);
  if (el) el.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(function(n){ n.classList.remove('active'); });
  var navEl = document.querySelector('.nav-item[data-page="'+id+'"]');
  if (navEl) navEl.classList.add('active');
  document.getElementById('main-content').scrollTop = 0;
  closeMobileNav();
}
document.querySelectorAll('.nav-item').forEach(function(n){
  n.addEventListener('click', function(){ showPage(this.getAttribute('data-page')); });
});

// ── MOBILE NAV ──
var hamburger = document.getElementById('hamburger');
var sidebar = document.getElementById('sidebar');
var navOverlay = document.getElementById('navOverlay');
hamburger.addEventListener('click', function(){
  sidebar.classList.toggle('open');
  navOverlay.classList.toggle('show');
});
navOverlay.addEventListener('click', closeMobileNav);
function closeMobileNav(){
  sidebar.classList.remove('open');
  navOverlay.classList.remove('show');
}

// ── YEAR CARDS ──
var yearColors = ['var(--blush)','var(--dusty-blue)','var(--sage)','var(--gold-light)','var(--rose)','var(--blush)','var(--ink-light)','var(--dusty-blue)','var(--sage)','var(--gold-light)'];
var yearGrid = document.getElementById('yearGrid');
years.forEach(function(y, i){
  var card = document.createElement('div');
  card.className = 'year-card';
  card.innerHTML = '<div class="year-num">'+y.year+'</div><div class="year-label">'+(y.label||'')+'</div><div class="year-highlight">'+(y.highlight||'')+'</div>';
  card.addEventListener('click', function(){ openYearModal(i); });
  yearGrid.appendChild(card);
});

// ── YEAR MODAL ──
var yearModal = document.getElementById('yearModal');
function openYearModal(i){
  var y = years[i];
  document.getElementById('modalYear').textContent = y.year;
  document.getElementById('modalLabel').textContent = y.label||'';
  document.getElementById('modalHighlight').textContent = y.highlight||'';
  document.getElementById('modalNote').textContent = y.note||'';
  yearModal.classList.add('show');
}
document.getElementById('yearModalClose').addEventListener('click', function(){ yearModal.classList.remove('show'); });
yearModal.addEventListener('click', function(e){ if(e.target===yearModal) yearModal.classList.remove('show'); });

// ── FAMILY CARDS ──
var familyGrid = document.getElementById('familyGrid');
familyMembers.forEach(function(m, i){
  var card = document.createElement('div');
  card.className = 'family-card';
  card.innerHTML = '<span class="member-emoji">'+(m.emoji||'👤')+'</span><div class="member-name">'+(m.name||'Family Member')+'</div><div class="member-role">'+(m.role||'')+'</div>';
  card.addEventListener('click', function(){ openFamilyDetail(i); });
  familyGrid.appendChild(card);
});

// ── FAMILY DETAIL PANEL ──
var detailPanel = document.getElementById('family-detail');
var detailOverlay = document.getElementById('family-detail-overlay');
function openFamilyDetail(i){
  var m = familyMembers[i];
  document.getElementById('detailEmoji').textContent = m.emoji||'👤';
  document.getElementById('detailName').textContent = m.name||'';
  document.getElementById('detailRole').textContent = m.role||'';
  var metaHtml = '';
  (m.meta||[]).forEach(function(pair){
    metaHtml += '<div class="meta-item"><div class="meta-label">'+pair[0]+'</div><div class="meta-value">'+pair[1]+'</div></div>';
  });
  document.getElementById('detailMeta').innerHTML = metaHtml;
  document.getElementById('detailStory1').textContent = m.story1||'';
  document.getElementById('detailQuote').textContent = m.quote||'';
  document.getElementById('detailStory2').textContent = m.story2||'';
  detailPanel.classList.add('open');
  detailOverlay.classList.add('show');
}
function closeFamilyDetail(){
  detailPanel.classList.remove('open');
  detailOverlay.classList.remove('show');
}
document.getElementById('detailClose').addEventListener('click', closeFamilyDetail);
detailOverlay.addEventListener('click', closeFamilyDetail);

// ── ADVENTURE CARDS ──
var adventureGrid = document.getElementById('adventureGrid');
adventures.forEach(function(a, i){
  var card = document.createElement('div');
  card.className = 'adventure-card';
  var color = a.color || 'var(--dusty-blue)';
  card.innerHTML = '<div class="adventure-img" style="background:'+color+'; opacity:0.45;">'+(a.emoji||'✈️')+'</div><div class="adventure-body"><h4>'+(a.title||'Adventure')+'</h4><p class="adv-dest">'+(a.dest||'')+' &middot; '+(a.year||'')+'</p><p class="adv-tagline">&ldquo;'+(a.tagline||'')+'&rdquo;</p></div>';
  card.addEventListener('click', function(){ openAdvModal(i); });
  adventureGrid.appendChild(card);
});

// ── ADVENTURE MODAL ──
var advModal = document.getElementById('advModal');
function openAdvModal(i){
  var a = adventures[i];
  document.getElementById('advModalTitle').textContent = a.title||'';
  document.getElementById('advModalDest').textContent = (a.dest||'') + ' · ' + (a.year||'');
  document.getElementById('advModalTagline').textContent = '\u201c' + (a.tagline||'') + '\u201d';
  document.getElementById('advModalStory').textContent = a.story||'';
  advModal.classList.add('show');
}
document.getElementById('advModalClose').addEventListener('click', function(){ advModal.classList.remove('show'); });
advModal.addEventListener('click', function(e){ if(e.target===advModal) advModal.classList.remove('show'); });

// ── VAULT COUNTDOWN ──
(function startCountdown() {
  var unlockDate = new Date(vaultStartYear + vaultAnniversaryYears, 0, 1);
  function update() {
    var now = new Date();
    var diff = unlockDate - now;
    if (diff <= 0) {
      document.getElementById('cdYears').textContent = '0';
      document.getElementById('cdMonths').textContent = '0';
      document.getElementById('cdDays').textContent = '0';
      return;
    }
    var totalDays = Math.floor(diff / (1000*60*60*24));
    var yrs = Math.floor(totalDays / 365);
    var mos = Math.floor((totalDays % 365) / 30);
    var dys = totalDays % 30;
    document.getElementById('cdYears').textContent = yrs;
    document.getElementById('cdMonths').textContent = mos;
    document.getElementById('cdDays').textContent = dys;
  }
  update();
  setInterval(update, 60000);
})();

// ── KEYBOARD: ESC closes modals/panels ──
document.addEventListener('keydown', function(e){
  if (e.key === 'Escape') {
    yearModal.classList.remove('show');
    advModal.classList.remove('show');
    closeFamilyDetail();
    closeMobileNav();
  }
});
