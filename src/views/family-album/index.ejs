<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= album.family_name || family.display_name %> — A Legacy Odyssey Family Album</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #F8F2E6;
  --ivory: #FFFCF5;
  --gold: #B8935A;
  --gold-light: #D4B483;
  --gold-dark: #8C6A35;
  --ink: #1E1812;
  --ink-mid: #4A3F32;
  --ink-light: #9C8B78;
  --sage: #7A9E7E;
  --rose: #C17F7F;
  --blush: #EDD9D0;
  --dusty-blue: #8BA7BC;
  --nav-width: 240px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Jost', sans-serif;
  background: var(--cream);
  color: var(--ink);
  line-height: 1.7;
  font-size: 16px;
  overflow: hidden;
  height: 100vh;
}

h1, h2, h3, h4, h5 {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 600;
  line-height: 1.3;
}

/* ── DEMO BANNER ── */
#demo-banner {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10000;
  background: #1a1510;
  color: #d4bb8a;
  text-align: center;
  padding: 0.55rem 1rem;
  font-family: 'Jost', sans-serif;
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  border-bottom: 2px solid #c8a96e;
  height: 44px;
}
#demo-banner a.demo-banner-cta {
  background: #c8a96e;
  color: #1a1510;
  text-decoration: none;
  padding: 0.3rem 0.85rem;
  border-radius: 3px;
  font-weight: 700;
  font-size: 0.82rem;
  letter-spacing: 0.06em;
  transition: background 0.2s;
  white-space: nowrap;
}
#demo-banner a.demo-banner-cta:hover { background: #d4bb8a; }

/* ── APP LAYOUT ── */
#app {
  height: 100vh;
  display: flex;
}
#app.has-banner {
  padding-top: 44px;
  height: 100vh;
}

/* ── SIDEBAR ── */
#sidebar {
  width: var(--nav-width);
  min-width: var(--nav-width);
  background: var(--ink);
  color: var(--cream);
  height: 100%;
  overflow-y: auto;
  padding: 2rem 0;
  display: flex;
  flex-direction: column;
}
#app.has-banner #sidebar {
  height: calc(100vh - 44px);
}
.sidebar-header {
  padding: 0 1.25rem 1.5rem;
  border-bottom: 1px solid rgba(184,147,90,0.2);
  margin-bottom: 1rem;
}
.sidebar-header h2 {
  font-size: 1.25rem;
  color: var(--gold);
  margin-bottom: 0.15rem;
}
.sidebar-header p {
  font-size: 0.72rem;
  color: var(--ink-light);
  text-transform: uppercase;
  letter-spacing: 0.12em;
}
.nav-group-label {
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--ink-light);
  padding: 1rem 1.25rem 0.4rem;
}
.nav-item {
  display: block;
  padding: 0.55rem 1.25rem;
  color: var(--cream);
  text-decoration: none;
  font-size: 0.88rem;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
  border-left: 3px solid transparent;
  user-select: none;
}
.nav-item:hover {
  background: rgba(184,147,90,0.1);
  color: var(--gold-light);
}
.nav-item.active {
  background: rgba(184,147,90,0.15);
  color: var(--gold);
  border-left-color: var(--gold);
}
.sidebar-footer {
  margin-top: auto;
  padding: 1.5rem 1.25rem 0;
  border-top: 1px solid rgba(184,147,90,0.15);
  font-size: 0.7rem;
  color: var(--ink-light);
  text-align: center;
  line-height: 1.5;
}
.sidebar-footer a { color: var(--gold-light); text-decoration: none; }

/* ── HAMBURGER ── */
#hamburger {
  display: none;
  position: fixed;
  top: 0.75rem;
  left: 1rem;
  z-index: 1001;
  background: var(--ink);
  border: none;
  color: var(--gold);
  width: 44px;
  height: 44px;
  border-radius: 8px;
  font-size: 1.4rem;
  cursor: pointer;
  align-items: center;
  justify-content: center;
}
#app.has-banner #hamburger { top: calc(44px + 0.5rem); }
#navOverlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
}
#navOverlay.show { display: block; }

/* ── MAIN CONTENT ── */
#main-content {
  flex: 1;
  overflow-y: auto;
  padding: 3rem 3.5rem 4rem;
  max-width: 900px;
}
.page-section { display: none; }
.page-section.active { display: block; }

/* ── TYPOGRAPHY ── */
.eyebrow {
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--gold);
  margin-bottom: 0.5rem;
}
.chapter-label {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--gold);
  margin-bottom: 0.3rem;
}
.section-title {
  font-size: 2.4rem;
  color: var(--ink);
  margin-bottom: 0.3rem;
}
.section-subtitle {
  font-size: 1.05rem;
  color: var(--ink-light);
  font-style: italic;
  margin-bottom: 2rem;
}
.section-divider {
  width: 50px;
  height: 2px;
  background: var(--gold);
  margin: 0 0 2rem;
}
.quote-block {
  border-left: 3px solid var(--gold);
  padding: 1.25rem 1.5rem;
  margin: 1.5rem 0;
  background: var(--ivory);
  border-radius: 0 8px 8px 0;
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.15rem;
  font-style: italic;
  color: var(--ink-mid);
  line-height: 1.7;
}
.quote-block .attribution {
  display: block;
  margin-top: 0.5rem;
  font-size: 0.9rem;
  font-style: normal;
  color: var(--ink-light);
}
.body-text {
  font-size: 1rem;
  color: var(--ink-mid);
  margin-bottom: 1.25rem;
  line-height: 1.8;
}
.subsection { margin-top: 2.5rem; }
.subsection h3 {
  font-size: 1.5rem;
  color: var(--ink);
  margin-bottom: 0.75rem;
}

/* ── STATS ROW ── */
.stats-row {
  display: flex;
  gap: 2rem;
  margin: 2.5rem 0;
  padding: 1.5rem 0;
  border-top: 1px solid rgba(184,147,90,0.25);
  border-bottom: 1px solid rgba(184,147,90,0.25);
  flex-wrap: wrap;
}
.stat-item { text-align: center; flex: 1; min-width: 100px; }
.stat-label {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--ink-light);
  margin-bottom: 0.3rem;
}
.stat-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem;
  font-weight: 600;
  color: var(--gold);
}

/* ── CHECKLIST ── */
.checklist {
  background: var(--ivory);
  border-radius: 12px;
  padding: 1.5rem 2rem;
  margin: 2rem 0;
  border: 1px solid rgba(184,147,90,0.15);
}
.checklist h4 { font-size: 1.1rem; margin-bottom: 1rem; color: var(--ink); }
.checklist-item { padding: 0.4rem 0; color: var(--ink-mid); font-size: 0.95rem; }
.checklist-item .check { color: var(--sage); margin-right: 0.5rem; font-weight: 600; }

/* ── IMAGE PLACEHOLDER ── */
.img-placeholder {
  width: 100%;
  height: 220px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
  margin: 1.5rem 0;
}

/* ── YEAR CARDS ── */
.year-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1.25rem;
  margin-top: 1.5rem;
}
.year-card {
  background: var(--ivory);
  border-radius: 12px;
  padding: 1.5rem;
  text-align: center;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  border: 1px solid rgba(184,147,90,0.12);
}
.year-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(30,24,18,0.1);
  border-color: var(--gold-light);
}
.year-card .year-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.4rem;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
  margin-bottom: 0.5rem;
}
.year-card .year-label { font-size: 0.95rem; font-weight: 500; color: var(--ink); margin-bottom: 0.3rem; }
.year-card .year-highlight { font-size: 0.82rem; color: var(--ink-light); font-style: italic; }

/* ── MODAL ── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(30,24,18,0.6);
  z-index: 2000;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}
.modal-overlay.show { display: flex; }
.modal-content {
  background: var(--cream);
  border-radius: 16px;
  max-width: 600px;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  padding: 2.5rem;
  position: relative;
}
.modal-close {
  position: absolute;
  top: 1rem;
  right: 1.25rem;
  background: none;
  border: none;
  font-size: 1.5rem;
  color: var(--ink-light);
  cursor: pointer;
  transition: color 0.2s;
}
.modal-close:hover { color: var(--ink); }
.modal-content .year-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 3rem;
  font-weight: 700;
  color: var(--gold);
  margin-bottom: 0.25rem;
}
.modal-content h3 { font-size: 1.5rem; margin-bottom: 0.5rem; }
.modal-content .highlight { color: var(--ink-light); font-style: italic; margin-bottom: 1.25rem; font-size: 0.95rem; }
.modal-content .note { color: var(--ink-mid); line-height: 1.8; }

/* ── FAMILY MEMBER CARDS ── */
.family-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1.25rem;
  margin-top: 1.5rem;
}
.family-card {
  background: var(--ivory);
  border-radius: 12px;
  padding: 1.5rem;
  text-align: center;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  border: 1px solid rgba(184,147,90,0.12);
}
.family-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(30,24,18,0.1);
  border-color: var(--gold-light);
}
.family-card .member-emoji { font-size: 3rem; margin-bottom: 0.75rem; display: block; }
.family-card .member-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 0.15rem;
}
.family-card .member-role { font-size: 0.82rem; color: var(--ink-light); text-transform: uppercase; letter-spacing: 0.08em; }

/* ── FAMILY DETAIL PANEL ── */
#family-detail {
  position: fixed;
  top: 0;
  right: -480px;
  width: 480px;
  max-width: 100vw;
  height: 100vh;
  background: var(--cream);
  z-index: 2000;
  overflow-y: auto;
  transition: right 0.4s cubic-bezier(0.4,0,0.2,1);
  box-shadow: -4px 0 24px rgba(30,24,18,0.15);
  padding: 2.5rem;
}
#family-detail.open { right: 0; }
#family-detail-overlay {
  position: fixed;
  inset: 0;
  background: rgba(30,24,18,0.5);
  z-index: 1999;
  display: none;
}
#family-detail-overlay.show { display: block; }
.detail-close {
  background: none;
  border: none;
  font-size: 1.5rem;
  color: var(--ink-light);
  cursor: pointer;
  margin-bottom: 1.5rem;
  transition: color 0.2s;
}
.detail-close:hover { color: var(--ink); }
.detail-emoji { font-size: 4rem; margin-bottom: 1rem; }
.detail-name { font-size: 1.8rem; margin-bottom: 0.15rem; }
.detail-role { font-size: 0.82rem; color: var(--ink-light); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem; }
.detail-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1.5rem; }
.meta-item { background: var(--ivory); border-radius: 8px; padding: 0.75rem 1rem; }
.meta-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-light); margin-bottom: 0.15rem; }
.meta-value { font-size: 0.9rem; color: var(--ink); }
.detail-story { color: var(--ink-mid); line-height: 1.8; margin-bottom: 1.25rem; }
.detail-quote {
  border-left: 3px solid var(--gold);
  padding: 1rem 1.25rem;
  margin: 1.25rem 0;
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.05rem;
  font-style: italic;
  color: var(--ink-mid);
  background: var(--ivory);
  border-radius: 0 8px 8px 0;
}

/* ── ADVENTURE CARDS ── */
.adventure-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.25rem;
  margin-top: 1.5rem;
}
.adventure-card {
  background: var(--ivory);
  border-radius: 12px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  border: 1px solid rgba(184,147,90,0.12);
}
.adventure-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(30,24,18,0.1);
  border-color: var(--gold-light);
}
.adventure-img { height: 140px; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; }
.adventure-body { padding: 1.25rem; }
.adventure-body h4 { font-size: 1.15rem; color: var(--ink); margin-bottom: 0.25rem; }
.adventure-body .adv-dest { font-size: 0.82rem; color: var(--gold); margin-bottom: 0.15rem; }
.adventure-body .adv-tagline { font-size: 0.88rem; color: var(--ink-light); font-style: italic; }

/* ── LETTER SECTION ── */
.letter-block {
  background: var(--ivory);
  border-radius: 12px;
  padding: 2.5rem;
  margin: 2rem 0;
  border: 1px solid rgba(184,147,90,0.15);
}
.letter-heading { font-size: 1.1rem; color: var(--gold); margin-bottom: 1.25rem; letter-spacing: 0.04em; }
.letter-body { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: var(--ink-mid); line-height: 2; }
.letter-body p { margin-bottom: 1rem; }

/* ── RECIPE CARDS ── */
.recipe-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.25rem;
  margin-top: 1.5rem;
}
.recipe-card {
  background: var(--ivory);
  border-radius: 12px;
  padding: 1.5rem;
  border: 1px solid rgba(184,147,90,0.12);
  transition: transform 0.2s, box-shadow 0.2s;
}
.recipe-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(30,24,18,0.1); }
.recipe-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--gold); margin-bottom: 0.4rem; }
.recipe-card h4 { font-size: 1.2rem; color: var(--ink); margin-bottom: 0.75rem; }
.recipe-note { font-size: 0.9rem; color: var(--ink-mid); font-style: italic; line-height: 1.7; margin-bottom: 1rem; }
.recipe-ingredients { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.recipe-ingredients span {
  background: var(--cream);
  padding: 0.25rem 0.65rem;
  border-radius: 20px;
  font-size: 0.78rem;
  color: var(--ink-mid);
}

/* ── VAULT ── */
.vault-container { text-align: center; padding: 3rem 0; }
.vault-icon { font-size: 5rem; margin-bottom: 1.5rem; }
.vault-box {
  background: var(--ivory);
  border: 2px solid var(--gold-light);
  border-radius: 16px;
  padding: 2.5rem;
  max-width: 500px;
  margin: 0 auto 2rem;
}
.countdown-row { display: flex; justify-content: center; gap: 2.5rem; margin: 2rem 0; }
.cd-unit { text-align: center; }
.cd-num { font-family: 'Cormorant Garamond', serif; font-size: 3rem; font-weight: 700; color: var(--gold); line-height: 1; }
.cd-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-light); margin-top: 0.3rem; }
.vault-sealed { font-size: 0.82rem; color: var(--ink-light); margin-top: 1rem; }

/* ── FOOTER ── */
.page-footer {
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(184,147,90,0.2);
  text-align: center;
  font-size: 0.82rem;
  color: var(--ink-light);
}
.page-footer a { color: var(--gold); text-decoration: none; }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  #sidebar {
    position: fixed;
    left: -280px;
    z-index: 1000;
    width: 280px;
    min-width: 280px;
    transition: left 0.35s cubic-bezier(0.4,0,0.2,1);
    height: 100vh;
  }
  #sidebar.open { left: 0; }
  #hamburger { display: flex; }
  #main-content { padding: 2rem 1.25rem 3rem; }
  .section-title { font-size: 1.8rem; }
  .stats-row { gap: 1rem; }
  .year-grid, .family-grid, .adventure-grid, .recipe-grid { grid-template-columns: 1fr 1fr; }
  .detail-meta { grid-template-columns: 1fr; }
  #family-detail { width: 100vw; right: -100vw; }
  .countdown-row { gap: 1.5rem; }
  .cd-num { font-size: 2.2rem; }
}
@media (max-width: 480px) {
  .year-grid, .family-grid, .adventure-grid, .recipe-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<%
const familyName = album.family_name || family.display_name || 'Our Family';
const established = album.established_year || '';
const hometown = album.hometown || '';
const welcomeQuote = album.welcome_quote || '';
const welcomeTexts = album.welcome_texts || [];
const stats = album.stats || [];
const ourStory = album.our_story || {};
const roots = album.roots || {};
const home = album.home || {};
const years = album.years || [];
const familyMembers = album.family_members || [];
const adventures = album.adventures || [];
const traditions = album.traditions || {};
const letters = album.letters || [];
const recipes = album.recipes || [];
const vault = album.vault || {};
const vaultStartYear = vault.family_start_year || established || new Date().getFullYear();
const vaultAnniversary = vault.anniversary_years || 25;
const vaultUnlockYear = vault.unlock_year || (parseInt(vaultStartYear) + parseInt(vaultAnniversary));
%>

<% if (isDemoDomain) { %>
<div id="demo-banner">
  <span>&#10022; This is a demo — create your own family album at Legacy Odyssey</span>
  <a href="https://www.legacyodyssey.com" target="_blank" class="demo-banner-cta">Get Your Own Album &rarr;</a>
</div>
<% } %>

<div id="app" class="<%= isDemoDomain ? 'has-banner' : '' %>">

  <!-- Hamburger -->
  <button id="hamburger">&#9776;</button>
  <div id="navOverlay"></div>

  <!-- Sidebar -->
  <nav id="sidebar">
    <div class="sidebar-header">
      <h2><%= familyName %></h2>
      <p>Family Album</p>
    </div>

    <div class="nav-group-label">The Album</div>
    <a class="nav-item active" data-page="page-welcome">&#127775; Welcome</a>
    <a class="nav-item" data-page="page-our-story">&#128145; Our Story</a>
    <a class="nav-item" data-page="page-roots">&#127758; Where We Come From</a>
    <a class="nav-item" data-page="page-home">&#127969; Our Home</a>
    <a class="nav-item" data-page="page-years">&#128197; Year by Year</a>

    <div class="nav-group-label">Family &amp; Moments</div>
    <a class="nav-item" data-page="page-family">&#128106; The Family</a>
    <a class="nav-item" data-page="page-adventures">&#9992;&#65039; Adventures</a>
    <a class="nav-item" data-page="page-traditions">&#127881; Traditions</a>
    <a class="nav-item" data-page="page-letters">&#128140; Letters</a>
    <a class="nav-item" data-page="page-recipes">&#127858; Family Recipes</a>

    <div class="nav-group-label">The Vault</div>
    <a class="nav-item" data-page="page-vault">&#128274; Time Capsule</a>

    <div class="sidebar-footer">
      <% if (isDemoDomain) { %>
      <p style="color:#d4bb8a;font-size:0.78rem;line-height:1.5;margin-bottom:0.6rem;">You're viewing a demo.<br>Create your own family album.</p>
      <a href="https://www.legacyodyssey.com" target="_blank" style="display:block;background:#c8a96e;color:#1a1510;text-decoration:none;padding:0.5rem 0.75rem;border-radius:3px;font-weight:700;font-size:0.82rem;text-align:center;letter-spacing:0.04em;">Get Your Own Album &rarr;</a>
      <% } else { %>
