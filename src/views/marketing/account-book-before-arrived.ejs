<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Before You Arrived – Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #faf7f2; color: #2c2416; min-height: 100vh; padding: 2rem 1rem 5rem; }
    .wrap { max-width: 680px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: #4a3f30; margin-bottom: 1.5rem; }
    .breadcrumb a { color: #c8a96e; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    h1 { font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 600; margin-bottom: 0.25rem; }
    .section-desc { color: #4a3f30; font-size: 0.92rem; margin-bottom: 2rem; }
    .flash { padding: 0.85rem 1.1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1.25rem; }
    .flash-success { background: #f0faf0; border: 1px solid #a8d5a8; color: #2e7d32; }
    .flash-error { background: #fdf2f2; border: 1px solid #e0b4b4; color: #c0392b; }
    label { font-size: 0.8rem; font-weight: 600; color: #4a3f30; text-transform: uppercase; letter-spacing: 0.04em; display: block; margin-bottom: 0.3rem; }
    input[type="text"] { padding: 0.65rem 0.85rem; border: 1.5px solid #e0d5c4; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.95rem; color: #2c2416; background: #fff; width: 100%; transition: border-color 0.2s; }
    input[type="text"]:focus { outline: none; border-color: #c8a96e; box-shadow: 0 0 0 3px rgba(200,169,110,0.12); }
    textarea { padding: 0.65rem 0.85rem; border: 1.5px solid #e0d5c4; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.95rem; color: #2c2416; background: #fff; width: 100%; min-height: 90px; resize: vertical; transition: border-color 0.2s; line-height: 1.6; }
    textarea:focus { outline: none; border-color: #c8a96e; box-shadow: 0 0 0 3px rgba(200,169,110,0.12); }

    /* Card item */
    .card-item {
      background: #fff;
      border-radius: 12px;
      border: 1px solid #f0ebe3;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      padding: 1.25rem;
      margin-bottom: 0.75rem;
      position: relative;
    }
    .card-item.sortable-ghost { opacity: 0.4; }
    .card-item.sortable-chosen { box-shadow: 0 4px 20px rgba(200,169,110,0.25); }
    .card-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
    .drag-handle { cursor: grab; color: #c8a96e; font-size: 1.1rem; line-height: 1; padding: 0.2rem; flex-shrink: 0; }
    .drag-handle:active { cursor: grabbing; }
    .card-num { font-size: 0.75rem; font-weight: 600; color: #b8a898; text-transform: uppercase; letter-spacing: 0.05em; flex: 1; }
    .card-delete { background: none; border: none; color: #c8a898; font-size: 1.1rem; cursor: pointer; padding: 0.2rem 0.4rem; border-radius: 4px; }
    .card-delete:hover { color: #c0392b; background: #fdf2f2; }
    .card-row { display: grid; grid-template-columns: 110px 1fr; gap: 0.85rem; }
    .card-fields { display: flex; flex-direction: column; gap: 0.75rem; }
    .field-group { display: flex; flex-direction: column; gap: 0.3rem; }

    /* Photo zone compact */
    .photo-zone-sm {
      border: 2px dashed #e0d5c4; border-radius: 8px;
      width: 110px; height: 110px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      cursor: pointer; transition: border-color 0.2s; overflow: hidden; position: relative; flex-shrink: 0;
    }
    .photo-zone-sm:hover { border-color: #c8a96e; background: #fdf9f3; }
    .photo-zone-sm.has-photo { border-style: solid; border-color: #c8a96e; }
    .photo-zone-sm img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .photo-zone-sm .hint { font-size: 0.7rem; color: #4a3f30; text-align: center; padding: 0 0.3rem; margin-top: 0.2rem; }
    .photo-zone-sm .hint strong { color: #c8a96e; }
    .photo-remove-sm {
      position: absolute; top: 0.25rem; right: 0.25rem;
      background: rgba(0,0,0,0.5); color: #fff;
      border: none; border-radius: 50%; width: 20px; height: 20px;
      font-size: 0.65rem; cursor: pointer; display: none; align-items: center; justify-content: center;
    }
    .photo-zone-sm.has-photo .photo-remove-sm { display: flex; }
    /* Rotate button — only shown when there's a photo */
    .photo-rotate-sm {
      position: absolute; top: 0.25rem; left: 0.25rem;
      background: rgba(0,0,0,0.5); color: #fff;
      border: none; border-radius: 50%; width: 20px; height: 20px;
      font-size: 0.7rem; cursor: pointer; display: none; align-items: center; justify-content: center;
      line-height: 1;
    }
    .photo-zone-sm.has-photo .photo-rotate-sm { display: flex; }
    .uploading-sm { font-size: 0.75rem; color: #c8a96e; margin-top: 0.25rem; display: none; text-align: center; }

    /* Make "remove card" unmistakable (was a faint ✕ that was easy to miss) */
    .card-delete {
      display: inline-flex; align-items: center; gap: 0.3rem;
      background: #fdf2f2; border: 1px solid #e8c4c4; color: #c0392b;
      font-size: 0.78rem; font-weight: 600; cursor: pointer;
      padding: 0.35rem 0.7rem; border-radius: 6px; font-family: 'Inter', sans-serif;
    }
    .card-delete:hover { background: #f8d7d7; color: #a93226; }

    /* Add card */
    .btn-add { display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; background: #fff; border: 2px dashed #c8a96e; border-radius: 10px; color: #c8a96e; font-family: 'Inter', sans-serif; font-size: 0.9rem; font-weight: 600; cursor: pointer; width: 100%; justify-content: center; transition: background 0.2s; margin-top: 0.5rem; }
    .btn-add:hover { background: #fdf9f3; }

    /* Save bar */
    .save-bar { position: sticky; bottom: 0; background: #faf7f2; border-top: 1px solid #e0d5c4; padding: 1rem 0; margin-top: 1.5rem; display: flex; gap: 1rem; align-items: center; }
    .btn-save { background: #c8a96e; color: #fff; border: none; border-radius: 8px; padding: 0.8rem 2rem; font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    .btn-save:hover { background: #b08e4a; }
    .btn-back { color: #4a3f30; text-decoration: none; font-size: 0.9rem; }
    .btn-back:hover { color: #2c2416; }
    .empty-state { text-align: center; padding: 2.5rem; background: #fff; border-radius: 12px; border: 1px dashed #e0d5c4; color: #4a3f30; font-size: 0.9rem; margin-bottom: 0.75rem; }

    /* Getting-Ready Checklist */
    .checklist-block { background: #fff; border: 1px solid #f0ebe3; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); padding: 1.25rem; margin-top: 1.5rem; }
    .checklist-title { font-family: 'Fraunces', serif; font-size: 1.25rem; font-weight: 600; margin-bottom: 0.2rem; }
    .checklist-desc { font-size: 0.82rem; color: #4a3f30; margin-bottom: 1rem; }
    .checklist-row { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.55rem; }
    .checklist-row .cl-check { width: 18px; height: 18px; accent-color: #c8a96e; flex-shrink: 0; cursor: pointer; }
    .checklist-row .cl-label { flex: 1; }
    .cl-del { background: none; border: none; color: #c8a898; font-size: 1rem; cursor: pointer; padding: 0.2rem 0.4rem; border-radius: 4px; flex-shrink: 0; }
    .cl-del:hover { color: #c0392b; background: #fdf2f2; }
  </style>
</head>
<body>
  <div class="wrap">

    <div class="breadcrumb">
      <a href="/account/dashboard">Account</a> &nbsp;/&nbsp;
      <a href="/account/book">My Book</a> &nbsp;/&nbsp;
      Before You Arrived
    </div>

    <h1>Before You Arrived</h1>
    <p class="section-desc">Pregnancy memories, the baby shower, the nursery, and the anticipation of arrival. Drag cards to reorder.</p>

    <% if (success) { %><div class="flash flash-success">✓ Saved successfully.</div><% } %>
    <% if (error) { %><div class="flash flash-error">Something went wrong. Please try again.</div><% } %>

    <form method="POST" action="/account/book/before-arrived" id="theForm">
      <input type="hidden" name="cards_json" id="cardsJson">
      <input type="hidden" name="checklist_json" id="checklistJson">

      <div id="cardsList">
        <% if (!cards || cards.length === 0) { %>
          <div class="empty-state" id="emptyState">No cards yet — click "Add Card" to get started.</div>
        <% } %>
        <% (cards || []).forEach(function(card, i) { %>
        <div class="card-item" data-id="<%= i %>">
          <div class="card-header">
            <span class="drag-handle">⠿</span>
            <span class="card-num">Card <%= i + 1 %></span>
            <button type="button" class="card-delete" onclick="deleteCard(this)" title="Remove this card">✕ Remove card</button>
          </div>
          <div class="card-row">
            <div>
              <div class="photo-zone-sm <%= card.photoUrl ? 'has-photo' : '' %>" onclick="triggerPhotoUpload(this)">
                <% if (card.photoUrl) { %>
                  <img src="<%= card.photoUrl %>" alt="">
                <% } else { %>
                  <img src="" alt="" style="display:none;">
                  <div style="font-size:1.3rem;">📷</div>
                  <div class="hint"><strong>Upload</strong></div>
                <% } %>
                <input type="hidden" class="photo-path" value="<%= card.photo_path || '' %>">
                <button type="button" class="photo-rotate-sm" onclick="rotatePhoto(event,this)" title="Rotate 90°">↻</button>
                <button type="button" class="photo-remove-sm" onclick="removeCardPhoto(event,this)">✕</button>
              </div>
              <div class="uploading-sm">Uploading…</div>
              <input type="file" accept="image/*" style="display:none" onchange="uploadCardPhoto(this)">
            <button type="button" class="rp-btn-trigger" onclick="repositionCard(this)">⤢ Reposition</button>
            </div>
            <div class="card-fields">
              <div class="field-group">
                <label>Title</label>
                <input type="text" class="card-title" value="<%= card.title || '' %>" placeholder="e.g. THE NURSERY">
              </div>
              <div class="field-group">
                <label>Subtitle</label>
                <input type="text" class="card-subtitle" value="<%= card.subtitle || '' %>" placeholder="e.g. Preparing Your Room">
              </div>
              <div class="field-group">
                <label>Story / Body</label>
                <textarea class="card-body" placeholder="Write the story for this card…"><%= card.body || '' %></textarea>
              </div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>

      <button type="button" class="btn-add" onclick="addCard()">+ Add Card</button>
      <button type="button" class="btn-add" onclick="document.getElementById('multiInput').click()" style="margin-top:0.4rem;">+ Add multiple photos</button>
      <input type="file" id="multiInput" accept="image/*" multiple style="display:none" onchange="addMultiplePhotos(this)">
      <div id="multiProgress" style="display:none; text-align:center; font-size:0.85rem; color:#c8a96e; margin-top:0.5rem;"></div>

      <!-- Getting-Ready Checklist (parity with the app's Before You Arrived screen) -->
      <div class="checklist-block">
        <h2 class="checklist-title">Getting-Ready Checklist</h2>
        <p class="checklist-desc">The little things you did to prepare. Check off what's done — shows as a checklist on your published book.</p>
        <div id="checklistList">
          <% (checklist || []).forEach(function(item) { %>
            <div class="checklist-row">
              <input type="checkbox" class="cl-check" <%= item.is_checked ? 'checked' : '' %>>
              <input type="text" class="cl-label" value="<%= item.label || '' %>" placeholder="e.g. Pack the hospital bag">
              <button type="button" class="cl-del" onclick="deleteChecklistItem(this)" title="Remove item">✕</button>
            </div>
          <% }); %>
        </div>
        <button type="button" class="btn-add" onclick="addChecklistItem()">+ Add Checklist Item</button>
      </div>

      <div class="save-bar">
        <button type="submit" class="btn-save">Save Changes</button>
        <a href="/account/book" class="btn-back">← Back to My Book</a>
      </div>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
  <script>
    // ── Sortable ────────────────────────────────────────────────────────────────
    const sortable = Sortable.create(document.getElementById('cardsList'), {
      handle: '.drag-handle',
      animation: 150,
      ghostClass: 'sortable-ghost',
      chosenClass: 'sortable-chosen',
    });

    // ── Renumber card headings after any change ─────────────────────────────────
    function renumber() {
      document.querySelectorAll('.card-item .card-num').forEach((el, i) => {
        el.textContent = 'Card ' + (i + 1);
      });
      const empty = document.getElementById('emptyState');
      if (empty) empty.style.display = document.querySelectorAll('.card-item').length ? 'none' : 'block';
    }

    // ── Build a blank card (shared by Add Card + multi-photo) ────────────────────
    function buildCard() {
      const empty = document.getElementById('emptyState');
      if (empty) empty.style.display = 'none';

      const div = document.createElement('div');
      div.className = 'card-item';
      div.innerHTML = `
        <div class="card-header">
          <span class="drag-handle">⠿</span>
          <span class="card-num">Card</span>
          <button type="button" class="card-delete" onclick="deleteCard(this)" title="Remove this card">✕ Remove card</button>
        </div>
        <div class="card-row">
          <div>
            <div class="photo-zone-sm" onclick="triggerPhotoUpload(this)">
              <img src="" alt="" style="display:none;">
              <div style="font-size:1.3rem;">📷</div>
              <div class="hint"><strong>Upload</strong></div>
              <input type="hidden" class="photo-path" value="">
              <button type="button" class="photo-rotate-sm" onclick="rotatePhoto(event,this)" title="Rotate 90°">↻</button>
              <button type="button" class="photo-remove-sm" onclick="removeCardPhoto(event,this)">✕</button>
            </div>
            <div class="uploading-sm">Uploading…</div>
            <input type="file" accept="image/*" style="display:none" onchange="uploadCardPhoto(this)">
            <button type="button" class="rp-btn-trigger" onclick="repositionCard(this)">⤢ Reposition</button>
          </div>
          <div class="card-fields">
            <div class="field-group">
              <label>Title</label>
              <input type="text" class="card-title" placeholder="e.g. THE NURSERY">
            </div>
            <div class="field-group">
              <label>Subtitle</label>
              <input type="text" class="card-subtitle" placeholder="e.g. Preparing Your Room">
            </div>
            <div class="field-group">
              <label>Story / Body</label>
              <textarea class="card-body" placeholder="Write the story for this card…"></textarea>
            </div>
          </div>
        </div>`;
      document.getElementById('cardsList').appendChild(div);
      renumber();
      return div;
    }

    // ── Add card ────────────────────────────────────────────────────────────────
    function addCard() { buildCard(); }

    // ── Add multiple photos: one card per file, then label after ─────────────────
    async function addMultiplePhotos(input) {
      if (!input.files || !input.files.length) return;
      let files = Array.from(input.files);
      if (files.length > 20) {
        alert('You can add up to 20 photos at a time. The first 20 will be added.');
        files = files.slice(0, 20);
      }
      const progress = document.getElementById('multiProgress');
      progress.style.display = 'block';
      let done = 0;
      for (const file of files) {
        progress.textContent = `Uploading ${done + 1} of ${files.length}…`;
        const card = buildCard();
        const zoneWrap = card.querySelector('.card-row > div');
        const zone = zoneWrap.querySelector('.photo-zone-sm');
        const uploadingEl = zoneWrap.querySelector('.uploading-sm');
        await uploadIntoZone(file, zone, uploadingEl);
        done++;
      }
      progress.textContent = `Added ${done} photo${done === 1 ? '' : 's'} — add titles below, then Save.`;
      setTimeout(() => { progress.style.display = 'none'; }, 4000);
      input.value = '';
    }

    // ── Shared: upload a single File into a given photo zone ─────────────────────
    async function uploadIntoZone(file, zone, uploadingEl) {
      uploadingEl.style.display = 'block';
      const fd = new FormData();
      fd.append('file', file);
      fd.append('section', 'before-arrived');
      try {
        const res = await fetch('/account/upload', { method: 'POST', body: fd });
        if (!res.ok) throw new Error();
        const data = await res.json();
        zone.querySelector('.photo-path').value = data.path;
        const img = zone.querySelector('img');
        img.src = data.url;
        img.style.display = 'block';
        zone.classList.add('has-photo');
        const icon = zone.querySelector('div[style*="font-size:1.3rem"]');
        if (icon) icon.style.display = 'none';
        const hint = zone.querySelector('.hint');
        if (hint) hint.style.display = 'none';
      } catch (e) {
        // leave the card blank so the user can retry that one
      } finally {
        uploadingEl.style.display = 'none';
      }
    }

    // ── Delete card ─────────────────────────────────────────────────────────────
    function deleteCard(btn) {
      btn.closest('.card-item').remove();
      renumber();
    }

    // ── Photo upload ────────────────────────────────────────────────────────────
    function triggerPhotoUpload(zone) {
      zone.parentElement.querySelector('input[type="file"]').click();
    }

    async function uploadCardPhoto(input) {
      if (!input.files || !input.files[0]) return;
      const cardRow = input.closest('.card-item').querySelector('.card-row > div');
      const zone = cardRow.querySelector('.photo-zone-sm');
      const uploadingEl = cardRow.querySelector('.uploading-sm');
      uploadingEl.style.display = 'block';

      const formData = new FormData();
      formData.append('file', input.files[0]);
      formData.append('section', 'before-arrived');
      try {
        const res = await fetch('/account/upload', { method: 'POST', body: formData });
        if (!res.ok) throw new Error();
        const data = await res.json();

        zone.querySelector('.photo-path').value = data.path;
        const img = zone.querySelector('img');
        img.src = data.url;
        img.style.display = 'block';
        zone.classList.add('has-photo');
        const icon = zone.querySelector('div[style*="font-size:1.3rem"]');
        if (icon) icon.style.display = 'none';
        const hint = zone.querySelector('.hint');
        if (hint) hint.style.display = 'none';
      } catch (e) {
        alert('Upload failed. Please try again.');
      } finally {
        uploadingEl.style.display = 'none';
        input.value = '';
      }
    }

    // ── Rotate photo 90° (client-side canvas → re-upload baked file) ─────────────
    // Bakes the rotation into a new JPEG so it renders correctly everywhere
    // (the website doesn't honor EXIF orientation). Supabase serves open CORS,
    // so we can read the cross-origin image into a canvas.
    async function rotatePhoto(e, btn) {
      e.stopPropagation();
      const zone = btn.closest('.photo-zone-sm');
      const img = zone.querySelector('img');
      const pathInput = zone.querySelector('.photo-path');
      const cardRow = zone.closest('.card-item').querySelector('.card-row > div');
      const uploadingEl = cardRow.querySelector('.uploading-sm');
      if (!img || !img.src || img.style.display === 'none') return;

      uploadingEl.textContent = 'Rotating…';
      uploadingEl.style.display = 'block';
      try {
        // Force a fresh CORS-enabled fetch (an already-cached non-CORS copy
        // would taint the canvas).
        const baseSrc = img.src.split('?')[0];
        const loader = new Image();
        loader.crossOrigin = 'anonymous';
        await new Promise((resolve, reject) => {
          loader.onload = resolve;
          loader.onerror = () => reject(new Error('load'));
          loader.src = baseSrc + '?cb=' + Date.now();
        });

        const canvas = document.createElement('canvas');
        canvas.width = loader.naturalHeight;   // swap dims for 90°
        canvas.height = loader.naturalWidth;
        const ctx = canvas.getContext('2d');
        ctx.translate(canvas.width / 2, canvas.height / 2);
        ctx.rotate(Math.PI / 2); // 90° clockwise
        ctx.drawImage(loader, -loader.naturalWidth / 2, -loader.naturalHeight / 2);

        const blob = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', 0.9));
        if (!blob) throw new Error('blob');

        const fd = new FormData();
        fd.append('file', blob, 'rotated.jpg');
        fd.append('section', 'before-arrived');
        const res = await fetch('/account/upload', { method: 'POST', body: fd });
        if (!res.ok) throw new Error('upload');
        const data = await res.json();

        pathInput.value = data.path;
        img.src = data.url + '?cb=' + Date.now();
      } catch (err) {
        alert('Could not rotate the photo. Please try again.');
      } finally {
        uploadingEl.style.display = 'none';
        uploadingEl.textContent = 'Uploading…';
      }
    }

    function removeCardPhoto(e, btn) {
      e.stopPropagation();
      const zone = btn.closest('.photo-zone-sm');
      zone.querySelector('.photo-path').value = '';
      const img = zone.querySelector('img');
      img.src = '';
      img.style.display = 'none';
      zone.classList.remove('has-photo');
      const icon = zone.querySelector('div[style*="font-size:1.3rem"]');
      if (icon) icon.style.display = 'block';
      const hint = zone.querySelector('.hint');
      if (hint) hint.style.display = 'block';
    }

    // ── Checklist add / delete ───────────────────────────────────────────────────
    function addChecklistItem() {
      const row = document.createElement('div');
      row.className = 'checklist-row';
      row.innerHTML =
        '<input type="checkbox" class="cl-check">' +
        '<input type="text" class="cl-label" placeholder="e.g. Pack the hospital bag">' +
        '<button type="button" class="cl-del" onclick="deleteChecklistItem(this)" title="Remove item">✕</button>';
      document.getElementById('checklistList').appendChild(row);
      row.querySelector('.cl-label').focus();
    }
    function deleteChecklistItem(btn) {
      btn.closest('.checklist-row').remove();
    }

    // ── Serialize on submit ──────────────────────────────────────────────────────
    document.getElementById('theForm').addEventListener('submit', function() {
      const cards = [];
      document.querySelectorAll('.card-item').forEach(el => {
        cards.push({
          title: el.querySelector('.card-title').value.trim(),
          subtitle: el.querySelector('.card-subtitle').value.trim() || null,
          body: el.querySelector('.card-body').value.trim() || null,
          photo_path: el.querySelector('.photo-path').value || null,
        });
      });
      document.getElementById('cardsJson').value = JSON.stringify(cards);

      const checklist = [];
      document.querySelectorAll('#checklistList .checklist-row').forEach(row => {
        const label = row.querySelector('.cl-label').value.trim();
        if (label) checklist.push({ label: label, is_checked: row.querySelector('.cl-check').checked });
      });
      document.getElementById('checklistJson').value = JSON.stringify(checklist);
    });

    renumber();
  </script>

  <%- include('_reposition-widget') %>
</body>
</html>
