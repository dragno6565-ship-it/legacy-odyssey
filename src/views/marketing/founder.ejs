  <script>
    // ---------- Domain availability check ----------
    const domainInput = document.getElementById('fdDomain');
    const checkBtn = document.getElementById('fdCheckBtn');
    const checkResult = document.getElementById('fdCheckResult');
    const submitBtn = document.getElementById('fdSubmit');
    let confirmedDomain = null;

    function sanitize(v) {
      return (v || '').toString().toLowerCase().trim().replace(/\.com$/i, '').replace(/[^a-z0-9-]/g, '');
    }

    async function checkDomain() {
      const raw = sanitize(domainInput.value);
      if (!raw || raw.length < 2) {
        checkResult.className = 'fd-form-check-result bad';
        checkResult.textContent = 'Enter at least 2 characters.';
        return;
      }
      domainInput.value = raw;
      checkResult.className = 'fd-form-check-result';
      checkResult.textContent = 'Checking…';
      submitBtn.disabled = true;
      confirmedDomain = null;
      try {
        const res = await fetch('/api/domains/search?name=' + encodeURIComponent(raw));
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Domain check failed.');
        const com = (data.results || []).find(r => r.tld === 'com');
        if (com && com.available) {
          confirmedDomain = com.domain;
          checkResult.className = 'fd-form-check-result ok';
          checkResult.textContent = '✓ ' + com.domain + ' is available.';
          submitBtn.disabled = false;
        } else {
          checkResult.className = 'fd-form-check-result bad';
          checkResult.textContent = '✗ ' + raw + '.com is taken. Try a variation (middle name, family name, nickname).';
          submitBtn.disabled = true;
        }
      } catch (err) {
        checkResult.className = 'fd-form-check-result bad';
        checkResult.textContent = err.message || 'Couldn\'t check that name.';
        submitBtn.disabled = true;
      }
    }

    checkBtn.addEventListener('click', checkDomain);
    domainInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); checkDomain(); }
    });
    domainInput.addEventListener('input', () => {
      // Any edit invalidates the previous check.
      if (confirmedDomain && sanitize(domainInput.value) !== sanitize(confirmedDomain.replace(/\.com$/, ''))) {
        confirmedDomain = null;
        submitBtn.disabled = true;
        checkResult.className = 'fd-form-check-result';
        checkResult.textContent = '';
      }
    });

    // ---------- Form submit → Stripe checkout ----------
    document.getElementById('fdForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorEl = document.getElementById('fdError');
      errorEl.textContent = '';

      const email = document.getElementById('fdEmail').value.trim();
      const founderNote = document.getElementById('fdNote').value.trim();
      if (!email) { errorEl.textContent = 'Please enter your email.'; return; }
      if (!confirmedDomain) { errorEl.textContent = 'Please check that your domain is available first.'; return; }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Processing…';
      try {
        const res = await fetch('/api/stripe/create-founder-page-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, domain: confirmedDomain, founderNote }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Something went wrong.');
        if (data.url) {
          window.location.href = data.url;
        } else {
          throw new Error('No checkout session URL returned.');
        }
      } catch (err) {
        errorEl.textContent = err.message;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Continue to checkout — $29/year';
      }
    });
  </script>
</body>
</html>
