<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Celebrations — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Jost', sans-serif; background: #faf7f2; color: #2c2416; min-height: 100vh; padding: 2rem 1rem 5rem; }
    .wrap { max-width: 760px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: #8a7e6b; margin-bottom: 1.5rem; }
    .breadcrumb a { color: #c8a96e; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    h1 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; margin-bottom: 0.25rem; }
    .section-desc { color: #8a7e6b; font-size: 0.92rem; margin-bottom: 2rem; }
    .flash { padding: 0.85rem 1.1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1.25rem; }
    .flash-success { background: #f0faf0; border: 1px solid #a8d5a8; color: #2e7d32; }
    .flash-error { background: #fdf2f2; border: 1px solid #e0b4b4; color: #c0392b; }

    .year-block { background: #fff; border-radius: 12px; border: 1px solid #f0ebe3; box-shadow: 0 2px 8px rgba(0,0,0,0.05); padding: 1.5rem; margin-bottom: 1.25rem; }
    .year-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
    .year-title { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: #2c2416; flex: 1; }
    .year-count { font-size: 0.75rem; color: #8a7e6b; letter-spacing: 0.04em; text-transform: uppercase; }
    .year-delete { background: none; border: 1px solid #e0d5c4; color: #8a7e6b; font-size: 0.75rem; padding: 0.35rem 0.7rem; border-radius: 6px; cursor: pointer; transition: all 0.15s; }
    .year-delete:hover { color: #c0392b; border-color: #e0b4b4; background: #fdf2f2; }
    .year-edit { background: none; border: 1px solid #e0d5c4; color: #8a7e6b; font-size: 0.75rem; padding: 0.35rem 0.7rem; border-radius: 6px; cursor: pointer; transition: all 0.15s; }
    .year-edit:hover { color: #c8a96e; border-color: #c8a96e; background: #fdf9f3; }
    .year-rename-form { display: flex; gap: 0.5rem; align-items: center; margin: -0.4rem 0 1rem; }
    .year-rename-form input[type="text"] { padding: 0.45rem 0.7rem; border: 1.5px solid #c8a96e; border-radius: 6px; font-family: 'Jost', sans-serif; font-size: 0.95rem; }
    .btn-rename-save { background: #c8a96e; color: #fff; border: none; padding: 0.45rem 0.9rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; cursor: pointer; font-family: 'Jost', sans-serif; }
    .btn-rename-cancel { background: none; border: 1px solid #e0d5c4; color: #8a7e6b; padding: 0.45rem 0.8rem; border-radius: 6px; font-size: 0.8rem; cursor: pointer; font-family: 'Jost', sans-serif; }

    .celebration-row {
      display: flex; align-items: center; gap: 1rem;
      padding: 0.85rem 1rem; background: #faf7f2; border-radius: 8px; margin-bottom: 0.5rem;
      text-decoration: none; color: inherit; transition: background 0.15s;
    }
    .celebration-row:hover { background: #f3eddf; }
    .celebration-thumb { width: 56px; height: 56px; border-radius: 6px; background: #ece4d6; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
    .celebration-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .celebration-thumb-empty { color: #c8a96e; font-size: 1.4rem; }
    .celebration-info { flex: 1; min-width: 0; }
    .celebration-title { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600; color: #2c2416; line-height: 1.3; }
    .celebration-meta { font-size: 0.78rem; color: #8a7e6b; margin-top: 0.15rem; }
    .celebration-meta .dot { margin: 0 0.4em; opacity: 0.5; }
    .celebration-chevron { color: #c8a96e; font-size: 1.3rem; flex-shrink: 0; }

    .add-celebration-form { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
    .add-celebration-form input[type="text"] { flex: 1; padding: 0.55rem 0.85rem; border: 1.5px solid #e0d5c4; border-radius: 8px; font-family: 'Jost', sans-serif; font-size: 0.92rem; background: #fff; }
    .add-celebration-form input[type="text"]:focus { outline: none; border-color: #c8a96e; box-shadow: 0 0 0 3px rgba(200,169,110,0.12); }
    .btn-add-celeb { background: #c8a96e; color: #fff; border: none; padding: 0.55rem 1rem; border-radius: 8px; font-family: 'Jost', sans-serif; font-size: 0.9rem; font-weight: 600; cursor: pointer; }
    .btn-add-celeb:hover { background: #b08e4a; }

    .empty-state-year { text-align: center; padding: 1.5rem; color: #8a7e6b; font-size: 0.88rem; font-style: italic; }

    .add-year-card { background: #fff; border: 2px dashed #c8a96e; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.25rem; }
    .add-year-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600; color: #c8a96e; margin-bottom: 0.5rem; }
    .add-year-card p { font-size: 0.85rem; color: #8a7e6b; margin-bottom: 0.85rem; }
    .add-year-form { display: flex; gap: 0.5rem; }
    .add-year-form input[type="text"] { flex: 1; padding: 0.55rem 0.85rem; border: 1.5px solid #e0d5c4; border-radius: 8px; font-family: 'Jost', sans-serif; font-size: 0.95rem; background: #fff; }
    .add-year-form input[type="text"]:focus { outline: none; border-color: #c8a96e; box-shadow: 0 0 0 3px rgba(200,169,110,0.12); }
    .btn-add-year { background: #c8a96e; color: #fff; border: none; padding: 0.55rem 1.25rem; border-radius: 8px; font-family: 'Jost', sans-serif; font-size: 0.95rem; font-weight: 600; cursor: pointer; }
    .btn-add-year:hover { background: #b08e4a; }

    .footer-actions { margin-top: 2rem; }
    .btn-back { color: #8a7e6b; text-decoration: none; font-size: 0.9rem; }
    .btn-back:hover { color: #2c2416; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="breadcrumb">
      <a href="/account/dashboard">Account</a> &nbsp;/&nbsp;
      <a href="/account/book">My Book</a> &nbsp;/&nbsp;
      Celebrations
    </div>

    <h1>Celebrations</h1>
    <p class="section-desc">Holidays, birthdays, traditions — and the photos and stories that go with them. Organized by year, with as many celebrations per year as you want.</p>

    <% if (success) { %><div class="flash flash-success">✓ Saved.</div><% } %>
    <% if (error) { %><div class="flash flash-error">Something went wrong (<%= error %>).</div><% } %>

    <% years.forEach(function(year) { %>
      <div class="year-block">
        <div class="year-header">
          <div class="year-title"><%= year.label %></div>
          <span class="year-count"><%= year.celebrations.length %> celebration<%= year.celebrations.length === 1 ? '' : 's' %></span>
          <button type="button" class="year-edit" onclick="startRenameYear(this)">Rename</button>
          <% if (years.length > 1) { %>
            <form method="POST" action="/account/book/celebrations/year/delete"
                  onsubmit="return confirm('Delete \'<%= year.label %>\' and all <%= year.celebrations.length %> celebration(s) inside it? This cannot be undone.');"
                  style="display:inline;">
              <input type="hidden" name="label" value="<%= year.label %>">
              <button type="submit" class="year-delete">Delete year</button>
            </form>
          <% } %>
        </div>
        <form method="POST" action="/account/book/celebrations/year/edit" class="year-rename-form" style="display:none;">
          <input type="hidden" name="old_label" value="<%= year.label %>">
          <input type="text" name="new_label" value="<%= year.label %>" placeholder="e.g. 2025" required>
          <button type="submit" class="btn-rename-save">Save</button>
          <button type="button" class="btn-rename-cancel" onclick="cancelRenameYear(this)">Cancel</button>
        </form>

        <% if (year.celebrations.length === 0) { %>
          <div class="empty-state-year">No celebrations in this year yet.</div>
        <% } %>

        <% year.celebrations.forEach(function(c) { %>
          <a class="celebration-row" href="/account/book/celebrations/edit/<%= c.id %>">
            <div class="celebration-thumb">
              <% if (c.photoUrl) { %>
                <img src="<%= c.photoUrl %>" alt="">
              <% } else { %>
                <span class="celebration-thumb-empty">🎉</span>
              <% } %>
            </div>
            <div class="celebration-info">
              <div class="celebration-title"><%= c.title || 'Untitled' %></div>
              <div class="celebration-meta">
                <% if (c.eyebrow) { %><%= c.eyebrow %><span class="dot">·</span><% } %>
                <%= c.photo_count %> photo<%= c.photo_count === 1 ? '' : 's' %>
                <% if (c.body) { %><span class="dot">·</span>Has story<% } %>
              </div>
            </div>
            <div class="celebration-chevron">›</div>
          </a>
        <% }); %>

        <form method="POST" action="/account/book/celebrations/new" class="add-celebration-form">
          <input type="hidden" name="year_label" value="<%= year.label %>">
          <input type="text" name="title" placeholder="Add a celebration (e.g. First Christmas)" required>
          <button type="submit" class="btn-add-celeb">+ Add</button>
        </form>
      </div>
    <% }); %>

    <div class="add-year-card">
      <h3>Add another year</h3>
      <p>Use the actual year — "2025", "2026" — or a custom label like "Toddler years."</p>
      <form method="POST" action="/account/book/celebrations/year/add" class="add-year-form">
        <input type="text" name="label" placeholder="e.g. 2026" required>
        <button type="submit" class="btn-add-year">+ Add year</button>
      </form>
    </div>

    <div class="footer-actions">
      <a class="btn-back" href="/account/book">← Back to my book</a>
    </div>
  </div>

  <script>
    // Rename a year: swap the title row for the inline rename form.
    function startRenameYear(btn) {
      var header = btn.closest('.year-header');
      var form = header.nextElementSibling; // the .year-rename-form
      header.style.display = 'none';
      form.style.display = 'flex';
      var input = form.querySelector('input[name="new_label"]');
      input.focus(); input.select();
    }
    function cancelRenameYear(btn) {
      var form = btn.closest('.year-rename-form');
      var header = form.previousElementSibling; // the .year-header
      form.style.display = 'none';
      header.style.display = 'flex';
    }
  </script>
</body>
</html>
