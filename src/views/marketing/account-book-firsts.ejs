<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Firsts – Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Jost', sans-serif; background: #faf7f2; color: #2c2416; min-height: 100vh; padding: 2rem 1rem 5rem; }
    .wrap { max-width: 680px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: #8a7e6b; margin-bottom: 1.5rem; }
    .breadcrumb a { color: #c8a96e; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    h1 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; margin-bottom: 0.25rem; }
    .section-desc { color: #8a7e6b; font-size: 0.92rem; margin-bottom: 2rem; }
    .flash { padding: 0.85rem 1.1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1.25rem; }
    .flash-success { background: #f0faf0; border: 1px solid #a8d5a8; color: #2e7d32; }
    .flash-error { background: #fdf2f2; border: 1px solid #e0b4b4; color: #c0392b; }
    label { font-size: 0.8rem; font-weight: 600; color: #8a7e6b; text-transform: uppercase; letter-spacing: 0.04em; display: block; margin-bottom: 0.3rem; }
    input[type="text"] { padding: 0.6rem 0.8rem; border: 1.5px solid #e0d5c4; border-radius: 8px; font-family: 'Jost', sans-serif; font-size: 0.9rem; color: #2c2416; background: #fff; width: 100%; transition: border-color 0.2s; }
    input[type="text"]:focus { outline: none; border-color: #c8a96e; box-shadow: 0 0 0 3px rgba(200,169,110,0.12); }
    textarea { padding: 0.6rem 0.8rem; border: 1.5px solid #e0d5c4; border-radius: 8px; font-family: 'Jost', sans-serif; font-size: 0.9rem; color: #2c2416; background: #fff; width: 100%; min-height: 70px; resize: vertical; transition: border-color 0.2s; line-height: 1.6; }
    textarea:focus { outline: none; border-color: #c8a96e; box-shadow: 0 0 0 3px rgba(200,169,110,0.12); }

    /* First item */
    .first-item {
      background: #fff;
      border-radius: 12px;
      border: 1px solid #f0ebe3;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      padding: 1.1rem 1.25rem;
      margin-bottom: 0.6rem;
    }
    .first-item.sortable-ghost { opacity: 0.4; }
    .first-item.sortable-chosen { box-shadow: 0 4px 20px rgba(200,169,110,0.2); }
    .first-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.85rem; }
    .drag-handle { cursor: grab; color: #c8a96e; font-size: 1.1rem; flex-shrink: 0; }
    .drag-handle:active { cursor: grabbing; }
    .first-main { display: grid; grid-template-columns: 60px 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem; }
    .first-delete { background: none; border: none; color: #c8a898; font-size: 1.1rem; cursor: pointer; padding: 0.1rem 0.3rem; border-radius: 4px; margin-left: auto; }
    .first-delete:hover { color: #c0392b; background: #fdf2f2; }

    /* Add first */
    .btn-add { display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; background: #fff; border: 2px dashed #c8a96e; border-radius: 10px; color: #c8a96e; font-family: 'Jost', sans-serif; font-size: 0.9rem; font-weight: 600; cursor: pointer; width: 100%; justify-content: center; transition: background 0.2s; margin-top: 0.5rem; }
    .btn-add:hover { background: #fdf9f3; }

    /* Save bar */
    .save-bar { position: sticky; bottom: 0; background: #faf7f2; border-top: 1px solid #e0d5c4; padding: 1rem 0; margin-top: 1.5rem; display: flex; gap: 1rem; align-items: center; }
    .btn-save { background: #c8a96e; color: #fff; border: none; border-radius: 8px; padding: 0.8rem 2rem; font-family: 'Jost', sans-serif; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    .btn-save:hover { background: #b08e4a; }
    .btn-back { color: #8a7e6b; text-decoration: none; font-size: 0.9rem; }
    .btn-back:hover { color: #2c2416; }
    .empty-state { text-align: center; padding: 2.5rem; background: #fff; border-radius: 12px; border: 1px dashed #e0d5c4; color: #8a7e6b; font-size: 0.9rem; margin-bottom: 0.75rem; }

    @media (max-width: 480px) { .first-main { grid-template-columns: 50px 1fr; } .first-main > div:last-child { grid-column: 1 / -1; } }
  </style>
</head>
<body>
  <div class="wrap">

    <div class="breadcrumb">
      <a href="/account/dashboard">Account</a> &nbsp;/&nbsp;
      <a href="/account/book">My Book</a> &nbsp;/&nbsp;
      Your Firsts
    </div>

    <h1>Your Firsts</h1>
    <p class="section-desc">First smile, first word, first steps and more. Drag to reorder.</p>

    <% if (success) { %><div class="flash flash-success">✓ Saved successfully.</div><% } %>
    <% if (error) { %><div class="flash flash-error">Something went wrong. Please try again.</div><% } %>

    <form method="POST" action="/account/book/firsts" id="firstsForm">
      <input type="hidden" name="firsts_json" id="firstsJson">

      <div id="firstsList">
        <% if (!firsts || firsts.length === 0) { %>
          <div class="empty-state" id="emptyState">No firsts yet — click "Add First" to get started.</div>
        <% } %>
        <% (firsts || []).forEach(function(f, i) { %>
        <div class="first-item">
          <div class="first-header">
            <span class="drag-handle">⠿</span>
            <button type="button" class="first-delete" onclick="deleteFirst(this)" title="Remove">✕</button>
          </div>
          <div class="first-main">
            <div>
              <label>Emoji</label>
              <input type="text" class="first-emoji" value="<%= f.emoji || '⭐' %>" placeholder="⭐" style="text-align:center;">
            </div>
            <div>
              <label>Title</label>
              <input type="text" class="first-title" value="<%= f.title || '' %>" placeholder="e.g. First Real Smile">
            </div>
            <div>
              <label>Date / Age</label>
              <input type="text" class="first-date" value="<%= f.date_text || '' %>" placeholder="e.g. 6 weeks old">
            </div>
          </div>
          <div>
            <label>Notes</label>
            <textarea class="first-note" placeholder="Tell the story of this first…"><%= f.note || '' %></textarea>
          </div>
        </div>
        <% }); %>
      </div>

      <button type="button" class="btn-add" onclick="addFirst()">+ Add First</button>

      <div class="save-bar">
        <button type="submit" class="btn-save">Save Changes</button>
        <a href="/account/book" class="btn-back">← Back to My Book</a>
      </div>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
  <script>
    Sortable.create(document.getElementById('firstsList'), {
      handle: '.drag-handle',
      animation: 150,
      ghostClass: 'sortable-ghost',
      chosenClass: 'sortable-chosen',
    });

    function addFirst() {
      const empty = document.getElementById('emptyState');
      if (empty) empty.style.display = 'none';

      const div = document.createElement('div');
      div.className = 'first-item';
      div.innerHTML = `
        <div class="first-header">
          <span class="drag-handle">⠿</span>
          <button type="button" class="first-delete" onclick="deleteFirst(this)" title="Remove">✕</button>
        </div>
        <div class="first-main">
          <div>
            <label>Emoji</label>
            <input type="text" class="first-emoji" value="⭐" placeholder="⭐" style="text-align:center;">
          </div>
          <div>
            <label>Title</label>
            <input type="text" class="first-title" placeholder="e.g. First Real Smile">
          </div>
          <div>
            <label>Date / Age</label>
            <input type="text" class="first-date" placeholder="e.g. 6 weeks old">
          </div>
        </div>
        <div>
          <label>Notes</label>
          <textarea class="first-note" placeholder="Tell the story of this first…"></textarea>
        </div>`;
      document.getElementById('firstsList').appendChild(div);
    }

    function deleteFirst(btn) {
      btn.closest('.first-item').remove();
      const empty = document.getElementById('emptyState');
      if (empty && !document.querySelectorAll('.first-item').length) {
        empty.style.display = 'block';
      }
    }

    document.getElementById('firstsForm').addEventListener('submit', function() {
      const firsts = [];
      document.querySelectorAll('.first-item').forEach(el => {
        firsts.push({
          emoji: el.querySelector('.first-emoji').value.trim() || '⭐',
          title: el.querySelector('.first-title').value.trim(),
          date_text: el.querySelector('.first-date').value.trim() || null,
          note: el.querySelector('.first-note').value.trim() || null,
        });
      });
      document.getElementById('firstsJson').value = JSON.stringify(firsts);
    });
  </script>
</body>
</html>
