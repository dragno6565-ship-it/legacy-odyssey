</head>
<body>
  <div class="wrap">

    <div class="header">
      <h1>My Account</h1>
      <a href="/account/logout" class="logout-link">Sign out</a>
    </div>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <% if (family) { %>

    <!-- My Book -->
    <a href="/account/book" style="text-decoration:none;">
      <div class="card" style="border: 1.5px solid #c8a96e; cursor: pointer; transition: box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='0 2px 16px rgba(0,0,0,0.06)'">
        <h2 style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
          <span>📖</span> My Book
        </h2>
        <p style="font-size:0.88rem;color:#8a7e6b;line-height:1.5;">Edit your child's story — photos, milestones, birth story, and more.</p>
        <span style="display:inline-block;margin-top:0.85rem;font-size:0.88rem;font-weight:600;color:#c8a96e;">Open Book Editor →</span>
      </div>
    </a>

    <!-- Account Info -->
    <div class="card">
      <h2>Account Details</h2>
      <div class="info-row">
        <span class="info-label">Name</span>
        <span class="info-value"><%= family.display_name || '—' %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Email</span>
        <span class="info-value"><%= family.email %></span>
      </div>
    </div>

    <!-- Subscription -->
    <div class="card">
      <h2>Subscription & Billing</h2>
      <div class="info-row">
        <span class="info-label">Status</span>
        <span class="info-value">
          <%
            const status = family.subscription_status || 'unknown';
            let badgeClass = 'badge-other';
            let statusLabel = status.charAt(0).toUpperCase() + status.slice(1);
            if (status === 'active') badgeClass = 'badge-active';
            else if (status === 'trialing') { badgeClass = 'badge-trialing'; statusLabel = 'Free Trial'; }
            else if (status === 'canceled' || status === 'cancelled') { badgeClass = 'badge-cancelled'; statusLabel = 'Cancelled'; }
          %>
          <span class="badge <%= badgeClass %>"><%= statusLabel %></span>
        </span>
      </div>
      <% if (family.billing_period) { %>
      <div class="info-row">
        <span class="info-label">Plan</span>
        <span class="info-value"><%= family.billing_period.charAt(0).toUpperCase() + family.billing_period.slice(1) %></span>
      </div>
      <% } %>

      <% if (family.stripe_customer_id) { %>
        <form method="POST" action="/account/portal">
          <button type="submit" class="btn-gold">Manage Subscription</button>
        </form>
        <p class="portal-note">Update your payment method or view invoices.</p>

        <% if (family.subscription_status !== 'canceled' && !family.archived_at) { %>
          <hr style="margin:24px 0;border:none;border-top:1px solid #e8e0d0;">
          <% if (typeof linkedFamilies !== 'undefined' && linkedFamilies && linkedFamilies.length > 1) { %>
            <!-- Multi-site customer: show Cancel This Site + Cancel All buttons -->
            <% if (typeof isPrimary !== 'undefined' && isPrimary) { %>
              <p style="font-size:14px;color:#4a4a5a;margin:0 0 12px;">
                This is your <strong>Primary site</strong>. To cancel just this one, you'll need to promote another site to be your new Primary. Or cancel everything at once.
              </p>
              <form method="POST" action="/account/cancel" onsubmit="return confirmPrimaryCancel(this);" style="display:inline-block;margin-right:8px;">
                <select name="promoteFamilyId" id="promoteSelect" style="padding:10px;border-radius:6px;border:1px solid #e0d5c4;margin-right:8px;">
                  <option value="">— Promote which site? —</option>
                  <% linkedFamilies.filter(f => f.id !== family.id && !f.archived_at).forEach(function(f) { %>
                    <option value="<%= f.id %>"><%= f.display_name || f.subdomain || f.email %><% if (f.custom_domain) { %> (<%= f.custom_domain %>)<% } %></option>
                  <% }) %>
                </select>
                <button type="submit" class="btn-cancel-secondary">Promote & Cancel This Site</button>
              </form>
              <form method="POST" action="/account/cancel" onsubmit="return confirmCancelAll(this);" style="display:inline-block;">
                <input type="hidden" name="all" value="true">
                <button type="submit" class="btn-cancel-danger">Cancel All <%= linkedFamilies.filter(f => !f.archived_at).length %> Sites</button>
              </form>
            <% } else { %>
              <p style="font-size:14px;color:#4a4a5a;margin:0 0 12px;">This site is one of your additional Legacy Odyssey sites. You can cancel it without affecting your Primary site.</p>
              <form method="POST" action="/account/cancel" onsubmit="return confirm('Cancel this site? You will keep access until your next renewal date, then this book goes offline. Your photos are saved for 1 year.');" style="display:inline-block;">
                <button type="submit" class="btn-cancel-secondary">Cancel This Site</button>
              </form>
            <% } %>
          <% } else { %>
            <!-- Single-site customer: simple Cancel button -->
            <form method="POST" action="/account/cancel" onsubmit="return confirm('Cancel your Legacy Odyssey subscription?\n\n• You keep access until your next renewal date\n• Your photos and stories are preserved for 1 year\n• Your custom domain auto-renewal stops\n• You can reactivate anytime within 1 year');">
              <button type="submit" class="btn-cancel-secondary">Cancel My Subscription</button>
            </form>
          <% } %>
          <p class="portal-note" style="margin-top:8px;">
            You will not be charged anything to cancel. Photos and stories are saved for 1 year.
          </p>
        <% } else { %>
          <p class="portal-note" style="color:#c0392b;"><strong>Cancelled.</strong> Your subscription is no longer active.</p>
        <% } %>
      <% } else { %>
        <a href="https://<%= appDomain %>/#pricing" class="btn-gold">View Plans</a>
        <p class="portal-note">You're on a free trial. Visit our pricing page to subscribe.</p>
      <% } %>
    </div>

    <% } %>

    <div class="footer">
      <a href="https://legacyodyssey.com">← Back to Legacy Odyssey</a>
      &nbsp;·&nbsp;
      <a href="mailto:hello@legacyodyssey.com">Contact Support</a>
    </div>

  </div>
</body>
</html>
