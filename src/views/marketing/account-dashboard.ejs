<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Pinterest Domain Verification -->
  <meta name="p:domain_verify" content="b146e195f22b09a16cdab391ec6f75c1"/>
  <title>My Account – Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #faf7f2;
      color: #2c2416;
      min-height: 100vh;
      padding: 2rem 1rem;
    }
    .wrap {
      max-width: 560px;
      margin: 0 auto;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }
    .header h1 {
      font-family: 'Fraunces', serif;
      font-size: 1.8rem;
      font-weight: 600;
    }
    .logout-link {
      font-size: 0.85rem;
      color: #4a3f30;
      text-decoration: none;
    }
    .logout-link:hover { color: #c0392b; }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.06);
      padding: 1.75rem;
      margin-bottom: 1.25rem;
    }
    .card h2 {
      font-family: 'Fraunces', serif;
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: #2c2416;
    }
    .info-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.6rem 0;
      border-bottom: 1px solid #f0ebe3;
      font-size: 0.95rem;
    }
    .info-row:last-child { border-bottom: none; }
    .info-label { color: #4a3f30; }
    .info-value { font-weight: 500; }
    .badge {
      display: inline-block;
      padding: 0.2rem 0.65rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
    }
    .badge-active { background: #e8f5e9; color: #2e7d32; }
    .badge-trialing { background: #fff8e1; color: #f57f17; }
    .badge-cancelled { background: #fdecea; color: #c0392b; }
    .badge-other { background: #f0ebe3; color: #6b5f4f; }
    .error {
      background: #fdf2f2;
      border: 1px solid #e0b4b4;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-size: 0.88rem;
      color: #c0392b;
      margin-bottom: 1.25rem;
    }
    .btn-gold {
      display: inline-block;
      padding: 0.75rem 1.75rem;
      background: #c8a96e;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s;
      margin-top: 1rem;
    }
    .btn-gold:hover { background: #b08e4a; }
    .portal-note {
      font-size: 0.82rem;
      color: #4a3f30;
      margin-top: 0.6rem;
      line-height: 1.5;
    }
    .footer {
      text-align: center;
      margin-top: 2rem;
      font-size: 0.82rem;
      color: #4a3f30;
    }
    .footer a { color: #c8a96e; text-decoration: none; }

    /* Cancel buttons */
    .btn-cancel-secondary {
      background: #fff;
      color: #c0392b;
      border: 1px solid #c0392b;
      padding: 0.7rem 1.4rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      margin-top: 0.4rem;
    }
    .btn-cancel-secondary:hover { background: #fdecea; }
    .btn-cancel-danger {
      background: #c0392b;
      color: #fff;
      border: none;
      padding: 0.7rem 1.4rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      margin-top: 0.4rem;
    }
    .btn-cancel-danger:hover { background: #a02818; }
  </style>

  <script>
    function confirmPrimaryCancel(form) {
      const sel = form.querySelector('#promoteSelect') || document.getElementById('promoteSelect');
      const promoteId = sel?.value;
      if (!promoteId) { alert('Please choose a site to promote to Primary first.'); return false; }
      const promoteName = sel.options[sel.selectedIndex].text;
      return confirm('Confirm:\n\n• This Primary site will cancel at your next renewal\n• ' + promoteName + ' will become your new Primary\n• Its billing stays at the current rate until this Primary\'s renewal date, then switches to the Primary rate\n• You will not be charged anything today\n\nProceed?');
    }
    function confirmCancelAll(form) {
      return confirm('Cancel ALL of your Legacy Odyssey sites?\n\n• Each site keeps access until its own next renewal date\n• Photos and stories are preserved for 1 year on all sites\n• Custom domain auto-renewals are turned off\n• You will not be charged anything today\n\nProceed?');
    }
  </script>

  <!-- Analytics & ads with EU/UK consent gating (G1) — shared partial -->
  <%- include('../partials/tracking') %>
</head>
<body>
  <div class="wrap">

    <div class="header">
      <h1>My Account</h1>
      <a href="/account/logout" class="logout-link">Sign out</a>
    </div>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <% if (family) { %>

    <!-- My Book -->
    <a href="/account/book" style="text-decoration:none;">
      <div class="card" style="border: 1.5px solid #c8a96e; cursor: pointer; transition: box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='0 2px 16px rgba(0,0,0,0.06)'">
        <h2 style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
          <span>📖</span> My Book
        </h2>
        <p style="font-size:0.88rem;color:#4a3f30;line-height:1.5;">Edit your child's story — photos, milestones, birth story, and more.</p>
        <span style="display:inline-block;margin-top:0.85rem;font-size:0.88rem;font-weight:600;color:#c8a96e;">Open Book Editor →</span>
      </div>
    </a>

    <!-- Contact (Contact List + Circles) -->
    <a href="/account/book/circles" style="text-decoration:none;">
      <div class="card" style="border: 1.5px solid #c8a96e; cursor: pointer; transition: box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='0 2px 16px rgba(0,0,0,0.06)'">
        <h2 style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
          <span style="display:inline-flex;color:#c8a96e;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
          Contact
          <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;color:#1a1510;background:#e7d3a6;padding:0.2rem 0.5rem;border-radius:6px;margin-left:auto;">New</span>
        </h2>
        <p style="font-size:0.88rem;color:#4a3f30;line-height:1.5;">Your Contact List and Circles — choose who can see the book, and tell them when there's something new.</p>
        <span style="display:inline-block;margin-top:0.85rem;font-size:0.88rem;font-weight:600;color:#c8a96e;">Open Contact →</span>
      </div>
    </a>

    <!-- Account Info -->
    <div class="card">
      <h2>Account Details</h2>
      <div class="info-row">
        <span class="info-label">Name</span>
        <span class="info-value"><%= family.display_name || '—' %></span>
      </div>
      <div class="info-row">
        <span class="info-label">Email</span>
        <span class="info-value"><%= family.email %></span>
      </div>
    </div>

    <!-- Subscription -->
    <div class="card">
      <h2>Subscription & Billing</h2>
      <div class="info-row">
        <span class="info-label">Status</span>
        <span class="info-value">
          <%
            const status = family.subscription_status || 'unknown';
            let badgeClass = 'badge-other';
            let statusLabel = status.charAt(0).toUpperCase() + status.slice(1);
            if (status === 'active') badgeClass = 'badge-active';
            else if (status === 'trialing') { badgeClass = 'badge-trialing'; statusLabel = 'Free Trial'; }
            else if (status === 'canceled' || status === 'cancelled') { badgeClass = 'badge-cancelled'; statusLabel = 'Cancelled'; }
          %>
          <span class="badge <%= badgeClass %>"><%= statusLabel %></span>
        </span>
      </div>
      <% if (family.billing_period) { %>
      <div class="info-row">
        <span class="info-label">Plan</span>
        <span class="info-value"><%= family.billing_period.charAt(0).toUpperCase() + family.billing_period.slice(1) %></span>
      </div>
      <% } %>

      <% if (family.stripe_customer_id) { %>
        <form method="POST" action="/account/portal">
          <button type="submit" class="btn-gold">Manage Subscription</button>
        </form>
        <p class="portal-note">Update your payment method or view invoices.</p>

        <% if (family.subscription_status !== 'canceled' && !family.archived_at) { %>
          <hr style="margin:24px 0;border:none;border-top:1px solid #e8e0d0;">
          <% if (typeof linkedFamilies !== 'undefined' && linkedFamilies && linkedFamilies.length > 1) { %>
            <!-- Multi-site customer: show Cancel This Site + Cancel All buttons -->
            <% if (typeof isPrimary !== 'undefined' && isPrimary) { %>
              <p style="font-size:14px;color:#4a4a5a;margin:0 0 12px;">
                This is your <strong>Primary site</strong>. To cancel just this one, you'll need to promote another site to be your new Primary. Or cancel everything at once.
              </p>
              <form method="POST" action="/account/cancel" onsubmit="return confirmPrimaryCancel(this);" style="display:inline-block;margin-right:8px;">
                <select name="promoteFamilyId" id="promoteSelect" style="padding:10px;border-radius:6px;border:1px solid #e0d5c4;margin-right:8px;">
                  <option value="">— Promote which site? —</option>
                  <% linkedFamilies.filter(f => f.id !== family.id && !f.archived_at).forEach(function(f) { %>
                    <option value="<%= f.id %>"><%= f.display_name || f.subdomain || f.email %><% if (f.custom_domain) { %> (<%= f.custom_domain %>)<% } %></option>
                  <% }) %>
                </select>
                <button type="submit" class="btn-cancel-secondary">Promote & Cancel This Site</button>
              </form>
              <form method="POST" action="/account/cancel" onsubmit="return confirmCancelAll(this);" style="display:inline-block;">
                <input type="hidden" name="all" value="true">
                <button type="submit" class="btn-cancel-danger">Cancel All <%= linkedFamilies.filter(f => !f.archived_at).length %> Sites</button>
              </form>
            <% } else { %>
              <p style="font-size:14px;color:#4a4a5a;margin:0 0 12px;">This site is one of your additional Legacy Odyssey sites. You can cancel it without affecting your Primary site.</p>
              <form method="POST" action="/account/cancel" onsubmit="return confirm('Cancel this site? You will keep access until your next renewal date, then this book goes offline. Your photos are saved for 1 year.');" style="display:inline-block;">
                <button type="submit" class="btn-cancel-secondary">Cancel This Site</button>
              </form>
            <% } %>
          <% } else { %>
            <!-- Single-site customer: simple Cancel button -->
            <form method="POST" action="/account/cancel" onsubmit="return confirm('Cancel your Legacy Odyssey subscription?\n\n• You keep access until your next renewal date\n• Your photos and stories are preserved for 1 year\n• Your custom domain auto-renewal stops\n• You can reactivate anytime within 1 year');">
              <button type="submit" class="btn-cancel-secondary">Cancel My Subscription</button>
            </form>
          <% } %>
          <p class="portal-note" style="margin-top:8px;">
            You will not be charged anything to cancel. Photos and stories are saved for 1 year.
          </p>
        <% } else { %>
          <hr style="margin:24px 0;border:none;border-top:1px solid #e8e0d0;">
          <div style="background:#fdf6e7;border:1px solid #e8d5a8;border-radius:10px;padding:18px 20px;">
            <p style="margin:0 0 8px;font-family:'Fraunces',Georgia,serif;font-size:18px;font-weight:600;color:#1a1a2e;">Your subscription is cancelled</p>
            <p style="margin:0 0 12px;font-size:14px;color:#4a4a5a;line-height:1.6;">All your photos, stories, and book content are still here — nothing has been deleted. Reactivate to bring your site back online.</p>
            <form method="POST" action="/account/reactivate-checkout" style="margin:0;">
              <button type="submit" class="btn-gold" style="margin:0;">Reactivate — $49.99/year</button>
            </form>
            <p style="margin:10px 0 0;font-size:12px;color:#4a3f30;">You'll be taken to Stripe to enter payment. Your custom domain auto-renewal will turn back on.</p>
          </div>
        <% } %>
      <% } else { %>
        <a href="https://<%= appDomain %>/#pricing" class="btn-gold">View Plans</a>
        <p class="portal-note">You're on a free trial. Visit our pricing page to subscribe.</p>
      <% } %>
    </div>

    <% if (typeof referral !== 'undefined' && referral && referral.code) { %>
    <div class="card">
      <h2>Refer friends, get a free year</h2>
      <p style="font-size:14px;color:#4a4a5a;line-height:1.6;margin-bottom:14px;">Share your link below. When <strong><%= referral.threshold %> friends</strong> start a book of their own, we credit your account <strong><%= referral.rewardLabel %></strong> toward your next renewal — automatically. No limit: every <%= referral.threshold %> more is another year on us.</p>

      <label style="display:block;font-size:12px;color:#4a3f30;margin-bottom:6px;letter-spacing:0.04em;text-transform:uppercase;">Your referral link</label>
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
        <input id="loRefLink" type="text" readonly value="<%= referral.link %>" onclick="this.select()"
          style="flex:1;min-width:220px;padding:11px 13px;border:1px solid #e0d5c4;border-radius:8px;background:#faf7f2;color:#2c2416;font-size:14px;" />
        <button type="button" class="btn-gold" style="margin:0;white-space:nowrap;" onclick="loCopyRef(this)">Copy link</button>
      </div>

      <div style="margin-top:18px;">
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
          <span style="font-size:13px;color:#4a4a5a;"><strong><%= referral.towardNext %></strong> of <%= referral.threshold %> toward your next free year</span>
          <% if (referral.creditsGranted > 0) { %>
            <span style="font-size:13px;color:#b08e4a;font-weight:600;"><%= referral.creditsGranted %> free year<%= referral.creditsGranted === 1 ? '' : 's' %> earned 🎉</span>
          <% } %>
        </div>
        <div style="height:8px;background:#efe7d8;border-radius:6px;overflow:hidden;">
          <div style="height:100%;width:<%= Math.round((referral.towardNext / referral.threshold) * 100) %>%;background:#c8a96e;border-radius:6px;transition:width .3s;"></div>
        </div>
        <p class="portal-note" style="margin-top:10px;">A referral counts once your friend completes their first paid checkout. Credits apply to your next invoice through Stripe.</p>
      </div>
    </div>
    <script>
      function loCopyRef(btn) {
        var input = document.getElementById('loRefLink');
        input.select();
        var done = function () { var t = btn.textContent; btn.textContent = 'Copied!'; setTimeout(function(){ btn.textContent = t; }, 1600); };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(input.value).then(done).catch(function(){ try { document.execCommand('copy'); done(); } catch(e){} });
        } else { try { document.execCommand('copy'); done(); } catch(e){} }
      }
    </script>
    <% } %>

    <div class="card">
      <h2>Your Data &amp; Privacy</h2>
      <p style="font-size:14px;color:#4a4a5a;line-height:1.6;margin-bottom:14px;">Download a copy of all the personal data we hold for your account at any time. See our <a href="/privacy" style="color:#c8a96e;">Privacy Policy</a>.</p>
      <a href="/account/export" class="btn-gold" style="display:inline-block;">Download My Data</a>
      <p class="portal-note" style="margin-top:10px;">To delete your account and all its data, cancel your subscription above, or email <a href="mailto:help@legacyodyssey.com">help@legacyodyssey.com</a> and we'll remove it.</p>
    </div>

    <% } %>

    <div class="footer">
      <a href="https://legacyodyssey.com">← Back to Legacy Odyssey</a>
      &nbsp;·&nbsp;
      <a href="mailto:hello@legacyodyssey.com">Contact Support</a>
    </div>

  </div>
</body>
</html>
