<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex,nofollow">
  <title>Legacy Odyssey · Gift Certificate</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: 'Jost', system-ui, sans-serif;
      background: #ece4d6;
      color: #1a1510;
      min-height: 100vh;
      padding: 32px 16px;
      display: flex; flex-direction: column; align-items: center;
    }

    .wrap { width: 100%; max-width: 880px; }

    /* ---------- Toolbar (hidden when printing) ---------- */
    .toolbar {
      display: flex; gap: 12px; align-items: center; justify-content: space-between;
      margin-bottom: 22px; flex-wrap: wrap;
    }
    .toolbar-msg {
      font-size: 13px; color: #5e564a;
    }
    .toolbar-actions { display: flex; gap: 10px; }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 11px 20px; border-radius: 6px; font-size: 13px; font-weight: 600;
      letter-spacing: 0.5px; text-transform: uppercase; cursor: pointer; border: none;
      font-family: inherit; text-decoration: none;
    }
    .btn-primary { background: #1a1510; color: #faf7f2; }
    .btn-primary:hover { background: #2c2416; }
    .btn-secondary { background: rgba(26,21,16,0.08); color: #1a1510; }
    .btn-secondary:hover { background: rgba(26,21,16,0.14); }

    /* ---------- The certificate itself ---------- */
    .cert {
      background: #faf7f2;
      box-shadow: 0 24px 60px rgba(26,21,16,0.18);
      border-radius: 6px;
      position: relative;
      padding: 56px 56px 64px;
      /* US Letter portrait aspect for visual reference on screen */
      aspect-ratio: 8.5 / 11;
      display: flex; flex-direction: column;
      overflow: hidden;
    }
    @media (max-width: 700px) {
      .cert { padding: 36px 24px 44px; aspect-ratio: auto; }
    }

    .cert::before, .cert::after {
      content: ''; position: absolute; pointer-events: none;
    }
    .cert::before {
      inset: 18px;
      border: 1px solid rgba(184,142,74,0.35);
      border-radius: 3px;
    }
    .cert::after {
      inset: 24px;
      border: 1px solid rgba(184,142,74,0.18);
      border-radius: 2px;
    }

    .cert-header { text-align: center; position: relative; z-index: 1; margin-bottom: 28px; }
    .cert-brand { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 500; letter-spacing: 6px; color: #b08e4a; text-transform: uppercase; }
    .cert-rule { width: 80px; height: 1px; background: #b08e4a; margin: 14px auto; }
    .cert-eyebrow { font-size: 12px; letter-spacing: 5px; text-transform: uppercase; color: #5e564a; margin-bottom: 8px; }
    .cert-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 6vw, 64px); font-weight: 400; line-height: 1.05; color: #1a1510; margin: 8px 0 0; }
    .cert-title em { font-style: italic; color: #b08e4a; }
    .cert-subtitle { font-size: 15px; color: #5e564a; margin-top: 14px; max-width: 540px; margin-left: auto; margin-right: auto; line-height: 1.55; }

    .cert-mid { flex: 1; position: relative; z-index: 1; display: flex; flex-direction: column; justify-content: center; padding: 18px 0; }

    .cert-fromto {
      display: grid; grid-template-columns: 1fr auto 1fr;
      gap: 18px; align-items: center;
      margin: 22px 0 32px;
    }
    @media (max-width: 600px) { .cert-fromto { grid-template-columns: 1fr; } }
    .cert-fromto-block { text-align: center; }
    .cert-fromto-label { font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: #b08e4a; margin-bottom: 8px; }
    .cert-fromto-name { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 500; color: #1a1510; line-height: 1.2; word-break: break-word; }
    .cert-fromto-divider { font-family: 'Cormorant Garamond', serif; font-size: 28px; color: rgba(184,142,74,0.5); }
    @media (max-width: 600px) { .cert-fromto-divider { display: none; } }

    .cert-message {
      max-width: 600px; margin: 0 auto 28px;
      padding: 14px 18px;
      font-family: 'Cormorant Garamond', serif; font-size: 18px; font-style: italic;
      color: #2c2416; line-height: 1.55; text-align: center;
      border-top: 1px solid rgba(184,142,74,0.25);
      border-bottom: 1px solid rgba(184,142,74,0.25);
    }

    .cert-code-wrap { text-align: center; margin: 14px 0 24px; }
    .cert-code-label { font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: #b08e4a; margin-bottom: 12px; }
    .cert-code {
      display: inline-block;
      font-family: 'Jost', sans-serif; font-size: clamp(20px, 3.4vw, 30px); font-weight: 700;
      letter-spacing: 4px; color: #1a1510;
      padding: 14px 26px;
      background: #fff;
      border: 1px dashed #b08e4a;
      border-radius: 6px;
      word-break: break-all;
    }

    .cert-footer { text-align: center; position: relative; z-index: 1; margin-top: auto; }
    .cert-redeem-label { font-size: 12px; letter-spacing: 3px; text-transform: uppercase; color: #5e564a; margin-bottom: 4px; }
    .cert-redeem-url { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #1a1510; }
    .cert-redeem-url strong { color: #b08e4a; font-weight: 500; }
    .cert-fineprint { margin-top: 18px; font-size: 11px; color: #8a7e6b; line-height: 1.55; }

    /* ---------- Print styles ---------- */
    @media print {
      @page { size: letter portrait; margin: 0.5in; }
      body { background: #fff; padding: 0; }
      .toolbar { display: none !important; }
      .cert {
        box-shadow: none !important;
        border-radius: 0 !important;
        aspect-ratio: auto !important;
        padding: 0.5in 0.6in !important;
        min-height: 10in;
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="toolbar">
      <div class="toolbar-msg">When you print this, your browser will offer "Save as PDF" — perfect for sending to a print shop or attaching to a card.</div>
      <div class="toolbar-actions">
        <button type="button" class="btn btn-secondary" onclick="window.location.href='/'">← Home</button>
        <button type="button" class="btn btn-primary" onclick="window.print()">🖨 Print Certificate</button>
      </div>
    </div>

    <div class="cert">
      <div class="cert-header">
        <div class="cert-brand">Legacy Odyssey</div>
        <div class="cert-rule"></div>
        <div class="cert-eyebrow">Gift Certificate</div>
        <h1 class="cert-title">A digital baby book<br>and their own <em>personal website.</em></h1>
        <p class="cert-subtitle">One full year of Legacy Odyssey — a real .com domain registered in the child's name, plus a beautifully designed digital baby book to fill it with.</p>
      </div>

      <div class="cert-mid">
        <div class="cert-fromto">
          <div class="cert-fromto-block">
            <div class="cert-fromto-label">From</div>
            <div class="cert-fromto-name"><%= gift.buyer_name || 'Someone special' %></div>
          </div>
          <div class="cert-fromto-divider">·</div>
          <div class="cert-fromto-block">
            <div class="cert-fromto-label">For</div>
            <div class="cert-fromto-name"><%= gift.recipient_name || 'You' %></div>
          </div>
        </div>

        <% if (gift.recipient_message) { %>
          <div class="cert-message">"<%= gift.recipient_message %>"</div>
        <% } %>

        <div class="cert-code-wrap">
          <div class="cert-code-label">Gift Code</div>
          <div class="cert-code"><%= gift.code %></div>
        </div>
      </div>

      <div class="cert-footer">
        <div class="cert-redeem-label">Redeem at</div>
        <div class="cert-redeem-url"><strong><%= bareRedeemUrl %></strong></div>
        <div class="cert-fineprint">
          One-year subscription · Recipient picks their own .com when they redeem
        </div>
      </div>
    </div>
  </div>
</body>
</html>
