<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex,nofollow">
  <title>Celebration Detail Mockup · Legacy Odyssey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --cream: #F8F2E6;
      --ivory: #FFFCF5;
      --gold: #B8935A;
      --gold-light: #D4B483;
      --gold-dark: #8C6A35;
      --ink: #1E1812;
      --ink-mid: #4A3F32;
      --ink-light: #9C8B78;
      --border: #E5DDC9;
      --nav-width: 260px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Jost', sans-serif;
      background: var(--cream);
      color: var(--ink);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ========== MOCKUP BANNER (clearly marks this as not-final) ========== */
    .mockup-banner {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: #1a1510; color: #c8a96e; padding: 10px 20px;
      font-size: 12px; letter-spacing: 1px; text-transform: uppercase;
      text-align: center; font-weight: 600;
      border-bottom: 1px solid rgba(200,169,110,0.3);
    }
    .mockup-banner a { color: #faf7f2; text-decoration: underline; margin-left: 16px; }
    body { padding-top: 38px; }

    /* ========== SIDEBAR ========== */
    #sidebar {
      position: fixed; top: 38px; left: 0;
      width: var(--nav-width); height: calc(100vh - 38px);
      background: var(--ink); color: var(--cream);
      overflow-y: auto;
      display: flex; flex-direction: column;
    }
    .sidebar-header {
      padding: 2rem 1.5rem 1.5rem;
      border-bottom: 1px solid rgba(184,147,90,0.2);
    }
    .sidebar-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 0.5rem;
    }
    .sidebar-child-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem; font-weight: 400; color: var(--cream);
      line-height: 1.2; font-style: italic;
    }
    .sidebar-tagline {
      font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--ink-light); margin-top: 0.35rem;
    }
    .sidebar-nav { padding: 1rem 0; flex: 1; }
    .nav-section-label {
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ink-light); padding: 1rem 1.5rem 0.5rem;
    }
    .nav-item {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.65rem 1.5rem;
      color: var(--cream); text-decoration: none;
      font-size: 0.92rem; cursor: pointer;
      transition: background 0.15s;
      position: relative;
    }
    .nav-item:hover { background: rgba(184,147,90,0.08); color: var(--gold-light); }
    .nav-item.active { color: var(--gold); }
    .nav-item.active::before {
      content: ''; position: absolute; left: 0; top: 0; bottom: 0;
      width: 3px; background: var(--gold);
    }
    .nav-icon { width: 18px; height: 18px; display: inline-flex; align-items: center; }
    .nav-icon svg { width: 16px; height: 16px; }
    .nav-label { flex: 1; }

    /* Nested dropdown for Celebrations */
    .nav-parent { /* clickable parent that toggles children */
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.65rem 1.5rem;
      color: var(--cream); text-decoration: none;
      font-size: 0.92rem; cursor: pointer;
      transition: background 0.15s;
    }
    .nav-parent.open { color: var(--gold-light); }
    .nav-parent .nav-chevron {
      margin-left: auto; transition: transform 0.2s;
      color: var(--ink-light);
    }
    .nav-parent.open .nav-chevron { transform: rotate(90deg); color: var(--gold); }
    .nav-children { padding: 0 0 0.25rem 0; }
    .nav-year {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.45rem 1.5rem 0.45rem 3rem;
      color: rgba(248,242,230,0.78); cursor: pointer;
      font-size: 0.85rem;
      transition: background 0.15s;
    }
    .nav-year:hover { background: rgba(184,147,90,0.06); color: var(--gold-light); }
    .nav-year.open { color: var(--gold-light); font-weight: 500; }
    .nav-year-chevron { margin-left: auto; color: var(--ink-light); transition: transform 0.2s; }
    .nav-year.open .nav-year-chevron { transform: rotate(90deg); color: var(--gold); }
    .nav-celebrations { padding: 0.15rem 0 0.5rem; }
    .nav-celebration {
      display: block; padding: 0.4rem 1.5rem 0.4rem 4.25rem;
      color: rgba(248,242,230,0.65); text-decoration: none;
      font-size: 0.82rem; line-height: 1.4;
      transition: color 0.15s;
      border-left: 1px solid rgba(184,147,90,0.15);
      margin-left: 2.5rem;
    }
    .nav-celebration:hover { color: var(--gold-light); }
    .nav-celebration.active {
      color: var(--gold); font-weight: 500;
      border-left-color: var(--gold);
    }

    /* ========== MAIN CONTENT ========== */
    #main {
      margin-left: var(--nav-width);
      min-height: calc(100vh - 38px);
    }

    /* Top breadcrumb */
    .breadcrumb {
      padding: 1.5rem 3rem 0;
      font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--ink-light);
    }
    .breadcrumb a { color: var(--ink-light); text-decoration: none; }
    .breadcrumb a:hover { color: var(--gold); }
    .breadcrumb-sep { margin: 0 0.5em; opacity: 0.5; }

    /* HERO */
    .celebration-hero {
      padding: 2rem 3rem 0;
      max-width: 1080px; margin: 0 auto;
    }
    .celebration-eyebrow {
      font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--gold); font-weight: 500; margin-bottom: 1rem;
    }
    .celebration-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 400; line-height: 1.05;
      color: var(--ink); margin-bottom: 1rem; letter-spacing: -0.01em;
    }
    .celebration-title em { font-style: italic; color: var(--gold-dark); }
    .celebration-meta {
      display: flex; flex-wrap: wrap; gap: 1.5rem;
      font-size: 0.85rem; color: var(--ink-mid);
      margin-bottom: 2.5rem;
    }
    .celebration-meta-item { display: flex; align-items: center; gap: 0.4rem; }
    .celebration-meta-item svg { width: 14px; height: 14px; color: var(--gold); }

    .celebration-hero-photo {
      width: 100%; aspect-ratio: 16/8;
      background: var(--ink); border-radius: 4px;
      overflow: hidden; margin-bottom: 3rem;
    }
    .celebration-hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

    /* SECTIONS */
    .celebration-section {
      max-width: 1080px; margin: 0 auto;
      padding: 0 3rem 3rem;
    }
    .celebration-section-label {
      font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--gold); font-weight: 500;
      margin-bottom: 1rem;
      display: flex; align-items: center; gap: 0.6rem;
    }
    .celebration-section-label::before {
      content: ''; width: 24px; height: 1px; background: var(--gold);
    }
    .celebration-section-h {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 400;
      color: var(--ink); margin-bottom: 1.25rem;
    }

    /* Story */
    .celebration-story {
      max-width: 720px; font-size: 1.05rem; line-height: 1.85;
      color: var(--ink-mid); font-weight: 300;
    }
    .celebration-story p { margin-bottom: 1.5rem; }
    .celebration-story em { font-style: italic; }

    /* Who was there - pill tags */
    .attendees-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .attendee-pill {
      display: inline-flex; align-items: center;
      background: rgba(184,147,90,0.1); border: 1px solid rgba(184,147,90,0.3);
      border-radius: 999px;
      padding: 0.4rem 1rem;
      font-size: 0.88rem; color: var(--ink); font-weight: 500;
    }

    /* Where - single line, with map icon */
    .location-line {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem; color: var(--ink); font-style: italic; font-weight: 400;
      max-width: 720px;
    }

    /* Gifts - bulleted list */
    .gifts-list {
      list-style: none; padding: 0;
      max-width: 720px;
    }
    .gifts-list li {
      padding: 0.65rem 0;
      border-bottom: 1px dashed var(--border);
      font-size: 1rem; color: var(--ink-mid);
      display: flex; align-items: flex-start; gap: 0.75rem;
    }
    .gifts-list li:last-child { border-bottom: none; }
    .gifts-list li::before {
      content: '✦'; color: var(--gold); flex-shrink: 0; font-size: 0.85rem; margin-top: 0.15rem;
    }

    /* Photo gallery */
    .photo-gallery {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.25rem;
    }
    .photo-card {
      background: var(--ivory); border-radius: 4px; overflow: hidden;
      box-shadow: 0 2px 8px rgba(30,24,18,0.05);
      cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;
    }
    .photo-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(30,24,18,0.12); }
    .photo-card-img { aspect-ratio: 4/5; overflow: hidden; }
    .photo-card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .photo-card-caption {
      padding: 0.85rem 1rem;
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.95rem; font-style: italic; color: var(--ink-mid);
      line-height: 1.5;
    }
    .photo-card-caption.empty { display: none; }

    /* Footer nav between celebrations */
    .celebration-pager {
      max-width: 1080px; margin: 2rem auto 0; padding: 2rem 3rem 4rem;
      border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
      gap: 2rem; flex-wrap: wrap;
    }
    .pager-link {
      display: flex; align-items: center; gap: 0.6rem;
      color: var(--ink-mid); text-decoration: none;
      font-size: 0.9rem; transition: color 0.15s;
    }
    .pager-link:hover { color: var(--gold); }
    .pager-link-label { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-light); }
    .pager-link-title { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; }
    .pager-link.prev { text-align: left; }
    .pager-link.next { text-align: right; margin-left: auto; }

    @media (max-width: 900px) {
      #sidebar { transform: translateX(-100%); }
      #main { margin-left: 0; }
      .breadcrumb, .celebration-hero, .celebration-section, .celebration-pager { padding-left: 1.5rem; padding-right: 1.5rem; }
    }
  </style>
</head>
<body>

  <!-- ====== MOCKUP BANNER ====== -->
  <div class="mockup-banner">
    🎨 Design Mockup — Celebration Detail Page
    <a href="/preview/celebration-mockup/full">Full version</a>
    <a href="/preview/celebration-mockup/sparse">Sparse version (most fields blank)</a>
    <a href="/preview/celebration-mockup/empty">Empty (just a title)</a>
  </div>

  <!-- ====== SIDEBAR (with new nested Celebrations dropdown) ====== -->
  <nav id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">✦ Legacy Odyssey</div>
      <div class="sidebar-child-name">Sophia Smith</div>
      <div class="sidebar-tagline">Born · January 14, 2025</div>
    </div>
    <div class="sidebar-nav">
      <div class="nav-section-label">The Book</div>
      <a class="nav-item"><span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8 5.8 21.3l2.4-7.4L2 9.4h7.6L12 2z"/></svg></span><span class="nav-label">Welcome</span></a>
      <a class="nav-item"><span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span><span class="nav-label">Before You Arrived</span></a>
      <a class="nav-item"><span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></span><span class="nav-label">Birth Story</span></a>
      <a class="nav-item"><span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></span><span class="nav-label">Coming Home</span></a>
      <a class="nav-item"><span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span><span class="nav-label">Month by Month</span></a>

      <div class="nav-section-label">Family &amp; Memories</div>
      <a class="nav-item"><span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></span><span class="nav-label">Our Family</span></a>
      <a class="nav-item"><span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></span><span class="nav-label">Your Firsts</span></a>

      <!-- THE NEW NESTED CELEBRATIONS DROPDOWN -->
      <div class="nav-parent open" onclick="this.classList.toggle('open')">
        <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg></span>
        <span class="nav-label" style="color:var(--gold);font-weight:500;">Celebrations</span>
        <span class="nav-chevron">▸</span>
      </div>
      <div class="nav-children">
        <div class="nav-year open" onclick="event.stopPropagation();this.classList.toggle('open')">
          <span>Year 1 (2025)</span>
          <span class="nav-year-chevron">▸</span>
        </div>
        <div class="nav-celebrations">
          <a class="nav-celebration active" href="#">First Christmas</a>
          <a class="nav-celebration" href="#">Easter Sunday</a>
          <a class="nav-celebration" href="#">Fourth of July</a>
          <a class="nav-celebration" href="#">Halloween</a>
          <a class="nav-celebration" href="#">First Birthday</a>
        </div>
        <div class="nav-year" onclick="event.stopPropagation();this.classList.toggle('open')">
          <span>Year 2 (2026)</span>
          <span class="nav-year-chevron">▸</span>
        </div>
        <div class="nav-year" onclick="event.stopPropagation();this.classList.toggle('open')">
          <span>Year 3 (2027)</span>
          <span class="nav-year-chevron">▸</span>
        </div>
      </div>

      <a class="nav-item"><span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span><span class="nav-label">Letters To You</span></a>
      <a class="nav-item"><span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 11l18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg></span><span class="nav-label">Family Recipes</span></a>
    </div>
  </nav>

  <!-- ====== MAIN CONTENT (this is what changes per variant) ====== -->
  <main id="main">
    <% const c = celebration; %>

    <div class="breadcrumb">
      <a href="#">Celebrations</a>
      <span class="breadcrumb-sep">›</span>
      <a href="#"><%= c.yearLabel %></a>
      <span class="breadcrumb-sep">›</span>
      <span><%= c.title.replace(/<[^>]*>/g, '') %></span>
    </div>

    <section class="celebration-hero">
      <% if (c.eyebrow) { %>
        <div class="celebration-eyebrow"><%= c.eyebrow %></div>
      <% } %>
      <h1 class="celebration-title"><%- c.title %></h1>

      <% if (c.date || c.location) { %>
        <div class="celebration-meta">
          <% if (c.date) { %>
            <div class="celebration-meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <%= c.date %>
            </div>
          <% } %>
          <% if (c.location) { %>
            <div class="celebration-meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <%= c.location %>
            </div>
          <% } %>
        </div>
      <% } %>

      <% if (c.coverPhoto) { %>
        <div class="celebration-hero-photo">
          <img src="<%= c.coverPhoto %>" alt="<%= c.title %>">
        </div>
      <% } %>
    </section>

    <% if (c.story) { %>
      <section class="celebration-section">
        <div class="celebration-section-label">The Story</div>
        <div class="celebration-story">
          <% c.story.split('\n\n').forEach(function(p) { %>
            <p><%- p.trim() %></p>
          <% }); %>
        </div>
      </section>
    <% } %>

    <% if (c.attendees && c.attendees.length) { %>
      <section class="celebration-section">
        <div class="celebration-section-label">Who Was There</div>
        <div class="attendees-grid">
          <% c.attendees.forEach(function(name) { %>
            <span class="attendee-pill"><%= name %></span>
          <% }); %>
        </div>
      </section>
    <% } %>

    <% if (c.gifts && c.gifts.length) { %>
      <section class="celebration-section">
        <div class="celebration-section-label">Presents</div>
        <ul class="gifts-list">
          <% c.gifts.forEach(function(g) { %>
            <li><%= g %></li>
          <% }); %>
        </ul>
      </section>
    <% } %>

    <% if (c.photos && c.photos.length) { %>
      <section class="celebration-section">
        <div class="celebration-section-label">The Album · <%= c.photos.length %> photo<%= c.photos.length === 1 ? '' : 's' %></div>
        <div class="photo-gallery">
          <% c.photos.forEach(function(p) { %>
            <div class="photo-card">
              <div class="photo-card-img"><img src="<%= p.url %>" alt="<%= p.caption || '' %>"></div>
              <% if (p.caption) { %>
                <div class="photo-card-caption">"<%= p.caption %>"</div>
              <% } %>
            </div>
          <% }); %>
        </div>
      </section>
    <% } %>

    <% if (c.prev || c.next) { %>
      <div class="celebration-pager">
        <% if (c.prev) { %>
          <a class="pager-link prev" href="#">
            <span>‹</span>
            <span>
              <div class="pager-link-label">Previous</div>
              <div class="pager-link-title"><%= c.prev %></div>
            </span>
          </a>
        <% } else { %><span></span><% } %>
        <% if (c.next) { %>
          <a class="pager-link next" href="#">
            <span>
              <div class="pager-link-label">Next</div>
              <div class="pager-link-title"><%= c.next %></div>
            </span>
            <span>›</span>
          </a>
        <% } %>
      </div>
    <% } %>
  </main>

  <script>
    // Toggle handlers added inline above. No external JS needed for the mockup.
  </script>
</body>
</html>
