<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Keepsakes redesign mockup — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <!-- Pull the real book stylesheet so the mockup looks identical to your-childs-name.com -->
  <link rel="stylesheet" href="/css/book.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
  <style>
    /* ─── Mockup toolbar (preview only — not part of the section) ─── */
    .mockup-toolbar {
      background: var(--ink);
      color: var(--cream);
      padding: 0.85rem 1.5rem;
      display: flex; gap: 1rem;
      align-items: center; flex-wrap: wrap;
      border-bottom: 1px solid var(--gold-dark);
    }
    .mockup-toolbar strong {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem; letter-spacing: 0.04em;
    }
    .mockup-toolbar a {
      color: var(--gold-light); text-decoration: none;
      padding: 0.35rem 0.85rem;
      border: 1px solid rgba(212,180,131,0.4);
      border-radius: 4px; font-size: 0.82rem;
    }
    .mockup-toolbar a.active { background: var(--gold); color: var(--ink); border-color: var(--gold); }
    .mockup-toolbar a:hover { background: rgba(212,180,131,0.15); }
    .mockup-note { color: rgba(248,242,230,0.55); font-size: 0.78rem; margin-left: auto; font-style: italic; }

    body { background: var(--cream); }

    /* ─── Keepsakes-specific page styles (uses book.css tokens) ─── */
    .keepsakes-body {
      padding: 3rem 4rem 5rem;
      max-width: 1100px;
    }

    /* Intro paragraph (matches recipes-intro feel) */
    .keepsakes-intro {
      max-width: 700px;
      margin: 0 auto 2.5rem;
      text-align: center;
    }
    .keepsakes-intro-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-style: italic;
      color: var(--ink-mid);
      line-height: 1.65;
    }

    /* Category filter row */
    .keepsake-filters {
      display: flex; flex-wrap: wrap; gap: 0.5rem;
      justify-content: center;
      margin-bottom: 2.5rem;
    }
    .filter-chip {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      border: 1px solid var(--gold);
      background: transparent;
      color: var(--ink);
      font-family: 'Jost', sans-serif;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      cursor: pointer;
      transition: all 0.18s;
    }
    .filter-chip svg { width: 0.95rem; height: 0.95rem; stroke-width: 1.6; }
    .filter-chip:hover { background: rgba(184,147,90,0.08); }
    .filter-chip.active {
      background: var(--gold);
      color: var(--ivory);
      border-color: var(--gold);
    }

    /* OVERVIEW grid */
    .keepsake-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
      gap: 1.5rem;
    }
    .keepsake-card {
      background: var(--ivory);
      border: 1px solid rgba(184,147,90,0.2);
      border-radius: 2px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      display: flex; flex-direction: column;
      transition: border-color 0.2s, box-shadow 0.2s;
      box-shadow: 0 2px 8px rgba(30,24,18,0.04);
    }
    .keepsake-card:hover {
      border-color: rgba(184,147,90,0.5);
      box-shadow: 0 6px 18px rgba(30,24,18,0.08);
    }
    .keepsake-photo {
      aspect-ratio: 4/5;
      background: var(--blush);
      position: relative;
      overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .keepsake-photo img { width: 100%; height: 100%; object-fit: cover; }
    .keepsake-photo-fallback {
      width: 100%; height: 100%;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 1.5rem 1rem;
      text-align: center;
    }
    .keepsake-photo-fallback .icon {
      width: 64px; height: 64px;
      border-radius: 50%;
      background: rgba(248,242,230,0.65);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 0.75rem;
      color: var(--gold-dark);
    }
    .keepsake-photo-fallback .icon svg { width: 32px; height: 32px; stroke-width: 1.4; }
    .keepsake-photo-fallback .placeholder-text {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      color: var(--ink-mid);
      font-size: 0.88rem;
      line-height: 1.4;
    }
    /* Category-specific tinted backgrounds (subtle, paper-like) */
    .bg-artwork    { background: linear-gradient(135deg, var(--blush), #f4d8c4); }
    .bg-schoolwork { background: linear-gradient(135deg, #dcead4, #c5d9bd); }
    .bg-award      { background: linear-gradient(135deg, #f1e1ba, var(--gold-light)); }
    .bg-memorabilia{ background: linear-gradient(135deg, #d8d8ea, #b3b8d4); }

    /* Category badge over photo */
    .keepsake-badge {
      position: absolute; top: 0.7rem; left: 0.7rem;
      background: var(--ink);
      color: var(--gold-light);
      padding: 0.25rem 0.6rem 0.25rem 0.55rem;
      border-radius: 2px;
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      display: inline-flex; align-items: center; gap: 0.35rem;
    }
    .keepsake-badge svg { width: 0.8rem; height: 0.8rem; stroke-width: 1.7; }

    .keepsake-body-text { padding: 1.15rem 1.25rem 1.3rem; }
    .keepsake-card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem; font-weight: 500;
      color: var(--ink); line-height: 1.25;
      margin-bottom: 0.35rem;
    }
    .keepsake-card-meta {
      font-size: 0.75rem; color: var(--ink-light);
      display: inline-flex; align-items: center; gap: 0.4rem;
      letter-spacing: 0.04em;
    }
    .keepsake-card-meta svg { width: 0.85rem; height: 0.85rem; stroke-width: 1.6; }

    /* DETAIL */
    .detail-back {
      color: var(--ink-light);
      text-decoration: none;
      font-size: 0.78rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      display: inline-flex; align-items: center; gap: 0.4rem;
      margin-bottom: 2rem;
    }
    .detail-back:hover { color: var(--gold); }
    .detail-back svg { width: 1rem; height: 1rem; }

    .keepsake-hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
      margin-bottom: 3rem;
    }
    @media (max-width: 760px) { .keepsake-hero { grid-template-columns: 1fr; gap: 2rem; } }
    .keepsake-hero-photo {
      aspect-ratio: 4/5;
      background: var(--blush);
      border-radius: 2px;
      overflow: hidden;
      box-shadow: 0 12px 32px rgba(30,24,18,0.12);
      display: flex; align-items: center; justify-content: center;
    }
    .keepsake-hero-photo img { width: 100%; height: 100%; object-fit: cover; }
    .keepsake-hero-eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
      display: inline-flex; align-items: center; gap: 0.4rem;
    }
    .keepsake-hero-eyebrow svg { width: 0.9rem; height: 0.9rem; stroke-width: 1.6; }
    .keepsake-hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 300;
      color: var(--ink);
      line-height: 1.1;
      margin-bottom: 1rem;
    }
    .keepsake-hero-title em { font-style: italic; color: var(--gold-light); }
    .keepsake-hero-desc {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-style: italic;
      color: var(--ink-mid);
      line-height: 1.55;
    }

    /* Meta strip */
    .keepsake-meta-strip {
      display: flex;
      background: var(--ivory);
      border: 1px solid rgba(184,147,90,0.2);
      border-radius: 2px;
      overflow: hidden;
      margin-bottom: 3rem;
    }
    .km-cell {
      flex: 1; padding: 1.1rem 0.85rem;
      text-align: center;
      border-right: 1px solid rgba(184,147,90,0.2);
    }
    .km-cell:last-child { border-right: 0; }
    .km-cell-icon {
      color: var(--gold);
      margin-bottom: 0.45rem;
      display: flex; justify-content: center;
    }
    .km-cell-icon svg { width: 1.3rem; height: 1.3rem; stroke-width: 1.5; }
    .km-cell-label {
      color: var(--ink-light);
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-bottom: 0.25rem;
    }
    .km-cell-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem; font-weight: 500;
      color: var(--ink);
    }

    /* Story */
    .keepsake-section { margin-bottom: 3rem; }
    .keepsake-section-eyebrow {
      color: var(--gold);
      font-size: 0.68rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 0.65rem;
    }
    .keepsake-section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.75rem; font-weight: 400;
      color: var(--ink);
      margin-bottom: 1.25rem;
    }
    .keepsake-story p {
      font-size: 1.02rem;
      line-height: 1.9;
      margin-bottom: 1.1rem;
      color: var(--ink);
    }
    .keepsake-story p:first-of-type::first-letter {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 3.4rem;
      float: left;
      line-height: 0.9;
      padding: 0.2rem 0.55rem 0 0;
      color: var(--gold);
    }

    /* Photo gallery */
    .photo-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
    }
    .photo-tile {
      aspect-ratio: 1/1;
      background: var(--blush);
      border-radius: 2px;
      overflow: hidden;
      cursor: zoom-in;
      display: flex; align-items: center; justify-content: center;
      transition: transform 0.2s;
    }
    .photo-tile:hover { transform: translateY(-2px); }
    .photo-tile img { width: 100%; height: 100%; object-fit: cover; }
    .photo-tile-fallback {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      color: var(--gold-dark);
    }
    .photo-tile-fallback svg { width: 36px; height: 36px; stroke-width: 1.4; opacity: 0.8; }

    /* Pager */
    .keepsake-pager {
      display: flex; justify-content: space-between;
      gap: 1rem;
      padding-top: 2.5rem;
      border-top: 1px solid rgba(184,147,90,0.2);
      margin-top: 1rem;
    }
    .keepsake-pager a {
      flex: 1; max-width: 48%;
      color: var(--ink); text-decoration: none;
      padding: 1rem 1.15rem;
      background: var(--ivory);
      border: 1px solid rgba(184,147,90,0.2);
      border-radius: 2px;
      transition: border-color 0.2s, background 0.2s;
    }
    .keepsake-pager a:hover { border-color: var(--gold); background: #fdf9f0; }
    .keepsake-pager-label {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-light);
      margin-bottom: 0.35rem;
      display: inline-flex; align-items: center; gap: 0.35rem;
    }
    .keepsake-pager-label svg { width: 0.8rem; height: 0.8rem; }
    .keepsake-pager-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--ink);
    }
    .keepsake-pager a.next { text-align: right; }
    .keepsake-pager a.next .keepsake-pager-label { justify-content: flex-end; }

    /* Sparse explainer */
    .sparse-note {
      text-align: center;
      padding: 2.25rem;
      background: var(--ivory);
      border: 1px dashed rgba(184,147,90,0.5);
      border-radius: 2px;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      color: var(--ink-mid);
      font-size: 1rem;
    }

    @media (max-width: 768px) {
      .keepsakes-body { padding: 2rem 1.5rem 3rem; }
      .keepsake-meta-strip { flex-wrap: wrap; }
      .km-cell { flex: 1 1 50%; border-bottom: 1px solid rgba(184,147,90,0.2); }
      .km-cell:nth-last-child(-n+2) { border-bottom: 0; }
      .km-cell:nth-child(2n) { border-right: 0; }
    }
  </style>
</head>
<body>

<div class="mockup-toolbar">
  <strong>Keepsakes — design mockup (v2: matches your-childs-name.com)</strong>
  <a href="/preview/keepsakes-mockup/overview" class="<%= variant === 'overview' ? 'active' : '' %>">1. Overview</a>
  <a href="/preview/keepsakes-mockup/detail" class="<%= variant === 'detail' ? 'active' : '' %>">2. Detail page</a>
  <a href="/preview/keepsakes-mockup/sparse" class="<%= variant === 'sparse' ? 'active' : '' %>">3. Sparse</a>
  <span class="mockup-note">Preview only — nothing is live yet.</span>
</div>

<!-- Reuse the real .page-header pattern from book.css so the chapter header matches the rest of the book -->
<section class="page-section active">
  <div class="page-header">
    <div class="page-header-eyebrow">Chapter Ten</div>
    <h2 class="page-header-title">Their <em>Keepsakes</em></h2>
    <p class="page-header-sub">Drawings, awards, certificates, handprints — the small things you can't keep forever, kept forever here.</p>
  </div>

  <div class="keepsakes-body">

  <% if (variant === 'overview') { %>

    <div class="keepsakes-intro">
      <p class="keepsakes-intro-text">A box in the closet only holds so much. Take a photo, add a note about what it meant, and let go of the original knowing it lives on here.</p>
    </div>

    <div class="keepsake-filters">
      <button class="filter-chip active"><i data-lucide="layers"></i> All</button>
      <button class="filter-chip"><i data-lucide="palette"></i> Artwork</button>
      <button class="filter-chip"><i data-lucide="graduation-cap"></i> Schoolwork</button>
      <button class="filter-chip"><i data-lucide="award"></i> Awards</button>
      <button class="filter-chip"><i data-lucide="archive"></i> Memorabilia</button>
    </div>

    <div class="keepsake-grid">

      <!-- 1. Artwork — first finger painting -->
      <a class="keepsake-card" href="/preview/keepsakes-mockup/detail">
        <div class="keepsake-photo bg-artwork">
          <span class="keepsake-badge"><i data-lucide="palette"></i> Artwork</span>
          <div class="keepsake-photo-fallback">
            <div class="icon"><i data-lucide="palette"></i></div>
            <div class="placeholder-text">Your photo<br>of the painting here</div>
          </div>
        </div>
        <div class="keepsake-body-text">
          <div class="keepsake-card-title">My first finger painting</div>
          <div class="keepsake-card-meta"><i data-lucide="calendar"></i> Age 2</div>
        </div>
      </a>

      <!-- 2. Award — Pre-K certificate -->
      <a class="keepsake-card" href="#">
        <div class="keepsake-photo bg-award">
          <span class="keepsake-badge"><i data-lucide="award"></i> Award</span>
          <div class="keepsake-photo-fallback">
            <div class="icon"><i data-lucide="award"></i></div>
            <div class="placeholder-text">Pre-K certificate</div>
          </div>
        </div>
        <div class="keepsake-body-text">
          <div class="keepsake-card-title">Pre-K Certificate of Completion</div>
          <div class="keepsake-card-meta"><i data-lucide="graduation-cap"></i> Pre-K</div>
        </div>
      </a>

      <!-- 3. Schoolwork — first writing my name -->
      <a class="keepsake-card" href="#">
        <div class="keepsake-photo bg-schoolwork">
          <span class="keepsake-badge"><i data-lucide="graduation-cap"></i> Schoolwork</span>
          <div class="keepsake-photo-fallback">
            <div class="icon"><i data-lucide="pencil"></i></div>
            <div class="placeholder-text">First time<br>writing my name</div>
          </div>
        </div>
        <div class="keepsake-body-text">
          <div class="keepsake-card-title">First time I wrote my own name</div>
          <div class="keepsake-card-meta"><i data-lucide="calendar"></i> Age 4</div>
        </div>
      </a>

      <!-- 4. Memorabilia — first lost tooth -->
      <a class="keepsake-card" href="#">
        <div class="keepsake-photo bg-memorabilia">
          <span class="keepsake-badge"><i data-lucide="archive"></i> Memorabilia</span>
          <div class="keepsake-photo-fallback">
            <div class="icon"><i data-lucide="sparkles"></i></div>
            <div class="placeholder-text">First lost tooth<br>April 2030</div>
          </div>
        </div>
        <div class="keepsake-body-text">
          <div class="keepsake-card-title">First lost tooth</div>
          <div class="keepsake-card-meta"><i data-lucide="calendar"></i> Age 5</div>
        </div>
      </a>

      <!-- 5. Artwork — handprint for Mother's Day -->
      <a class="keepsake-card" href="#">
        <div class="keepsake-photo bg-artwork">
          <span class="keepsake-badge"><i data-lucide="palette"></i> Artwork</span>
          <div class="keepsake-photo-fallback">
            <div class="icon"><i data-lucide="hand"></i></div>
            <div class="placeholder-text">Handprint art<br>for Mother's Day</div>
          </div>
        </div>
        <div class="keepsake-body-text">
          <div class="keepsake-card-title">Handprint art for Mother's Day</div>
          <div class="keepsake-card-meta"><i data-lucide="calendar"></i> Age 3</div>
        </div>
      </a>

      <!-- 6. Award — swim ribbon -->
      <a class="keepsake-card" href="#">
        <div class="keepsake-photo bg-award">
          <span class="keepsake-badge"><i data-lucide="award"></i> Award</span>
          <div class="keepsake-photo-fallback">
            <div class="icon"><i data-lucide="medal"></i></div>
            <div class="placeholder-text">First-place ribbon<br>swim meet</div>
          </div>
        </div>
        <div class="keepsake-body-text">
          <div class="keepsake-card-title">First-place ribbon — swim meet</div>
          <div class="keepsake-card-meta"><i data-lucide="calendar"></i> Age 6</div>
        </div>
      </a>

      <!-- 7. Schoolwork — kindergarten report card -->
      <a class="keepsake-card" href="#">
        <div class="keepsake-photo bg-schoolwork">
          <span class="keepsake-badge"><i data-lucide="graduation-cap"></i> Schoolwork</span>
          <div class="keepsake-photo-fallback">
            <div class="icon"><i data-lucide="file-text"></i></div>
            <div class="placeholder-text">Kindergarten<br>report card</div>
          </div>
        </div>
        <div class="keepsake-body-text">
          <div class="keepsake-card-title">Kindergarten report card</div>
          <div class="keepsake-card-meta"><i data-lucide="graduation-cap"></i> Kindergarten</div>
        </div>
      </a>

      <!-- 8. Memorabilia — concert program -->
      <a class="keepsake-card" href="#">
        <div class="keepsake-photo bg-memorabilia">
          <span class="keepsake-badge"><i data-lucide="archive"></i> Memorabilia</span>
          <div class="keepsake-photo-fallback">
            <div class="icon"><i data-lucide="music"></i></div>
            <div class="placeholder-text">Spring concert<br>program</div>
          </div>
        </div>
        <div class="keepsake-body-text">
          <div class="keepsake-card-title">Spring concert program</div>
          <div class="keepsake-card-meta"><i data-lucide="calendar"></i> Age 6</div>
        </div>
      </a>

    </div>

  <% } else if (variant === 'detail') { %>

    <a class="detail-back" href="/preview/keepsakes-mockup/overview"><i data-lucide="chevron-left"></i> All keepsakes</a>

    <div class="keepsake-hero">
      <div class="keepsake-hero-photo bg-artwork">
        <div class="keepsake-photo-fallback" style="padding: 2rem;">
          <div class="icon" style="width: 96px; height: 96px;">
            <i data-lucide="palette" style="width: 48px; height: 48px;"></i>
          </div>
          <div class="placeholder-text" style="font-size: 1rem;">Your photo of<br>the painting goes here</div>
        </div>
      </div>
      <div>
        <div class="keepsake-hero-eyebrow"><i data-lucide="palette"></i> Artwork</div>
        <h1 class="keepsake-hero-title">My first <em>finger painting</em></h1>
        <p class="keepsake-hero-desc">A swirl of blue, yellow, and red — done at the kitchen table on a Saturday morning with both hands and a healthy disregard for the paper's edges.</p>
      </div>
    </div>

    <div class="keepsake-meta-strip">
      <div class="km-cell">
        <div class="km-cell-icon"><i data-lucide="user"></i></div>
        <div class="km-cell-label">Made by</div>
        <div class="km-cell-value">Sophia</div>
      </div>
      <div class="km-cell">
        <div class="km-cell-icon"><i data-lucide="calendar"></i></div>
        <div class="km-cell-label">Age</div>
        <div class="km-cell-value">2 years old</div>
      </div>
      <div class="km-cell">
        <div class="km-cell-icon"><i data-lucide="clock"></i></div>
        <div class="km-cell-label">Date</div>
        <div class="km-cell-value">March 2028</div>
      </div>
      <div class="km-cell">
        <div class="km-cell-icon"><i data-lucide="tag"></i></div>
        <div class="km-cell-label">Category</div>
        <div class="km-cell-value">Artwork</div>
      </div>
    </div>

    <div class="keepsake-section keepsake-story">
      <div class="keepsake-section-eyebrow">The Story</div>
      <h2 class="keepsake-section-title">How this happened</h2>
      <p>It was raining outside and Daddy pulled out the finger paints from the back of the cupboard. Sophia took one look at the blue jar, plunged her whole hand in, and slapped it on the paper like she'd been waiting her whole life to do exactly that.</p>
      <p>Twenty minutes later there was paint on the chair, paint on the dog, and paint on the wall in places we didn't think a two-year-old could reach. We saved this one painting and threw the rest of the morning out with the paper towels.</p>
    </div>

    <div class="keepsake-section">
      <div class="keepsake-section-eyebrow">More photos</div>
      <h2 class="keepsake-section-title">Different angles</h2>
      <div class="photo-gallery">
        <div class="photo-tile bg-artwork">
          <div class="photo-tile-fallback"><i data-lucide="image"></i></div>
        </div>
        <div class="photo-tile bg-artwork">
          <div class="photo-tile-fallback"><i data-lucide="image"></i></div>
        </div>
        <div class="photo-tile bg-artwork">
          <div class="photo-tile-fallback"><i data-lucide="image"></i></div>
        </div>
      </div>
    </div>

    <div class="keepsake-pager">
      <a href="#" class="prev">
        <div class="keepsake-pager-label"><i data-lucide="chevron-left"></i> Previous</div>
        <div class="keepsake-pager-title">Pre-K Certificate of Completion</div>
      </a>
      <a href="#" class="next">
        <div class="keepsake-pager-label">Next <i data-lucide="chevron-right"></i></div>
        <div class="keepsake-pager-title">First time I wrote my name</div>
      </a>
    </div>

  <% } else if (variant === 'sparse') { %>

    <a class="detail-back" href="/preview/keepsakes-mockup/overview"><i data-lucide="chevron-left"></i> All keepsakes</a>

    <div class="keepsake-hero">
      <div class="keepsake-hero-photo bg-memorabilia">
        <div class="keepsake-photo-fallback" style="padding: 2rem;">
          <div class="icon" style="width: 96px; height: 96px;">
            <i data-lucide="sparkles" style="width: 48px; height: 48px;"></i>
          </div>
          <div class="placeholder-text" style="font-size: 1rem;">Your photo of the<br>tooth goes here</div>
        </div>
      </div>
      <div>
        <div class="keepsake-hero-eyebrow"><i data-lucide="archive"></i> Memorabilia</div>
        <h1 class="keepsake-hero-title">First <em>lost tooth</em></h1>
        <p class="keepsake-hero-desc">Pulled out at the kitchen table after wiggling it for a week.</p>
      </div>
    </div>

    <div class="sparse-note">
      Every other section — meta strip, story, gallery, pager — stays hidden because nothing was filled in. The owner fills in only what they care about; empty fields never show.
    </div>

  <% } %>

  </div>
</section>

<script>
  if (window.lucide) window.lucide.createIcons();
</script>
</body>
</html>
