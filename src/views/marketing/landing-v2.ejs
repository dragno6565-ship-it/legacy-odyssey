          <input type="email" id="founderEmail" placeholder="you@example.com"
            style="width:100%;padding:0.8rem 1rem;background:#2C2416;border:1px solid rgba(184,147,90,0.4);border-radius:6px;color:#F8F2E6;font-size:0.95rem;box-sizing:border-box;margin-bottom:1.25rem;">
          <button id="founderSubmitBtn" style="width:100%;padding:1rem;background:#B8935A;color:#1E1812;border:none;border-radius:6px;font-weight:700;font-size:1rem;cursor:pointer;">
            Continue to Payment &rarr;
          </button>
          <p style="font-size:0.72rem;color:rgba(248,242,230,0.28);text-align:center;margin:0.75rem 0 0;">ℹ️ Please verify domain spelling above before completing purchase.</p>
        </div>

        <p id="founderModalError" style="display:none;color:#c0392b;font-size:0.85rem;margin:0.75rem 0 0;text-align:center;"></p>
