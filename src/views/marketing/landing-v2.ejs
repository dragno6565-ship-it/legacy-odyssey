      <button onclick="document.getElementById('founderModal').style.display='none'" style="position:absolute;top:12px;right:16px;background:none;border:none;color:#B8935A;font-size:1.4rem;cursor:pointer;">&times;</button>
      <h3 style="font-family:Georgia,serif;color:#F8F2E6;margin:0 0 0.2rem;font-size:1.4rem;" id="founderModalTitle">Start Your Family's Book</h3>
