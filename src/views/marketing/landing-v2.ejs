      <div id="founderModalForm">
        <div id="founderStep1">
          <div style="background:#2C2416;border:1px solid rgba(184,147,90,0.3);border-radius:6px;padding:0.5rem 0.85rem;margin-bottom:1rem;display:inline-block;">
            <span style="color:rgba(248,242,230,0.5);font-size:0.78rem;">Creating: </span>
            <span style="color:#B8935A;font-weight:700;font-size:0.78rem;">👶 Baby Book</span>
          </div>
          <label style="display:block;color:#B8935A;font-size:0.82rem;margin-bottom:0.5rem;letter-spacing:0.05em;">STEP 1 — CHOOSE YOUR DOMAIN</label>
          <p style="font-size:0.8rem;color:rgba(248,242,230,0.55);margin:0 0 0.75rem;">This is the .com address your baby book will live at. It's permanent — check spelling carefully.</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.5rem;align-items:stretch;">
            <input type="text" id="founderDomainSearch" placeholder="your-childs-name" autocomplete="off" spellcheck="false"
              style="flex:1 1 140px;min-width:0;padding:0.8rem 1rem;background:#2C2416;border:1px solid rgba(184,147,90,0.4);border-radius:6px;color:#F8F2E6;font-size:0.95rem;box-sizing:border-box;">
            <span style="display:flex;align-items:center;color:rgba(248,242,230,0.4);font-size:0.9rem;white-space:nowrap;">.com</span>
            <button type="button" id="founderDomainSearchBtn" style="flex:0 0 auto;padding:0.8rem 1.25rem;background:#B8935A;color:#1E1812;border:none;border-radius:6px;font-weight:700;font-size:0.9rem;cursor:pointer;white-space:nowrap;">Check</button>
          </div>
          <div id="founderDomainResult" style="min-height:36px;font-size:0.88rem;margin-bottom:0.75rem;"></div>
          <div id="founderDomainConfirmed" style="display:none;background:#1a2e1a;border:1px solid #4a8a4a;border-radius:6px;padding:0.75rem 1rem;margin-bottom:1rem;">
            <span style="color:#7cb87c;font-weight:700;">&#10003; </span>
            <span id="founderDomainConfirmedName" style="color:#F8F2E6;font-weight:600;"></span>
            <button type="button" id="founderDomainChangeBtn" style="margin-left:0.75rem;background:none;border:none;color:#B8935A;font-size:0.8rem;cursor:pointer;text-decoration:underline;">Change</button>
          </div>
          <button type="button" id="founderNextBtn" disabled style="width:100%;padding:0.9rem;background:#4a3f2f;color:#8a7a5a;border:none;border-radius:6px;font-weight:700;font-size:1rem;cursor:not-allowed;transition:all 0.2s;">
            Next: Enter Your Email &rarr;
          </button>
        </div>

        <div id="founderStep2" style="display:none;">
          <button type="button" onclick="founderGoBack()" style="background:none;border:none;color:#B8935A;font-size:0.85rem;cursor:pointer;padding:0;margin-bottom:1rem;">&#8592; Back</button>
          <div style="background:#2C2416;border:1px solid rgba(184,147,90,0.3);border-radius:6px;padding:0.75rem 1rem;margin-bottom:1.25rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <span><span style="color:rgba(248,242,230,0.5);font-size:0.8rem;">Type: </span><span id="founderStep2TypeLabel" style="color:#B8935A;font-weight:700;font-size:0.8rem;"></span></span>
            <span><span style="color:rgba(248,242,230,0.5);font-size:0.8rem;">Domain: </span><span id="founderStep2Domain" style="color:#B8935A;font-weight:700;font-size:0.8rem;"></span></span>
          </div>
          <div id="founderStep2Summary" style="background:#1a2e1a;border:1px solid #4a8a4a;border-radius:8px;padding:1rem;margin-bottom:1.25rem;">
            <div style="color:#7cb87c;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;margin-bottom:0.6rem;">✓ YOUR ORDER</div>
            <div style="display:flex;flex-direction:column;gap:0.35rem;">
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <span id="step3TypeSummary" style="color:#F8F2E6;font-size:0.85rem;">Baby Book</span>
                <span id="step3PriceSummary" style="color:#B8935A;font-weight:700;font-size:0.85rem;">$29 first year</span>
              </div>
              <div style="color:#B8935A;font-size:0.82rem;">🌐 <span id="step3DomainSummary" style="font-weight:600;"></span></div>
              <div style="color:rgba(248,242,230,0.45);font-size:0.74rem;margin-top:0.2rem;">Unlimited photos · milestones · letters · recipes · SSL hosting</div>
              <div style="color:rgba(248,242,230,0.35);font-size:0.72rem;">Renews at $49.99/yr after first year — cancel anytime</div>
