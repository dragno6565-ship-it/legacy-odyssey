<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Family Recipes — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #faf7f2; color: #2c2416; min-height: 100vh; padding: 2rem 1rem 5rem; }
    .wrap { max-width: 820px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: #4a3f30; margin-bottom: 1.5rem; }
    .breadcrumb a { color: #c8a96e; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    h1 { font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 600; margin-bottom: 0.25rem; }
    .section-desc { color: #4a3f30; font-size: 0.92rem; margin-bottom: 2rem; }
    .flash { padding: 0.85rem 1.1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1.25rem; }
    .flash-success { background: #f0faf0; border: 1px solid #a8d5a8; color: #2e7d32; }
    .flash-error { background: #fdf2f2; border: 1px solid #e0b4b4; color: #c0392b; }

    .recipes-block { background: #fff; border-radius: 12px; border: 1px solid #f0ebe3; box-shadow: 0 2px 8px rgba(0,0,0,0.05); padding: 1.5rem; margin-bottom: 1.25rem; }
    .recipe-row {
      display: flex; align-items: center; gap: 1rem;
      padding: 0.85rem 1rem; background: #faf7f2; border-radius: 8px; margin-bottom: 0.5rem;
      text-decoration: none; color: inherit; transition: background 0.15s;
    }
    .recipe-row:hover { background: #f3eddf; }
    .recipe-thumb { width: 64px; height: 64px; border-radius: 6px; background: #ece4d6; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
    .recipe-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .recipe-thumb-empty { color: #c8a96e; font-size: 1.6rem; }
    .recipe-info { flex: 1; min-width: 0; }
    .recipe-title { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 600; color: #2c2416; line-height: 1.3; }
    .recipe-meta { font-size: 0.78rem; color: #4a3f30; margin-top: 0.15rem; }
    .recipe-meta .dot { margin: 0 0.4em; opacity: 0.5; }
    .recipe-chevron { color: #c8a96e; font-size: 1.3rem; flex-shrink: 0; }

    .add-form { display: flex; gap: 0.5rem; margin-top: 1rem; }
    .add-form input[type="text"] { flex: 1; padding: 0.65rem 0.95rem; border: 1.5px solid #e0d5c4; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.95rem; background: #fff; }
    .add-form input[type="text"]:focus { outline: none; border-color: #c8a96e; box-shadow: 0 0 0 3px rgba(200,169,110,0.12); }
    .btn-add { background: #c8a96e; color: #fff; border: none; padding: 0.65rem 1.25rem; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.95rem; font-weight: 600; cursor: pointer; }
    .btn-add:hover { background: #b08e4a; }

    .empty-state { text-align: center; padding: 2rem; color: #4a3f30; font-size: 0.92rem; font-style: italic; }
    .footer-actions { margin-top: 2rem; }
    .btn-back { color: #4a3f30; text-decoration: none; font-size: 0.9rem; }
    .btn-back:hover { color: #2c2416; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="breadcrumb">
      <a href="/account/dashboard">Account</a> &nbsp;/&nbsp;
      <a href="/account/book">My Book</a> &nbsp;/&nbsp;
      Family Recipes
    </div>

    <h1>Family Recipes</h1>
    <p class="section-desc">The dishes that mean home. Each recipe gets its own page with photos, a story, ingredients, and step-by-step directions.</p>

    <% if (success) { %><div class="flash flash-success">✓ Saved.</div><% } %>
    <% if (error) { %><div class="flash flash-error">Something went wrong (<%= error %>).</div><% } %>

    <div class="recipes-block">
      <% if ((recipes || []).length === 0) { %>
        <div class="empty-state">No recipes yet. Add your first one below.</div>
      <% } %>

      <% (recipes || []).forEach(function(r) { %>
        <a class="recipe-row" href="/account/book/recipes/edit/<%= r.id %>">
          <div class="recipe-thumb">
            <% if (r.photoUrl) { %>
              <img src="<%= r.photoUrl %>" alt="">
            <% } else { %>
              <span class="recipe-thumb-empty">🍴</span>
            <% } %>
          </div>
          <div class="recipe-info">
            <div class="recipe-title"><%= r.title || 'Untitled' %></div>
            <div class="recipe-meta">
              <% if (r.origin_label) { %><%= r.origin_label %><span class="dot">·</span><% } %>
              <%= r.photo_count %> photo<%= r.photo_count === 1 ? '' : 's' %>
              <% if (r.ingredientCount > 0) { %><span class="dot">·</span><%= r.ingredientCount %> ingredient<%= r.ingredientCount === 1 ? '' : 's' %><% } %>
              <% if (r.stepCount > 0) { %><span class="dot">·</span><%= r.stepCount %> step<%= r.stepCount === 1 ? '' : 's' %><% } %>
              <% if (r.story) { %><span class="dot">·</span>Has story<% } %>
            </div>
          </div>
          <div class="recipe-chevron">›</div>
        </a>
      <% }); %>

      <form method="POST" action="/account/book/recipes/new" class="add-form">
        <input type="text" name="title" placeholder="Add a recipe (e.g. Grandma's Pancakes)" required>
        <button type="submit" class="btn-add">+ Add</button>
      </form>
    </div>

    <div class="footer-actions">
      <a class="btn-back" href="/account/book">← Back to my book</a>
    </div>
  </div>
</body>
</html>
