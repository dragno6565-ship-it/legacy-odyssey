<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Rewardful affiliate tracking (Friends of Legacy Odyssey) -->
  <script>(function(w,r){w._rwq=r;w[r]=w[r]||function(){(w[r].q=w[r].q||[]).push(arguments)}})(window,'rewardful');</script>
  <script async src='https://r.wdfl.co/rw.js' data-rewardful='0a0312'></script>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout — Give the Gift · Legacy Odyssey</title>
  <meta name="robots" content="noindex">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://js.stripe.com/v3/"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; font-family: 'Jost', system-ui, sans-serif; background: #faf7f2; color: #2c2416; line-height: 1.5; }
    a { color: #b08e4a; }
    .gc-nav { height: 60px; display: flex; align-items: center; justify-content: center; background: #1a1510; }
    .gc-nav a { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 500; color: #faf7f2; text-decoration: none; letter-spacing: 0.5px; }
    .gc-nav a span { color: #c8a96e; }
    .gc-wrap { max-width: 880px; margin: 0 auto; padding: 40px 20px 80px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
    @media (max-width: 760px) { .gc-wrap { grid-template-columns: 1fr; gap: 28px; } }

    .gc-card { background: #fff; border: 1px solid #e0d5c4; border-radius: 14px; padding: 30px 28px; box-shadow: 0 20px 50px rgba(26,21,16,0.08); }
    .gc-eyebrow { font-size: 12px; letter-spacing: 3px; text-transform: uppercase; color: #c8a96e; font-weight: 600; margin-bottom: 10px; }
    .gc-h { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 500; margin: 0 0 6px; color: #1a1510; }
    .gc-sub { font-size: 14px; color: #5e564a; margin: 0 0 22px; }

    /* Summary (left) */
    .gc-summary-row { display: flex; justify-content: space-between; align-items: baseline; padding: 12px 0; border-bottom: 1px solid #f0e8dc; }
    .gc-summary-row:last-child { border-bottom: none; }
    .gc-summary-label { font-size: 14px; color: #2c2416; font-weight: 500; }
    .gc-summary-hint { font-size: 12px; color: #8a7e6b; }
    .gc-summary-price { font-family: 'Cormorant Garamond', serif; font-size: 26px; color: #1a1510; }
    .gc-total { display: flex; justify-content: space-between; align-items: baseline; margin-top: 14px; padding-top: 16px; border-top: 2px solid #1a1510; }
    .gc-total-num { font-family: 'Cormorant Garamond', serif; font-size: 34px; color: #1a1510; }
    .gc-includes { list-style: none; padding: 0; margin: 22px 0 0; }
    .gc-includes li { display: flex; gap: 10px; font-size: 13.5px; color: #5e564a; padding: 6px 0; }
    .gc-includes svg { width: 16px; height: 16px; color: #c8a96e; flex-shrink: 0; margin-top: 2px; }

    /* Plan toggle */
    .gc-plans { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
    @media (max-width: 420px) { .gc-plans { grid-template-columns: 1fr; } }
    .gc-plan { position: relative; cursor: pointer; border: 1px solid #e0d5c4; border-radius: 10px; padding: 14px; transition: all .15s; }
    .gc-plan:hover { border-color: #c8a96e; }
    .gc-plan.checked { border-color: #c8a96e; background: rgba(200,169,110,0.08); }
    .gc-plan input { position: absolute; opacity: 0; }
    .gc-plan-name { font-size: 13px; font-weight: 600; color: #1a1510; }
    .gc-plan-price { font-family: 'Cormorant Garamond', serif; font-size: 24px; color: #b08e4a; margin-top: 2px; }
    .gc-plan-hint { font-size: 11px; color: #8a7e6b; margin-top: 2px; }

    /* Form */
    .gc-field { margin-bottom: 14px; }
    .gc-field label { display: block; font-size: 12px; letter-spacing: 0.4px; text-transform: uppercase; color: #8a7e6b; font-weight: 500; margin-bottom: 6px; }
    .gc-field input, .gc-field textarea, .gc-field select {
      width: 100%; padding: 11px 13px; background: #fff; border: 1px solid #e0d5c4; border-radius: 6px;
      color: #2c2416; font-family: 'Jost', sans-serif; font-size: 14px;
    }
    .gc-field input:focus, .gc-field textarea:focus { outline: none; border-color: #c8a96e; box-shadow: 0 0 0 1px #c8a96e; }
    .gc-field textarea { min-height: 70px; resize: vertical; }
    .gc-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    @media (max-width: 520px) { .gc-row2 { grid-template-columns: 1fr; } }
    .gc-radios { display: grid; gap: 8px; }
    .gc-radio { display: flex; gap: 10px; align-items: flex-start; padding: 10px 12px; border: 1px solid #e0d5c4; border-radius: 6px; cursor: pointer; }
    .gc-radio.checked { border-color: #c8a96e; background: rgba(200,169,110,0.06); }
    .gc-radio input { margin-top: 3px; accent-color: #c8a96e; }
    .gc-radio-label { font-size: 13.5px; font-weight: 500; color: #2c2416; }
    .gc-radio-hint { font-size: 12px; color: #8a7e6b; }
    #gcScheduledRow { display: none; }
    #gcScheduledRow.show { display: block; }

    .gc-btn {
      width: 100%; padding: 15px; background: #c8a96e; color: #1a1510; border: none; border-radius: 6px;
      font-size: 14px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; cursor: pointer;
      transition: background .2s; margin-top: 8px; font-family: inherit;
    }
    .gc-btn:hover { background: #d4bb8a; }
    .gc-btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .gc-msg { color: #c0392b; font-size: 13px; min-height: 16px; margin: 10px 0 0; }
    .gc-trust { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 14px; color: #8a7e6b; font-size: 12px; }
    .gc-trust svg { width: 14px; height: 14px; }
    .gc-back { display: inline-block; margin-top: 14px; font-size: 13px; color: #8a7e6b; background: none; border: none; cursor: pointer; text-decoration: underline; }

    #gcPaymentStep { display: none; }
    #gcPaymentElement { margin: 8px 0 4px; }
    .gc-notice { background: rgba(200,169,110,0.1); border: 1px solid rgba(200,169,110,0.4); border-radius: 10px; padding: 18px 20px; font-size: 14px; color: #5e564a; }
  </style>
</head>
<body>
  <nav class="gc-nav"><a href="/">Legacy <span>Odyssey</span></a></nav>

  <% if (!publishableKey) { %>
    <div class="gc-wrap" style="grid-template-columns:1fr;max-width:560px;">
      <div class="gc-card gc-notice">
        Our on-brand checkout isn't switched on yet. Please use the
        <a href="/gift">standard gift checkout</a> for now.
      </div>
    </div>
  <% } else { %>

  <div class="gc-wrap">
    <!-- LEFT: order summary -->
    <div class="gc-card">
      <div class="gc-eyebrow">Your gift</div>
      <h1 class="gc-h">Order summary</h1>
      <p class="gc-sub">A real .com and a beautifully designed digital baby book.</p>

      <div class="gc-plans">
        <label class="gc-plan checked" data-plan="annual">
          <input type="radio" name="gcPlan" value="annual" checked>
          <div class="gc-plan-name">One Year</div>
          <div class="gc-plan-price">$29</div>
          <div class="gc-plan-hint">One full year, intro price</div>
        </label>
        <label class="gc-plan" data-plan="childhood">
          <input type="radio" name="gcPlan" value="childhood">
          <div class="gc-plan-name">Entire Childhood</div>
          <div class="gc-plan-price">$450</div>
          <div class="gc-plan-hint">All 18 years · no renewals</div>
        </label>
      </div>

      <div class="gc-summary-row">
        <div>
          <div class="gc-summary-label" id="gcSummaryName">Legacy Odyssey — 1 Year Gift</div>
          <div class="gc-summary-hint" id="gcSummaryHint">One-time · includes one full year</div>
        </div>
        <div class="gc-summary-price" id="gcSummaryPrice">$29</div>
      </div>
      <div class="gc-total">
        <div class="gc-summary-label">Total today</div>
        <div class="gc-total-num" id="gcTotal">$29</div>
      </div>

      <ul class="gc-includes">
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Their own real .com domain</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>A beautifully designed digital baby book</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>A printable certificate emailed to you</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>No card stays on you afterward</li>
      </ul>
    </div>

    <!-- RIGHT: details → payment -->
    <div class="gc-card">
      <!-- STEP 1: details -->
      <div id="gcDetailsStep">
        <div class="gc-eyebrow">Step 1 of 2</div>
        <h2 class="gc-h">Gift details</h2>
        <p class="gc-sub">We'll email you a printable certificate either way.</p>

        <div class="gc-row2">
          <div class="gc-field"><label for="gcBuyerEmail">Your email</label><input type="email" id="gcBuyerEmail" placeholder="you@example.com" required></div>
          <div class="gc-field"><label for="gcBuyerName">Your name</label><input type="text" id="gcBuyerName" placeholder="Optional"></div>
        </div>
        <div class="gc-field"><label for="gcRecipientName">Recipient's name</label><input type="text" id="gcRecipientName" placeholder="e.g. Sarah Smith" required></div>

        <div class="gc-field">
          <label>How would you like to deliver it?</label>
          <div class="gc-radios">
            <label class="gc-radio checked"><input type="radio" name="gcDelivery" value="email_now" checked><div><div class="gc-radio-label">Email it now</div><div class="gc-radio-hint">They get it the moment payment clears.</div></div></label>
            <label class="gc-radio"><input type="radio" name="gcDelivery" value="email_scheduled"><div><div class="gc-radio-label">Schedule the email</div><div class="gc-radio-hint">Pick a date — perfect for a shower or due date.</div></div></label>
            <label class="gc-radio"><input type="radio" name="gcDelivery" value="print"><div><div class="gc-radio-label">I'll give it to them myself</div><div class="gc-radio-hint">No email — you get the printable certificate.</div></div></label>
          </div>
        </div>
        <div class="gc-field" id="gcScheduledRow"><label for="gcScheduledDate">Send on this date</label><input type="date" id="gcScheduledDate"></div>
        <div class="gc-field" id="gcRecipientEmailRow"><label for="gcRecipientEmail">Recipient's email</label><input type="email" id="gcRecipientEmail" placeholder="them@example.com"></div>
        <div class="gc-field"><label for="gcMessage">Personal note (optional)</label><textarea id="gcMessage" placeholder="Write something they'll see when they redeem…"></textarea></div>

        <button type="button" class="gc-btn" id="gcContinueBtn">Continue to Payment →</button>
        <p class="gc-msg" id="gcDetailsMsg"></p>
      </div>

      <!-- STEP 2: payment -->
      <div id="gcPaymentStep">
        <div class="gc-eyebrow">Step 2 of 2</div>
        <h2 class="gc-h">Payment</h2>
        <p class="gc-sub">Paying <strong id="gcPayAmount">$29</strong> — one-time.</p>
        <div id="gcPaymentElement"></div>
        <button type="button" class="gc-btn" id="gcPayBtn">Pay <span id="gcPayBtnAmount">$29</span></button>
        <p class="gc-msg" id="gcPayMsg"></p>
        <div class="gc-trust">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Secured by Stripe
        </div>
        <button type="button" class="gc-back" id="gcBackBtn">← Edit gift details</button>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var PUBLISHABLE_KEY = <%- JSON.stringify(publishableKey) %>;
      var APP_DOMAIN = <%- JSON.stringify(appDomain) %>;
      var INITIAL_PLAN = <%- JSON.stringify(initialPlan) %>;

      var stripe = Stripe(PUBLISHABLE_KEY);
      var elements = null;

      function $(id) { return document.getElementById(id); }
      function currentPlan() {
        var c = document.querySelector('input[name="gcPlan"]:checked');
        return c ? c.value : 'annual';
      }
      function amountLabel() { return currentPlan() === 'childhood' ? '$450' : '$29'; }

      // ----- Plan toggle + summary -----
      function syncPlan() {
        var isCh = currentPlan() === 'childhood';
        document.querySelectorAll('.gc-plan').forEach(function (el) {
          el.classList.toggle('checked', el.querySelector('input').checked);
        });
        $('gcSummaryName').textContent = isCh ? 'Legacy Odyssey — Entire Childhood Gift' : 'Legacy Odyssey — 1 Year Gift';
        $('gcSummaryHint').textContent = isCh ? 'One-time · covers all 18 years' : 'One-time · includes one full year';
        $('gcSummaryPrice').textContent = amountLabel();
        $('gcTotal').textContent = amountLabel();
        $('gcPayAmount').textContent = amountLabel();
        $('gcPayBtnAmount').textContent = amountLabel();
      }
      document.querySelectorAll('input[name="gcPlan"]').forEach(function (r) { r.addEventListener('change', syncPlan); });
      if (INITIAL_PLAN === 'childhood') { document.querySelector('input[name="gcPlan"][value="childhood"]').checked = true; }
      syncPlan();

      // ----- Delivery method UI -----
      function syncDelivery() {
        var sel = document.querySelector('input[name="gcDelivery"]:checked').value;
        document.querySelectorAll('.gc-radio').forEach(function (el) { el.classList.remove('checked'); });
        document.querySelector('input[name="gcDelivery"]:checked').closest('.gc-radio').classList.add('checked');
        $('gcScheduledRow').classList.toggle('show', sel === 'email_scheduled');
        $('gcRecipientEmailRow').style.display = (sel === 'print') ? 'none' : '';
      }
      document.querySelectorAll('input[name="gcDelivery"]').forEach(function (r) { r.addEventListener('change', syncDelivery); });
      syncDelivery();

      // ----- Step 1 → create PaymentIntent → mount Payment Element -----
      $('gcContinueBtn').addEventListener('click', async function () {
        var msg = $('gcDetailsMsg');
        msg.textContent = '';
        var delivery = document.querySelector('input[name="gcDelivery"]:checked').value;
        var buyerEmail = $('gcBuyerEmail').value.trim();
        var recipientName = $('gcRecipientName').value.trim();
        var recipientEmail = delivery === 'print' ? '' : $('gcRecipientEmail').value.trim();
        if (!buyerEmail) { msg.textContent = 'Please enter your email.'; return; }
        if (!recipientName) { msg.textContent = "Please enter the recipient's name."; return; }
        if (delivery !== 'print' && !recipientEmail) { msg.textContent = "Please enter the recipient's email."; return; }

        var btn = $('gcContinueBtn');
        btn.disabled = true; btn.textContent = 'Preparing…';

        var payload = {
          buyerEmail: buyerEmail,
          buyerName: $('gcBuyerName').value.trim(),
          recipientName: recipientName,
          recipientEmail: recipientEmail,
          giftMessage: $('gcMessage').value,
          deliveryMethod: delivery,
          scheduledDate: delivery === 'email_scheduled' ? $('gcScheduledDate').value : null,
          plan: currentPlan(),
        };

        // Conversion tracking (if pixels present)
        try {
          var amt = currentPlan() === 'childhood' ? 450 : 29;
          if (typeof fbq !== 'undefined') fbq('track', 'InitiateCheckout', { value: amt, currency: 'USD', content_category: 'gift' });
          if (typeof pintrk !== 'undefined') pintrk('track', 'checkout', { value: amt, currency: 'USD' });
        } catch (e) {}

        try {
          var res = await fetch('/api/stripe/create-gift-payment-intent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          var data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Could not start checkout.');

          var appearance = {
            theme: 'flat',
            variables: {
              colorPrimary: '#c8a96e',
              colorBackground: '#ffffff',
              colorText: '#2c2416',
              colorTextSecondary: '#8a7e6b',
              colorDanger: '#c0392b',
              fontFamily: 'Jost, system-ui, sans-serif',
              borderRadius: '6px',
              spacingUnit: '4px',
            },
            rules: {
              '.Label': { color: '#8a7e6b', fontWeight: '500', textTransform: 'uppercase', fontSize: '12px', letterSpacing: '0.4px' },
              '.Input': { borderColor: '#e0d5c4', boxShadow: 'none', padding: '11px 13px' },
              '.Input:focus': { borderColor: '#c8a96e', boxShadow: '0 0 0 1px #c8a96e' },
              '.Tab': { borderColor: '#e0d5c4' },
              '.Tab:hover': { borderColor: '#c8a96e' },
              '.Tab--selected': { borderColor: '#c8a96e', boxShadow: '0 0 0 1px #c8a96e' },
            },
          };
          elements = stripe.elements({
            clientSecret: data.clientSecret,
            appearance: appearance,
            fonts: [{ cssSrc: 'https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600&display=swap' }],
          });
          var paymentElement = elements.create('payment', {
            defaultValues: { billingDetails: { email: buyerEmail } },
          });
          paymentElement.mount('#gcPaymentElement');

          $('gcDetailsStep').style.display = 'none';
          $('gcPaymentStep').style.display = 'block';
        } catch (err) {
          msg.textContent = err.message;
          btn.disabled = false; btn.textContent = 'Continue to Payment →';
        }
      });

      // ----- Step 2: confirm payment -----
      $('gcPayBtn').addEventListener('click', async function () {
        if (!elements) return;
        var btn = $('gcPayBtn');
        var msg = $('gcPayMsg');
        msg.textContent = '';
        btn.disabled = true; btn.textContent = 'Processing…';
        var result = await stripe.confirmPayment({
          elements: elements,
          confirmParams: { return_url: 'https://' + APP_DOMAIN + '/gift/thank-you' },
        });
        // confirmPayment only returns here on immediate error; success redirects.
        if (result.error) {
          msg.textContent = result.error.message || 'Payment could not be completed.';
          btn.disabled = false; btn.textContent = 'Pay ' + amountLabel();
        }
      });

      $('gcBackBtn').addEventListener('click', function () {
        $('gcPaymentStep').style.display = 'none';
        $('gcDetailsStep').style.display = 'block';
        var cb = $('gcContinueBtn'); cb.disabled = false; cb.textContent = 'Continue to Payment →';
      });

      // ----- Prefill from the /gift form handoff (single data entry on cutover) -----
      (function () {
        var raw;
        try { raw = sessionStorage.getItem('lo_gift'); sessionStorage.removeItem('lo_gift'); } catch (e) { raw = null; }
        if (!raw) return;
        var d; try { d = JSON.parse(raw); } catch (e) { return; }
        if (!d) return;
        var planRadio = document.querySelector('input[name="gcPlan"][value="' + (d.plan === 'childhood' ? 'childhood' : 'annual') + '"]');
        if (planRadio) planRadio.checked = true;
        syncPlan();
        if (d.buyerEmail) $('gcBuyerEmail').value = d.buyerEmail;
        if (d.buyerName) $('gcBuyerName').value = d.buyerName;
        if (d.recipientName) $('gcRecipientName').value = d.recipientName;
        if (d.recipientEmail) $('gcRecipientEmail').value = d.recipientEmail;
        if (d.giftMessage) $('gcMessage').value = d.giftMessage;
        var dm = d.deliveryMethod || 'email_now';
        var dr = document.querySelector('input[name="gcDelivery"][value="' + dm + '"]');
        if (dr) dr.checked = true;
        syncDelivery();
        if (d.scheduledDate) $('gcScheduledDate').value = d.scheduledDate;
        // Auto-advance straight to payment when the handed-off details are complete.
        if (d.buyerEmail && d.recipientName && (dm === 'print' || d.recipientEmail)) {
          $('gcContinueBtn').click();
        }
      })();
    })();
  </script>
  <% } %>
</body>
</html>
