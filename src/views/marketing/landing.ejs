  <script>
    document.getElementById('contactForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const form = e.target;
      const btn = form.querySelector('.contact-submit');
      const success = document.getElementById('contactSuccess');
      const error = document.getElementById('contactError');
      success.style.display = 'none';
      error.style.display = 'none';
      btn.disabled = true;
      btn.textContent = 'Sending...';
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: form.name.value,
            email: form.email.value,
            topic: form.topic.value,
            message: form.message.value,
          }),
        });
        if (res.ok) {
          success.style.display = 'block';
          pintrk('track', 'lead');
          form.reset();
        } else {
          error.style.display = 'block';
        }
      } catch (err) {
        error.style.display = 'block';
      }
      btn.disabled = false;
      btn.textContent = 'Send Message';
    });
  </script>
  <script>
    document.getElementById('waitlistForm')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const email = document.getElementById('waitlistEmail').value.trim();
      const btn = document.getElementById('waitlistBtn');
      const success = document.getElementById('waitlistSuccess');

      btn.textContent = 'Adding you...';
      btn.disabled = true;

      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'hero' })
        });
        const data = await res.json();

        if (data.success) {
          document.getElementById('waitlistForm').style.display = 'none';
          success.style.display = 'block';
          if (typeof pintrk !== 'undefined') pintrk('track', 'lead');
          if (typeof fbq !== 'undefined') fbq('track', 'Lead');
        } else {
          btn.textContent = 'Get Early Access';
          btn.disabled = false;
          alert(data.message || 'Something went wrong. Please try again.');
        }
      } catch (err) {
        btn.textContent = 'Get Early Access';
        btn.disabled = false;
        alert('Something went wrong. Please try again.');
      }
    });
  </script>
  <script>
    // Founder spot counter + modal wiring
    (async function() {
      let founderSoldOut = false;
      try {
        const res = await fetch('/api/stripe/founder-spots');
        const data = await res.json();
        const remaining = data.remaining;
        const pct = (remaining / data.total) * 100;
        founderSoldOut = data.soldOut;

        // Hero counter
        document.getElementById('spotsRemaining').textContent = remaining;
        document.getElementById('spotsBarFill').style.width = pct + '%';

        // Card counter
        const cardText = document.getElementById('founderCardSpotsText');
        if (data.soldOut) {
          if (cardText) cardText.textContent = 'All founder spots claimed';
          const btn = document.getElementById('founderCheckoutBtn');
          if (btn) { btn.textContent = 'Sold Out'; btn.disabled = true; btn.style.opacity = '0.5'; }
          // Hero button
          const heroBtn = document.getElementById('founderBtn');
          if (heroBtn) { heroBtn.textContent = 'Founder Spots Sold Out — Join Waitlist'; heroBtn.href = '#waitlist'; heroBtn.style.background = '#6b5b45'; }
        } else {
          if (cardText) cardText.textContent = remaining + ' of 100 founder spots remaining';
          const heroBtn = document.getElementById('founderBtn');
          if (heroBtn) heroBtn.href = '#pricing';
        }
      } catch (e) {
        const spots = document.getElementById('founderSpots');
        if (spots) spots.style.display = 'none';
        const cardText = document.getElementById('founderCardSpotsText');
        if (cardText) cardText.style.display = 'none';
      }

      // Open modal on founder card button click
      document.getElementById('founderCheckoutBtn')?.addEventListener('click', function() {
        if (founderSoldOut) return;
        document.getElementById('founderModal').style.display = 'flex';
        // Pre-fill email from waitlist form if already entered
        const waitlistEmail = document.getElementById('waitlistEmail')?.value;
        if (waitlistEmail) document.getElementById('founderEmail').value = waitlistEmail;
      });

      // Founder checkout submit
      document.getElementById('founderSubmitBtn')?.addEventListener('click', async function() {
        const email = document.getElementById('founderEmail').value.trim();
        const domain = document.getElementById('founderDomain').value.trim();
        const btn = document.getElementById('founderSubmitBtn');
        const errEl = document.getElementById('founderModalError');
        errEl.style.display = 'none';

        if (!email || !email.includes('@')) {
          errEl.textContent = 'Please enter a valid email address.';
          errEl.style.display = 'block';
          return;
        }

        btn.textContent = 'Redirecting to payment...';
        btn.disabled = true;

        try {
          const res = await fetch('/api/stripe/create-founder-checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, domain: domain || undefined }),
          });
          const data = await res.json();

          if (data.soldOut) {
            document.getElementById('founderModalSoldOut').style.display = 'block';
            document.getElementById('founderModalForm').style.display = 'none';
            return;
          }
          if (data.url) {
            if (typeof fbq !== 'undefined') fbq('track', 'InitiateCheckout', { value: 29, currency: 'USD' });
            if (typeof pintrk !== 'undefined') pintrk('track', 'checkout', { value: 29, currency: 'USD' });
            window.location.href = data.url;
          } else {
            throw new Error(data.error || 'Something went wrong');
          }
        } catch (err) {
          errEl.textContent = err.message || 'Something went wrong. Please try again.';
          errEl.style.display = 'block';
          btn.textContent = 'Continue to Payment →';
          btn.disabled = false;
        }
      });

      // Close modal on backdrop click
      document.getElementById('founderModal')?.addEventListener('click', function(e) {
        if (e.target === this) this.style.display = 'none';
      });
    })();
  </script>

