  <script>
    // Toggle scheduled-date row based on selected delivery method.
    const radios = document.querySelectorAll('input[name="deliveryMethod"]');
    const scheduledRow = document.getElementById('lgScheduledDateRow');
    const recipientEmailRow = document.getElementById('lgRecipientEmailRow');
    const recipientEmailInput = document.getElementById('lgRecipientEmail');

    function syncDeliveryUI() {
      const selected = document.querySelector('input[name="deliveryMethod"]:checked').value;
      // Visual selected state on radio cards
      document.querySelectorAll('.lg-form-radio').forEach(el => el.classList.remove('checked'));
      document.querySelector('input[name="deliveryMethod"]:checked').closest('.lg-form-radio').classList.add('checked');
      // Show schedule date only when scheduled
      if (selected === 'email_scheduled') {
        scheduledRow.classList.add('show');
      } else {
        scheduledRow.classList.remove('show');
      }
      // Recipient email is only needed when we're the ones emailing them.
      const needsEmail = (selected === 'email_now' || selected === 'email_scheduled');
      recipientEmailRow.style.display = needsEmail ? '' : 'none';
      recipientEmailInput.required = needsEmail;
    }
    radios.forEach(r => r.addEventListener('change', syncDeliveryUI));
    syncDeliveryUI();

    // ----- Gift tier (plan) selector: One Year ($29) vs Entire Childhood ($450) -----
    const planRadios = document.querySelectorAll('input[name="giftPlan"]');
    function currentGiftPlan() {
      const checked = document.querySelector('input[name="giftPlan"]:checked');
      return checked ? checked.value : 'annual';
    }
    function giftButtonLabel() {
      return currentGiftPlan() === 'childhood' ? 'Give the Gift — $450' : 'Give the Gift — $29';
    }
    function syncPlanUI() {
      const isChildhood = currentGiftPlan() === 'childhood';
      document.querySelectorAll('.lg-plan-opt').forEach(el => {
        el.classList.toggle('checked', el.querySelector('input').checked);
      });
      document.getElementById('lgPriceNum').textContent = isChildhood ? '$450' : '$29';
      document.getElementById('lgPricePeriod').textContent = isChildhood ? 'one-time · 18 years' : 'one-time · one year';
      document.getElementById('lgBadge').textContent = isChildhood ? 'Best Value' : 'Introductory Offer';
      document.getElementById('lgRenewalNote').innerHTML = isChildhood
        ? 'One payment covers all 18 years of childhood — <strong>no renewals, ever.</strong> The recipient picks their own .com when they redeem.'
        : 'Introductory price · Includes one full year. After that, the recipient adds their own card to keep going at $49.99/year — or lets it lapse with no charges to anyone.';
      document.getElementById('lgUrgency').textContent = isChildhood
        ? 'One payment now — never another charge across all 18 years.'
        : "$29 introductory pricing — locked in for the recipient's full first year.";
      document.getElementById('lgGiftBtn').textContent = giftButtonLabel();
    }
    planRadios.forEach(r => r.addEventListener('change', syncPlanUI));
    syncPlanUI();

    // ----- Scroll reveal -----
    (function () {
      const els = document.querySelectorAll('.lg-reveal');
      if (!('IntersectionObserver' in window) || !els.length) {
        els.forEach(el => el.classList.add('in'));
        return;
      }
      const io = new IntersectionObserver((entries) => {
        entries.forEach(en => {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      els.forEach(el => io.observe(el));
    })();

    // Form submit
    document.getElementById('lgGiftForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('lgGiftBtn');
      const errorEl = document.getElementById('lgGiftError');
      errorEl.textContent = '';
      btn.disabled = true;
      btn.textContent = 'Processing…';

      const deliveryMethod = document.querySelector('input[name="deliveryMethod"]:checked').value;
      const plan = currentGiftPlan();
      const payload = {
        buyerEmail: document.getElementById('lgBuyerEmail').value,
        buyerName: document.getElementById('lgBuyerName').value,
        recipientName: document.getElementById('lgRecipientName').value,
        recipientEmail: deliveryMethod === 'print' ? '' : document.getElementById('lgRecipientEmail').value,
        giftMessage: document.getElementById('lgGiftMessage').value,
        deliveryMethod: deliveryMethod,
        scheduledDate: deliveryMethod === 'email_scheduled' ? document.getElementById('lgScheduledDate').value : null,
        plan: plan,
      };

      // Conversion tracking — gift checkout initiated (gated by consent via tracking partial)
      try {
        const amt = plan === 'childhood' ? 450 : 29;
        if (typeof fbq !== 'undefined') fbq('track', 'InitiateCheckout', { value: amt, currency: 'USD', content_category: 'gift' });
        if (typeof pintrk !== 'undefined') pintrk('track', 'checkout', { value: amt, currency: 'USD' });
      } catch (e) {}

      // Cut over to the on-brand embedded checkout (Payment Element): carry the
      // details the buyer just entered to /gift/checkout so they don't re-type
      // them, then land straight on the branded payment step. (Replaces the old
      // hosted Stripe Checkout redirect.)
      try { sessionStorage.setItem('lo_gift', JSON.stringify(payload)); } catch (e) {}
      window.location.href = '/gift/checkout';
    });
  </script>

