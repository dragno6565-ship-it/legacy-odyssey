<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Contacts – Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:#faf7f2; color:#2c2416; padding:2rem 1rem 5rem; }
    .wrap { max-width:760px; margin:0 auto; }
    .breadcrumb { font-size:0.82rem; color:#4a3f30; margin-bottom:1.25rem; }
    .breadcrumb a { color:#c8a96e; text-decoration:none; }
    h1 { font-family:'Fraunces',serif; font-size:2rem; font-weight:600; margin-bottom:0.25rem; }
    .section-desc { color:#4a3f30; font-size:0.92rem; margin-bottom:1.5rem; }
    h2 { font-family:'Fraunces',serif; font-size:1.4rem; font-weight:600; margin:2rem 0 0.75rem; }
    .banner { padding:0.7rem 1rem; border-radius:8px; font-size:0.9rem; margin-bottom:1rem; }
    .banner.ok { background:#eaf4ea; color:#2e6b2e; }
    .banner.err { background:#fdecea; color:#c0392b; }
    .card { background:#fff; border:1px solid #f0ebe3; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.05); padding:1rem 1.1rem; margin-bottom:0.85rem; }
    label { display:block; font-size:0.78rem; font-weight:600; color:#4a3f30; text-transform:uppercase; letter-spacing:0.04em; margin:0 0 0.3rem; }
    input[type=text], input[type=email], input[type=tel] { width:100%; padding:0.6rem 0.8rem; border:1.5px solid #e0d5c4; border-radius:8px; font-family:'Inter',sans-serif; font-size:0.95rem; color:#2c2416; margin-bottom:0.6rem; }
    .row { display:flex; gap:0.6rem; flex-wrap:wrap; }
    .row > div { flex:1; min-width:140px; }
    .btn { background:#c8a96e; color:#fff; border:none; border-radius:8px; padding:0.55rem 1.1rem; font-family:'Inter',sans-serif; font-size:0.9rem; font-weight:600; cursor:pointer; }
    .btn:hover { background:#b08e4a; }
    .btn-sm { padding:0.35rem 0.7rem; font-size:0.8rem; }
    .btn-danger { background:#fff; color:#c0392b; border:1px solid #e6c9c4; }
    .btn-ghost { background:#f0e8dc; color:#2c2416; }
    .chips { display:flex; flex-wrap:wrap; gap:0.35rem; margin:0.4rem 0; }
    .chip { background:#f0e8dc; color:#6b5e44; border-radius:999px; padding:0.15rem 0.6rem; font-size:0.75rem; }
    .checks { display:flex; flex-wrap:wrap; gap:0.5rem 1rem; margin:0.3rem 0 0.7rem; }
    .checks label { display:flex; align-items:center; gap:0.35rem; text-transform:none; letter-spacing:0; font-weight:400; color:#2c2416; font-size:0.88rem; margin:0; }
    .empty { color:#4a3f30; font-size:0.9rem; padding:0.5rem 0; }
    .muted { color:#4a3f30; font-size:0.82rem; }
    .inline { display:inline; }
    .contact-head { display:flex; justify-content:space-between; align-items:baseline; gap:0.5rem; }
    .contact-head strong { font-size:1.05rem; }
    details summary { cursor:pointer; color:#c8a96e; font-size:0.85rem; margin-top:0.4rem; }
    .back { display:inline-block; margin-top:1.5rem; color:#4a3f30; text-decoration:none; font-size:0.9rem; }
    .note { background:#fbf6ed; border:1px solid #e0d5c4; border-left:4px solid #c8a96e; border-radius:8px; padding:0.7rem 0.9rem; font-size:0.84rem; color:#6b5e44; margin-bottom:1rem; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="breadcrumb"><a href="/account/dashboard">My Account</a> &nbsp;/&nbsp; Your Contacts</div>
    <h1>Your Contacts</h1>
    <p class="section-desc">Your Contact List and Circles — keep a private list of the people who can see your website, organize them into Circles (like “Grandparents” or “Close Family”), and tell them when there's something new.</p>

    <% if (success) { %><div class="banner ok">Saved.</div><% } %>
    <% if (typeof sent !== 'undefined' && sent) { %><div class="banner ok">Update sent to <%= sent %> <%= sent === '1' ? 'person' : 'people' %>. They each got their own private link.</div><% } %>
    <% if (error) { %><div class="banner err"><%= (error === '1') ? 'Something went wrong. Please try again.' : error %></div><% } %>

    <% var emailable = (contacts || []).filter(function(c){ return c.email && c.notify_opt_in !== false && !c.unsubscribed_at; }); %>
    <% if ((contacts || []).length) { %>
    <!-- ===== SHARE AN UPDATE ===== -->
    <h2 style="margin-top:0.5rem;">Share an update</h2>
    <div class="card" style="border:1.5px solid #c8a96e;">
      <p class="muted" style="margin-bottom:0.7rem;">Let people know there's something new on your website. <strong>Tick anyone with an email</strong> and send — each gets their own private link, no password. For anyone with a <strong>phone</strong>, tap <strong>Copy text</strong> and paste it into your Messages app.</p>
      <form action="/account/book/circles/notify" method="POST" id="loShareForm" onsubmit="return loShareSubmit();">
        <label>Who do you want to share with?</label>
        <div class="chips" style="margin:0.3rem 0 0.5rem;">
          <button type="button" class="chip lo-quick" onclick="loPickAll()">Everyone with email (<%= emailable.length %>)</button>
          <% (circles || []).forEach(function(c) { var n = emailable.filter(function(p){ return (p.circle_ids || []).indexOf(c.id) !== -1; }).length; if (n) { %>
            <button type="button" class="chip lo-quick" onclick="loPickCircle('<%= c.id %>')"><%= c.name %> (<%= n %>)</button>
          <% } }); %>
          <button type="button" class="chip lo-quick" onclick="loPickNone()">Clear</button>
        </div>
        <input type="text" id="loShareSearch" placeholder="Search contacts…" oninput="loShareFilter()" autocomplete="off"
          style="width:100%; padding:0.55rem 0.8rem; border:1.5px solid #e0d5c4; border-radius:8px; margin-bottom:0.5rem;">
        <div id="loShareList" style="max-height:280px; overflow:auto; border:1px solid #eee3d3; border-radius:8px; padding:0 0.7rem; margin-bottom:0.6rem;">
          <% (contacts || []).forEach(function(p) { var canEmail = p.email && p.notify_opt_in !== false && !p.unsubscribed_at; %>
            <div class="lo-prow" data-search="<%= ((p.name||'') + ' ' + (p.email||'') + ' ' + (p.phone||'')).toLowerCase().replace(/\"/g,'') %>" data-circles="<%= (p.circle_ids || []).join(',') %>"
              style="display:flex; align-items:center; gap:0.55rem; padding:0.5rem 0; border-bottom:1px solid #f0ebe3;">
              <% if (canEmail) { %>
                <input type="checkbox" name="contactIds[]" value="<%= p.id %>" class="lo-pcb" onchange="loShareCount()" style="width:18px; height:18px; flex:none;" title="Email this person their private link">
              <% } else { %>
                <span style="width:18px; flex:none; text-align:center; color:#c8a96e;" title="No email — use Copy text">•</span>
              <% } %>
              <span style="flex:1; min-width:0;"><strong><%= p.name %></strong><span class="muted" style="font-size:0.85em;"><%= p.email ? ' · ' + p.email : '' %><%= p.phone ? ' · ' + p.phone : '' %><%= (!p.email && !p.phone) ? ' · no email or phone' : '' %></span></span>
              <% if (p.phone) { %>
                <button type="button" class="btn btn-sm" data-token="<%= p.access_token %>" onclick="loCopyText(this)" style="flex:none;">Copy text</button>
              <% } %>
            </div>
          <% }); %>
        </div>
        <input type="text" name="note" maxlength="500" placeholder="Add a short note (optional) — e.g. New first-birthday photos are up!"
          style="width:100%; padding:0.55rem 0.8rem; border:1.5px solid #e0d5c4; border-radius:8px; margin-bottom:0.6rem;">
        <button type="submit" class="btn" id="loShareBtn" disabled>Email <span id="loShareCount">0</span> selected</button>
        <span class="muted" style="margin-left:0.6rem;">Tick people with an email to send links; use Copy text for phone numbers.</span>
      </form>
    </div>
    <% } %>

    <!-- ===== CIRCLES ===== -->
    <h2>Circles</h2>
    <% if (!circles || circles.length === 0) { %>
      <div class="empty">No circles yet — create one below (e.g. “Grandparents”).</div>
    <% } %>
    <% (circles || []).forEach(function(c) { %>
      <div class="card">
        <div class="contact-head">
          <strong><%= c.name %></strong>
          <span class="muted"><%= c.member_count %> <%= c.member_count === 1 ? 'person' : 'people' %></span>
        </div>
        <details>
          <summary>Rename or delete</summary>
          <form action="/account/book/circles/<%= c.id %>/rename" method="POST" class="row" style="margin-top:0.5rem;">
            <div><input type="text" name="name" value="<%= c.name %>" maxlength="120"></div>
            <button type="submit" class="btn btn-sm">Rename</button>
          </form>
          <form action="/account/book/circles/<%= c.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete the “<%= c.name %>” circle? (Your contacts stay — they’re just removed from this circle.)');">
            <button type="submit" class="btn btn-sm btn-danger">Delete circle</button>
          </form>
        </details>
      </div>
    <% }); %>
    <div class="card">
      <form action="/account/book/circles" method="POST" class="row">
        <div>
          <label>New circle name</label>
          <input type="text" name="name" placeholder="e.g. Grandparents" maxlength="120" required style="margin-bottom:0;">
        </div>
        <button type="submit" class="btn" style="align-self:flex-end;">+ Add Circle</button>
      </form>
    </div>

    <!-- ===== CONTACTS ===== -->
    <h2>Contact List</h2>
    <% if (!contacts || contacts.length === 0) { %>
      <div class="empty">No contacts yet — add the first person below.</div>
    <% } %>
    <% if ((contacts || []).length > 3) { %>
      <input type="text" id="loContactSearch" placeholder="Search contacts…" oninput="loContactFilter()" autocomplete="off"
        style="width:100%; padding:0.55rem 0.8rem; border:1.5px solid #e0d5c4; border-radius:8px; margin-bottom:0.7rem;">
      <div id="loContactNone" class="muted" style="display:none; margin-bottom:0.7rem;">No contacts match that search.</div>
    <% } %>
    <% (contacts || []).forEach(function(p) { %>
      <div class="card lo-contact-card" data-search="<%= ((p.name||'') + ' ' + (p.email||'') + ' ' + (p.phone||'')).toLowerCase().replace(/\"/g,'') %>">
        <div class="contact-head">
          <strong><%= p.name %></strong>
          <span class="inline" style="display:inline-flex; gap:0.4rem;">
            <% if (p.phone) { %>
              <button type="button" class="btn btn-sm" data-token="<%= p.access_token %>" onclick="loCopyText(this)">Copy text</button>
            <% } %>
            <form action="/account/book/circles/contacts/<%= p.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Remove <%= p.name %> from your list? Their view link will stop working.');">
              <button type="submit" class="btn btn-sm btn-danger">Remove</button>
            </form>
          </span>
        </div>
        <div class="muted"><%= p.email || 'no email' %><%= p.phone ? ' · ' + p.phone : '' %></div>
        <% var pc = (circles || []).filter(function(c){ return (p.circle_ids || []).indexOf(c.id) !== -1; }); %>
        <% if (pc.length) { %><div class="chips"><% pc.forEach(function(c){ %><span class="chip"><%= c.name %></span><% }); %></div><% } %>
        <details>
          <summary>Edit</summary>
          <form action="/account/book/circles/contacts/<%= p.id %>/update" method="POST" style="margin-top:0.5rem;">
            <div class="row">
              <div><label>Name</label><input type="text" name="name" value="<%= p.name %>" maxlength="120" required></div>
              <div><label>Email</label><input type="email" name="email" value="<%= p.email || '' %>"></div>
              <div><label>Phone</label><input type="tel" name="phone" value="<%= p.phone || '' %>"></div>
            </div>
            <% if (circles && circles.length) { %>
              <label>Circles</label>
              <div class="checks">
                <% circles.forEach(function(c){ %>
                  <label><input type="checkbox" name="circleIds" value="<%= c.id %>" <%= (p.circle_ids||[]).indexOf(c.id)!==-1 ? 'checked' : '' %>> <%= c.name %></label>
                <% }); %>
              </div>
            <% } %>
            <button type="submit" class="btn btn-sm">Save changes</button>
          </form>
        </details>
      </div>
    <% }); %>

    <div class="card">
      <form action="/account/book/circles/contacts" method="POST">
        <div class="row">
          <div><label>Name</label><input type="text" name="name" placeholder="Full name" maxlength="120" required></div>
          <div><label>Email</label><input type="email" name="email" placeholder="them@example.com"></div>
          <div><label>Phone</label><input type="tel" name="phone" placeholder="optional"></div>
        </div>
        <% if (circles && circles.length) { %>
          <label>Add to circles</label>
          <div class="checks">
            <% circles.forEach(function(c){ %>
              <label><input type="checkbox" name="circleIds" value="<%= c.id %>"> <%= c.name %></label>
            <% }); %>
          </div>
        <% } %>
        <button type="submit" class="btn">+ Add Person</button>
      </form>
    </div>

    <a href="/account/dashboard" class="back">← Back to My Account</a>
  </div>

  <style>
    .lo-quick { cursor:pointer; background:#fff; border:1.5px solid #c8a96e; color:#8a6d2f; font-family:'Inter',sans-serif; font-size:0.85rem; font-weight:600; padding:0.3rem 0.8rem; border-radius:999px; }
    .lo-quick:hover { background:#f7efe0; }
    .lo-prow:hover { background:#faf7f2; }
  </style>
  <script>
    var LO_BOOK_URL = <%- JSON.stringify(bookUrl || '') %>;
    var LO_SITE_LABEL = <%- JSON.stringify(siteLabel || 'your website') %>;
    function loShareCount(){
      var n = document.querySelectorAll('.lo-pcb:checked').length;
      var c = document.getElementById('loShareCount'); if(c) c.textContent = n;
      var b = document.getElementById('loShareBtn'); if(b) b.disabled = (n === 0);
    }
    function loPickAll(){ document.querySelectorAll('#loShareList .lo-pcb').forEach(function(cb){ cb.checked = true; }); loShareCount(); }
    function loPickNone(){ document.querySelectorAll('#loShareList .lo-pcb').forEach(function(cb){ cb.checked = false; }); loShareCount(); }
    function loPickCircle(id){
      document.querySelectorAll('#loShareList .lo-prow').forEach(function(row){
        if((row.getAttribute('data-circles')||'').split(',').indexOf(id) !== -1){ var cb = row.querySelector('.lo-pcb'); if(cb) cb.checked = true; }
      });
      loShareCount();
    }
    function loShareFilter(){
      var q = (document.getElementById('loShareSearch').value || '').toLowerCase().trim();
      document.querySelectorAll('#loShareList .lo-prow').forEach(function(row){
        var hay = row.getAttribute('data-search') || '';
        row.style.display = (!q || hay.indexOf(q) !== -1) ? 'flex' : 'none';
      });
    }
    function loShareSubmit(){
      var n = document.querySelectorAll('.lo-pcb:checked').length;
      if(!n){ alert('Pick at least one person to share with.'); return false; }
      return confirm('Email an update to ' + n + ' ' + (n === 1 ? 'person' : 'people') + '? Each gets their own private link.');
    }
    function loContactFilter(){
      var q = (document.getElementById('loContactSearch').value || '').toLowerCase().trim();
      var shown = 0;
      document.querySelectorAll('.lo-contact-card').forEach(function(card){
        var match = !q || (card.getAttribute('data-search') || '').indexOf(q) !== -1;
        card.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      var none = document.getElementById('loContactNone');
      if (none) none.style.display = shown ? 'none' : 'block';
    }
    function loCopyText(btn){
      var token = btn.getAttribute('data-token') || '';
      var link = LO_BOOK_URL + '/?circle=' + token;
      var msg = "There's something new on " + LO_SITE_LABEL + " — take a look (no password needed): " + link;
      var done = function(){ var t = btn.textContent; btn.textContent = 'Copied!'; setTimeout(function(){ btn.textContent = t; }, 1500); };
      if(navigator.clipboard && navigator.clipboard.writeText){ navigator.clipboard.writeText(msg).then(done).catch(function(){ window.prompt('Copy this message to text:', msg); }); }
      else { window.prompt('Copy this message to text:', msg); }
    }
  </script>
</body>
</html>
