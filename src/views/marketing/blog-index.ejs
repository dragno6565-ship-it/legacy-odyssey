  <img height="1" width="1" style="display:none;" alt=""
    src="https://ct.pinterest.com/v3/?event=init&tid=2613467907928&noscript=1" />
  </noscript>
  <!-- end Pinterest Tag -->

  <style>
    .blog-index-wrap {
      max-width: 820px;
      margin: 0 auto;
      padding: 4rem 1.5rem 6rem;
    }
    .blog-index-header {
      margin-bottom: 3rem;
    }
    .blog-index-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 600;
      color: #1E1812;
      margin-bottom: 0.5rem;
    }
    .blog-index-header p {
      color: rgba(30, 24, 18, 0.55);
      font-size: 1rem;
    }
    .blog-posts {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .blog-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(200, 169, 110, 0.18);
      border-radius: 12px;
      padding: 2rem;
      text-decoration: none;
      display: block;
      transition: border-color 0.2s, background 0.2s;
    }
    .blog-card:hover {
      border-color: rgba(200, 169, 110, 0.45);
      background: rgba(200, 169, 110, 0.06);
    }
    .blog-card-category {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #c8a96e;
      margin-bottom: 0.75rem;
    }
    .blog-card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 600;
      color: #1E1812;
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }
    .blog-card-excerpt {
      color: rgba(30, 24, 18, 0.8);
      font-size: 0.95rem;
      line-height: 1.7;
      margin-bottom: 1.25rem;
    }
    .blog-card-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.8rem;
      color: rgba(30, 24, 18, 0.5);
    }
    .blog-card-read-more {
      color: #c8a96e;
      font-weight: 600;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>

  <nav class="marketing-nav" id="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Legacy <span>Odyssey</span></a>
      <ul class="nav-links" id="navLinks">
        <li><a href="/#features">Features</a></li>
        <li><a href="/#how-it-works">How It Works</a></li>
        <li><a href="/blog" class="active">Blog</a></li>
        <li><a href="/#pricing">Pricing</a></li>
        <li><a href="/#help">Help</a></li>
        <li><a href="/account">My Account</a></li>
        <li><a href="/#pricing" class="nav-cta">Get Started</a></li>
      </ul>
      <button class="nav-hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <main>
    <div class="blog-index-wrap">

      <div class="blog-index-header">
        <h1>The Legacy Odyssey Blog</h1>
        <p>Guides, ideas, and inspiration for documenting your family's story.</p>
      </div>

      <div class="blog-posts">
        <% posts.forEach(function(post) { %>
        <a href="<%= post.url %>" class="blog-card">
          <div class="blog-card-category"><%= post.category %></div>
          <div class="blog-card-title"><%= post.title %></div>
          <div class="blog-card-excerpt"><%= post.excerpt %></div>
          <div class="blog-card-meta">
            <span><%= post.date %></span>
            <span>&bull;</span>
            <span><%= post.readTime %></span>
            <span class="blog-card-read-more">Read more &rarr;</span>
          </div>
        </a>
        <% }); %>
      </div>

    </div>
  </main>

  <footer class="marketing-footer">
    <div class="footer-inner">
      <div class="footer-brand">Legacy <span>Odyssey</span></div>
      <ul class="footer-links">
        <li><a href="/#features">Features</a></li>
        <li><a href="/#pricing">Pricing</a></li>
        <li><a href="/#help">Help</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/terms">Terms</a></li>
        <li><a href="/privacy">Privacy</a></li>
      </ul>
      <div class="footer-copy">&copy; 2026 Legacy Odyssey. All rights reserved.</div>
    </div>
  </footer>

  <script>
    // Nav hamburger
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('navLinks');
    if (hamburger) {
      hamburger.addEventListener('click', () => navLinks.classList.toggle('open'));
    }
  </script>

</body>
</html>
