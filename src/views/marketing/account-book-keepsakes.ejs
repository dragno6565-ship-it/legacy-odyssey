<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Their Keepsakes — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #faf7f2; color: #2c2416; min-height: 100vh; padding: 2rem 1rem 5rem; }
    .wrap { max-width: 820px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: #6b5d47; margin-bottom: 1.5rem; }
    .breadcrumb a { color: #c8a96e; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    h1 { font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 600; margin-bottom: 0.25rem; }
    .section-desc { color: #6b5d47; font-size: 0.92rem; margin-bottom: 2rem; }
    .flash { padding: 0.85rem 1.1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1.25rem; }
    .flash-success { background: #f0faf0; border: 1px solid #a8d5a8; color: #2e7d32; }
    .flash-error { background: #fdf2f2; border: 1px solid #e0b4b4; color: #c0392b; }

    .keepsakes-block { background: #fff; border-radius: 12px; border: 1px solid #f0ebe3; box-shadow: 0 2px 8px rgba(0,0,0,0.05); padding: 1.5rem; margin-bottom: 1.25rem; }
    .keepsake-row {
      display: flex; align-items: center; gap: 1rem;
      padding: 0.85rem 1rem; background: #faf7f2; border-radius: 8px; margin-bottom: 0.5rem;
      text-decoration: none; color: inherit; transition: background 0.15s;
    }
    .keepsake-row:hover { background: #f3eddf; }
    .keepsake-thumb { width: 64px; height: 64px; border-radius: 6px; background: #ece4d6; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
    .keepsake-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .keepsake-thumb-icon { color: #c8a96e; }
    .keepsake-thumb-icon svg { width: 26px; height: 26px; stroke-width: 1.5; }
    .keepsake-info { flex: 1; min-width: 0; }
    .keepsake-title { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 600; color: #2c2416; line-height: 1.3; }
    .keepsake-meta { font-size: 0.78rem; color: #6b5d47; margin-top: 0.15rem; }
    .keepsake-meta .dot { margin: 0 0.4em; opacity: 0.5; }
    .keepsake-meta .cat-tag {
      display: inline-flex; align-items: center; gap: 0.3rem;
      background: #f0ebe3; color: #c8a96e;
      padding: 0.1rem 0.5rem; border-radius: 999px;
      font-size: 0.72rem;
      text-transform: uppercase; letter-spacing: 0.06em;
      margin-right: 0.4em;
    }
    .keepsake-meta .cat-tag svg { width: 0.8rem; height: 0.8rem; }
    .keepsake-chevron { color: #c8a96e; font-size: 1.3rem; flex-shrink: 0; }

    .add-form { display: flex; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap; }
    .add-form input[type="text"] { flex: 1; min-width: 200px; padding: 0.65rem 0.95rem; border: 1.5px solid #e0d5c4; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.95rem; background: #fff; }
    .add-form select { padding: 0.65rem 0.95rem; border: 1.5px solid #e0d5c4; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.92rem; background: #fff; color: #2c2416; }
    .add-form input[type="text"]:focus, .add-form select:focus { outline: none; border-color: #c8a96e; box-shadow: 0 0 0 3px rgba(200,169,110,0.12); }
    .btn-add { background: #c8a96e; color: #fff; border: none; padding: 0.65rem 1.25rem; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.95rem; font-weight: 600; cursor: pointer; }
    .btn-add:hover { background: #b08e4a; }

    .empty-state { text-align: center; padding: 2rem; color: #6b5d47; font-size: 0.92rem; font-style: italic; }
    .footer-actions { margin-top: 2rem; }
    .btn-back { color: #6b5d47; text-decoration: none; font-size: 0.9rem; }
    .btn-back:hover { color: #2c2416; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="breadcrumb">
      <a href="/account/dashboard">Account</a> &nbsp;/&nbsp;
      <a href="/account/book">My Book</a> &nbsp;/&nbsp;
      Their Keepsakes
    </div>

    <h1>Their Keepsakes</h1>
    <p class="section-desc">Drawings, awards, certificates, handprints — preserve photos of the physical things you can't keep forever.</p>

    <% if (success) { %><div class="flash flash-success">✓ Saved.</div><% } %>
    <% if (error) { %><div class="flash flash-error">Something went wrong (<%= error %>).</div><% } %>

    <%
      const CATEGORY_DEFS = {
        artwork:     { label: 'Artwork',     icon: 'palette' },
        schoolwork:  { label: 'Schoolwork',  icon: 'graduation-cap' },
        award:       { label: 'Award',       icon: 'award' },
        memorabilia: { label: 'Memorabilia', icon: 'archive' },
      };
      function catLabel(c) { return (CATEGORY_DEFS[c] || {}).label || (c ? c.charAt(0).toUpperCase() + c.slice(1) : null); }
      function catIcon(c) { return (CATEGORY_DEFS[c] || {}).icon || 'sparkles'; }
    %>

    <div class="keepsakes-block">
      <% if ((keepsakes || []).length === 0) { %>
        <div class="empty-state">No keepsakes yet. Add your first one below.</div>
      <% } %>

      <% (keepsakes || []).forEach(function(k) { %>
        <a class="keepsake-row" href="/account/book/keepsakes/edit/<%= k.id %>">
          <div class="keepsake-thumb">
            <% if (k.photoUrl) { %>
              <img src="<%= k.photoUrl %>" alt="">
            <% } else { %>
              <span class="keepsake-thumb-icon"><i data-lucide="<%= catIcon(k.category) %>"></i></span>
            <% } %>
          </div>
          <div class="keepsake-info">
            <div class="keepsake-title"><%= k.title || 'Untitled' %></div>
            <div class="keepsake-meta">
              <% if (k.category && catLabel(k.category)) { %>
                <span class="cat-tag"><i data-lucide="<%= catIcon(k.category) %>"></i> <%= catLabel(k.category) %></span>
              <% } %>
              <% if (k.age_text) { %><%= k.age_text %><span class="dot">·</span><% } %>
              <%= k.photo_count %> photo<%= k.photo_count === 1 ? '' : 's' %>
              <% if (k.story) { %><span class="dot">·</span>Has story<% } %>
            </div>
          </div>
          <div class="keepsake-chevron">›</div>
        </a>
      <% }); %>

      <form method="POST" action="/account/book/keepsakes/new" class="add-form">
        <input type="text" name="title" placeholder="Add a keepsake (e.g. First finger painting)" required>
        <select name="category">
          <option value="">Pick a category…</option>
          <option value="artwork">Artwork</option>
          <option value="schoolwork">Schoolwork</option>
          <option value="award">Award</option>
          <option value="memorabilia">Memorabilia</option>
        </select>
        <button type="submit" class="btn-add">+ Add</button>
      </form>
    </div>

    <div class="footer-actions">
      <a class="btn-back" href="/account/book">← Back to my book</a>
    </div>
  </div>
  <script>if (window.lucide) window.lucide.createIcons();</script>
</body>
</html>
