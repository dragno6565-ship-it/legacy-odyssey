<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Month by Month – Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Jost', sans-serif; background: #faf7f2; color: #2c2416; min-height: 100vh; padding: 2rem 1rem 4rem; }
    .wrap { max-width: 760px; margin: 0 auto; }
    .breadcrumb { font-size: 0.82rem; color: #8a7e6b; margin-bottom: 1.5rem; }
    .breadcrumb a { color: #c8a96e; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    h1 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 600; margin-bottom: 0.25rem; }
    .section-desc { color: #8a7e6b; font-size: 0.92rem; margin-bottom: 2rem; }
    .flash { padding: 0.85rem 1.1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1.25rem; }
    .flash-success { background: #f0faf0; border: 1px solid #a8d5a8; color: #2e7d32; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 0.85rem; }
    .month-card {
      background: #fff;
      border-radius: 12px;
      border: 1px solid #f0ebe3;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      text-decoration: none;
      color: inherit;
      overflow: hidden;
      transition: box-shadow 0.2s, transform 0.15s;
      display: flex;
      flex-direction: column;
    }
    .month-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,0.1); transform: translateY(-2px); }
    .month-photo { height: 100px; background: #f0ebe3; overflow: hidden; position: relative; }
    .month-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .month-photo-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: #c8a96e; opacity: 0.4; }
    .month-body { padding: 0.85rem; flex: 1; }
    .month-num { font-size: 0.7rem; font-weight: 600; color: #c8a96e; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.2rem; }
    .month-label { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 600; color: #2c2416; margin-bottom: 0.3rem; line-height: 1.3; }
    .month-highlight { font-size: 0.78rem; color: #8a7e6b; line-height: 1.4; }
    .month-has-content { width: 6px; height: 6px; border-radius: 50%; background: #c8a96e; display: inline-block; margin-left: 0.35rem; vertical-align: middle; }
    .back-link { display: inline-block; margin-top: 1.5rem; color: #8a7e6b; text-decoration: none; font-size: 0.9rem; }
    .back-link:hover { color: #2c2416; }
  </style>
</head>
<body>
  <div class="wrap">

    <div class="breadcrumb">
      <a href="/account/dashboard">Account</a> &nbsp;/&nbsp;
      <a href="/account/book">My Book</a> &nbsp;/&nbsp;
      Month by Month
    </div>

    <h1>Month by Month</h1>
    <p class="section-desc">Click any month to add a photo, stats, and notes.</p>

    <% if (success) { %><div class="flash flash-success">✓ Saved successfully.</div><% } %>

    <%
      const monthNames = ['','January','February','March','April','May','June','July','August','September','October','November','December'];
      const ordinals = ['','One','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Eleven','Twelve'];
      const monthMap = {};
      (months || []).forEach(m => { monthMap[m.month_number] = m; });
    %>

    <div class="grid">
      <% for (let i = 1; i <= 12; i++) { %>
        <%
          const m = monthMap[i] || {};
          const hasContent = (m.photo_path && m.photo_path.trim()) || (m.note && m.note.trim()) || (m.highlight && m.highlight.trim());
        %>
        <a href="/account/book/months/<%= i %>" class="month-card">
          <div class="month-photo">
            <% if (m.photoUrl) { %>
              <img src="<%= m.photoUrl %>" alt="Month <%= i %>">
            <% } else { %>
              <div class="month-photo-placeholder">📅</div>
            <% } %>
          </div>
          <div class="month-body">
            <div class="month-num">Month <%= i %> <% if (hasContent) { %><span class="month-has-content"></span><% } %></div>
            <div class="month-label"><%= m.label || (ordinals[i] + ' Month Old') %></div>
            <% if (m.highlight) { %>
              <div class="month-highlight"><%= m.highlight %></div>
            <% } %>
          </div>
        </a>
      <% } %>
    </div>

    <a href="/account/book" class="back-link">← Back to My Book</a>

  </div>
</body>
</html>
