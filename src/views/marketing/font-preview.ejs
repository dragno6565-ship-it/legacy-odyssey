<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex">
  <title>Font <%= font.n %> · <%= font.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=<%= font.g %>&display=swap" rel="stylesheet">
  <style>
    :root { --serif: <%= font.serif %>; --sans: <%= font.sans %>; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    /* Darker, higher-contrast text than the live pages so it "pops" */
    body { font-family: var(--sans); background: #faf7f2; color: #1f1810; -webkit-font-smoothing: antialiased; }

    /* Numbered switcher bar */
    .switch { position: sticky; top: 0; z-index: 10; background: #1a1510; padding: 0.7rem 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; justify-content: center; }
    .switch .lbl { color: #d4bb8a; font-size: 0.8rem; margin-right: 0.4rem; letter-spacing: 0.03em; }
    .switch a { display: inline-flex; align-items: center; justify-content: center; min-width: 2.1rem; height: 2.1rem; padding: 0 0.7rem; border-radius: 7px; text-decoration: none; font-size: 0.95rem; font-weight: 600; color: #faf7f2; border: 1.5px solid #4a3f2e; }
    .switch a.active { background: #c8a96e; color: #1a1510; border-color: #c8a96e; }

    /* Specimen band — makes the typeface unmistakable */
    .specimen { background: #1a1510; color: #faf7f2; text-align: center; padding: 2.2rem 1rem 2.4rem; }
    .specimen .num { font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: #c8a96e; font-weight: 600; }
    .specimen .aa { font-family: var(--serif); font-size: 4.5rem; line-height: 1; color: #fff; margin: 0.5rem 0 0.3rem; font-weight: 700; }
    .specimen .name { font-family: var(--serif); font-size: 1.9rem; font-weight: 600; color: #f0e2c8; }
    .specimen .tag { font-size: 0.92rem; color: #b7a98f; margin-top: 0.35rem; }
    .specimen .line { font-family: var(--serif); font-size: 1.35rem; color: #e8dcc4; margin-top: 1.1rem; font-weight: 500; }

    .wrap { max-width: 560px; margin: 0 auto; padding: 1.75rem 1.1rem 3rem; }
    .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .top h1 { font-family: var(--serif); font-size: 2.2rem; font-weight: 700; color: #1a1510; }
    .signout { font-size: 0.88rem; color: #6b5d47; text-decoration: none; font-weight: 500; }

    .card { background: #fff; border: 1px solid #e6dac6; border-radius: 12px; padding: 1.4rem 1.4rem; margin-bottom: 1rem; }
    .card.action { border: 1.5px solid #c8a96e; }
    .card h2 { font-family: var(--serif); font-size: 1.5rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; color: #1a1510; }
    .card .sub { font-size: 0.95rem; color: #6b5d47; line-height: 1.5; margin-top: 0.35rem; }
    .card .go { display: inline-block; font-size: 0.95rem; font-weight: 600; color: #b08e4a; margin-top: 0.85rem; text-decoration: none; }
    .ico { color: #c8a96e; display: inline-flex; }
    .pill-new { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #1a1510; background: #e7d3a6; padding: 0.22rem 0.55rem; border-radius: 6px; margin-left: auto; }

    .row { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0; font-size: 1rem; }
    .row + .row { border-top: 1px solid #efe7d8; }
    .row .k { color: #6b5d47; }
    .row .v { font-weight: 600; color: #1f1810; }
    .badge { font-size: 0.78rem; font-weight: 700; padding: 0.2rem 0.7rem; border-radius: 20px; background: #e3f3e4; color: #246b28; }
    .btn-gold { display: inline-block; margin-top: 0.9rem; padding: 0.75rem 1.5rem; background: #c8a96e; color: #1a1510; border: none; border-radius: 8px; font-size: 0.98rem; font-weight: 700; font-family: var(--sans); cursor: pointer; text-decoration: none; }
    .fine { font-size: 0.85rem; color: #6b5d47; margin-top: 0.5rem; }
    .foot { text-align: center; font-size: 0.88rem; color: #6b5d47; margin-top: 1.5rem; }
    .pick { text-align: center; margin-top: 2rem; font-size: 0.95rem; color: #8a7e6b; }
  </style>
</head>
<body>
  <div class="switch">
    <span class="lbl">Compare:</span>
    <% all.forEach(function(f){ %>
      <a href="/font/<%= f.n %>" class="<%= f.n === font.n ? 'active' : '' %>"><%= f.n %></a>
    <% }); %>
  </div>

  <div class="specimen">
    <div class="num">Font <%= font.n %> of <%= all.length %></div>
    <div class="aa">Aa</div>
    <div class="name"><%= font.name %></div>
    <div class="tag"><%= font.tag %></div>
    <div class="line">Your child&rsquo;s story, beautifully told.</div>
  </div>

  <div class="wrap">
    <div class="top">
      <h1>My Account</h1>
      <a href="#" class="signout">Sign out</a>
    </div>

    <div class="card action">
      <h2><span class="ico"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></span> My Book</h2>
      <div class="sub">Edit your child&rsquo;s story — photos, milestones, birth story, and more.</div>
      <a href="#" class="go">Open Book Editor →</a>
    </div>

    <div class="card action">
      <h2><span class="ico"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span> Your Circles <span class="pill-new">New</span></h2>
      <div class="sub">Choose who can see the book — and tell them when you add something new.</div>
      <a href="#" class="go">Open Circles →</a>
    </div>

    <div class="card">
      <h2>Account Details</h2>
      <div class="row"><span class="k">Name</span><span class="v">Sam Smith</span></div>
      <div class="row"><span class="k">Email</span><span class="v">sam@example.com</span></div>
    </div>

    <div class="card">
      <h2>Subscription &amp; Billing</h2>
      <div class="row"><span class="k">Status</span><span class="badge">Active</span></div>
      <div class="row"><span class="k">Plan</span><span class="v">Annual</span></div>
      <a href="#" class="btn-gold">Manage Subscription</a>
      <div class="fine">Update your payment method or view invoices.</div>
    </div>

    <div class="card">
      <h2>Your Data &amp; Privacy</h2>
      <div class="sub" style="margin-bottom:0.4rem;">Download a copy of all the personal data we hold for your account at any time.</div>
      <a href="#" class="btn-gold">Download My Data</a>
    </div>

    <div class="foot">← Back to Legacy Odyssey&nbsp;·&nbsp;Contact Support</div>
    <div class="pick">Use the numbers up top to flip between fonts. Tell me the number you want.</div>
  </div>
</body>
</html>
