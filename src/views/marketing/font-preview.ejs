<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex">
  <title>Font <%= font.n %> · <%= font.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=<%= font.g %>&display=swap" rel="stylesheet">
  <style>
    :root { --serif: <%= font.serif %>; --sans: <%= font.sans %>; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--sans); background: #faf7f2; color: #2c2416; -webkit-font-smoothing: antialiased; }

    /* Numbered switcher bar */
    .switch { position: sticky; top: 0; z-index: 10; background: #1a1510; padding: 0.7rem 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; justify-content: center; }
    .switch .lbl { color: #d4bb8a; font-size: 0.8rem; margin-right: 0.4rem; }
    .switch a { display: inline-flex; align-items: center; justify-content: center; min-width: 2.1rem; height: 2.1rem; padding: 0 0.65rem; border-radius: 7px; text-decoration: none; font-size: 0.9rem; font-weight: 600; color: #faf7f2; border: 1.5px solid #4a3f2e; }
    .switch a.active { background: #c8a96e; color: #1a1510; border-color: #c8a96e; }
    .switch .now { color: #faf7f2; font-size: 0.82rem; margin-left: 0.5rem; }

    .wrap { max-width: 560px; margin: 0 auto; padding: 1.75rem 1.1rem 3rem; }
    .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .top h1 { font-family: var(--serif); font-size: 2rem; font-weight: 600; }
    .signout { font-size: 0.85rem; color: #8a7e6b; text-decoration: none; }

    .card { background: #fff; border: 1px solid #ece2d2; border-radius: 12px; padding: 1.4rem 1.4rem; margin-bottom: 1rem; }
    .card.action { border: 1.5px solid #c8a96e; }
    .card h2 { font-family: var(--serif); font-size: 1.35rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; }
    .card .sub { font-size: 0.92rem; color: #8a7e6b; line-height: 1.5; margin-top: 0.3rem; }
    .card .go { display: inline-block; font-size: 0.92rem; font-weight: 600; color: #c8a96e; margin-top: 0.85rem; text-decoration: none; }
    .ico { color: #c8a96e; }
    .pill-new { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #1a1510; background: #e7d3a6; padding: 0.22rem 0.55rem; border-radius: 6px; margin-left: auto; }

    .row { display: flex; justify-content: space-between; align-items: center; padding: 0.55rem 0; font-size: 0.98rem; }
    .row + .row { border-top: 1px solid #f0ebe3; }
    .row .k { color: #8a7e6b; }
    .row .v { font-weight: 500; }
    .badge { font-size: 0.78rem; font-weight: 600; padding: 0.2rem 0.7rem; border-radius: 20px; background: #e8f5e9; color: #2e7d32; }
    .btn-gold { display: inline-block; margin-top: 0.9rem; padding: 0.7rem 1.5rem; background: #c8a96e; color: #fff; border: none; border-radius: 8px; font-size: 0.95rem; font-weight: 600; font-family: var(--sans); cursor: pointer; text-decoration: none; }
    .fine { font-size: 0.82rem; color: #8a7e6b; margin-top: 0.5rem; }
    .foot { text-align: center; font-size: 0.85rem; color: #8a7e6b; margin-top: 1.5rem; }
  </style>
</head>
<body>
  <div class="switch">
    <span class="lbl">Font:</span>
    <% all.forEach(function(f){ %>
      <a href="/font/<%= f.n %>" class="<%= f.n === font.n ? 'active' : '' %>"><%= f.n %></a>
    <% }); %>
    <span class="now">→ <%= font.name %></span>
  </div>

  <div class="wrap">
    <div class="top">
      <h1>My Account</h1>
      <a href="#" class="signout">Sign out</a>
    </div>

    <div class="card action">
      <h2><span class="ico">📖</span> My Book</h2>
      <div class="sub">Edit your child's story — photos, milestones, birth story, and more.</div>
      <a href="#" class="go">Open Book Editor →</a>
    </div>

    <div class="card action">
      <h2><span class="ico">👥</span> Your Circles <span class="pill-new">New</span></h2>
      <div class="sub">Choose who can see the book — and tell them when you add something new.</div>
      <a href="#" class="go">Open Circles →</a>
    </div>

    <div class="card">
      <h2>Account Details</h2>
      <div class="row"><span class="k">Name</span><span class="v">Sam Smith</span></div>
      <div class="row"><span class="k">Email</span><span class="v">sam@example.com</span></div>
    </div>

    <div class="card">
      <h2>Subscription &amp; Billing</h2>
      <div class="row"><span class="k">Status</span><span class="badge">Active</span></div>
      <div class="row"><span class="k">Plan</span><span class="v">Annual</span></div>
      <a href="#" class="btn-gold">Manage Subscription</a>
      <div class="fine">Update your payment method or view invoices.</div>
    </div>

    <div class="card">
      <h2>Your Data &amp; Privacy</h2>
      <div class="sub" style="margin-bottom:0.4rem;">Download a copy of all the personal data we hold for your account at any time.</div>
      <a href="#" class="btn-gold">Download My Data</a>
    </div>

    <div class="foot">← Back to Legacy Odyssey&nbsp;·&nbsp;Contact Support</div>
  </div>
</body>
</html>
