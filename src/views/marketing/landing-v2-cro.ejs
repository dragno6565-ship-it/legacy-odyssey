  <!-- ====== JS — checkout modal preserved verbatim ====== -->
  <script>
    let _founderSelectedDomain = null;
    let _checkoutPlan = 'annual';
    const _bookType = 'baby_book';
    let _founderPrefillDomain = null;

    function openFounderModal(plan, prefillDomain) {
      _checkoutPlan = plan || 'annual';
      _founderSelectedDomain = null;
      _founderPrefillDomain = prefillDomain || null;
      document.getElementById('founderStep1').style.display = '';
      document.getElementById('founderStep2').style.display = 'none';
      document.getElementById('founderDomainSearch').value = '';
      document.getElementById('founderDomainResult').innerHTML = '';
      document.getElementById('founderDomainConfirmed').style.display = 'none';
      document.getElementById('founderNextBtn').disabled = true;
      document.getElementById('founderNextBtn').style.background = '#4a3f2f';
      document.getElementById('founderNextBtn').style.color = '#8a7a5a';
      document.getElementById('founderNextBtn').style.cursor = 'not-allowed';
      document.getElementById('founderModalError').style.display = 'none';
      if (_checkoutPlan === 'monthly') {
        document.getElementById('founderModalSubtitle').textContent = '$4.99/month + $5.99 one-time setup fee. Cancel anytime.';
      } else if (_checkoutPlan === 'childhood') {
        document.getElementById('founderModalSubtitle').textContent = '$450 one time — covers all 18 years of childhood. No annual renewals.';
      } else {
        document.getElementById('founderModalSubtitle').textContent = '$29 your first year — renews at $49.99/year. Cancel anytime.';
      }
      document.getElementById('founderModal').style.display = 'flex';
      if (_founderPrefillDomain) {
        const domainInput = document.getElementById('founderDomainSearch');
        const resultEl = document.getElementById('founderDomainResult');
        domainInput.value = _founderPrefillDomain.replace('.com', '');
        resultEl.innerHTML = '<span style="color:#7cb87c;font-weight:600;">&#10003; ' + _founderPrefillDomain + ' is available!</span>';
        founderConfirmDomain(_founderPrefillDomain);
        _founderPrefillDomain = null;
      } else {
        setTimeout(() => document.getElementById('founderDomainSearch').focus(), 100);
      }
    }
    function founderGoBack() {
      document.getElementById('founderStep2').style.display = 'none';
      document.getElementById('founderStep1').style.display = '';
    }
    async function founderSearchDomain() {
      const raw = document.getElementById('founderDomainSearch').value.trim().replace(/[^a-zA-Z0-9-]/g, '');
      const resultEl = document.getElementById('founderDomainResult');
      if (!raw || raw.length < 2) {
        resultEl.innerHTML = '<span style="color:#c0392b;">Please enter at least 2 characters.</span>';
        return;
      }
      const domain = raw.toLowerCase() + '.com';
      resultEl.innerHTML = '<span style="color:rgba(248,242,230,0.4);">Checking availability…</span>';
      document.getElementById('founderDomainSearchBtn').disabled = true;
      try {
        const res = await fetch('/api/domains/search?name=' + encodeURIComponent(raw));
        const data = await res.json();
        const primary = (data.results || []).find(r => r.domain === domain);
        if (primary && primary.available && primary.underBudget) {
          resultEl.innerHTML = '<span style="color:#7cb87c;font-weight:600;">&#10003; ' + domain + ' is available!</span>';
          founderConfirmDomain(domain);
        } else if (primary) {
          resultEl.innerHTML = '<span style="color:#c0392b;">&#10007; ' + domain + ' is taken.</span>' +
            (data.alternatives && data.alternatives.length ? '<br><span style="color:rgba(248,242,230,0.5);font-size:0.8rem;">Try one of these:</span>' : '');
          if (data.alternatives && data.alternatives.length) {
            data.alternatives.slice(0, 3).forEach(function(alt) {
              const btn = document.createElement('button');
              btn.type = 'button';
              btn.style = 'display:inline-block;margin:4px 4px 0 0;padding:4px 10px;background:#2C2416;border:1px solid rgba(184,147,90,0.4);border-radius:4px;color:#B8935A;font-size:0.8rem;cursor:pointer;';
              btn.textContent = alt.domain;
              btn.onclick = function() {
                document.getElementById('founderDomainSearch').value = alt.domain.replace('.com','');
                founderConfirmDomain(alt.domain);
                resultEl.innerHTML = '<span style="color:#7cb87c;font-weight:600;">&#10003; ' + alt.domain + ' is available!</span>';
              };
              resultEl.appendChild(btn);
            });
          }
          _founderSelectedDomain = null;
          document.getElementById('founderNextBtn').disabled = true;
          document.getElementById('founderNextBtn').style.background = '#4a3f2f';
          document.getElementById('founderNextBtn').style.color = '#8a7a5a';
          document.getElementById('founderNextBtn').style.cursor = 'not-allowed';
          document.getElementById('founderDomainConfirmed').style.display = 'none';
        } else {
          resultEl.innerHTML = '<span style="color:#c0392b;">Could not check availability. Try again.</span>';
        }
      } catch(e) {
        resultEl.innerHTML = '<span style="color:#c0392b;">Connection error. Please try again.</span>';
      }
      document.getElementById('founderDomainSearchBtn').disabled = false;
    }
    function founderConfirmDomain(domain) {
      _founderSelectedDomain = domain;
      document.getElementById('founderDomainConfirmedName').textContent = 'www.' + domain;
      document.getElementById('founderDomainConfirmed').style.display = 'block';
      const nextBtn = document.getElementById('founderNextBtn');
      nextBtn.disabled = false;
      nextBtn.style.background = '#B8935A';
      nextBtn.style.color = '#1E1812';
      nextBtn.style.cursor = 'pointer';
    }
    document.addEventListener('DOMContentLoaded', function() {
      document.getElementById('founderDomainSearchBtn').addEventListener('click', founderSearchDomain);
      document.getElementById('founderDomainSearch').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); founderSearchDomain(); }
      });
      document.getElementById('founderDomainChangeBtn').addEventListener('click', function() {
        _founderSelectedDomain = null;
        document.getElementById('founderDomainConfirmed').style.display = 'none';
        document.getElementById('founderDomainResult').innerHTML = '';
        document.getElementById('founderDomainSearch').value = '';
        document.getElementById('founderNextBtn').disabled = true;
        document.getElementById('founderNextBtn').style.background = '#4a3f2f';
        document.getElementById('founderNextBtn').style.color = '#8a7a5a';
        document.getElementById('founderNextBtn').style.cursor = 'not-allowed';
        document.getElementById('founderDomainSearch').focus();
      });
      document.getElementById('founderNextBtn').addEventListener('click', function() {
        if (!_founderSelectedDomain) return;
        const typeLabel = '👶 Baby Book';
        document.getElementById('founderStep2TypeLabel').textContent = typeLabel;
        document.getElementById('founderStep2Domain').textContent = 'www.' + _founderSelectedDomain;
        document.getElementById('step3TypeSummary').textContent = typeLabel;
        document.getElementById('step3DomainSummary').textContent = 'www.' + _founderSelectedDomain;
        document.getElementById('step3PriceSummary').textContent = _checkoutPlan === 'monthly' ? '$4.99/mo' : (_checkoutPlan === 'childhood' ? '$450 / 18 years' : '$29 first year');
        document.getElementById('founderStep1').style.display = 'none';
        document.getElementById('founderStep2').style.display = '';
        setTimeout(() => document.getElementById('founderEmail').focus(), 100);
      });
      document.getElementById('founderSubmitBtn').addEventListener('click', async function() {
        const email = document.getElementById('founderEmail').value.trim();
        const errEl = document.getElementById('founderModalError');
        errEl.style.display = 'none';
        if (!email || !email.includes('@')) { errEl.textContent = 'Please enter a valid email address.'; errEl.style.display = 'block'; return; }
        if (!_founderSelectedDomain) { errEl.textContent = 'Please go back and select a domain first.'; errEl.style.display = 'block'; return; }
        const btn = document.getElementById('founderSubmitBtn');
        btn.textContent = 'Redirecting to payment…';
        btn.disabled = true;
        try {
          let endpoint, body, trackValue;
          const _ref = loGetReferral();
          if (_checkoutPlan === 'monthly') {
            endpoint = '/api/stripe/create-checkout';
            body = { email, domain: _founderSelectedDomain, period: 'monthly', book_type: _bookType || 'baby_book' };
            trackValue = 4.99;
          } else if (_checkoutPlan === 'childhood') {
            endpoint = '/api/stripe/create-childhood-checkout';
            body = { email, domain: _founderSelectedDomain, book_type: _bookType || 'baby_book' };
            trackValue = 450;
          } else {
            endpoint = '/api/stripe/create-founder-checkout';
            body = { email, domain: _founderSelectedDomain, book_type: _bookType || 'baby_book' };
            trackValue = 29;
          }
          if (_ref) body.ref = _ref;
          const res = await fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
          const data = await res.json();
          if (data.url) {
            if (typeof fbq !== 'undefined') fbq('track', 'InitiateCheckout', { value: trackValue, currency: 'USD' });
            if (typeof pintrk !== 'undefined') pintrk('track', 'checkout', { value: trackValue, currency: 'USD' });
            window.location.href = data.url;
          } else { throw new Error(data.error || 'Something went wrong'); }
        } catch (err) {
          errEl.textContent = err.message || 'Something went wrong. Please try again.';
          errEl.style.display = 'block';
          btn.textContent = 'Continue to Payment →';
          btn.disabled = false;
        }
      });
      document.getElementById('founderModal').addEventListener('click', function(e) { if (e.target === this) this.style.display = 'none'; });
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('open') === 'checkout') { setTimeout(() => openFounderModal('annual'), 600); }
    });

    // --- Referral attribution (B13) ---
    // Persist ?ref=CODE for 90 days so it survives the visit-to-checkout gap,
    // then hand it to the Stripe checkout call above.
    function loGetReferral() {
      try {
        var m = document.cookie.match(/(?:^|;\s*)lo_ref=([^;]+)/);
        return m ? decodeURIComponent(m[1]) : null;
      } catch (e) { return null; }
    }
    (function captureReferral() {
      try {
        var code = new URLSearchParams(window.location.search).get('ref');
        if (!code) return;
        code = code.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 12);
        if (!code) return;
        var exp = new Date(Date.now() + 90 * 864e5).toUTCString();
        document.cookie = 'lo_ref=' + encodeURIComponent(code) + '; expires=' + exp + '; path=/; SameSite=Lax';
      } catch (e) {}
    })();
  </script>

  <!-- ====== Hero search + contact form (preserved) ====== -->
  <script>
    async function loHeroSearch(ev) {
      if (ev) ev.preventDefault();
      const inputEl = document.getElementById('loHeroInput');
      const resultEl = document.getElementById('loHeroResult');
      const btn = document.getElementById('loHeroBtn');
      const raw = inputEl.value.trim().toLowerCase().replace(/[^a-z0-9-]/g, '').replace(/\.com$/i, '');
      if (!raw || raw.length < 2) { resultEl.textContent = 'Type a name first (at least 2 characters).'; resultEl.className = 'lo-hero-search-result'; return; }
      resultEl.textContent = 'Checking availability…';
      resultEl.className = 'lo-hero-search-result';
      btn.disabled = true;
      try {
        const res = await fetch('/api/domains/search?name=' + encodeURIComponent(raw));
        const data = await res.json();
        const domain = raw + '.com';
        const primary = (data.results || []).find(r => r.domain === domain);
        if (primary && primary.available && primary.underBudget) {
          resultEl.textContent = '✓ ' + domain + ' is available — opening checkout…';
          resultEl.className = 'lo-hero-search-result available';
          openFounderModal('annual', domain);
        } else if (primary) {
          let msg = '✗ ' + domain + ' is taken.';
          if (data.alternatives && data.alternatives.length) { msg += ' Try: ' + data.alternatives.slice(0, 3).map(a => a.domain).join(' · '); }
          resultEl.textContent = msg;
          resultEl.className = 'lo-hero-search-result taken';
        } else {
          resultEl.textContent = 'Could not check that name. Please try again.';
          resultEl.className = 'lo-hero-search-result taken';
        }
      } catch (err) {
        resultEl.textContent = 'Connection error. Please try again.';
        resultEl.className = 'lo-hero-search-result taken';
      }
      btn.disabled = false;
    }

    document.getElementById('loContactForm')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const form = e.target;
      const status = document.getElementById('loContactStatus');
      const data = {
        name: form.name.value.trim(),
        email: form.email.value.trim(),
        message: form.message.value.trim(),
        website: form.website.value,
        cfTurnstileToken: (form.querySelector('[name="cf-turnstile-response"]') || {}).value || '',
      };
      status.textContent = 'Sending…';
      try {
        const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        if (res.ok) {
          status.textContent = "Thanks — we'll get back to you within a day.";
          if (typeof fbq !== 'undefined') fbq('track', 'Lead');
          if (typeof pintrk !== 'undefined') pintrk('track', 'lead');
          form.reset();
          if (window.turnstile && typeof window.turnstile.reset === 'function') window.turnstile.reset();
        } else {
          const err = await res.json().catch(() => ({}));
          status.textContent = err.error || 'Something went wrong. Please email hello@legacyodyssey.com.';
          if (window.turnstile && typeof window.turnstile.reset === 'function') window.turnstile.reset();
        }
      } catch (err) { status.textContent = 'Network error. Please email hello@legacyodyssey.com.'; }
    });
  </script>

  <!-- ====== CRO additions: reveal-on-scroll, counters, exit-intent, countdown, lead/newsletter stubs ====== -->
  <script>
    // D3: appearance animations on scroll
    (function () {
      var els = document.querySelectorAll('.lo-reveal');
      if (!els.length) return;
      if (!('IntersectionObserver' in window)) { els.forEach(function(e){ e.classList.add('is-visible'); }); return; }
      function inView(el) {
        var r = el.getBoundingClientRect();
        var vh = window.innerHeight || document.documentElement.clientHeight;
        return r.top < vh && r.bottom > 0;
      }
      // Reveal anything currently on screen. Runs on load and just after any
      // hash-jump repositioning so a deep link (e.g. /#pricing) never strands
      // the visitor on an invisible (opacity:0) section.
      function revealVisible() {
        els.forEach(function (e) { if (!e.classList.contains('is-visible') && inView(e)) e.classList.add('is-visible'); });
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) { if (en.isIntersecting) { en.target.classList.add('is-visible'); io.unobserve(en.target); } });
      }, { threshold: 0.12 });
      els.forEach(function (e) { io.observe(e); });
      revealVisible();
      window.addEventListener('load', function () { revealVisible(); setTimeout(revealVisible, 300); setTimeout(revealVisible, 800); });
    })();

    // D3/D9: animated count-up for figures with data-count
    (function () {
      var nums = document.querySelectorAll('.lo-figure-num[data-count]');
      if (!nums.length) return;
      function run(el) {
        var target = parseFloat(el.getAttribute('data-count')) || 0;
        var prefix = el.getAttribute('data-prefix') || '';
        var suffix = el.getAttribute('data-suffix') || '';
        var dur = 1100, start = null;
        function step(ts) {
          if (!start) start = ts;
          var p = Math.min((ts - start) / dur, 1);
          var v = Math.round(target * (0.5 - Math.cos(p * Math.PI) / 2));
          el.textContent = prefix + v + suffix;
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }
      if (!('IntersectionObserver' in window)) { nums.forEach(run); return; }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) { if (en.isIntersecting) { run(en.target); io.unobserve(en.target); } });
      }, { threshold: 0.5 });
      nums.forEach(function (n) { io.observe(n); });
    })();

    // D9#3: optional urgency countdown. Honest by design — only runs if a real
    // future date is set in #loCountdown[data-end]. Otherwise it stays as the
    // visible placeholder text. e.g. data-end="2026-06-30T23:59:59".
    (function () {
      var el = document.getElementById('loCountdown');
      if (!el) return;
      var endStr = el.getAttribute('data-end');
      var end = endStr ? new Date(endStr).getTime() : NaN;
      if (!end || isNaN(end)) return; // leave placeholder text
      function tick() {
        var diff = end - Date.now();
        if (diff <= 0) { el.textContent = 'today'; return; }
        var d = Math.floor(diff / 86400000), h = Math.floor(diff % 86400000 / 3600000), m = Math.floor(diff % 3600000 / 60000);
        el.textContent = d + 'd ' + h + 'h ' + m + 'm';
        setTimeout(tick, 30000);
      }
      tick();
    })();

    // D8: lead-magnet capture (front-end stub) — replace with a real provider.
    function loLeadSubmit(source) {
      var isExit = source === 'exit';
      var input = document.getElementById(isExit ? 'loExitEmail' : 'loLeadEmail');
      var email = (input && input.value || '').trim();
      if (!email || !email.includes('@')) { if (input) input.focus(); return; }
      fetch('/api/waitlist', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email, source: isExit ? 'exit_intent' : 'lead_magnet' }) }).catch(function(){});
      if (typeof fbq !== 'undefined') fbq('track', 'Lead');
      if (typeof pintrk !== 'undefined') pintrk('track', 'lead');
      if (isExit) {
        var box = document.querySelector('#loExit .lo-exit-box');
        if (box) box.innerHTML = '<button class="lo-exit-close" onclick="loCloseExit()" aria-label="Close">&times;</button><h3>You’re in!</h3><p>Check your inbox — your guide is on its way.</p>';
        setTimeout(loCloseExit, 2500);
      } else {
        var panel = document.querySelector('#loLeadWidget .lo-leadwidget-panel');
        if (panel) panel.innerHTML = '<button class="lo-leadwidget-close" onclick="document.getElementById(\'loLeadWidget\').classList.remove(\'open\')" aria-label="Close">&times;</button><h4>You’re in!</h4><p>Check your inbox — your guide is on its way.</p>';
      }
    }

    // D8: newsletter footer capture (front-end stub)
    document.getElementById('loFootNewsForm')?.addEventListener('submit', function (e) {
      e.preventDefault();
      var status = document.getElementById('loFootNewsStatus');
      var email = (e.target.email.value || '').trim();
      if (!email || !email.includes('@')) { status.textContent = 'Please enter a valid email.'; return; }
      status.textContent = 'Joining…';
      fetch('/api/waitlist', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email, source: 'newsletter' }) })
        .then(function () { status.textContent = "Thanks — you're subscribed!"; if (typeof fbq !== 'undefined') fbq('track', 'Lead'); e.target.reset(); })
        .catch(function () { status.textContent = 'Something went wrong — please try again.'; });
    });

    // D8#6: exit-intent popup (desktop, once per session)
    (function () {
      var shown = sessionStorage.getItem('loExitShown') === '1';
      var exit = document.getElementById('loExit');
      if (!exit) return;
      function open() {
        if (shown) return;
        shown = true; sessionStorage.setItem('loExitShown', '1');
        exit.classList.add('open');
      }
      window.loCloseExit = function () { exit.classList.remove('open'); };
      document.addEventListener('mouseout', function (e) {
        if (!e.relatedTarget && e.clientY <= 0) open();
      });
    })();

    // (Cookie-consent banner is handled by the shared /js/consent.js, included
    // via partials/tracking.ejs — no inline banner needed here.)
  </script>

  <!-- ====== Robust hash scrolling (matches landing-v2) ====== -->
  <script>
    (function () {
      if (!location.hash) return;
      function jumpToHash() {
        var el;
        try { el = document.querySelector(location.hash); } catch (e) { return; }
        if (!el) return;
        var prev = document.documentElement.style.scrollBehavior;
        document.documentElement.style.scrollBehavior = 'auto';
        window.scrollTo(0, el.getBoundingClientRect().top + window.pageYOffset - 80);
        document.documentElement.style.scrollBehavior = prev;
      }
      window.addEventListener('load', function () { jumpToHash(); setTimeout(jumpToHash, 250); setTimeout(jumpToHash, 700); });
    })();
  </script>

