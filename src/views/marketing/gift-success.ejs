<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Pinterest Domain Verification -->
  <meta name="p:domain_verify" content="b146e195f22b09a16cdab391ec6f75c1"/>
  <title>Your Gift is Ready! — Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/marketing.css">
  <style>
    .success-page { padding-top: 100px; min-height: 100vh; }

    .success-container {
      max-width: 600px;
      margin: 0 auto;
      padding: 3rem 2rem 4rem;
      text-align: center;
    }

    .success-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
    }

    .success-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.8rem;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }

    .success-subtext {
      color: var(--ink-light);
      font-weight: 300;
      font-size: 1.05rem;
      margin-bottom: 2.5rem;
      line-height: 1.6;
    }

    .gift-code-box {
      border: 2px dashed var(--gold);
      border-radius: 12px;
      padding: 2rem 1.5rem;
      margin-bottom: 1.5rem;
      background: var(--cream);
    }

    .gift-code-label {
      font-size: 0.8rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--ink-light);
      margin-bottom: 0.75rem;
    }

    .gift-code-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem;
      font-weight: 600;
      color: var(--gold-dark);
      letter-spacing: 0.08em;
      word-break: break-all;
      user-select: all;
    }

    .copy-btn {
      display: inline-block;
      margin-top: 1rem;
      padding: 0.6rem 1.5rem;
      background: var(--gold);
      color: var(--white);
      border: none;
      border-radius: 6px;
      font-family: 'Jost', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .copy-btn:hover { background: var(--gold-dark); }

    .redeem-link-box {
      background: var(--white);
      border: 1px solid rgba(184, 147, 90, 0.2);
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
    }

    .redeem-link-label {
      font-size: 0.8rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--ink-light);
      margin-bottom: 0.5rem;
    }

    .redeem-link-url {
      font-size: 0.95rem;
      color: var(--gold-dark);
      word-break: break-all;
    }

    .redeem-link-url a {
      color: var(--gold-dark);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .redeem-link-url a:hover { color: var(--gold); }

    .success-instructions {
      font-size: 1.05rem;
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 0.75rem;
    }

    .success-note {
      font-size: 0.9rem;
      color: var(--ink-light);
      font-weight: 300;
      line-height: 1.6;
      margin-bottom: 0.5rem;
    }

    .buyer-email-note {
      font-size: 0.85rem;
      color: var(--ink-light);
      font-weight: 300;
      margin-top: 2rem;
    }
  </style>
  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LMJVX82M3Q"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LMJVX82M3Q');
  </script>
  <!-- End Google Analytics 4 -->

  <!-- Meta Pixel Code -->
  <script>
  !function(f,b,e,v,n,t,s)
  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window, document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '839009299208301');
  fbq('track', 'PageView');
  </script>
  <noscript>
  <img height="1" width="1" style="display:none"
  src="https://www.facebook.com/tr?id=839009299208301&ev=PageView&noscript=1"/>
  </noscript>
  <!-- End Meta Pixel Code -->

  <!-- Hotjar Tracking -->
  <script src="https://t.contentsquare.net/uxa/38cdf4e1f1a56.js"></script>

  <!-- Pinterest Tag -->
  <script>
  !function(e){if(!window.pintrk){window.pintrk = function () {
  window.pintrk.queue.push(Array.prototype.slice.call(arguments))};var
    n=window.pintrk;n.queue=[],n.version="3.0";var
    t=document.createElement("script");t.async=!0,t.src=e;var
    r=document.getElementsByTagName("script")[0];
    r.parentNode.insertBefore(t,r)}}("https://s.pinimg.com/ct/core.js");
  pintrk('load', '2613467907928');
  pintrk('page');
  </script>
  <noscript>
  <img height="1" width="1" style="display:none;" alt=""
    src="https://ct.pinterest.com/v3/?event=init&tid=2613467907928&noscript=1" />
  </noscript>
  <!-- end Pinterest Tag -->
</head>
<body>

  <!-- ====== NAV ====== -->
  <nav class="marketing-nav">
    <div class="nav-inner">
      <a href="https://legacyodyssey.com" class="nav-logo">Legacy <span>Odyssey</span></a>
    </div>
  </nav>

  <!-- ====== SUCCESS CONTENT ====== -->
  <main class="success-page">
    <div class="success-container">
      <div class="success-icon">&#10024;</div>
      <h1 class="success-heading">Your gift is ready!</h1>
      <%
        // Friendly, timing-aware message right under the heading.
        let timingMsg = '';
        const recipName = (typeof recipientName !== 'undefined' && recipientName) ? recipientName : 'them';
        if (deliveryMethod === 'email_scheduled' && deliverAt) {
          const d = new Date(deliverAt);
          const dateStr = d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });
          timingMsg = `We'll email <strong>${recipName}</strong> the gift on <strong>${dateStr}</strong>. Until then, the certificate below is yours to print, fold into a card, or hand over in person.`;
        } else if (recipientEmail) {
          timingMsg = `We've already emailed <strong>${recipName}</strong> the gift — it should be in their inbox shortly. The certificate below is yours to print and hand over too, if you'd like.`;
        } else {
          timingMsg = `Your gift is ready to give. Print the certificate below to hand it over in person.`;
        }
      %>
      <p class="success-subtext"><%- timingMsg %></p>

      <% if (certificateUrl) { %>
      <div style="background:#1a1510;color:#faf7f2;border-radius:12px;padding:28px 26px;margin:24px 0;text-align:center;">
        <div style="font-family:'Cormorant Garamond',Georgia,serif;font-size:22px;color:#c8a96e;margin-bottom:6px;">Your printable certificate</div>
        <div style="font-size:14px;color:rgba(250,247,242,0.78);line-height:1.55;margin-bottom:18px;">
          A beautifully designed gift certificate, ready to print or save as PDF — perfect to hand over wrapped at the shower.
        </div>
        <a href="<%= certificateUrl %>" target="_blank" style="display:inline-block;background:#c8a96e;color:#1a1510;padding:13px 28px;border-radius:6px;text-decoration:none;font-size:14px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;">View &amp; Print Certificate →</a>
      </div>
      <% } %>

      <div class="gift-code-box">
        <div class="gift-code-label">Gift Code</div>
        <div class="gift-code-value" id="giftCodeValue"><%= giftCode %></div>
        <button class="copy-btn" id="copyBtn" onclick="copyCode()">Copy Code</button>
      </div>

      <div class="redeem-link-box">
        <div class="redeem-link-label">Redemption Link</div>
        <div class="redeem-link-url">
          <a href="<%= redeemUrl %>" id="redeemLink"><%= redeemUrl %></a>
        </div>
      </div>

      <p class="success-note">$29 introductory price · One-year subscription · Recipient picks their own custom .com when they redeem · Code valid for 1 year.</p>

      <p class="buyer-email-note">A confirmation has been sent to <strong><%= buyerEmail %></strong>. If you don't see it within a minute, check your spam or junk folder.</p>

      <% if (typeof recipientEmail !== 'undefined' && recipientEmail) { %>
        <div style="background:#fff8e7;border:1px solid #e8d9b0;border-left:4px solid #c8a96e;border-radius:8px;padding:1rem 1.2rem;margin:1.5rem auto 0;max-width:540px;text-align:left;font-size:0.93rem;color:#2c2416;line-height:1.55;">
          <strong style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:#1a1510;">A note for the recipient</strong><br>
          When <%= (typeof recipientName !== 'undefined' && recipientName) ? recipientName : 'they' %> receives the redemption email, ask them to <strong>check their spam or junk folder</strong> if they don't see it &mdash; and to mark it <em>Not Spam</em> if it lands there. That keeps our future emails reaching their inbox.
        </div>
      <% } %>
    </div>
  </main>

  <!-- ====== FOOTER ====== -->
  <footer class="marketing-footer">
    <div class="footer-inner">
      <div class="footer-brand">Legacy <span>Odyssey</span></div>
      <ul class="footer-links">
        <li><a href="https://legacyodyssey.com">Home</a></li>
        <li><a href="/terms">Terms</a></li>
        <li><a href="/privacy">Privacy</a></li>
      </ul>
      <div class="footer-copy">&copy; 2026 Legacy Odyssey. All rights reserved.</div>
    </div>
  </footer>

  <script>
    function copyCode() {
      const code = document.getElementById('giftCodeValue').textContent;
      navigator.clipboard.writeText(code).then(() => {
        const btn = document.getElementById('copyBtn');
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy Code'; }, 2000);
      });
    }
    // GA4 purchase event
    gtag('event', 'purchase', {
      transaction_id: '<%= giftCode %>',
      value: 29,
      currency: 'USD',
      items: [{
        item_id: 'gift',
        item_name: 'Legacy Odyssey Gift',
        price: 29,
        quantity: 1
      }]
    });
  </script>

</body>
</html>
