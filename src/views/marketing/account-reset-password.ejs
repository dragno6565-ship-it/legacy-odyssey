<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password – Legacy Odyssey</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #faf7f2;
      color: #2c2416;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }
    .wrap { width: 100%; max-width: 420px; }
    .logo { text-align: center; margin-bottom: 2rem; }
    .logo h1 { font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 600; color: #2c2416; letter-spacing: 0.04em; }
    .logo p { font-size: 0.85rem; color: #4a3f30; margin-top: 0.25rem; }
    .card { background: #fff; border-radius: 12px; box-shadow: 0 2px 16px rgba(0,0,0,0.06); padding: 2rem; }
    .card h2 { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 600; margin-bottom: 0.5rem; color: #2c2416; }
    .card p.desc { font-size: 0.88rem; color: #4a3f30; margin-bottom: 1.5rem; line-height: 1.6; }
    .field { margin-bottom: 1.25rem; }
    label { display: block; font-size: 0.85rem; font-weight: 500; color: #6b5f4f; margin-bottom: 0.4rem; }
    input {
      width: 100%; padding: 0.75rem 1rem;
      border: 1px solid #e0d5c4; border-radius: 8px;
      font-family: 'Inter', sans-serif; font-size: 0.95rem;
      color: #2c2416; background: #faf7f2; outline: none;
      transition: border-color 0.15s;
    }
    input:focus { border-color: #c8a96e; }
    .pw-wrap { position: relative; }
    .pw-wrap input { padding-right: 3.5rem; }
    .pw-toggle {
      position: absolute; top: 50%; right: 0.75rem;
      transform: translateY(-50%);
      background: none; border: none; cursor: pointer;
      font-family: 'Inter', sans-serif; font-size: 0.8rem; font-weight: 500;
      color: #c8a96e; padding: 0.25rem 0.5rem;
      letter-spacing: 0.04em; text-transform: uppercase;
    }
    .pw-toggle:hover { color: #b08e4a; }
    .error { background: #fdf2f2; border: 1px solid #e0b4b4; border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.88rem; color: #c0392b; margin-bottom: 1.25rem; }
    .success-box { background: #f0faf0; border: 1px solid #a8d5a8; border-radius: 8px; padding: 1.25rem; font-size: 0.92rem; color: #2e7d32; line-height: 1.6; }
    .success-box strong { display: block; margin-bottom: 0.4rem; font-size: 1rem; }
    .btn {
      width: 100%; padding: 0.85rem;
      background: #c8a96e; color: #fff;
      border: none; border-radius: 8px;
      font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 600;
      cursor: pointer; transition: background 0.2s;
    }
    .btn:hover { background: #b08e4a; }
    .footer-links { text-align: center; margin-top: 1.5rem; font-size: 0.85rem; color: #4a3f30; }
    .footer-links a { color: #c8a96e; text-decoration: none; }
    .footer-links a:hover { text-decoration: underline; }
    .invalid-link { text-align: center; padding: 1rem 0; }
    .invalid-link p { color: #4a3f30; font-size: 0.92rem; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="logo">
      <h1>Legacy Odyssey</h1>
      <p>Account Management</p>
    </div>

    <div class="card">
      <h2>Set a new password</h2>

      <% if (success) { %>
        <div class="success-box" id="success-view">
          <strong>Password updated!</strong>
          Your password has been changed. You can sign in two ways:
          <p style="margin:1rem 0 0.5rem;font-weight:500;color:#2c2416;">From your web browser</p>
          <p style="margin:0 0 0.5rem;font-size:0.92rem;">Edit your book from any computer or phone browser.</p>
          <a href="/account" style="display:inline-block;padding:0.6rem 1.2rem;background:#c8a96e;color:#fff;border-radius:6px;text-decoration:none;font-weight:500;font-size:0.95rem;">Sign in on the web &rarr;</a>
          <p style="margin:1.25rem 0 0.5rem;font-weight:500;color:#2c2416;">Or use the mobile app</p>
          <p style="margin:0 0 0.5rem;font-size:0.92rem;">Best for adding photos on the go.</p>
          <a href="https://apps.apple.com/app/id6760883565" target="_blank" style="margin-right:0.5rem;color:#c8a96e;font-weight:500;">App Store</a>
          ·
          <a href="https://play.google.com/store/apps/details?id=com.legacyodyssey.app" target="_blank" style="margin-left:0.5rem;color:#c8a96e;font-weight:500;">Google Play</a>
        </div>
      <% } else { %>
        <!--
          The page supports BOTH reset-link flavors:
            1. ?token_hash=...  (older PKCE/verifyOtp flow — server POST handles it)
            2. #access_token=...&type=recovery  (Supabase implicit flow — client-side JS)
          Server renders one of these blocks based on whether ?token_hash is set;
          inline JS below detects the hash-fragment case and overrides the view.
        -->
        <div id="form-view" style="<%= token_hash ? '' : 'display:none;' %>">
          <p class="desc">Choose a new password for your Legacy Odyssey account. It must be at least 6 characters.</p>

          <% if (error) { %><div class="error"><%= error %></div><% } %>
          <div class="error" id="js-error" style="display:none;"></div>

          <form method="POST" action="/account/reset-password" id="reset-form">
            <input type="hidden" name="token_hash" value="<%= token_hash %>" id="token-hash-input">
            <div class="field">
              <label for="new_password">New password</label>
              <div class="pw-wrap">
                <input type="password" id="new_password" name="new_password" autocomplete="new-password" required placeholder="At least 6 characters" minlength="6">
                <button type="button" class="pw-toggle" data-target="new_password" aria-label="Show password">Show</button>
              </div>
            </div>
            <div class="field">
              <label for="confirm_password">Confirm new password</label>
              <div class="pw-wrap">
                <input type="password" id="confirm_password" name="confirm_password" autocomplete="new-password" required placeholder="Repeat your new password">
                <button type="button" class="pw-toggle" data-target="confirm_password" aria-label="Show password">Show</button>
              </div>
            </div>
            <button type="submit" class="btn" id="submit-btn">Update Password</button>
          </form>
        </div>

        <div class="invalid-link" id="invalid-view" style="<%= token_hash ? 'display:none;' : '' %>">
          <p id="invalid-text">This reset link is invalid or has expired.</p>
          <a href="/account/forgot-password" class="btn" style="display:block;text-align:center;text-decoration:none;">Request a new link</a>
        </div>

        <script>
          // ─── Show/hide password toggles ────────────────────────────────
          document.querySelectorAll('.pw-toggle').forEach(function(btn) {
            btn.addEventListener('click', function() {
              var input = document.getElementById(btn.getAttribute('data-target'));
              if (!input) return;
              var showing = input.type === 'text';
              input.type = showing ? 'password' : 'text';
              btn.textContent = showing ? 'Show' : 'Hide';
              btn.setAttribute('aria-label', showing ? 'Show password' : 'Hide password');
            });
          });

          // ─── Hash-fragment recovery flow ──────────────────────────────
          // Supabase recovery links redirect with the access token in the
          // URL hash fragment (`#access_token=jwt&type=recovery&...`). The
          // server never sees the hash, so we have to parse it client-side
          // and PUT the new password directly to Supabase Auth.
          var SUPABASE_URL  = <%- JSON.stringify(supabaseUrl  || process.env.SUPABASE_URL  || '') %>;
          var SUPABASE_ANON = <%- JSON.stringify(supabaseAnonKey || process.env.SUPABASE_ANON_KEY || '') %>;
          var formView    = document.getElementById('form-view');
          var invalidView = document.getElementById('invalid-view');
          var invalidText = document.getElementById('invalid-text');
          var errorBox    = document.getElementById('js-error');
          var resetForm   = document.getElementById('reset-form');
          var submitBtn   = document.getElementById('submit-btn');
          var hashAccessToken = null;

          (function detectHashToken() {
            var hash = window.location.hash.substring(1);
            if (!hash) return;
            var params = new URLSearchParams(hash);
            var accessToken = params.get('access_token');
            var errorCode   = params.get('error_code') || params.get('error');
            var errorDesc   = params.get('error_description');
            if (errorCode || errorDesc) {
              invalidText.textContent = decodeURIComponent((errorDesc || errorCode).replace(/\+/g, ' '));
              return;
            }
            if (accessToken) {
              hashAccessToken = accessToken;
              // Show the form, hide the invalid block
              formView.style.display = '';
              invalidView.style.display = 'none';
              // Wipe the hash so the token isn't reusable via browser history
              try { history.replaceState(null, '', window.location.pathname + window.location.search); } catch(_) {}
            }
          })();

          // ─── Form submit: route to client-side flow when we have a hash-flow token
          if (resetForm) {
            resetForm.addEventListener('submit', function(e) {
              if (!hashAccessToken) return; // let the normal form POST happen
              e.preventDefault();
              errorBox.style.display = 'none';
              var pw  = document.getElementById('new_password').value;
              var cpw = document.getElementById('confirm_password').value;
              if (!pw || pw.length < 6) { errorBox.textContent = 'Password must be at least 6 characters.'; errorBox.style.display = 'block'; return; }
              if (pw !== cpw)            { errorBox.textContent = 'Passwords do not match.'; errorBox.style.display = 'block'; return; }

              submitBtn.disabled = true;
              submitBtn.textContent = 'Updating...';

              fetch(SUPABASE_URL + '/auth/v1/user', {
                method: 'PUT',
                headers: {
                  'Content-Type': 'application/json',
                  'Authorization': 'Bearer ' + hashAccessToken,
                  'apikey': SUPABASE_ANON,
                },
                body: JSON.stringify({ password: pw }),
              }).then(function(res) {
                return res.ok ? null : res.json().catch(function(){ return {}; }).then(function(d){ throw new Error(d.message || d.error_description || 'Failed to update password.'); });
              }).then(function() {
                // Reload the page in "success" state by hitting the success view from a fresh GET
                document.body.innerHTML = '<div style="max-width:420px;margin:4rem auto;padding:2rem 1rem;text-align:center;font-family:Inter,sans-serif;color:#2c2416;">'
                  + '<h1 style="font-family:\'Fraunces\',serif;font-size:2rem;font-weight:600;color:#2c2416;margin-bottom:0.5rem;">Legacy Odyssey</h1>'
                  + '<p style="color:#4a3f30;margin-bottom:2rem;">Account Management</p>'
                  + '<div style="background:#f0faf0;border:1px solid #a8d5a8;border-radius:8px;padding:1.5rem;color:#2e7d32;line-height:1.6;">'
                  + '<strong style="display:block;margin-bottom:0.5rem;font-size:1rem;">Password updated!</strong>'
                  + 'Your password has been changed. You can sign in two ways:'
                  + '<p style="margin:1rem 0 0.5rem;font-weight:500;color:#2c2416;">From your web browser</p>'
                  + '<p style="margin:0 0 0.5rem;font-size:0.92rem;">Edit your book from any computer or phone browser.</p>'
                  + '<a href="/account" style="display:inline-block;padding:0.6rem 1.2rem;background:#c8a96e;color:#fff;border-radius:6px;text-decoration:none;font-weight:500;font-size:0.95rem;">Sign in on the web &rarr;</a>'
                  + '<p style="margin:1.25rem 0 0.5rem;font-weight:500;color:#2c2416;">Or use the mobile app</p>'
                  + '<p style="margin:0 0 0.5rem;font-size:0.92rem;">Best for adding photos on the go.</p>'
                  + '<a href="https://apps.apple.com/app/id6760883565" target="_blank" style="margin-right:0.5rem;color:#c8a96e;font-weight:500;">App Store</a> &middot; '
                  + '<a href="https://play.google.com/store/apps/details?id=com.legacyodyssey.app" target="_blank" style="margin-left:0.5rem;color:#c8a96e;font-weight:500;">Google Play</a>'
                  + '</div>'
                  + '</div>';
              }).catch(function(err) {
                errorBox.textContent = err.message || 'Could not update password. Please try again.';
                errorBox.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.textContent = 'Update Password';
              });
            });
          }
        </script>
      <% } %>
    </div>

    <div class="footer-links">
      <% if (success) { %>
        <a href="/account">Sign in now →</a>
      <% } else { %>
        <a href="/account">← Back to Sign In</a>
      <% } %>
    </div>
  </div>
</body>
</html>
